---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { supabaseAdmin, createAuthClient } from '../lib/supabase';

const { data: products } = await supabaseAdmin
  .from('products')
  .select('id, name, slug, category, description, image_url, in_stock, unit, units_per_carton, price_ht, stock_quantity')
  .order('position', { ascending: true })
  .order('name', { ascending: true });

const supabase = createAuthClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
const isClient = user?.user_metadata?.role === 'client';

const cartMap: Record<string, number> = {};
if (isClient && user) {
  const { data: cartRows } = await supabaseAdmin
    .from('cart_items')
    .select('product_id, quantity')
    .eq('user_id', user.id);
  for (const row of cartRows ?? []) {
    cartMap[row.product_id] = row.quantity;
  }
}

const totalCartQty = Object.values(cartMap).reduce((s, q) => s + q, 0);

const priceMap: Record<string, number> = {};
for (const p of products ?? []) priceMap[p.id] = Number(p.price_ht ?? 0);

const totalCartHT = Object.entries(cartMap).reduce(
  (s, [id, qty]) => s + qty * (priceMap[id] ?? 0), 0
);

const total   = products?.length ?? 0;
const inStock = products?.filter(p => p.in_stock).length ?? 0;

const CAT_LABEL: Record<string, string> = {
  boissons:    'Boissons',
  snacks:      'Snacks',
  confiseries: 'Confiseries',
};

const CAT_BG: Record<string, string> = {
  boissons:    'oklch(0.72 0.10 210)',
  snacks:      'oklch(0.78 0.10 60)',
  confiseries: 'oklch(0.76 0.10 330)',
};

const initialCat = Astro.url.searchParams.get('cat') ?? 'tous';

// Safe JSON for product metadata (used by cart drawer JS)
const productsMetaJSON = JSON.stringify(
  (products ?? []).map(p => ({
    id: p.id,
    name: p.name,
    unit: p.unit ?? null,
    units_per_carton: p.units_per_carton ?? null,
    image_url: p.image_url ?? null,
    category: p.category ?? null,
  }))
).replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026');
---
<Base
  title="Catalogue — Inca Import"
  description="Découvrez notre catalogue de boissons, snacks et confiseries disponibles pour les gérants de stations-service et supérettes à La Réunion."
>
  <Nav user={user} />
  <main>

    <!-- Product metadata for cart drawer JS -->
    {isClient && (
      <script type="application/json" id="productsMetaData" set:html={productsMetaJSON} />
    )}

    <!-- Hero banner -->
    <section class="cat-banner">
      <p class="cat-banner-text">Commandez en quelques clics, livré sous 48h</p>
    </section>

    <!-- Page header -->
    <section class="cat-header">
      <div class="container cat-header-inner">
        <div class="cat-header-text">
          <h1 class="cat-title">Catalogue</h1>
          <p class="cat-meta">
            {total} référence{total !== 1 ? 's' : ''}
            <span class="cat-meta-sep" aria-hidden="true">·</span>
            {inStock} en stock
            <span class="cat-meta-sep" aria-hidden="true">·</span>
            Livraison 48h · La Réunion
          </p>
        </div>
        {isClient && (
          <p class="client-greeting">
            Connecté ·&nbsp;<strong>{user?.user_metadata?.nom ?? user?.email}</strong>
          </p>
        )}
      </div>
    </section>

    <!-- Sticky filter + search bar -->
    <div class="filter-bar-wrap">
      <div class="container">
        <div class="filter-bar">
          <div class="filter-tabs" role="group" aria-label="Filtrer par catégorie" data-initial-cat={initialCat}>
            <div class="tab-indicator" aria-hidden="true"></div>
            <button class={`filter-tab${initialCat === 'tous' ? ' is-active' : ''}`} data-cat="tous">Tous</button>
            <button class={`filter-tab${initialCat === 'boissons' ? ' is-active' : ''}`} data-cat="boissons">Boissons</button>
            <button class={`filter-tab${initialCat === 'snacks' ? ' is-active' : ''}`} data-cat="snacks">Snacks</button>
            <button class={`filter-tab${initialCat === 'confiseries' ? ' is-active' : ''}`} data-cat="confiseries">Confiseries</button>
          </div>
        </div>
        <div class="search-row">
          <div class="search-wrap">
            <svg class="search-icon" width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.4"/>
              <path d="M9.5 9.5L13 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
            <input
              type="search"
              id="cat-search"
              placeholder="Rechercher un produit…"
              class="search-input"
              aria-label="Rechercher un produit par nom ou description"
            />
            <button type="button" class="search-clear" id="searchClear" aria-label="Effacer la recherche" hidden>
              <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                <path d="M1 1l9 9M10 1L1 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
          <p class="search-results-count" id="searchResultsCount" hidden aria-live="polite"></p>
        </div>
      </div>
    </div>

    <!-- Product grid -->
    <section class="products-section">
      <div class="container">
        {products && products.length > 0 ? (
          <div class="products-grid" id="productsGrid">
            {products.map(p => {
              const priceFormatted = p.price_ht
                ? Number(p.price_ht).toFixed(2).replace('.', ',')
                : null;
              return (
              <article
                class={`product-card${!p.in_stock ? ' product-card--oos' : ''}`}
                data-cat={p.category}
                data-search={`${p.name} ${p.description ?? ''}`.toLowerCase()}
              >
                <div
                  class="product-img"
                  style={!p.image_url ? `background:${CAT_BG[p.category] ?? 'oklch(0.82 0 0)'}` : ''}
                >
                  {p.image_url ? (
                    <img src={p.image_url} alt={p.name} loading="lazy" decoding="async" />
                  ) : (
                    <span class="img-letter" aria-hidden="true">{p.name[0].toUpperCase()}</span>
                  )}
                  {!p.in_stock && (
                    <span class="oos-badge" aria-label="Rupture de stock">Rupture de stock</span>
                  )}
                </div>

                <div class="product-body">
                  <div class="badge-row">
                    <span class={`cat-badge cat-badge--${p.category}`}>
                      {CAT_LABEL[p.category] ?? p.category}
                    </span>
                    <span class="min-badge">min. 1 {p.unit ?? 'carton'}</span>
                  </div>

                  <div class="product-name-group">
                    <h2 class="product-name">
                      {p.slug ? (
                        <a href={`/catalogue/${p.slug}`} class="product-name-link">{p.name}</a>
                      ) : p.name}
                    </h2>
                    {isClient && priceFormatted && (
                      <p class="product-price" aria-label={`Prix : ${priceFormatted} euros HT`}>
                        {priceFormatted}&nbsp;<span class="price-currency">€</span>
                        <span class="price-suffix">HT</span>
                      </p>
                    )}
                  </div>

                  {p.units_per_carton ? (
                    <p class="product-unit">{p.units_per_carton} unités/{p.unit ?? 'carton'}</p>
                  ) : p.unit ? (
                    <p class="product-unit">{p.unit}</p>
                  ) : null}

                  {isClient && (p.stock_quantity ?? 0) > 0 && (
                    <p class={`prod-stock prod-stock--${(p.stock_quantity ?? 0) < 5 ? 'low' : 'ok'}`}>
                      {p.stock_quantity === 1
                        ? `1 ${p.unit ?? 'carton'} disponible`
                        : `${p.stock_quantity} ${p.unit ?? 'carton'}s disponibles`}
                    </p>
                  )}

                  {p.description && <p class="product-desc">{p.description}</p>}

                  {isClient && p.in_stock ? (
                    <div
                      class="cart-controls"
                      data-product-id={p.id}
                      data-initial-qty={cartMap[p.id] ?? 0}
                      data-price={priceMap[p.id] ?? 0}
                    >
                      <button type="button" class="qty-btn qty-btn--dec" aria-label={`Retirer ${p.name} du panier`}>−</button>
                      <input
                        class="qty-val"
                        type="text"
                        inputmode="numeric"
                        pattern="[0-9]*"
                        value={String(cartMap[p.id] ?? 0)}
                        data-empty={!cartMap[p.id]}
                        aria-label={`Quantité de ${p.name}`}
                      />
                      <button type="button" class="qty-btn qty-btn--inc" aria-label={`Ajouter ${p.name} au panier`}>+</button>
                    </div>
                  ) : !isClient ? (
                    <a href="/connexion" class="card-cta">
                      Se connecter pour commander
                      <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                        <path d="M2.5 6.5h8M7 3l3.5 3.5L7 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  ) : null}
                </div>
              </article>
              );
            })}
          </div>
        ) : (
          <div class="empty-state">
            <p class="empty-title">Le catalogue est en cours de construction.</p>
            <p class="empty-body">Revenez bientôt ou <a href="/#compte">ouvrez un compte</a> pour être informé.</p>
          </div>
        )}

        <p class="no-results" id="noResults" hidden aria-live="polite">
          Aucun produit ne correspond à votre recherche.
        </p>
      </div>
    </section>

    <!-- Bottom CTA band (guests only) -->
    {!isClient && (
      <section class="cta-band" aria-label="Accès professionnel">
        <div class="container cta-band-inner">
          <div>
            <p class="cta-band-title">Accédez aux tarifs professionnels</p>
            <p class="cta-band-sub">Commandez en ligne, livraison sous 48h, équipe locale à La Réunion.</p>
          </div>
          <a href="/inscription" class="btn btn-primary">Ouvrir un compte →</a>
        </div>
      </section>
    )}

  </main>
  <Footer />

  {isClient && (
    <>
      <!-- Logout form (used by drawer) -->
      <form id="logoutForm" action="/api/auth/client-logout" method="POST" hidden>
      </form>

      <!-- Backdrop -->
      <div class="cart-backdrop" id="cartBackdrop" aria-hidden="true"></div>

      <!-- Cart drawer -->
      <aside
        class="cart-drawer"
        id="cartDrawer"
        role="dialog"
        aria-label="Votre panier"
        aria-modal="true"
        aria-hidden="true"
      >
        <div class="drawer-header">
          <h2 class="drawer-heading">Panier</h2>
          <div class="drawer-header-actions">
            <button type="button" class="drawer-logout" id="drawerLogoutBtn" aria-label="Se déconnecter">
              Déconnexion
            </button>
            <button type="button" class="drawer-close" id="drawerClose" aria-label="Fermer le panier">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="drawer-body" id="drawerBody">
          <ul class="drawer-items-list" id="drawerItemsList" aria-label="Articles dans votre panier"></ul>
          <p class="drawer-empty" id="drawerEmpty" aria-live="polite">Votre panier est vide.</p>
        </div>

        <div class="drawer-footer">
          <div class="drawer-total-row">
            <span class="drawer-total-label">Total HT</span>
            <span class="drawer-total-amount" id="drawerTotal">{totalCartHT.toFixed(2).replace('.', ',')} €</span>
          </div>
          <a href="/commande" class="btn btn-primary drawer-checkout">
            Passer commande
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </aside>

      <!-- Cart toggle button -->
      <button
        class="cart-toggle"
        id="cartToggle"
        aria-label={`Ouvrir le panier — ${totalCartQty} article${totalCartQty !== 1 ? 's' : ''}`}
        aria-expanded="false"
        aria-controls="cartDrawer"
      >
        <svg class="cart-toggle-icon" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <path d="M1.5 1.5h3l2.4 11.5m0 0H18l1.5-7H6.9m0 7-.9 4h13.5" stroke="white" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="8.5" cy="20" r="1.5" fill="white"/>
          <circle cx="17.5" cy="20" r="1.5" fill="white"/>
        </svg>
        <span
          class="cart-toggle-badge"
          id="cartBadge"
          data-empty={totalCartQty === 0}
          aria-hidden="true"
        >{totalCartQty}</span>
      </button>
    </>
  )}

</Base>

<script>
  // ── Sliding filter indicator ──────────────────────────────────
  const tabsEl    = document.querySelector<HTMLElement>('.filter-tabs');
  const indicator = document.querySelector<HTMLElement>('.tab-indicator');
  const tabs      = document.querySelectorAll<HTMLButtonElement>('.filter-tab');

  function moveIndicator(tab: HTMLButtonElement, animate = true) {
    if (!indicator) return;
    if (!animate) indicator.style.transition = 'none';
    indicator.style.left  = `${tab.offsetLeft}px`;
    indicator.style.width = `${tab.offsetWidth}px`;
    if (!animate) requestAnimationFrame(() => { indicator.style.transition = ''; });
  }

  const initialActive = document.querySelector<HTMLButtonElement>('.filter-tab.is-active');
  if (initialActive && indicator) {
    moveIndicator(initialActive, false);
    requestAnimationFrame(() => { indicator.style.opacity = '1'; });
  }

  // ── Filter & search ───────────────────────────────────────────
  const cards          = document.querySelectorAll<HTMLElement>('.product-card');
  const grid            = document.getElementById('productsGrid');
  const searchInput     = document.getElementById('cat-search') as HTMLInputElement;
  const searchClearBtn  = document.getElementById('searchClear') as HTMLButtonElement;
  const resultsCountEl  = document.getElementById('searchResultsCount') as HTMLElement;
  const noResults       = document.getElementById('noResults') as HTMLElement;

  let activeCat   = tabsEl?.dataset.initialCat ?? 'tous';
  let searchQuery = '';

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const catMatch    = activeCat === 'tous' || card.dataset.cat === activeCat;
      const searchMatch = (card.dataset.search ?? '').includes(searchQuery);
      const show = catMatch && searchMatch;
      card.hidden = !show;
      if (show) visible++;
    });
    noResults.hidden = visible > 0;

    if (searchQuery) {
      resultsCountEl.textContent = `${visible} résultat${visible !== 1 ? 's' : ''} pour « ${searchInput.value.trim()} »`;
      resultsCountEl.hidden = false;
    } else {
      resultsCountEl.hidden = true;
    }
  }

  // Brief crossfade on the grid whenever the result set changes
  let fadeTimer: number | undefined;
  function applyFiltersWithFade() {
    if (!grid) { applyFilters(); return; }
    grid.classList.add('is-updating');
    window.clearTimeout(fadeTimer);
    fadeTimer = window.setTimeout(() => {
      applyFilters();
      grid.classList.remove('is-updating');
    }, 90);
  }

  function updateClearButton() {
    searchClearBtn.hidden = searchInput.value.length === 0;
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('is-active'));
      tab.classList.add('is-active');
      activeCat = tab.dataset.cat ?? 'tous';
      moveIndicator(tab);
      applyFiltersWithFade();
    });
  });

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    updateClearButton();
    applyFiltersWithFade();
  });

  searchClearBtn?.addEventListener('click', () => {
    searchInput.value = '';
    searchQuery = '';
    updateClearButton();
    applyFiltersWithFade();
    searchInput.focus();
  });

  if (activeCat !== 'tous') applyFilters();

  // ── Cart drawer (clients only) ────────────────────────────────
  const cartToggle  = document.getElementById('cartToggle');
  if (!cartToggle) {
    // Guest — no cart logic needed
  } else {
    // Parse product metadata
    type ProductMeta = { id: string; name: string; unit: string | null; units_per_carton: number | null; image_url: string | null; category: string | null };
    const metaEl  = document.getElementById('productsMetaData');
    const allMeta: ProductMeta[] = metaEl ? JSON.parse(metaEl.textContent ?? '[]') : [];
    const productMap = Object.fromEntries(allMeta.map(p => [p.id, p]));

    // Cart state (source of truth)
    const cartState: Record<string, number> = {};
    const priceMap:  Record<string, number>  = {};

    document.querySelectorAll<HTMLElement>('.cart-controls').forEach(ctrl => {
      const id  = ctrl.dataset.productId!;
      const qty = parseInt(ctrl.dataset.initialQty ?? '0', 10);
      priceMap[id]  = parseFloat(ctrl.dataset.price ?? '0');
      if (qty > 0) cartState[id] = qty;
    });

    // Drawer elements
    const backdrop       = document.getElementById('cartBackdrop')!;
    const drawer         = document.getElementById('cartDrawer')!;
    const drawerClose    = document.getElementById('drawerClose')!;
    const drawerLogout   = document.getElementById('drawerLogoutBtn')!;
    const drawerItemsList = document.getElementById('drawerItemsList')!;
    const drawerEmptyEl  = document.getElementById('drawerEmpty')!;
    const drawerTotalEl  = document.getElementById('drawerTotal')!;
    const cartBadge      = document.getElementById('cartBadge')!;
    const logoutForm     = document.getElementById('logoutForm') as HTMLFormElement;

    let isOpen = false;

    // ── Drawer open / close ──────────────────────────────────────
    function openDrawer() {
      isOpen = true;
      drawer.classList.add('is-open');
      backdrop.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      cartToggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      drawerClose.focus();
    }

    function closeDrawer() {
      isOpen = false;
      drawer.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      cartToggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      cartToggle.focus();
    }

    cartToggle.addEventListener('click', () => isOpen ? closeDrawer() : openDrawer());
    drawerClose.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);
    drawerLogout.addEventListener('click', () => logoutForm?.submit());

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && isOpen) closeDrawer();
    });

    // ── Cart totals ───────────────────────────────────────────────
    function calcTotalQty(): number {
      return Object.values(cartState).reduce((s, q) => s + (q > 0 ? q : 0), 0);
    }

    function calcTotalHT(): number {
      return Object.entries(cartState)
        .reduce((s, [id, q]) => s + (q > 0 ? q * (priceMap[id] ?? 0) : 0), 0);
    }

    // ── Render ───────────────────────────────────────────────────
    function updateBadge() {
      const qty = calcTotalQty();
      cartBadge.textContent = String(qty);
      cartBadge.dataset.empty = qty === 0 ? 'true' : 'false';
      cartToggle.setAttribute('aria-label',
        `${isOpen ? 'Fermer' : 'Ouvrir'} le panier — ${qty} article${qty !== 1 ? 's' : ''}`
      );
    }

    function updateTotal() {
      drawerTotalEl.textContent = calcTotalHT().toFixed(2).replace('.', ',') + ' €';
    }

    function renderDrawerItems() {
      const active = Object.entries(cartState).filter(([, q]) => q > 0);
      drawerEmptyEl.hidden = active.length > 0;
      drawerItemsList.innerHTML = '';

      const CORAL      = 'oklch(0.568 0.149 45.9)';
      const CORAL_DIM  = 'oklch(0.50 0.149 45.9)';
      const RED        = 'oklch(0.58 0.16 25)';
      const RED_DEEP   = 'oklch(0.44 0.20 25)';
      const CAT_BG: Record<string, string> = {
        boissons: 'oklch(0.72 0.10 210)', snacks: 'oklch(0.78 0.10 60)',
        confiseries: 'oklch(0.76 0.10 330)',
      };

      active.forEach(([id, qty], idx) => {
        const meta = productMap[id];
        if (!meta) return;
        const linePrice = (qty * (priceMap[id] ?? 0)).toFixed(2).replace('.', ',');
        const unitLine  = meta.units_per_carton
          ? `${meta.units_per_carton} unités/${meta.unit ?? 'carton'}`
          : (meta.unit ?? '');
        const isLast = idx === active.length - 1;

        // ── <li> ─────────────────────────────────────────────────
        const li = document.createElement('li');
        li.dataset.productId = id;
        Object.assign(li.style, {
          display: 'flex', flexDirection: 'row', alignItems: 'center',
          gap: '12px', padding: '12px 0', margin: '0', listStyle: 'none',
          borderBottom: isLast ? 'none' : '1px solid var(--color-border)',
          background: 'transparent',
        });

        // ── Avatar (48×48, locked) ─────────────────────────────
        const avatar = document.createElement('div');
        Object.assign(avatar.style, {
          width: '48px', minWidth: '48px', maxWidth: '48px', height: '48px',
          borderRadius: '8px', overflow: 'hidden',
          flexShrink: '0', flexGrow: '0', flexBasis: '48px',
          background: CAT_BG[meta.category ?? ''] ?? 'oklch(0.82 0.04 45)',
        });

        if (meta.image_url) {
          const img = document.createElement('img');
          img.src  = meta.image_url;
          img.alt  = '';
          img.loading = 'lazy';
          Object.assign(img.style, {
            display: 'block', width: '48px', height: '48px', objectFit: 'cover',
          });
          avatar.appendChild(img);
        } else {
          const letter = document.createElement('span');
          letter.textContent = meta.name[0].toUpperCase();
          Object.assign(letter.style, {
            display: 'flex', width: '100%', height: '100%',
            alignItems: 'center', justifyContent: 'center',
            fontFamily: 'var(--font-display)', fontSize: '1.25rem',
            fontWeight: '700', color: 'white', lineHeight: '1',
          });
          avatar.appendChild(letter);
        }

        // ── Body ───────────────────────────────────────────────
        const body = document.createElement('div');
        Object.assign(body.style, {
          flex: '1', minWidth: '0', display: 'flex',
          flexDirection: 'column', gap: '5px',
        });

        // Row 1 — name + price
        const row1 = document.createElement('div');
        Object.assign(row1.style, {
          display: 'flex', alignItems: 'baseline',
          justifyContent: 'space-between', gap: '8px',
        });

        const nameEl = document.createElement('p');
        nameEl.textContent = meta.name;
        Object.assign(nameEl.style, {
          margin: '0', flex: '1', minWidth: '0',
          fontFamily: 'var(--font-body)', fontSize: '0.8125rem', fontWeight: '700',
          color: 'var(--color-ink)', lineHeight: '1.2',
          whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis',
        });

        const priceEl = document.createElement('p');
        priceEl.textContent = `${linePrice} €`;
        Object.assign(priceEl.style, {
          margin: '0', flexShrink: '0',
          fontFamily: 'var(--font-display)', fontSize: '0.8125rem', fontWeight: '700',
          color: CORAL, letterSpacing: '-0.02em', whiteSpace: 'nowrap',
        });

        row1.appendChild(nameEl);
        row1.appendChild(priceEl);

        // Row 2 — unit info + stepper + delete
        const row2 = document.createElement('div');
        Object.assign(row2.style, {
          display: 'flex', alignItems: 'center',
          justifyContent: 'space-between', gap: '6px',
        });

        const metaEl = document.createElement('p');
        metaEl.textContent = unitLine;
        Object.assign(metaEl.style, {
          margin: '0', flex: '1', minWidth: '0',
          fontFamily: 'var(--font-body)', fontSize: '0.6875rem',
          color: 'var(--color-muted)', lineHeight: '1',
          whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis',
        });

        const actions = document.createElement('div');
        Object.assign(actions.style, {
          display: 'flex', alignItems: 'center', gap: '8px', flexShrink: '0',
        });

        // Coral pill stepper
        const stepper = document.createElement('div');
        Object.assign(stepper.style, {
          display: 'inline-flex', alignItems: 'stretch',
          height: '28px', borderRadius: '14px',
          overflow: 'hidden', background: CORAL, flexShrink: '0',
        });

        function makeStepBtn(label: string, text: string) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.textContent = text;
          btn.setAttribute('aria-label', label);
          Object.assign(btn.style, {
            width: '28px', height: '28px',
            border: 'none', background: 'transparent',
            fontSize: '1rem', fontWeight: '400', lineHeight: '1',
            cursor: 'pointer', color: 'white', padding: '0', flexShrink: '0',
            display: 'flex', alignItems: 'center', justifyContent: 'center',
          });
          btn.addEventListener('mouseenter', () => { btn.style.background = CORAL_DIM; });
          btn.addEventListener('mouseleave', () => { btn.style.background = 'transparent'; });
          return btn;
        }

        const decBtn = makeStepBtn(`Retirer un ${meta.name}`, '−');
        const incBtn = makeStepBtn(`Ajouter un ${meta.name}`, '+');

        const qtyValEl = document.createElement('span');
        qtyValEl.textContent = String(qty);
        qtyValEl.setAttribute('aria-live', 'polite');
        Object.assign(qtyValEl.style, {
          display: 'flex', alignItems: 'center', justifyContent: 'center',
          minWidth: '22px', padding: '0 3px',
          fontFamily: 'var(--font-body)', fontSize: '0.75rem', fontWeight: '700',
          color: 'white', lineHeight: '1',
        });

        stepper.append(decBtn, qtyValEl, incBtn);

        // "Supprimer" text button
        const delBtn = document.createElement('button');
        delBtn.type = 'button';
        delBtn.textContent = 'Supprimer';
        delBtn.setAttribute('aria-label', `Supprimer ${meta.name} du panier`);
        Object.assign(delBtn.style, {
          border: 'none', background: 'none', padding: '0', margin: '0',
          fontFamily: 'var(--font-body)', fontSize: '0.6875rem', fontWeight: '500',
          color: RED, cursor: 'pointer', lineHeight: '1',
          textDecoration: 'none', whiteSpace: 'nowrap',
        });
        delBtn.addEventListener('mouseenter', () => {
          delBtn.style.color = RED_DEEP; delBtn.style.textDecoration = 'underline';
        });
        delBtn.addEventListener('mouseleave', () => {
          delBtn.style.color = RED; delBtn.style.textDecoration = 'none';
        });

        actions.append(stepper, delBtn);
        row2.append(metaEl, actions);
        body.append(row1, row2);
        li.append(avatar, body);
        drawerItemsList.appendChild(li);

        // ── Events ────────────────────────────────────────────
        decBtn.addEventListener('click', () => {
          if ((cartState[id] ?? 0) <= 0) return;
          cartState[id]--;
          syncCardControl(id);
          sendCartUpdate(id, cartState[id]);
          renderCart();
        });
        incBtn.addEventListener('click', () => {
          cartState[id] = (cartState[id] ?? 0) + 1;
          syncCardControl(id);
          sendCartUpdate(id, cartState[id]);
          renderCart();
        });
        delBtn.addEventListener('click', () => {
          cartState[id] = 0;
          syncCardControl(id);
          sendCartUpdate(id, 0);
          renderCart();
        });
      });
    }

    function renderCart() {
      updateBadge();
      updateTotal();
      renderDrawerItems();
    }

    function syncCardControl(productId: string) {
      const ctrl = document.querySelector<HTMLElement>(`.cart-controls[data-product-id="${productId}"]`);
      if (!ctrl) return;
      const valInput = ctrl.querySelector<HTMLInputElement>('.qty-val');
      const qty = cartState[productId] ?? 0;
      if (valInput) {
        valInput.value        = String(qty);
        valInput.dataset.empty = qty === 0 ? 'true' : 'false';
      }
    }

    // ── API ──────────────────────────────────────────────────────
    async function sendCartUpdate(productId: string, qty: number) {
      try {
        const endpoint = qty === 0 ? '/api/cart/remove' : '/api/cart/add';
        await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(qty === 0 ? { productId } : { productId, qty }),
        });
      } catch {
        // Optimistic update — silent fail
      }
    }

    // ── Fly-to-cart animation ────────────────────────────────────
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function flyToCart(fromEl: HTMLElement, productId: string) {
      if (reducedMotion) return;

      // Get product image from the card
      const card   = document.querySelector<HTMLElement>(`.cart-controls[data-product-id="${productId}"]`)?.closest<HTMLElement>('.product-card');
      const imgEl  = card?.querySelector<HTMLImageElement>('.product-img img');
      const imgSrc = imgEl?.src ?? null;
      // Fallback: first letter of product name from card
      const letter = card?.querySelector<HTMLElement>('.img-letter')?.textContent?.trim() ?? null;

      const fromRect   = fromEl.getBoundingClientRect();
      const toggleRect = cartToggle.getBoundingClientRect();

      const startX = fromRect.left + fromRect.width  / 2;
      const startY = fromRect.top  + fromRect.height / 2;
      const endX   = toggleRect.left + toggleRect.width  / 2;
      const endY   = toggleRect.top  + toggleRect.height / 2;

      // Dramatic parabolic arc — peak well above both endpoints
      const dy  = endY - startY;
      const dx  = endX - startX;
      const cpX = startX + dx * 0.35;
      const cpY = Math.min(startY, endY) - Math.max(Math.abs(dy), Math.abs(dx)) * 0.55 - 80;

      const thumb = document.createElement('div');
      thumb.className = imgSrc ? 'fly-dot fly-dot--img' : 'fly-dot fly-dot--letter';
      thumb.setAttribute('aria-hidden', 'true');

      if (imgSrc) {
        const img = document.createElement('img');
        img.src = imgSrc;
        img.alt = '';
        thumb.appendChild(img);
      } else if (letter) {
        thumb.textContent = letter;
      }

      thumb.style.cssText = `offset-path:path('M ${startX} ${startY} Q ${cpX} ${cpY} ${endX} ${endY}');offset-rotate:0deg;`;
      document.body.appendChild(thumb);

      const anim = thumb.animate(
        [
          { offsetDistance: '0%',   opacity: 1, transform: 'translate(-50%,-50%) scale(1)' },
          { offsetDistance: '70%',  opacity: 1, transform: 'translate(-50%,-50%) scale(0.9)' },
          { offsetDistance: '100%', opacity: 0, transform: 'translate(-50%,-50%) scale(0.15)' },
        ],
        { duration: 380, easing: 'cubic-bezier(0.25, 0.46, 0.45, 0.94)', fill: 'forwards' }
      );

      anim.onfinish = () => {
        thumb.remove();
        cartToggle.classList.add('cart-bounce');
        cartToggle.addEventListener('animationend',
          () => cartToggle.classList.remove('cart-bounce'), { once: true });
      };
    }

    // ── Card controls ────────────────────────────────────────────
    function pulse(btn: HTMLButtonElement) {
      btn.classList.add('btn-pressed');
      btn.addEventListener('animationend', () => btn.classList.remove('btn-pressed'), { once: true });
    }

    document.querySelectorAll<HTMLElement>('.cart-controls').forEach(ctrl => {
      const productId = ctrl.dataset.productId!;
      const initQty   = parseInt(ctrl.dataset.initialQty ?? '0', 10);
      if (initQty > 0) cartState[productId] = initQty;

      const valInput = ctrl.querySelector<HTMLInputElement>('.qty-val')!;
      const decBtn   = ctrl.querySelector<HTMLButtonElement>('.qty-btn--dec')!;
      const incBtn   = ctrl.querySelector<HTMLButtonElement>('.qty-btn--inc')!;

      function refreshCard(qty: number) {
        valInput.value        = String(qty);
        valInput.dataset.empty = qty === 0 ? 'true' : 'false';
      }
      refreshCard(initQty);

      decBtn.addEventListener('click', async () => {
        const cur = cartState[productId] ?? 0;
        if (cur === 0) return;
        pulse(decBtn);
        cartState[productId] = cur - 1;
        refreshCard(cur - 1);
        renderCart();
        await sendCartUpdate(productId, cur - 1);
      });

      incBtn.addEventListener('click', async () => {
        const newQty = (cartState[productId] ?? 0) + 1;
        pulse(incBtn);
        flyToCart(incBtn, productId);
        cartState[productId] = newQty;
        refreshCard(newQty);
        renderCart();
        await sendCartUpdate(productId, newQty);
      });

      // Direct keyboard input on qty field
      valInput.addEventListener('focus', () => { valInput.select(); });
      valInput.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter') { e.preventDefault(); valInput.blur(); }
      });
      valInput.addEventListener('blur', async () => {
        const raw = parseInt(valInput.value, 10);
        const newQty = isNaN(raw) || raw < 0 ? 0 : raw;
        const prev = cartState[productId] ?? 0;
        refreshCard(newQty);
        if (newQty === prev) return;
        cartState[productId] = newQty;
        renderCart();
        await sendCartUpdate(productId, newQty);
      });
    });

    // Initialize on load
    renderCart();
  }
</script>

