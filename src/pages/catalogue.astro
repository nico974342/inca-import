---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { supabaseAdmin, createAuthClient } from '../lib/supabase';

// Products (all, including OOS)
const { data: products } = await supabaseAdmin
  .from('products')
  .select('id, name, slug, category, description, image_url, in_stock, unit, units_per_carton, price_ht')
  .order('position', { ascending: true })
  .order('name', { ascending: true });

// Auth check — is this a logged-in client?
const supabase = createAuthClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
const isClient = user?.user_metadata?.role === 'client';

// Cart items for logged-in clients
const cartMap: Record<string, number> = {};
if (isClient && user) {
  const { data: cartRows } = await supabaseAdmin
    .from('cart_items')
    .select('product_id, quantity')
    .eq('user_id', user.id);
  for (const row of cartRows ?? []) {
    cartMap[row.product_id] = row.quantity;
  }
}

const totalCartQty = Object.values(cartMap).reduce((s, q) => s + q, 0);

const priceMap: Record<string, number> = {};
for (const p of products ?? []) priceMap[p.id] = Number(p.price_ht ?? 0);

const totalCartHT = Object.entries(cartMap).reduce(
  (s, [id, qty]) => s + qty * (priceMap[id] ?? 0), 0
);

const total   = products?.length ?? 0;
const inStock = products?.filter(p => p.in_stock).length ?? 0;

const CAT_LABEL: Record<string, string> = {
  boissons:    'Boissons',
  snacks:      'Snacks',
  confiseries: 'Confiseries',
};

const CAT_BG: Record<string, string> = {
  boissons:    'oklch(0.72 0.10 210)',
  snacks:      'oklch(0.78 0.10 60)',
  confiseries: 'oklch(0.76 0.10 330)',
};
---
<Base
  title="Catalogue — Inca Import"
  description="Découvrez notre catalogue de boissons, snacks et confiseries disponibles pour les gérants de stations-service et supérettes à La Réunion."
>
  <Nav user={user} />
  <main>

    <!-- Page header -->
    <section class="cat-header">
      <div class="container">
        <h1 class="cat-title">Catalogue</h1>
        <p class="cat-subtitle">
          {total} référence{total !== 1 ? 's' : ''} &nbsp;·&nbsp;
          {inStock} en stock &nbsp;·&nbsp; Livraison sous 48h à La Réunion
          {isClient && (
            <span class="client-tag">
              · Connecté : {user?.user_metadata?.nom ?? user?.email}
            </span>
          )}
        </p>
      </div>
    </section>

    <!-- Sticky filter bar -->
    <div class="filter-bar-wrap">
      <div class="container">
        <div class="filter-bar">
          <div class="filter-tabs" role="group" aria-label="Filtrer par catégorie">
            <button class="filter-tab is-active" data-cat="tous">Tous</button>
            <button class="filter-tab" data-cat="boissons">Boissons</button>
            <button class="filter-tab" data-cat="snacks">Snacks</button>
            <button class="filter-tab" data-cat="confiseries">Confiseries</button>
          </div>
          <div class="search-wrap">
            <svg class="search-icon" width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.4"/>
              <path d="M9.5 9.5L13 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
            <input
              type="search"
              id="cat-search"
              placeholder="Rechercher…"
              class="search-input"
              aria-label="Rechercher un produit"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Product grid -->
    <section class="products-section">
      <div class="container">
        {products && products.length > 0 ? (
          <div class="products-grid" id="productsGrid">
            {products.map(p => (
              <article
                class={`product-card${!p.in_stock ? ' product-card--oos' : ''}`}
                data-cat={p.category}
                data-name={p.name.toLowerCase()}
              >
                <!-- Image -->
                <div
                  class="product-img"
                  style={!p.image_url ? `background:${CAT_BG[p.category] ?? 'oklch(0.82 0 0)'}` : ''}
                >
                  {p.image_url ? (
                    <img src={p.image_url} alt={p.name} loading="lazy" decoding="async" />
                  ) : (
                    <span class="img-letter" aria-hidden="true">
                      {p.name[0].toUpperCase()}
                    </span>
                  )}
                  {!p.in_stock && (
                    <span class="oos-overlay" aria-hidden="true">Rupture de stock</span>
                  )}
                </div>

                <!-- Body -->
                <div class="product-body">
                  <div class="product-meta">
                    <span class={`cat-badge cat-badge--${p.category}`}>
                      {CAT_LABEL[p.category] ?? p.category}
                    </span>
                    {p.in_stock ? (
                      <span class="stock-dot stock-dot--in">En stock</span>
                    ) : (
                      <span class="stock-dot stock-dot--out">Rupture</span>
                    )}
                  </div>

                  <h2 class="product-name">
                    {p.slug ? (
                      <a href={`/catalogue/${p.slug}`} class="product-name-link">{p.name}</a>
                    ) : p.name}
                  </h2>

                  {p.units_per_carton ? (
                    <p class="product-unit">{p.units_per_carton} unités/{p.unit ?? 'carton'}</p>
                  ) : p.unit ? (
                    <p class="product-unit">{p.unit}</p>
                  ) : null}

                  {p.description && (
                    <p class="product-desc">{p.description}</p>
                  )}

                  <!-- Cart area: different per auth state -->
                  {isClient && p.in_stock ? (
                    <div
                      class="cart-controls"
                      data-product-id={p.id}
                      data-initial-qty={cartMap[p.id] ?? 0}
                      data-price={priceMap[p.id] ?? 0}
                    >
                      <button
                        type="button"
                        class="qty-btn qty-btn--dec"
                        aria-label={`Retirer ${p.name} du panier`}
                      >−</button>
                      <span class="qty-val" data-empty={!cartMap[p.id]}>
                        {cartMap[p.id] ?? 0}
                      </span>
                      <button
                        type="button"
                        class="qty-btn qty-btn--inc"
                        aria-label={`Ajouter ${p.name} au panier`}
                      >+</button>
                    </div>
                  ) : !isClient ? (
                    <a href="/connexion" class="card-cta">
                      Se connecter pour commander
                      <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                        <path d="M2.5 6.5h8M7 3l3.5 3.5L7 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  ) : null}
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <p class="empty-title">Le catalogue est en cours de construction.</p>
            <p class="empty-body">Revenez bientôt ou <a href="/#compte">ouvrez un compte</a> pour être informé.</p>
          </div>
        )}

        <p class="no-results" id="noResults" hidden aria-live="polite">
          Aucun produit ne correspond à votre recherche.
        </p>
      </div>
    </section>

    <!-- Bottom CTA band (only for non-clients) -->
    {!isClient && (
      <section class="cta-band" aria-label="Accès professionnel">
        <div class="container cta-inner">
          <div>
            <p class="cta-title">Accédez aux tarifs professionnels</p>
            <p class="cta-sub">Commandez en ligne, livraison sous 48h, équipe locale à La Réunion.</p>
          </div>
          <a href="/inscription" class="btn btn-primary">Ouvrir un compte →</a>
        </div>
      </section>
    )}

  </main>
  <Footer />

  <!-- Sticky cart bar (clients only) -->
  {isClient && (
    <div class="cart-bar" id="cartBar">
      <div class="container cart-bar-inner">
        <div class="cart-bar-info">
          <p class="cart-bar-text">
            <strong><span id="cartSummary">{totalCartQty} article{totalCartQty !== 1 ? 's' : ''}</span></strong>
            {' '}dans votre panier
          </p>
          <p class="cart-bar-total" id="cartTotal">
            Total HT : {totalCartHT.toFixed(2).replace('.', ',')} €
          </p>
        </div>
        <div class="cart-bar-actions">
          <form action="/api/auth/client-logout" method="POST">
            <button type="submit" class="btn-logout">Déconnexion</button>
          </form>
          <a href="/commande" class="btn btn-white">Voir ma commande →</a>
        </div>
      </div>
    </div>
  )}

</Base>

<script>
  // ── Filter & search (unchanged) ───────────────────────────────
  const tabs        = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const cards       = document.querySelectorAll<HTMLElement>('.product-card');
  const searchInput = document.getElementById('cat-search') as HTMLInputElement;
  const noResults   = document.getElementById('noResults') as HTMLElement;

  let activeCat   = 'tous';
  let searchQuery = '';

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const catMatch  = activeCat === 'tous' || card.dataset.cat === activeCat;
      const nameMatch = (card.dataset.name ?? '').includes(searchQuery);
      const show = catMatch && nameMatch;
      card.hidden = !show;
      if (show) visible++;
    });
    noResults.hidden = visible > 0;
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('is-active'));
      tab.classList.add('is-active');
      activeCat = tab.dataset.cat ?? 'tous';
      applyFilters();
    });
  });

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    applyFilters();
  });

  // ── Cart logic (clients only) ─────────────────────────────────
  const cartBar     = document.getElementById('cartBar');
  const cartSummary = document.getElementById('cartSummary');

  if (!cartBar) {
    // Not logged in as client — no cart logic needed
  } else {
    // Initialize cart state and price map from server-rendered data attributes
    const cartState: Record<string, number> = {};
    const priceMap: Record<string, number>  = {};

    document.querySelectorAll<HTMLElement>('.cart-controls').forEach(ctrl => {
      const productId = ctrl.dataset.productId!;
      const initQty   = parseInt(ctrl.dataset.initialQty ?? '0', 10);
      priceMap[productId] = parseFloat(ctrl.dataset.price ?? '0');
      if (initQty > 0) cartState[productId] = initQty;

      const valSpan = ctrl.querySelector<HTMLElement>('.qty-val')!;
      const decBtn  = ctrl.querySelector<HTMLButtonElement>('.qty-btn--dec')!;
      const incBtn  = ctrl.querySelector<HTMLButtonElement>('.qty-btn--inc')!;

      function refreshCard(qty: number) {
        valSpan.textContent   = String(qty);
        valSpan.dataset.empty = qty === 0 ? 'true' : 'false';
      }
      refreshCard(initQty);

      decBtn.addEventListener('click', async () => {
        const cur    = cartState[productId] ?? 0;
        if (cur === 0) return;
        const newQty = cur - 1;
        cartState[productId] = newQty;
        refreshCard(newQty);
        updateCartBar();
        await sendCartUpdate(productId, newQty);
      });

      incBtn.addEventListener('click', async () => {
        const newQty = (cartState[productId] ?? 0) + 1;
        cartState[productId] = newQty;
        refreshCard(newQty);
        updateCartBar();
        await sendCartUpdate(productId, newQty);
      });
    });

    async function sendCartUpdate(productId: string, qty: number) {
      try {
        if (qty === 0) {
          await fetch('/api/cart/remove', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId }),
          });
        } else {
          await fetch('/api/cart/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId, qty }),
          });
        }
      } catch {
        // Silent fail — state is optimistically updated
      }
    }

    function updateCartBar() {
      let totalQty = 0;
      let totalHT  = 0;
      for (const [productId, qty] of Object.entries(cartState)) {
        if (qty > 0) {
          totalQty += qty;
          totalHT  += qty * (priceMap[productId] ?? 0);
        }
      }
      if (cartSummary) {
        cartSummary.textContent = `${totalQty} article${totalQty !== 1 ? 's' : ''}`;
      }
      const cartTotalEl = document.getElementById('cartTotal');
      if (cartTotalEl) {
        cartTotalEl.textContent = `Total HT : ${totalHT.toFixed(2).replace('.', ',')} €`;
      }
      cartBar.classList.toggle('is-visible', totalQty > 0);
    }

    // Show bar if items already in cart on page load
    updateCartBar();
  }
</script>

<style>
/* ── Page header ──────────────────────────────────── */
.cat-header {
  padding: clamp(var(--space-10), 5vw, var(--space-16)) 0 var(--space-6);
  border-bottom: 1px solid var(--color-border);
}

.cat-title {
  font-family: var(--font-display);
  font-size: clamp(2.25rem, 6vw, 3.5rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: var(--color-ink);
  line-height: 1.05;
  margin-bottom: var(--space-3);
}

.cat-subtitle {
  font-size: var(--text-sm);
  color: var(--color-muted);
}

.client-tag {
  color: oklch(0.40 0.13 145);
  font-weight: 500;
}

/* ── Filter bar ───────────────────────────────────── */
.filter-bar-wrap {
  position: sticky;
  top: 64px;
  z-index: var(--z-dropdown);
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
  padding: var(--space-4) 0;
}

.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  flex-wrap: wrap;
}

.filter-tabs {
  display: flex;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.filter-tab {
  padding: 0.4375rem var(--space-4);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-muted);
  background: transparent;
  border: 1.5px solid var(--color-border-strong);
  border-radius: var(--radius-full);
  cursor: pointer;
  min-height: 36px;
  transition: color var(--dur-fast), background var(--dur-fast), border-color var(--dur-fast);
}
.filter-tab:hover    { color: var(--color-ink); }
.filter-tab.is-active {
  color: white;
  background: var(--color-primary);
  border-color: var(--color-primary);
}
.filter-tab:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; }

.search-wrap { position: relative; }
.search-icon {
  position: absolute;
  left: 11px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--color-muted);
  pointer-events: none;
}
.search-input {
  padding: 0.4375rem var(--space-4) 0.4375rem 2rem;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-ink);
  background: var(--color-bg);
  border: 1.5px solid var(--color-border-strong);
  border-radius: var(--radius-full);
  width: 200px;
  min-height: 36px;
  outline: none;
  transition: border-color var(--dur-fast), box-shadow var(--dur-fast);
}
.search-input::placeholder { color: var(--color-muted); }
.search-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px oklch(0.568 0.149 45.9 / 0.12);
}

/* ── Products section ─────────────────────────────── */
.products-section {
  padding: clamp(var(--space-8), 4vw, var(--space-14)) 0;
}

.products-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: var(--space-5);
}

/* ── Product card ─────────────────────────────────── */
.product-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: border-color var(--dur-fast), box-shadow var(--dur-base);
}
.product-card:not(.product-card--oos):hover {
  border-color: var(--color-border-strong);
  box-shadow: 0 4px 20px oklch(0 0 0 / 0.07);
}

.product-card--oos { opacity: 0.5; }
.product-card--oos .product-img img { filter: grayscale(50%); }

/* Image */
.product-img {
  position: relative;
  aspect-ratio: 4 / 3;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-surface-2);
}
.product-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s var(--ease-out-expo);
}
.product-card:not(.product-card--oos):hover .product-img img {
  transform: scale(1.04);
}

.img-letter {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 6vw, 4rem);
  font-weight: 700;
  color: white;
  opacity: 0.55;
  line-height: 1;
  user-select: none;
}

.oos-overlay {
  position: absolute;
  bottom: var(--space-3);
  left: var(--space-3);
  background: oklch(0.14 0.02 45 / 0.65);
  color: white;
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.03em;
  padding: 3px 10px;
  border-radius: var(--radius-full);
  backdrop-filter: blur(4px);
}

/* Body */
.product-body {
  padding: var(--space-4) var(--space-5) var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  flex: 1;
}

.product-meta {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.cat-badge {
  font-size: var(--text-xs);
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  line-height: 1.6;
}
.cat-badge--boissons    { background: oklch(0.93 0.05 220); color: oklch(0.33 0.10 220); }
.cat-badge--snacks      { background: oklch(0.94 0.05 60);  color: oklch(0.38 0.12 60);  }
.cat-badge--confiseries { background: oklch(0.93 0.06 330); color: oklch(0.36 0.12 330); }

.stock-dot {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: var(--text-xs);
  font-weight: 500;
  line-height: 1.6;
}
.stock-dot::before {
  content: '';
  width: 5px;
  height: 5px;
  border-radius: 50%;
  flex-shrink: 0;
}
.stock-dot--in  { color: oklch(0.40 0.13 145); }
.stock-dot--in::before  { background: oklch(0.52 0.17 145); }
.stock-dot--out { color: oklch(0.46 0.08 25); }
.stock-dot--out::before { background: oklch(0.58 0.12 25); }

.product-name {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 600;
  letter-spacing: -0.015em;
  color: var(--color-ink);
  line-height: 1.2;
  margin-top: var(--space-1);
}

.product-desc {
  font-size: var(--text-sm);
  color: var(--color-muted);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-unit {
  font-size: var(--text-xs);
  color: var(--color-muted);
  font-weight: 500;
  letter-spacing: 0.01em;
}

/* Guest CTA */
.card-cta {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  margin-top: auto;
  padding-top: var(--space-4);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-primary-deep);
  text-decoration: none;
  transition: gap var(--dur-fast) var(--ease-out-quart), color var(--dur-fast);
  border-top: 1px solid var(--color-border);
}
.card-cta:hover { gap: var(--space-3); color: var(--color-primary); }
.product-card--oos .card-cta { pointer-events: none; opacity: 0.5; }

/* ── Cart controls ────────────────────────────────── */
.cart-controls {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-top: auto;
  padding-top: var(--space-4);
  border-top: 1px solid var(--color-border);
}

.qty-btn {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-full);
  border: 1.5px solid var(--color-border-strong);
  background: transparent;
  font-size: 1.125rem;
  line-height: 1;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-ink);
  flex-shrink: 0;
  transition: background var(--dur-fast), border-color var(--dur-fast), color var(--dur-fast);
  user-select: none;
}
.qty-btn:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
}
.qty-btn--dec:active,
.qty-btn--inc:active { transform: scale(0.92); }

.qty-val {
  flex: 1;
  text-align: center;
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-ink);
  min-width: 1.5rem;
  transition: color var(--dur-fast);
}
.qty-val[data-empty="true"] {
  color: var(--color-muted);
  font-weight: 400;
}

/* ── Empty / no results ───────────────────────────── */
.empty-state {
  padding: var(--space-20) 0;
  text-align: center;
}
.empty-title {
  font-size: var(--text-lg);
  font-weight: 500;
  color: var(--color-ink);
  margin-bottom: var(--space-3);
}
.empty-body { color: var(--color-muted); }
.empty-body a { color: var(--color-primary-deep); font-weight: 500; }

.no-results {
  padding: var(--space-16) 0;
  text-align: center;
  color: var(--color-muted);
  font-size: var(--text-base);
}

/* ── Bottom CTA ───────────────────────────────────── */
.cta-band {
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
  padding: clamp(var(--space-10), 5vw, var(--space-16)) 0;
}
.cta-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-6);
  flex-wrap: wrap;
}
.cta-title {
  font-family: var(--font-display);
  font-size: clamp(1.375rem, 3vw, 1.875rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-ink);
  margin-bottom: var(--space-2);
}
.cta-sub { font-size: var(--text-sm); color: var(--color-muted); }

/* ── Cart bar ─────────────────────────────────────── */
.cart-bar {
