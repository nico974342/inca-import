---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { supabaseAdmin, createAuthClient } from '../lib/supabase';

const { data: products } = await supabaseAdmin
  .from('products')
  .select('id, name, slug, category, description, image_url, in_stock, unit, units_per_carton, price_ht')
  .order('position', { ascending: true })
  .order('name', { ascending: true });

const supabase = createAuthClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
const isClient = user?.user_metadata?.role === 'client';

const cartMap: Record<string, number> = {};
if (isClient && user) {
  const { data: cartRows } = await supabaseAdmin
    .from('cart_items')
    .select('product_id, quantity')
    .eq('user_id', user.id);
  for (const row of cartRows ?? []) {
    cartMap[row.product_id] = row.quantity;
  }
}

const totalCartQty = Object.values(cartMap).reduce((s, q) => s + q, 0);

const priceMap: Record<string, number> = {};
for (const p of products ?? []) priceMap[p.id] = Number(p.price_ht ?? 0);

const totalCartHT = Object.entries(cartMap).reduce(
  (s, [id, qty]) => s + qty * (priceMap[id] ?? 0), 0
);

const total   = products?.length ?? 0;
const inStock = products?.filter(p => p.in_stock).length ?? 0;

const CAT_LABEL: Record<string, string> = {
  boissons:    'Boissons',
  snacks:      'Snacks',
  confiseries: 'Confiseries',
};

const CAT_BG: Record<string, string> = {
  boissons:    'oklch(0.72 0.10 210)',
  snacks:      'oklch(0.78 0.10 60)',
  confiseries: 'oklch(0.76 0.10 330)',
};

const initialCat = Astro.url.searchParams.get('cat') ?? 'tous';

// Safe JSON for product metadata (used by cart drawer JS)
const productsMetaJSON = JSON.stringify(
  (products ?? []).map(p => ({
    id: p.id,
    name: p.name,
    unit: p.unit ?? null,
    units_per_carton: p.units_per_carton ?? null,
  }))
).replace(/</g, '\\u003c').replace(/>/g, '\\u003e').replace(/&/g, '\\u0026');
---
<Base
  title="Catalogue — Inca Import"
  description="Découvrez notre catalogue de boissons, snacks et confiseries disponibles pour les gérants de stations-service et supérettes à La Réunion."
>
  <Nav user={user} />
  <main>

    <!-- Product metadata for cart drawer JS -->
    {isClient && (
      <script type="application/json" id="productsMetaData" set:html={productsMetaJSON} />
    )}

    <!-- Page header -->
    <section class="cat-header">
      <div class="container cat-header-inner">
        <div class="cat-header-text">
          <h1 class="cat-title">Catalogue</h1>
          <p class="cat-meta">
            {total} référence{total !== 1 ? 's' : ''}
            <span class="cat-meta-sep" aria-hidden="true">·</span>
            {inStock} en stock
            <span class="cat-meta-sep" aria-hidden="true">·</span>
            Livraison 48h · La Réunion
          </p>
        </div>
        {isClient && (
          <p class="client-greeting">
            Connecté ·&nbsp;<strong>{user?.user_metadata?.nom ?? user?.email}</strong>
          </p>
        )}
      </div>
    </section>

    <!-- Sticky filter bar -->
    <div class="filter-bar-wrap">
      <div class="container">
        <div class="filter-bar">
          <div class="filter-tabs" role="group" aria-label="Filtrer par catégorie" data-initial-cat={initialCat}>
            <div class="tab-indicator" aria-hidden="true"></div>
            <button class={`filter-tab${initialCat === 'tous' ? ' is-active' : ''}`} data-cat="tous">Tous</button>
            <button class={`filter-tab${initialCat === 'boissons' ? ' is-active' : ''}`} data-cat="boissons">Boissons</button>
            <button class={`filter-tab${initialCat === 'snacks' ? ' is-active' : ''}`} data-cat="snacks">Snacks</button>
            <button class={`filter-tab${initialCat === 'confiseries' ? ' is-active' : ''}`} data-cat="confiseries">Confiseries</button>
          </div>
          <div class="search-wrap">
            <svg class="search-icon" width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.4"/>
              <path d="M9.5 9.5L13 13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            </svg>
            <input
              type="search"
              id="cat-search"
              placeholder="Rechercher…"
              class="search-input"
              aria-label="Rechercher un produit"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- Product grid -->
    <section class="products-section">
      <div class="container">
        {products && products.length > 0 ? (
          <div class="products-grid" id="productsGrid">
            {products.map(p => {
              const priceFormatted = p.price_ht
                ? Number(p.price_ht).toFixed(2).replace('.', ',')
                : null;
              return (
              <article
                class={`product-card${!p.in_stock ? ' product-card--oos' : ''}`}
                data-cat={p.category}
                data-name={p.name.toLowerCase()}
              >
                <div
                  class="product-img"
                  style={!p.image_url ? `background:${CAT_BG[p.category] ?? 'oklch(0.82 0 0)'}` : ''}
                >
                  {p.image_url ? (
                    <img src={p.image_url} alt={p.name} loading="lazy" decoding="async" />
                  ) : (
                    <span class="img-letter" aria-hidden="true">{p.name[0].toUpperCase()}</span>
                  )}
                  {!p.in_stock && (
                    <span class="oos-badge" aria-label="Rupture de stock">Rupture de stock</span>
                  )}
                </div>

                <div class="product-body">
                  <span class={`cat-badge cat-badge--${p.category}`}>
                    {CAT_LABEL[p.category] ?? p.category}
                  </span>

                  <div class="product-name-group">
                    <h2 class="product-name">
                      {p.slug ? (
                        <a href={`/catalogue/${p.slug}`} class="product-name-link">{p.name}</a>
                      ) : p.name}
                    </h2>
                    {isClient && priceFormatted && (
                      <p class="product-price" aria-label={`Prix : ${priceFormatted} euros HT`}>
                        {priceFormatted}&nbsp;<span class="price-currency">€</span>
                        <span class="price-suffix">HT</span>
                      </p>
                    )}
                  </div>

                  {p.units_per_carton ? (
                    <p class="product-unit">{p.units_per_carton} unités/{p.unit ?? 'carton'}</p>
                  ) : p.unit ? (
                    <p class="product-unit">{p.unit}</p>
                  ) : null}

                  {p.description && <p class="product-desc">{p.description}</p>}

                  {isClient && p.in_stock ? (
                    <div
                      class="cart-controls"
                      data-product-id={p.id}
                      data-initial-qty={cartMap[p.id] ?? 0}
                      data-price={priceMap[p.id] ?? 0}
                    >
                      <button type="button" class="qty-btn qty-btn--dec" aria-label={`Retirer ${p.name} du panier`}>−</button>
                      <span class="qty-val" data-empty={!cartMap[p.id]}>{cartMap[p.id] ?? 0}</span>
                      <button type="button" class="qty-btn qty-btn--inc" aria-label={`Ajouter ${p.name} au panier`}>+</button>
                    </div>
                  ) : !isClient ? (
                    <a href="/connexion" class="card-cta">
                      Se connecter pour commander
                      <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                        <path d="M2.5 6.5h8M7 3l3.5 3.5L7 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </a>
                  ) : null}
                </div>
              </article>
              );
            })}
          </div>
        ) : (
          <div class="empty-state">
            <p class="empty-title">Le catalogue est en cours de construction.</p>
            <p class="empty-body">Revenez bientôt ou <a href="/#compte">ouvrez un compte</a> pour être informé.</p>
          </div>
        )}

        <p class="no-results" id="noResults" hidden aria-live="polite">
          Aucun produit ne correspond à votre recherche.
        </p>
      </div>
    </section>

    <!-- Bottom CTA band (guests only) -->
    {!isClient && (
      <section class="cta-band" aria-label="Accès professionnel">
        <div class="container cta-band-inner">
          <div>
            <p class="cta-band-title">Accédez aux tarifs professionnels</p>
            <p class="cta-band-sub">Commandez en ligne, livraison sous 48h, équipe locale à La Réunion.</p>
          </div>
          <a href="/inscription" class="btn btn-primary">Ouvrir un compte →</a>
        </div>
      </section>
    )}

  </main>
  <Footer />

  {isClient && (
    <>
      <!-- Logout form (used by drawer) -->
      <form id="logoutForm" action="/api/auth/client-logout" method="POST" hidden>
      </form>

      <!-- Backdrop -->
      <div class="cart-backdrop" id="cartBackdrop" aria-hidden="true"></div>

      <!-- Cart drawer -->
      <aside
        class="cart-drawer"
        id="cartDrawer"
        role="dialog"
        aria-label="Votre panier"
        aria-modal="true"
        aria-hidden="true"
      >
        <div class="drawer-header">
          <h2 class="drawer-heading">Panier</h2>
          <div class="drawer-header-actions">
            <button type="button" class="drawer-logout" id="drawerLogoutBtn" aria-label="Se déconnecter">
              Déconnexion
            </button>
            <button type="button" class="drawer-close" id="drawerClose" aria-label="Fermer le panier">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="drawer-body" id="drawerBody">
          <ul class="drawer-items-list" id="drawerItemsList" aria-label="Articles dans votre panier"></ul>
          <p class="drawer-empty" id="drawerEmpty" aria-live="polite">Votre panier est vide.</p>
        </div>

        <div class="drawer-footer">
          <div class="drawer-total-row">
            <span class="drawer-total-label">Total HT</span>
            <span class="drawer-total-amount" id="drawerTotal">{totalCartHT.toFixed(2).replace('.', ',')} €</span>
          </div>
          <a href="/commande" class="btn btn-primary drawer-checkout">
            Passer commande
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </aside>

      <!-- Cart toggle button -->
      <button
        class="cart-toggle"
        id="cartToggle"
        aria-label={`Ouvrir le panier — ${totalCartQty} article${totalCartQty !== 1 ? 's' : ''}`}
        aria-expanded="false"
        aria-controls="cartDrawer"
      >
        <svg class="cart-toggle-icon" width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <path d="M1.5 1.5h3l2.4 11.5m0 0H18l1.5-7H6.9m0 7-.9 4h13.5" stroke="white" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="8.5" cy="20" r="1.5" fill="white"/>
          <circle cx="17.5" cy="20" r="1.5" fill="white"/>
        </svg>
        <span
          class="cart-toggle-badge"
          id="cartBadge"
          data-empty={totalCartQty === 0}
          aria-hidden="true"
        >{totalCartQty}</span>
      </button>
    </>
  )}

</Base>

<script>
  // ── Sliding filter indicator ──────────────────────────────────
  const tabsEl    = document.querySelector<HTMLElement>('.filter-tabs');
  const indicator = document.querySelector<HTMLElement>('.tab-indicator');
  const tabs      = document.querySelectorAll<HTMLButtonElement>('.filter-tab');

  function moveIndicator(tab: HTMLButtonElement, animate = true) {
    if (!indicator) return;
    if (!animate) indicator.style.transition = 'none';
    indicator.style.left  = `${tab.offsetLeft}px`;
    indicator.style.width = `${tab.offsetWidth}px`;
    if (!animate) requestAnimationFrame(() => { indicator.style.transition = ''; });
  }

  const initialActive = document.querySelector<HTMLButtonElement>('.filter-tab.is-active');
  if (initialActive && indicator) {
    moveIndicator(initialActive, false);
    requestAnimationFrame(() => { indicator.style.opacity = '1'; });
  }

  // ── Filter & search ───────────────────────────────────────────
  const cards       = document.querySelectorAll<HTMLElement>('.product-card');
  const searchInput = document.getElementById('cat-search') as HTMLInputElement;
  const noResults   = document.getElementById('noResults') as HTMLElement;

  let activeCat   = tabsEl?.dataset.initialCat ?? 'tous';
  let searchQuery = '';

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const catMatch  = activeCat === 'tous' || card.dataset.cat === activeCat;
      const nameMatch = (card.dataset.name ?? '').includes(searchQuery);
      const show = catMatch && nameMatch;
      card.hidden = !show;
      if (show) visible++;
    });
    noResults.hidden = visible > 0;
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('is-active'));
      tab.classList.add('is-active');
      activeCat = tab.dataset.cat ?? 'tous';
      moveIndicator(tab);
      applyFilters();
    });
  });

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    applyFilters();
  });

  if (activeCat !== 'tous') applyFilters();

  // ── Cart drawer (clients only) ────────────────────────────────
  const cartToggle  = document.getElementById('cartToggle');
  if (!cartToggle) {
    // Guest — no cart logic needed
  } else {
    // Parse product metadata
    type ProductMeta = { id: string; name: string; unit: string | null; units_per_carton: number | null };
    const metaEl  = document.getElementById('productsMetaData');
    const allMeta: ProductMeta[] = metaEl ? JSON.parse(metaEl.textContent ?? '[]') : [];
    const productMap = Object.fromEntries(allMeta.map(p => [p.id, p]));

    // Cart state (source of truth)
    const cartState: Record<string, number> = {};
    const priceMap:  Record<string, number>  = {};

    document.querySelectorAll<HTMLElement>('.cart-controls').forEach(ctrl => {
      const id  = ctrl.dataset.productId!;
      const qty = parseInt(ctrl.dataset.initialQty ?? '0', 10);
      priceMap[id]  = parseFloat(ctrl.dataset.price ?? '0');
      if (qty > 0) cartState[id] = qty;
    });

    // Drawer elements
    const backdrop       = document.getElementById('cartBackdrop')!;
    const drawer         = document.getElementById('cartDrawer')!;
    const drawerClose    = document.getElementById('drawerClose')!;
    const drawerLogout   = document.getElementById('drawerLogoutBtn')!;
    const drawerItemsList = document.getElementById('drawerItemsList')!;
    const drawerEmptyEl  = document.getElementById('drawerEmpty')!;
    const drawerTotalEl  = document.getElementById('drawerTotal')!;
    const cartBadge      = document.getElementById('cartBadge')!;
    const logoutForm     = document.getElementById('logoutForm') as HTMLFormElement;

    let isOpen = false;

    // ── Drawer open / close ──────────────────────────────────────
    function openDrawer() {
      isOpen = true;
      drawer.classList.add('is-open');
      backdrop.classList.add('is-open');
      drawer.setAttribute('aria-hidden', 'false');
      cartToggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      drawerClose.focus();
    }

    function closeDrawer() {
      isOpen = false;
      drawer.classList.remove('is-open');
      backdrop.classList.remove('is-open');
      drawer.setAttribute('aria-hidden', 'true');
      cartToggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      cartToggle.focus();
    }

    cartToggle.addEventListener('click', () => isOpen ? closeDrawer() : openDrawer());
    drawerClose.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);
    drawerLogout.addEventListener('click', () => logoutForm?.submit());

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && isOpen) closeDrawer();
    });

    // ── Cart totals ───────────────────────────────────────────────
    function calcTotalQty(): number {
      return Object.values(cartState).reduce((s, q) => s + (q > 0 ? q : 0), 0);
    }

    function calcTotalHT(): number {
      return Object.entries(cartState)
        .reduce((s, [id, q]) => s + (q > 0 ? q * (priceMap[id] ?? 0) : 0), 0);
    }

    // ── Render ───────────────────────────────────────────────────
    function updateBadge() {
      const qty = calcTotalQty();
      cartBadge.textContent = String(qty);
      cartBadge.dataset.empty = qty === 0 ? 'true' : 'false';
      cartToggle.setAttribute('aria-label',
        `${isOpen ? 'Fermer' : 'Ouvrir'} le panier — ${qty} article${qty !== 1 ? 's' : ''}`
      );
    }

    function updateTotal() {
      drawerTotalEl.textContent = calcTotalHT().toFixed(2).replace('.', ',') + ' €';
    }

    function renderDrawerItems() {
      const active = Object.entries(cartState).filter(([, q]) => q > 0);
      drawerEmptyEl.hidden = active.length > 0;

      // Sync existing items, add new ones, remove old ones
      // Simpler: full rebuild (fast enough for catalogue sizes)
      drawerItemsList.innerHTML = '';

      active.forEach(([id, qty]) => {
        const meta = productMap[id];
        if (!meta) return;
        const linePrice = (qty * (priceMap[id] ?? 0)).toFixed(2).replace('.', ',');
        const unitLine  = meta.units_per_carton
          ? `${meta.units_per_carton} unités/${meta.unit ?? 'carton'}`
          : (meta.unit ?? '');

        const li = document.createElement('li');
        li.className = 'drawer-item';
        li.dataset.productId = id;
        li.innerHTML = `
          <div class="drawer-item-top">
            <p class="drawer-item-name">${meta.name}</p>
            <p class="drawer-item-price">${linePrice}&nbsp;€</p>
          </div>
          ${unitLine ? `<p class="drawer-item-meta">${unitLine}</p>` : ''}
          <div class="drawer-item-controls">
            <div class="drawer-stepper">
              <button type="button" class="d-qty-btn d-qty-dec" aria-label="Retirer un ${meta.name}">−</button>
              <span class="d-qty-val" aria-live="polite">${qty}</span>
              <button type="button" class="d-qty-btn d-qty-inc" aria-label="Ajouter un ${meta.name}">+</button>
            </div>
            <button type="button" class="drawer-item-del" aria-label="Supprimer ${meta.name} du panier">
              <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
                <path d="M2 4h11M5 4V2.75a.75.75 0 0 1 .75-.75h3.5a.75.75 0 0 1 .75.75V4M6 7v4.5M9 7v4.5M3 4l.65 8.35a.75.75 0 0 0 .75.65h6.2a.75.75 0 0 0 .75-.65L12 4"
                  stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        `;

        li.querySelector('.d-qty-dec')?.addEventListener('click', () => {
          if ((cartState[id] ?? 0) <= 0) return;
          cartState[id]--;
          syncCardControl(id);
          sendCartUpdate(id, cartState[id]);
          renderCart();
        });

        li.querySelector('.d-qty-inc')?.addEventListener('click', () => {
          cartState[id] = (cartState[id] ?? 0) + 1;
          syncCardControl(id);
          sendCartUpdate(id, cartState[id]);
          renderCart();
        });

        li.querySelector('.drawer-item-del')?.addEventListener('click', () => {
          cartState[id] = 0;
          syncCardControl(id);
          sendCartUpdate(id, 0);
          renderCart();
        });

        drawerItemsList.appendChild(li);
      });
    }

    function renderCart() {
      updateBadge();
      updateTotal();
      renderDrawerItems();
    }

    function syncCardControl(productId: string) {
      const ctrl = document.querySelector<HTMLElement>(`.cart-controls[data-product-id="${productId}"]`);
      if (!ctrl) return;
      const valSpan = ctrl.querySelector<HTMLElement>('.qty-val');
      const qty = cartState[productId] ?? 0;
      if (valSpan) {
        valSpan.textContent   = String(qty);
        valSpan.dataset.empty = qty === 0 ? 'true' : 'false';
      }
    }

    // ── API ──────────────────────────────────────────────────────
    async function sendCartUpdate(productId: string, qty: number) {
      try {
        const endpoint = qty === 0 ? '/api/cart/remove' : '/api/cart/add';
        await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(qty === 0 ? { productId } : { productId, qty }),
        });
      } catch {
        // Optimistic update — silent fail
      }
    }

    // ── Fly-to-cart animation ────────────────────────────────────
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function flyToCart(fromEl: HTMLElement) {
      if (reducedMotion) return;
      const fromRect   = fromEl.getBoundingClientRect();
      const toggleRect = cartToggle.getBoundingClientRect();

      const startX = fromRect.left + fromRect.width  / 2;
      const startY = fromRect.top  + fromRect.height / 2;
      const endX   = toggleRect.left + toggleRect.width  / 2;
      const endY   = toggleRect.top  + toggleRect.height / 2;

      // Arc control point: pull upward and toward the end
      const cpX = startX + (endX - startX) * 0.25;
      const cpY = Math.min(startY, endY) - Math.abs(endY - startY) * 0.6 - 60;

      const dot = document.createElement('div');
      dot.className = 'fly-dot';
      dot.style.cssText = `left:${startX}px;top:${startY}px;offset-path:path('M ${startX} ${startY} Q ${cpX} ${cpY} ${endX} ${endY}');offset-rotate:0deg;`;
      document.body.appendChild(dot);

      const anim = dot.animate(
        [{ offsetDistance: '0%', opacity: 1, transform: 'translate(-50%,-50%) scale(1)' },
         { offsetDistance: '85%', opacity: 1, transform: 'translate(-50%,-50%) scale(0.8)' },
         { offsetDistance: '100%', opacity: 0, transform: 'translate(-50%,-50%) scale(0.3)' }],
        { duration: 580, easing: 'ease-in-out', fill: 'forwards' }
      );

      anim.onfinish = () => {
        dot.remove();
        cartToggle.classList.add('cart-bounce');
        cartToggle.addEventListener('animationend',
          () => cartToggle.classList.remove('cart-bounce'), { once: true });
      };
    }

    // ── Card controls ────────────────────────────────────────────
    function pulse(btn: HTMLButtonElement) {
      btn.classList.add('btn-pressed');
      btn.addEventListener('animationend', () => btn.classList.remove('btn-pressed'), { once: true });
    }

    document.querySelectorAll<HTMLElement>('.cart-controls').forEach(ctrl => {
      const productId = ctrl.dataset.productId!;
      const initQty   = parseInt(ctrl.dataset.initialQty ?? '0', 10);
      if (initQty > 0) cartState[productId] = initQty;

      const valSpan = ctrl.querySelector<HTMLElement>('.qty-val')!;
      const decBtn  = ctrl.querySelector<HTMLButtonElement>('.qty-btn--dec')!;
      const incBtn  = ctrl.querySelector<HTMLButtonElement>('.qty-btn--inc')!;

      function refreshCard(qty: number) {
        valSpan.textContent   = String(qty);
        valSpan.dataset.empty = qty === 0 ? 'true' : 'false';
      }
      refreshCard(initQty);

      decBtn.addEventListener('click', async () => {
        const cur = cartState[productId] ?? 0;
        if (cur === 0) return;
        pulse(decBtn);
        cartState[productId] = cur - 1;
        refreshCard(cur - 1);
        renderCart();
        await sendCartUpdate(productId, cur - 1);
      });

      incBtn.addEventListener('click', async () => {
        const newQty = (cartState[productId] ?? 0) + 1;
        pulse(incBtn);
        flyToCart(incBtn);
        cartState[productId] = newQty;
        refreshCard(newQty);
        renderCart();
        await sendCartUpdate(productId, newQty);
      });
    });

    // Initialize on load
    renderCart();
  }
</script>

