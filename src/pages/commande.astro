---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { supabaseAdmin, createAuthClient } from '../lib/supabase';
import { Resend } from 'resend';
import { generateOrderPDF } from '../lib/pdf';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/connexion');

const CAT_LABEL: Record<string, string> = {
  boissons:    'Boissons',
  snacks:      'Snacks',
  confiseries: 'Confiseries',
};

// ── POST: confirm order ────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form  = await Astro.request.formData();
  const notes = (form.get('notes') as string)?.trim() ?? '';

  const { data: items } = await supabaseAdmin
    .from('cart_items')
    .select('quantity, products(id, name, category, unit, units_per_carton, price_ht)')
    .eq('user_id', user.id);

  if (!items?.length) return Astro.redirect('/catalogue');

  // Create order record
  const { data: order, error: orderError } = await supabaseAdmin
    .from('orders')
    .insert({
      user_id:   user.id,
      nom:       user.user_metadata?.nom ?? '',
      societe:   user.user_metadata?.societe ?? '',
      telephone: user.user_metadata?.telephone ?? '',
      email:     user.email ?? '',
      notes,
    })
    .select('id')
    .single();

  if (orderError || !order) return Astro.redirect('/commande?error=1');

  // Snapshot order items
  await supabaseAdmin.from('order_items').insert(
    items.map(item => {
      const p = item.products as any;
      return {
        order_id:     order.id,
        product_id:   p?.id ?? null,
        product_name: p?.name ?? 'Produit inconnu',
        quantity:     item.quantity,
        unit:         p?.unit ?? null,
      };
    })
  );

  // Clear cart
  await supabaseAdmin.from('cart_items').delete().eq('user_id', user.id);

  // Build email/PDF data (use items captured before cart was cleared)
  const nom     = user.user_metadata?.nom ?? user.email ?? '';
  const societe = user.user_metadata?.societe ?? '';
  const tel     = user.user_metadata?.telephone ?? '';
  const orderTotalHT = items.reduce(
    (s, item) => s + item.quantity * Number((item.products as any)?.price_ht ?? 0), 0
  );

  // Generate PDF — non-blocking on error
  let pdfBuffer: Buffer | null = null;
  try {
    pdfBuffer = await generateOrderPDF({
      id: order.id,
      nom,
      societe,
      email: user.email ?? '',
      telephone: tel,
      notes,
      items: items.map(item => {
        const p = item.products as any;
        return { product_name: p?.name ?? '?', quantity: item.quantity, unit: p?.unit, price_ht: p?.price_ht };
      }),
      totalHT: orderTotalHT,
      date: new Date().toLocaleDateString('fr-FR'),
    });
  } catch (pdfErr) {
    console.error('[PDF] Error:', pdfErr);
  }

  // Send notification email — non-blocking
  try {
    const resend = new Resend(import.meta.env.RESEND_API_KEY);
    const lignes = items.map(item => {
      const p      = item.products as any;
      const unit   = p?.unit ? ` (${p.unit})` : '';
      const lineHT = (item.quantity * Number(p?.price_ht ?? 0)).toFixed(2).replace('.', ',');
      return `• ${p?.name ?? '?'} × ${item.quantity}${unit} — ${lineHT} € HT`;
    }).join('\n');

    const emailPayload: Parameters<typeof resend.emails.send>[0] = {
      from:    'onboarding@resend.dev',
      to:      'inca-import@hotmail.com',
      subject: `Nouvelle commande — ${nom}${societe ? ` (${societe})` : ''}`,
      text: [
        '=== Nouvelle commande Inca Import ===',
        '',
        `Client    : ${nom}`,
        `Société   : ${societe || '—'}`,
        `Email     : ${user.email}`,
        `Téléphone : ${tel || '—'}`,
        '',
        'Articles commandés :',
        lignes,
        '',
        `Total HT  : ${orderTotalHT.toFixed(2).replace('.', ',')} €`,
        ...(notes ? ['', `Notes : ${notes}`] : []),
        '',
        `Référence : ${order.id}`,
      ].join('\n'),
      ...(pdfBuffer ? { attachments: [{ filename: `commande_${order.id.slice(0, 8)}.pdf`, content: pdfBuffer }] } : {}),
    };

    console.log('[Resend] Sending email:', JSON.stringify({ from: emailPayload.from, to: emailPayload.to, subject: emailPayload.subject }));
    const { data: emailData, error: emailError } = await resend.emails.send(emailPayload);
    if (emailError) console.error('[Resend] API error:', JSON.stringify(emailError));
    else console.log('[Resend] Success:', JSON.stringify(emailData));
  } catch (emailErr) {
    console.error('[Resend] Exception:', emailErr);
  }

  return Astro.redirect('/commande?success=1');
}

// ── GET: show cart ─────────────────────────────────────────────
const success  = !!Astro.url.searchParams.get('success');
const hasError = !!Astro.url.searchParams.get('error');

type CartItem = {
  quantity: number;
  products: { id: string; name: string; category: string; unit: string | null; units_per_carton: number | null; price_ht: number | null } | null;
};

let cartItems: CartItem[] = [];
if (!success) {
  const { data } = await supabaseAdmin
    .from('cart_items')
    .select('quantity, products(id, name, category, unit, units_per_carton, price_ht)')
    .eq('user_id', user.id)
    .order('updated_at', { ascending: true });

  cartItems = (data ?? []) as CartItem[];
  if (cartItems.length === 0) return Astro.redirect('/catalogue');
}

const nom     = user.user_metadata?.nom ?? user.email ?? '';
const societe = user.user_metadata?.societe ?? '';
const totalQty = cartItems.reduce((s, i) => s + i.quantity, 0);
const totalHT  = cartItems.reduce((s, i) => s + i.quantity * Number(i.products?.price_ht ?? 0), 0);
const fmtHT    = (n: number) => n.toFixed(2).replace('.', ',') + ' €';
---
<Base
  title="Votre commande — Inca Import"
  description="Récapitulatif de votre commande Inca Import."
>
  <Nav user={user} />
  <main>

    <!-- Page header -->
    <section class="order-header">
      <div class="container">
        <h1 class="order-title">
          {success ? 'Commande envoyée' : 'Votre commande'}
        </h1>
        {!success && (
          <p class="order-meta">
            {nom}{societe ? ` · ${societe}` : ''} · {totalQty} article{totalQty > 1 ? 's' : ''}
          </p>
        )}
      </div>
    </section>

    <div class="container order-body">

      {/* ── Success state ──────────────────────────── */}
      {success && (
        <div class="success-card">
          <div class="success-icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none">
              <circle cx="24" cy="24" r="22" stroke="oklch(0.52 0.17 145)" stroke-width="2"/>
              <path d="M14 24l7 7 13-13" stroke="oklch(0.52 0.17 145)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h2 class="success-title">Commande bien reçue !</h2>
          <p class="success-body">
            L'équipe Inca Import a été notifiée et vous contactera rapidement
            pour confirmer et organiser la livraison.
          </p>
          <a href="/catalogue" class="btn btn-primary">Retour au catalogue</a>
        </div>
      )}

      {/* ── Error banner ──────────────────────────── */}
      {hasError && !success && (
        <p class="order-error" role="alert">
          Une erreur est survenue lors de la validation. Veuillez réessayer.
        </p>
      )}

      {/* ── Cart recap + confirm ──────────────────── */}
      {!success && (
        <div class="order-layout">
          <div class="order-main">
            <div class="order-card">
              <h2 class="section-label">Articles commandés</h2>
              <div class="order-table-wrap">
                <table class="order-table">
                  <thead>
                    <tr>
                      <th class="col-product">Produit</th>
                      <th class="col-cat">Catégorie</th>
                      <th class="col-qty">Quantité</th>
                      <th class="col-price">Prix HT</th>
                    </tr>
                  </thead>
                  <tbody>
                    {cartItems.map(item => {
                      const p          = item.products;
                      const lineHT     = item.quantity * Number(p?.price_ht ?? 0);
                      const unit       = p?.unit ?? 'carton';
                      const upc        = p?.units_per_carton;
                      const totalUnits = upc ? item.quantity * upc : null;
                      return (
                        <tr>
                          <td class="col-product product-name-cell">{p?.name ?? '—'}</td>
                          <td class="col-cat">
                            {p?.category && (
                              <span class={`cat-badge cat-badge--${p.category}`}>
                                {CAT_LABEL[p.category] ?? p.category}
                              </span>
                            )}
                          </td>
                          <td class="col-qty qty-cell">
                            <span class="qty-primary">{item.quantity} {item.quantity === 1 ? unit : `${unit}s`}</span>
                            {totalUnits && (
                              <span class="qty-units">= {totalUnits} unités</span>
                            )}
                          </td>
                          <td class="col-price price-cell">{fmtHT(lineHT)}</td>
                        </tr>
                      );
                    })}
                  </tbody>
                  <tfoot>
                    <tr class="total-row">
                      <td colspan="3" class="total-label-cell">Total HT</td>
                      <td class="col-price price-cell total-price-cell">{fmtHT(totalHT)}</td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>

            <div class="order-card">
              <h2 class="section-label">Informations client</h2>
              <dl class="client-dl">
                <div class="dl-row">
                  <dt>Nom</dt>
                  <dd>{nom}</dd>
                </div>
                {societe && (
                  <div class="dl-row">
                    <dt>Société</dt>
                    <dd>{societe}</dd>
                  </div>
                )}
                <div class="dl-row">
                  <dt>Email</dt>
                  <dd>{user.email}</dd>
                </div>
                {user.user_metadata?.telephone && (
                  <div class="dl-row">
                    <dt>Téléphone</dt>
                    <dd>{user.user_metadata.telephone}</dd>
                  </div>
                )}
              </dl>
            </div>
          </div>

          <aside class="order-aside">
            <div class="confirm-card">
              <h2 class="section-label">Confirmer la commande</h2>

              <div class="aside-total">
                <span class="aside-total-label">Total HT</span>
                <span class="aside-total-amount">{fmtHT(totalHT)}</span>
              </div>

              <p class="confirm-info">
                En confirmant, vous envoyez votre commande à l'équipe Inca Import.
                Aucun paiement en ligne — un devis vous sera transmis.
              </p>

              <form method="POST">
                <div class="field">
                  <label for="notes">Notes ou précisions</label>
                  <textarea
                    id="notes"
                    name="notes"
                    rows="4"
                    placeholder="Contraintes de livraison, quantités à ajuster…"
                  ></textarea>
                </div>
                <button type="submit" class="btn btn-primary confirm-btn">
                  Envoyer ma commande →
                </button>
              </form>

              <p class="confirm-back">
                <a href="/catalogue">← Modifier le panier</a>
              </p>
            </div>
          </aside>
        </div>
      )}

    </div>
  </main>
  <Footer />
</Base>

<style>
/* ── Header ──────────────────────────────────────── */
.order-header {
  padding: clamp(var(--space-10), 5vw, var(--space-16)) 0 var(--space-6);
  border-bottom: 1px solid var(--color-border);
}

.order-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 2.75rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  color: var(--color-ink);
  line-height: 1.05;
  margin-bottom: var(--space-3);
}

.order-meta {
  font-size: var(--text-sm);
  color: var(--color-muted);
}

/* ── Body ───────────────────────────────────────── */
.order-body {
  padding: clamp(var(--space-8), 4vw, var(--space-14)) 0 clamp(var(--space-16), 8vw, var(--space-24));
}

/* ── Success ────────────────────────────────────── */
.success-card {
  max-width: 480px;
  margin: 0 auto;
  text-align: center;
  padding: var(--space-10) 0 var(--space-8);
}

.success-icon {
  display: flex;
  justify-content: center;
  margin-bottom: var(--space-5);
}

.success-title {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--color-ink);
  margin-bottom: var(--space-4);
}

.success-body {
  font-size: var(--text-base);
  color: var(--color-muted);
  line-height: 1.65;
  margin-bottom: var(--space-8);
  max-width: 400px;
  margin-inline: auto;
  margin-bottom: var(--space-8);
}

/* ── Error ──────────────────────────────────────── */
.order-error {
  font-size: var(--text-sm);
  color: oklch(0.50 0.19 25);
  background: oklch(0.97 0.04 25);
  border: 1px solid oklch(0.88 0.07 25);
  border-radius: var(--radius-sm);
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-6);
}

/* ── Layout ─────────────────────────────────────── */
.order-layout {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: var(--space-8);
  align-items: start;
}

.order-main {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

/* ── Cards ──────────────────────────────────────── */
.order-card,
.confirm-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-6) var(--space-7);
}

.section-label {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: var(--space-5);
}

/* ── Table ──────────────────────────────────────── */
.order-table-wrap { overflow-x: auto; }

.order-table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--text-sm);
}

.order-table th {
  text-align: left;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0 var(--space-3) var(--space-3);
  border-bottom: 1px solid var(--color-border);
  white-space: nowrap;
}
.order-table th:first-child { padding-left: 0; }

.order-table td {
  padding: var(--space-4) var(--space-3);
  border-bottom: 1px solid var(--color-border);
  vertical-align: middle;
}
.order-table td:first-child { padding-left: 0; }
.order-table tr:last-child td { border-bottom: none; }

.product-name-cell {
  font-weight: 500;
  color: var(--color-ink);
}

.qty-cell {
  vertical-align: middle;
}

.qty-primary {
  display: block;
  font-weight: 600;
  color: var(--color-ink);
}

.qty-units {
  display: block;
  font-size: var(--text-xs);
  color: var(--color-muted);
  margin-top: 2px;
}

.col-product { width: 38%; }
.col-cat     { width: 20%; }
.col-qty     { width: 22%; }
.col-price   { width: 20%; text-align: right; }

.price-cell {
  font-weight: 600;
  color: var(--color-ink);
  text-align: right;
  white-space: nowrap;
}

.total-row td {
  border-top: 2px solid var(--color-border-strong);
  border-bottom: none;
  padding-top: var(--space-4);
}

.total-label-cell {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.total-price-cell {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-ink);
}

/* ── Category badge ─────────────────────────────── */
.cat-badge {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--radius-full);
}
.cat-badge--boissons    { background: oklch(0.93 0.05 220); color: oklch(0.33 0.10 220); }
.cat-badge--snacks      { background: oklch(0.94 0.05 60);  color: oklch(0.38 0.12 60);  }
.cat-badge--confiseries { background: oklch(0.93 0.06 330); color: oklch(0.36 0.12 330); }

/* ── Client info ────────────────────────────────── */
.client-dl {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.dl-row {
  display: flex;
  gap: var(--space-4);
  font-size: var(--text-sm);
}

.dl-row dt {
  width: 90px;
  flex-shrink: 0;
  color: var(--color-muted);
  font-weight: 500;
}

.dl-row dd {
  color: var(--color-ink);
}

/* ── Confirm card ───────────────────────────────── */
.aside-total {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-4);
  background: var(--color-surface);
  border-radius: var(--radius-sm);
  padding: var(--space-4) var(--space-5);
  margin-bottom: var(--space-5);
}

.aside-total-label {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.aside-total-amount {
  font-size: 1.375rem;
  font-weight: 700;
  color: var(--color-ink);
  letter-spacing: -0.02em;
}

.confirm-info {
  font-size: var(--text-sm);
  color: var(--color-muted);
  line-height: 1.6;
  margin-bottom: var(--space-5);
}

.field {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  margin-bottom: var(--space-4);
}

.field label {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
}

textarea {
  width: 100%;
  padding: 0.6875rem 0.875rem;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-ink);
  background: var(--color-bg);
  border: 1.5px solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  resize: vertical;
  outline: none;
  line-height: 1.55;
  transition: border-color var(--dur-fast), box-shadow var(--dur-fast);
  box-sizing: border-box;
}
textarea::placeholder { color: var(--color-muted); }
textarea:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px oklch(0.568 0.149 45.9 / 0.15);
}

.confirm-btn { width: 100%; }

.confirm-back {
  margin-top: var(--space-4);
  text-align: center;
}
.confirm-back a {
  font-size: var(--text-sm);
  color: var(--color-muted);
  text-decoration: none;
  transition: color var(--dur-fast);
}
.confirm-back a:hover { color: var(--color-ink); }

/* ── Responsive ─────────────────────────────────── */
@media (max-width: 900px) {
  .order-layout {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 480px) {
  .order-card,
  .confirm-card { padding: var(--space-5); }
}
</style>
