---
import '../../styles/global.css';
import { createAuthClient } from '../../lib/supabase';

const supabase = createAuthClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (user?.user_metadata?.role === 'client') return Astro.redirect('/catalogue');

const error = Astro.url.searchParams.get('error');
const reinitialise = !!Astro.url.searchParams.get('reinitialise');

const ERRORS: Record<string, string> = {
  champs_requis:          'Email et mot de passe sont obligatoires.',
  identifiants_invalides: 'Email ou mot de passe incorrect.',
  trop_de_tentatives:     'Trop de tentatives échouées. Réessayez dans 15 minutes.',
  rate_limit:             'Trop de tentatives. Patientez une minute avant de réessayer.',
};
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Connexion Client — Inca Import</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Barlow+Semi+Condensed:wght@700&family=Figtree:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body class="auth-body">
  <main class="auth-shell">
    <div class="auth-card">

      <a href="/connexion" class="auth-back" aria-label="Retour au choix de connexion">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Retour
      </a>

      <a href="/" class="auth-brand" aria-label="Inca Import — accueil">
        <span class="wm-inca">Inca</span><span class="wm-import">Import</span>
      </a>
      <p class="auth-subtitle">Connexion à votre espace client</p>

      {error && (
        <p class="auth-error" role="alert">{ERRORS[error] ?? 'Une erreur est survenue.'}</p>
      )}

      {reinitialise && (
        <p class="auth-success-msg" role="status">Mot de passe mis à jour. Connectez-vous.</p>
      )}

      <form method="POST" action="/api/auth/client-login" class="auth-form" novalidate>
        <div class="field">
          <label for="email">Adresse email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            placeholder="jean@exemple.re"
            autofocus
          />
        </div>

        <div class="field">
          <label for="password">Mot de passe</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autocomplete="current-password"
            placeholder="••••••••"
          />
          <a href="/mot-de-passe-oublie" class="auth-forgot">Mot de passe oublié ?</a>
        </div>

        <button type="submit" class="btn btn-primary auth-submit">Se connecter</button>
      </form>

      <p class="auth-footer">
        Pas encore client ?
        <a href="/inscription">Ouvrir un compte →</a>
      </p>
    </div>
  </main>
</body>
</html>

<style>
.auth-body {
  font-family: var(--font-body);
  background: var(--color-surface);
  min-height: 100dvh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-6);
}

.auth-shell {
  width: 100%;
  max-width: 420px;
}

.auth-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-10);
}

.auth-back {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-muted);
  text-decoration: none;
  margin-bottom: var(--space-6);
  min-height: 44px;
  padding: var(--space-2) var(--space-1);
  margin-left: calc(-1 * var(--space-1));
  transition: color var(--dur-fast);
}
.auth-back:hover { color: var(--color-ink); }
.auth-back:focus-visible {
  outline: 2px solid var(--color-primary);
  outline-offset: 2px;
  border-radius: var(--radius-xs);
}

.auth-brand {
  display: block;
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -0.025em;
  text-decoration: none;
  margin-bottom: var(--space-2);
}
.wm-inca   { color: var(--color-primary); }
.wm-import { color: var(--color-ink); font-weight: 400; }

.auth-subtitle {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-muted);
  margin-bottom: var(--space-8);
}

.auth-error {
  font-size: var(--text-sm);
  color: oklch(0.50 0.19 25);
  background: oklch(0.97 0.04 25);
  border: 1px solid oklch(0.88 0.07 25);
  border-radius: var(--radius-sm);
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-5);
}

.auth-success-msg {
  font-size: var(--text-sm);
  font-weight: 500;
  color: oklch(0.35 0.12 145);
  background: oklch(0.96 0.04 145);
  border: 1px solid oklch(0.85 0.08 145);
  border-radius: var(--radius-sm);
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-5);
}

.auth-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.field {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

label {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
}

input[type="email"],
input[type="password"] {
  width: 100%;
  padding: 0.6875rem 0.875rem;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-ink);
  background: var(--color-bg);
  border: 1.5px solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  min-height: 44px;
  outline: none;
  transition: border-color var(--dur-fast), box-shadow var(--dur-fast);
  box-sizing: border-box;
}
input::placeholder { color: var(--color-muted); }
input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px oklch(0.568 0.149 45.9 / 0.15);
}

.auth-forgot {
  align-self: flex-end;
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-muted);
  text-decoration: none;
}
.auth-forgot:hover { color: var(--color-primary-deep); }

.auth-submit { width: 100%; margin-top: var(--space-2); }

.auth-footer {
  font-size: var(--text-sm);
  color: var(--color-muted);
  margin-top: var(--space-6);
  text-align: center;
}
.auth-footer a {
  color: var(--color-primary-deep);
  font-weight: 500;
  text-decoration: none;
}
.auth-footer a:hover { color: var(--color-primary); }

@media (max-width: 480px) {
  .auth-card { padding: var(--space-8) var(--space-6); }
}
</style>
