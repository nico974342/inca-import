---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { supabaseAdmin, createAuthClient } from '../lib/supabase';

const supabase = createAuthClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();

if (!user || user.user_metadata?.role !== 'client') {
  return Astro.redirect('/connexion?from=/mes-commandes');
}

// Fetch orders for this user, newest first
const { data: orders } = await supabaseAdmin
  .from('orders')
  .select('id, status, created_at, notes')
  .or(`user_id.eq.${user.id},email.eq.${user.email}`)
  .order('created_at', { ascending: false });

// Fetch all order items for those orders in one query
const orderIds = (orders ?? []).map(o => o.id);
const { data: allItems } = orderIds.length
  ? await supabaseAdmin
      .from('order_items')
      .select('order_id, product_name, quantity, unit, product_id, price_ht_snapshot')
      .in('order_id', orderIds)
  : { data: [] };

// Group items by order_id
const itemsByOrder: Record<string, typeof allItems> = {};
for (const item of allItems ?? []) {
  if (!itemsByOrder[item.order_id]) itemsByOrder[item.order_id] = [];
  itemsByOrder[item.order_id].push(item);
}

// Compute order total HT from the prices captured at order time
function orderTotal(orderId: string): number | null {
  const items = itemsByOrder[orderId] ?? [];
  if (!items.length) return null;
  let total = 0;
  let hasPrice = false;
  for (const item of items) {
    const price = (item as any).price_ht_snapshot;
    if (price != null) {
      total += Number(price) * item.quantity;
      hasPrice = true;
    }
  }
  return hasPrice ? total : null;
}

const STATUS_LABEL: Record<string, string> = {
  en_attente:     'En attente',
  confirmee:      'Confirmée',
  en_preparation: 'En préparation',
  expediee:       'Expédiée',
  livree:         'Livrée',
  annulee:        'Annulée',
  // legacy fallbacks
  recu:    'Reçu',
  confirme: 'Confirmé',
  livre:   'Livré',
  annule:  'Annulé',
};

const STATUS_COLOR: Record<string, string> = {
  en_attente:     'muted',
  confirmee:      'blue',
  en_preparation: 'amber',
  expediee:       'purple',
  livree:         'green',
  annulee:        'red',
  // legacy fallbacks
  recu:    'muted',
  confirme: 'blue',
  livre:   'green',
  annule:  'red',
};

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('fr-FR', {
    day: '2-digit', month: 'long', year: 'numeric',
  });
}

function shortId(id: string): string {
  return id.slice(0, 8).toUpperCase();
}
---
<Base
  title="Mes commandes — Inca Import"
  description="Historique de vos commandes Inca Import."
>
  <Nav user={user} />
  <main class="orders-main">
    <div class="container">

      <header class="orders-header">
        <div>
          <h1 class="orders-title">Mes commandes</h1>
          <p class="orders-sub">
            {orders?.length
              ? `${orders.length} commande${orders.length > 1 ? 's' : ''} passée${orders.length > 1 ? 's' : ''}`
              : 'Aucune commande pour le moment'}
          </p>
        </div>
        <a href="/catalogue" class="btn btn-primary orders-cta">
          Commander à nouveau
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </header>

      {!orders?.length ? (
        <div class="orders-empty">
          <svg class="empty-icon" width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
            <rect x="8" y="14" width="32" height="28" rx="3" stroke="currentColor" stroke-width="1.75"/>
            <path d="M16 14v-3a8 8 0 0 1 16 0v3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            <path d="M18 24h12M18 31h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <p class="empty-title">Vous n'avez pas encore passé de commande.</p>
          <p class="empty-body">Explorez le catalogue et passez votre première commande.</p>
          <a href="/catalogue" class="btn btn-primary" style="margin-top: var(--space-6)">Voir le catalogue →</a>
        </div>
      ) : (
        <ul class="orders-list" aria-label="Liste de vos commandes">
          {orders.map(order => {
            const items   = itemsByOrder[order.id] ?? [];
            const total   = orderTotal(order.id);
            const status  = order.status ?? 'recu';
            const colorKey = STATUS_COLOR[status] ?? 'muted';
            return (
              <li class="order-card">
                <details class="order-details">
                  <summary class="order-summary">
                    <div class="order-summary-left">
                      <span class={`status-badge status-badge--${colorKey}`}>
                        {STATUS_LABEL[status] ?? status}
                      </span>
                      <div class="order-id-date">
                        <span class="order-id">#{shortId(order.id)}</span>
                        <span class="order-date">{formatDate(order.created_at)}</span>
                      </div>
                    </div>
                    <div class="order-summary-right">
                      <span class="order-item-count">
                        {items.length} article{items.length !== 1 ? 's' : ''}
                      </span>
                      {total !== null && (
                        <span class="order-total">
                          {total.toFixed(2).replace('.', ',')}&nbsp;€&nbsp;<span class="total-suffix">HT</span>
                        </span>
                      )}
                      <svg class="chevron-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                  </summary>

                  <div class="order-body">
                    {items.length > 0 ? (
                      <table class="order-table" aria-label={`Détail de la commande #${shortId(order.id)}`}>
                        <thead>
                          <tr>
                            <th scope="col">Produit</th>
                            <th scope="col" class="th-right">Qté</th>
                            <th scope="col" class="th-right">PU HT</th>
                            <th scope="col" class="th-right">Total HT</th>
                          </tr>
                        </thead>
                        <tbody>
                          {items.map(item => {
                            const pu    = (item as any).price_ht_snapshot;
                            const puFmt = pu != null ? Number(pu).toFixed(2).replace('.', ',') : '—';
                            const lineFmt = pu != null
                              ? (Number(pu) * item.quantity).toFixed(2).replace('.', ',')
                              : '—';
                            return (
                              <tr>
                                <td class="td-name">
                                  <span class="item-name">{item.product_name}</span>
                                  {item.unit && <span class="item-unit">{item.unit}</span>}
                                </td>
                                <td class="td-right">{item.quantity}</td>
                                <td class="td-right">{puFmt}&nbsp;€</td>
                                <td class="td-right td-total">{lineFmt}&nbsp;€</td>
                              </tr>
                            );
                          })}
                        </tbody>
                        {total !== null && (
                          <tfoot>
                            <tr class="tfoot-total">
                              <td colspan="3" class="tfoot-label">Total HT</td>
                              <td class="td-right td-total tfoot-amount">
                                {total.toFixed(2).replace('.', ',')}&nbsp;€
                              </td>
                            </tr>
                          </tfoot>
                        )}
                      </table>
                    ) : (
                      <p class="order-no-items">Aucun article enregistré pour cette commande.</p>
                    )}
                    {order.notes && (
                      <p class="order-notes">
                        <strong>Notes :</strong> {order.notes}
                      </p>
                    )}
                    <div class="order-footer-actions">
                      <a href={`/api/orders/${order.id}/invoice`} class="btn-invoice" download>
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M7 1v8M4 6l3 3 3-3M2 10v1a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        Accusé de réception de commande
                      </a>
                    </div>
                  </div>
                </details>
              </li>
            );
          })}
        </ul>
      )}

    </div>
  </main>
  <Footer />
</Base>

<style>
.orders-main {
  padding: clamp(var(--space-10), 5vw, var(--space-16)) 0
           clamp(var(--space-16), 8vw, var(--space-24));
}

/* Header */
.orders-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--space-6);
  flex-wrap: wrap;
  margin-bottom: clamp(var(--space-8), 4vw, var(--space-12));
  padding-bottom: var(--space-6);
  border-bottom: 1px solid var(--color-border);
}

.orders-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--color-ink);
  line-height: 1.08;
  margin-bottom: var(--space-2);
}

.orders-sub {
  font-size: var(--text-sm);
  color: var(--color-muted);
}

.orders-cta {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  flex-shrink: 0;
}

/* Empty state */
.orders-empty {
  padding: clamp(var(--space-16), 8vw, var(--space-24)) 0;
  text-align: center;
  max-width: 400px;
  margin: 0 auto;
}

.empty-icon {
  color: var(--color-border-strong);
  margin: 0 auto var(--space-6);
  display: block;
}

.empty-title {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 600;
  color: var(--color-ink);
  margin-bottom: var(--space-3);
}

.empty-body {
  font-size: var(--text-sm);
  color: var(--color-muted);
  line-height: 1.6;
}

/* Orders list */
.orders-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.order-card {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: border-color var(--dur-fast), box-shadow var(--dur-base);
}
.order-card:has(details[open]) {
  border-color: var(--color-border-strong);
  box-shadow: 0 4px 24px oklch(0 0 0 / 0.06);
}

/* Summary row */
.order-details summary { list-style: none; }
.order-details summary::-webkit-details-marker { display: none; }

.order-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  padding: var(--space-4) var(--space-5);
  cursor: pointer;
  user-select: none;
  transition: background var(--dur-fast);
  background: var(--color-bg);
}
.order-summary:hover { background: var(--color-surface); }

.order-summary-left {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex: 1;
  min-width: 0;
}

.order-id-date {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.order-id {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-ink);
  letter-spacing: 0.02em;
}

.order-date {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  color: var(--color-muted);
}

.order-summary-right {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  flex-shrink: 0;
}

.order-item-count {
  font-size: var(--text-xs);
  color: var(--color-muted);
  white-space: nowrap;
}

.order-total {
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-ink);
  letter-spacing: -0.02em;
  white-space: nowrap;
}
.total-suffix {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 400;
  color: var(--color-muted);
}

.chevron-icon {
  color: var(--color-muted);
  flex-shrink: 0;
  transition: transform 0.22s var(--ease-out-expo);
}
details[open] .chevron-icon { transform: rotate(180deg); }

/* Status badge */
.status-badge {
  display: inline-flex;
  align-items: center;
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  padding: 3px 10px;
  border-radius: var(--radius-full);
  white-space: nowrap;
  flex-shrink: 0;
  letter-spacing: 0.01em;
}
.status-badge--muted  { background: var(--color-surface);     color: var(--color-muted); }
.status-badge--blue   { background: oklch(0.93 0.05 220);     color: oklch(0.33 0.12 220); }
.status-badge--amber  { background: oklch(0.95 0.07 80);      color: oklch(0.40 0.14 80); }
.status-badge--purple { background: oklch(0.93 0.05 295);     color: oklch(0.38 0.12 295); }
.status-badge--green  { background: oklch(0.92 0.08 150);     color: oklch(0.32 0.12 150); }
.status-badge--red    { background: oklch(0.95 0.04 25);      color: oklch(0.46 0.18 25); }

/* Expanded body */
.order-body {
  padding: 0 var(--space-5) var(--space-5);
  border-top: 1px solid var(--color-border);
  animation: slide-open 0.2s var(--ease-out-expo);
}

@keyframes slide-open {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

@media (prefers-reduced-motion: reduce) {
  .order-body { animation: none; }
}

/* Items table */
.order-table {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  margin-top: var(--space-4);
}

.order-table th {
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-muted);
  text-align: left;
  padding: var(--space-2) var(--space-3) var(--space-2) 0;
  border-bottom: 1px solid var(--color-border);
  letter-spacing: 0.03em;
  text-transform: uppercase;
}
.order-table th.th-right { text-align: right; padding-right: 0; }

.order-table td {
  padding: var(--space-3) var(--space-3) var(--space-3) 0;
  border-bottom: 1px solid var(--color-border);
  color: var(--color-ink);
  vertical-align: middle;
}
.order-table tbody tr:last-child td { border-bottom: none; }

.td-name { width: 100%; }

.item-name {
  display: block;
  font-weight: 600;
  line-height: 1.3;
}
.item-unit {
  display: block;
  font-size: var(--text-xs);
  color: var(--color-muted);
  margin-top: 1px;
}

.td-right  { text-align: right; white-space: nowrap; padding-right: 0; }
.td-total  { font-weight: 700; }

/* Table footer total */
.tfoot-total td {
  padding-top: var(--space-4);
  border-top: 2px solid var(--color-border-strong);
  border-bottom: none;
}
.tfoot-label {
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  text-align: right;
  padding-right: var(--space-4) !important;
}
.tfoot-amount {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-ink);
}

.order-notes {
  margin-top: var(--space-4);
  font-size: var(--text-sm);
  color: var(--color-muted);
  line-height: 1.6;
  padding: var(--space-3) var(--space-4);
  background: oklch(0.97 0.008 45.9);
  border-radius: var(--radius-sm);
  border: 1px solid oklch(0.90 0.015 45.9);
}
.order-notes strong { color: var(--color-ink); }

.order-no-items {
  padding: var(--space-5) 0;
  font-size: var(--text-sm);
  color: var(--color-muted);
  text-align: center;
}

/* Invoice download */
.order-footer-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: var(--space-4);
  margin-top: var(--space-4);
  border-top: 1px solid var(--color-border);
}

.btn-invoice {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-primary);
  text-decoration: none;
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-sm);
  border: 1px solid oklch(0.568 0.149 45.9 / 0.28);
  background: oklch(0.568 0.149 45.9 / 0.04);
  transition: background var(--dur-fast), border-color var(--dur-fast);
}
.btn-invoice:hover {
  background: oklch(0.568 0.149 45.9 / 0.09);
  border-color: oklch(0.568 0.149 45.9 / 0.45);
}

/* Responsive */
@media (max-width: 600px) {
  .order-summary { flex-wrap: wrap; gap: var(--space-3); }
  .order-summary-right { gap: var(--space-3); }
  .orders-header { align-items: flex-start; flex-direction: column; }
  .order-table th:nth-child(3),
  .order-table td:nth-child(3) { display: none; }
}
</style>
