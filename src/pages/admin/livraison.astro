---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';
import { generateDeliverySummaryPDF, generatePDVDeliveryPDF } from '../../lib/pdf';
import { Resend } from 'resend';

const FROM = import.meta.env.RESEND_FROM ?? 'onboarding@resend.dev';

function slugPDV(name: string): string {
  return name
    .toLowerCase()
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

const FIXED_PDVS = [
  { key: 'fixed_ola-tamarins',    name: 'OLA Tamarins',    clientLabel: null as string | null },
  { key: 'fixed_vito-saint-paul', name: 'VITO Saint-Paul', clientLabel: null as string | null },
  { key: 'fixed_total-tamarins',  name: 'TOTAL Tamarins',  clientLabel: null as string | null },
];

const [{ data: clients }, { data: productsRaw }] = await Promise.all([
  supabaseAdmin
    .from('client_accounts')
    .select('id, user_id, nom, societe, points_de_vente')
    .not('points_de_vente', 'is', null)
    .neq('points_de_vente', '')
    .order('nom'),
  supabaseAdmin
    .from('products')
    .select('id, name, unit, category')
    .eq('in_stock', true)
    .order('category', { ascending: true })
    .order('name', { ascending: true }),
]);

const clientPDVs = (clients ?? []).map(c => ({
  key: `client_${c.id}`,
  name: c.points_de_vente as string,
  clientLabel: c.nom + (c.societe ? ` · ${c.societe}` : ''),
}));

const userIdToClientKey = new Map(
  (clients ?? [])
    .filter(c => c.user_id)
    .map(c => [c.user_id as string, `client_${c.id}`])
);

const allPDVs = [...FIXED_PDVS, ...clientPDVs];
const products = productsRaw ?? [];

type Product = (typeof products)[number];
const productsByCategory = products.reduce<Record<string, Product[]>>((acc, p) => {
  const cat = p.category ?? 'Autre';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(p);
  return acc;
}, {});

let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const transporterEmail = (form.get('transporter_email') as string)?.trim();
  const notes = (form.get('notes') as string)?.trim() || null;
  const loadedOrderIds = ((form.get('loaded_order_ids') as string) ?? '')
    .split(',').map(s => s.trim()).filter(Boolean);

  if (!transporterEmail) {
    errorMessage = "L'email du transporteur est requis.";
  } else {
    const now = new Date();
    const dateStr = now.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
    const compact = now.toISOString().slice(0, 10).replace(/-/g, '');
    const deliveryId = `LIV-${compact}-${String(Math.floor(Math.random() * 9000) + 1000)}`;

    const deliveryPDVs: { name: string; items: { product_name: string; quantity: number; unit?: string | null }[] }[] = [];
    for (const pdv of allPDVs) {
      if (form.get(`included_${pdv.key}`) !== 'on') continue;
      const items: { product_name: string; quantity: number; unit?: string | null }[] = [];
      for (const p of products) {
        const qty = parseInt((form.get(`qty_${pdv.key}_${p.id}`) as string) || '0', 10);
        if (qty > 0) items.push({ product_name: p.name, quantity: qty, unit: p.unit });
      }
      if (items.length > 0) deliveryPDVs.push({ name: pdv.name, items });
    }

    if (deliveryPDVs.length === 0) {
      errorMessage = 'Sélectionnez au moins un point de vente avec des produits.';
    } else {
      try {
        const deliveryData = {
          id: deliveryId,
          date: dateStr,
          transporter_email: transporterEmail,
          pdvs: deliveryPDVs,
          notes,
        };

        const [summaryBuffer, ...pdvBuffers] = await Promise.all([
          generateDeliverySummaryPDF(deliveryData),
          ...deliveryPDVs.map(pdv => generatePDVDeliveryPDF(pdv, deliveryId, dateStr)),
        ]);

        const attachments = [
          { filename: `recapitulatif-${deliveryId}.pdf`, content: summaryBuffer },
          ...deliveryPDVs.map((pdv, i) => ({
            filename: `livraison-${slugPDV(pdv.name)}-${deliveryId}.pdf`,
            content: pdvBuffers[i],
          })),
        ];

        const pdvListHtml = deliveryPDVs.map(p => `&bull; ${p.name}`).join('<br/>');
        const attachListHtml = [
          `&bull; <strong>R&eacute;capitulatif</strong> &mdash; bilan consolid&eacute; pour le chargement`,
          ...deliveryPDVs.map(p => `&bull; <strong>${p.name}</strong> &mdash; bon de livraison individuel`),
        ].join('<br/>');

        const resend = new Resend(import.meta.env.RESEND_API_KEY);
        const { error: sendError } = await resend.emails.send({
          from: FROM,
          to: ['inca-import@hotmail.com', transporterEmail],
          subject: `Livraison ${deliveryId} — ${deliveryPDVs.length} PDV · ${dateStr}`,
          html: `<p>Bonjour,</p>
<p>Le bon de livraison <strong>${deliveryId}</strong> du ${dateStr} est pr&ecirc;t (${deliveryPDVs.length} point${deliveryPDVs.length > 1 ? 's' : ''} de vente).</p>
<p><strong>Points de vente :</strong><br/>${pdvListHtml}</p>
<p><strong>Pi&egrave;ces jointes (${attachments.length}) :</strong><br/>${attachListHtml}</p>
<p>Cordialement,<br/>Inca Import</p>`,
          attachments,
        });

        if (sendError) {
          console.error('[livraison] Resend error:', sendError);
          errorMessage = `PDF générés mais l'envoi a échoué : ${sendError.message}`;
        } else {
          successMessage = `${attachments.length} PDF envoyés pour ${deliveryId} → ${transporterEmail} + inca-import@hotmail.com`;
          if (loadedOrderIds.length > 0) {
            await supabaseAdmin
              .from('orders')
              .update({ status: 'en_preparation' })
              .in('id', loadedOrderIds);
          }
        }
      } catch (e) {
        console.error(e);
        errorMessage = "Une erreur est survenue lors de la génération ou de l'envoi.";
      }
    }
  }
}

const categories = Object.keys(productsByCategory).sort();

// ── Confirmed orders pending delivery ──────────────────────────────────────
const { data: confirmedOrders } = await supabaseAdmin
  .from('orders')
  .select('id, user_id')
  .eq('status', 'confirmee');

const confirmedOrderIds = (confirmedOrders ?? []).map(o => o.id);

const { data: confirmedItems } = confirmedOrderIds.length > 0
  ? await supabaseAdmin
      .from('order_items')
      .select('order_id, product_id, quantity')
      .in('order_id', confirmedOrderIds)
      .not('product_id', 'is', null)
  : { data: [] as { order_id: string; product_id: string; quantity: number }[] };

const orderToPdvKey = new Map<string, string>();
for (const order of confirmedOrders ?? []) {
  const key = order.user_id ? userIdToClientKey.get(order.user_id) : undefined;
  if (key) orderToPdvKey.set(order.id, key);
}

const pendingQtys: Record<string, Record<string, number>> = {};
for (const item of confirmedItems ?? []) {
  if (!item.product_id) continue;
  const pdvKey = orderToPdvKey.get(item.order_id);
  if (!pdvKey) continue;
  if (!pendingQtys[pdvKey]) pendingQtys[pdvKey] = {};
  pendingQtys[pdvKey][item.product_id] = (pendingQtys[pdvKey][item.product_id] ?? 0) + item.quantity;
}

const loadableOrderIds = (confirmedOrders ?? []).filter(o => orderToPdvKey.has(o.id)).map(o => o.id);
const pendingCount = confirmedOrderIds.length;
const pendingPDVNames = Object.keys(pendingQtys)
  .map(key => allPDVs.find(p => p.key === key)?.name)
  .filter((n): n is string => !!n);
---

<AdminLayout title="Bon de livraison" activeNav="livraison">

  {successMessage && (
    <div class="alert alert-success" role="status">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="7" stroke="oklch(0.52 0.17 145)" stroke-width="1.25"/>
        <path d="M4.5 8l2.5 2.5 4-4" stroke="oklch(0.52 0.17 145)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {successMessage}
    </div>
  )}
  {errorMessage && (
    <div class="alert alert-error" role="alert">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="7" stroke="oklch(0.50 0.19 25)" stroke-width="1.25"/>
        <path d="M8 5v3.5M8 11h.01" stroke="oklch(0.50 0.19 25)" stroke-width="1.25" stroke-linecap="round"/>
      </svg>
      {errorMessage}
    </div>
  )}

  {pendingCount > 0 && (
    <div class="pending-banner">
      <div class="pending-banner-left">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="8" stroke="oklch(0.45 0.14 80)" stroke-width="1.3"/>
          <path d="M9 5.5v4M9 12h.01" stroke="oklch(0.45 0.14 80)" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
        <div class="pending-banner-text">
          <span class="pending-banner-title">
            {pendingCount} commande{pendingCount > 1 ? 's' : ''} confirmée{pendingCount > 1 ? 's' : ''} en attente de livraison
          </span>
          {pendingPDVNames.length > 0 && (
            <span class="pending-banner-sub">
              PDV concernés : {pendingPDVNames.join(' · ')}
            </span>
          )}
          {loadableOrderIds.length < pendingCount && (
            <span class="pending-banner-warn">
              {pendingCount - loadableOrderIds.length} commande{pendingCount - loadableOrderIds.length > 1 ? 's' : ''} sans PDV associé — à traiter manuellement.
            </span>
          )}
        </div>
      </div>
      {loadableOrderIds.length > 0 && (
        <button type="button" id="loadPendingBtn" class="btn-load-pending">
          Charger dans le formulaire
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
            <path d="M2 6.5h9M7.5 3l4 3.5-4 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      )}
    </div>
  )}

  <script id="pendingData" type="application/json" set:html={JSON.stringify({ qtys: pendingQtys, orderIds: loadableOrderIds })}></script>

  <form method="POST" class="liv-form" id="livForm">
    <input type="hidden" name="loaded_order_ids" id="loadedOrderIds" value="" />

    <!-- Transporter -->
    <section class="liv-section">
      <h2 class="liv-section-title">Transporteur</h2>
      <div class="field-group">
        <div class="field">
          <label for="transporter_name">Nom</label>
          <input type="text" id="transporter_name" value="Coursier OI" disabled class="input-readonly" />
        </div>
        <div class="field">
          <label for="transporter_email">Email du transporteur <span class="req" aria-hidden="true">*</span></label>
          <input type="email" id="transporter_email" name="transporter_email" required placeholder="coursier@exemple.re" autocomplete="off" />
        </div>
      </div>
    </section>

    <!-- Points de vente -->
    <section class="liv-section">
      <h2 class="liv-section-title">Points de vente</h2>
      <p class="liv-section-hint">Cochez les points de vente à livrer, puis renseignez les quantités.</p>

      <div class="pdv-list">
        {allPDVs.map(pdv => (
          <div class="pdv-card" data-pdv={pdv.key}>
            <label class="pdv-header">
              <input
                type="checkbox"
                name={`included_${pdv.key}`}
                class="pdv-checkbox"
                data-target={`pdv-body-${pdv.key}`}
              />
              <span class="pdv-header-text">
                <span class="pdv-name">{pdv.name}</span>
                {pdv.clientLabel && <span class="pdv-client">{pdv.clientLabel}</span>}
              </span>
              <svg class="pdv-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </label>

            <div class="pdv-body" id={`pdv-body-${pdv.key}`} hidden>
              {categories.length === 0 ? (
                <p class="pdv-empty">Aucun produit en stock.</p>
              ) : (
                categories.map(cat => (
                  <div class="pdv-cat">
                    <p class="pdv-cat-name">{cat}</p>
                    <div class="pdv-products">
                      {productsByCategory[cat].map(p => (
                        <div class="pdv-product-row">
                          <span class="pdv-product-name">{p.name}</span>
                          {p.unit && <span class="pdv-product-unit">{p.unit}</span>}
                          <div class="stepper">
                            <button type="button" class="step-btn step-dec" aria-label={`Diminuer ${p.name}`}>−</button>
                            <input
                              type="number"
                              name={`qty_${pdv.key}_${p.id}`}
                              class="step-input"
                              value="0"
                              min="0"
                              max="9999"
                              aria-label={`Quantité ${p.name}`}
                            />
                            <button type="button" class="step-btn step-inc" aria-label={`Augmenter ${p.name}`}>+</button>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                ))
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Notes -->
    <section class="liv-section">
      <h2 class="liv-section-title">Notes</h2>
      <textarea name="notes" class="liv-notes" rows="3" placeholder="Instructions de livraison, horaires, remarques…"></textarea>
    </section>

    <!-- Sticky submit bar -->
    <div class="liv-submit-bar">
      <span class="liv-total-label">
        Total articles : <strong id="totalQty">0</strong>
      </span>
      <button type="submit" class="btn btn-primary liv-submit-btn">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M7.5 3l4.5 4-4.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Générer &amp; envoyer le bon
      </button>
    </div>

  </form>
</AdminLayout>

<script>
  // Toggle PDV body on checkbox change
  document.querySelectorAll<HTMLInputElement>('.pdv-checkbox').forEach(cb => {
    const targetId = cb.dataset.target!;
    const body = document.getElementById(targetId);
    const card = cb.closest('.pdv-card');

    cb.addEventListener('change', () => {
      if (body) body.hidden = !cb.checked;
      card?.classList.toggle('pdv-card--open', cb.checked);
      if (!cb.checked && body) {
        // Reset quantities when unchecked
        body.querySelectorAll<HTMLInputElement>('.step-input').forEach(i => { i.value = '0'; });
      }
      updateTotal();
    });
  });

  // Stepper buttons
  document.querySelectorAll<HTMLElement>('.pdv-body').forEach(body => {
    body.addEventListener('click', e => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.step-btn');
      if (!btn) return;
      const row = btn.closest('.stepper')!;
      const input = row.querySelector<HTMLInputElement>('.step-input')!;
      let val = parseInt(input.value || '0', 10);
      if (btn.classList.contains('step-dec')) val = Math.max(0, val - 1);
      else val = Math.min(9999, val + 1);
      input.value = String(val);
      updateTotal();
    });

    body.addEventListener('input', e => {
      if ((e.target as HTMLElement).classList.contains('step-input')) updateTotal();
    });
  });

  function updateTotal() {
    let total = 0;
    document.querySelectorAll<HTMLInputElement>('.step-input').forEach(i => {
      total += parseInt(i.value || '0', 10);
    });
    const el = document.getElementById('totalQty');
    if (el) el.textContent = String(total);
  }

  // ── Load pending confirmed orders into form ────────────────────────────────
  const pendingDataEl = document.getElementById('pendingData');
  const loadPendingBtn = document.getElementById('loadPendingBtn') as HTMLButtonElement | null;
  const loadedOrderIdsInput = document.getElementById('loadedOrderIds') as HTMLInputElement | null;

  if (pendingDataEl && loadPendingBtn) {
    const pending = JSON.parse(pendingDataEl.textContent || '{}') as {
      qtys: Record<string, Record<string, number>>;
      orderIds: string[];
    };

    loadPendingBtn.addEventListener('click', () => {
      for (const [pdvKey, products] of Object.entries(pending.qtys ?? {})) {
        const checkbox = document.querySelector<HTMLInputElement>(`input[name="included_${pdvKey}"]`);
        if (checkbox && !checkbox.checked) {
          checkbox.checked = true;
          checkbox.dispatchEvent(new Event('change', { bubbles: true }));
        }
        for (const [productId, qty] of Object.entries(products)) {
          const input = document.querySelector<HTMLInputElement>(`input[name="qty_${pdvKey}_${productId}"]`);
          if (input) {
            const existing = parseInt(input.value || '0', 10);
            input.value = String(existing + qty);
          }
        }
      }
      if (loadedOrderIdsInput) loadedOrderIdsInput.value = (pending.orderIds ?? []).join(',');
      updateTotal();

      loadPendingBtn.textContent = '✓ Chargé';
      loadPendingBtn.classList.add('btn-load-pending--done');
      loadPendingBtn.disabled = true;

      document.getElementById('livForm')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }
</script>

<style>
/* ── Pending orders banner ───────────────────────── */
.pending-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  flex-wrap: wrap;
  padding: var(--space-4) var(--space-5);
  margin-bottom: var(--space-5);
  background: oklch(0.96 0.06 80);
  border: 1.5px solid oklch(0.87 0.10 80);
  border-radius: var(--radius-md);
}

.pending-banner-left {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  flex: 1;
  min-width: 0;
}
.pending-banner-left svg { flex-shrink: 0; margin-top: 2px; }

.pending-banner-text {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.pending-banner-title {
  font-size: var(--text-sm);
  font-weight: 700;
  color: oklch(0.38 0.14 80);
}
.pending-banner-sub {
  font-size: var(--text-xs);
  color: oklch(0.50 0.10 80);
}
.pending-banner-warn {
  font-size: var(--text-xs);
  color: oklch(0.46 0.18 25);
  margin-top: 2px;
}

.btn-load-pending {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 600;
  color: white;
  background: oklch(0.52 0.14 80);
  border: none;
  border-radius: var(--radius-sm);
  padding: var(--space-2) var(--space-4);
  height: 38px;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity var(--dur-fast), background var(--dur-fast);
  flex-shrink: 0;
}
.btn-load-pending:hover { opacity: 0.88; }
.btn-load-pending--done { background: oklch(0.45 0.13 150); cursor: default; }

/* ── Alerts ──────────────────────────────────────── */
.alert {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3);
  border-radius: var(--radius-sm);
  padding: var(--space-3) var(--space-4);
  font-size: var(--text-sm);
  margin-bottom: var(--space-6);
}
.alert svg { flex-shrink: 0; margin-top: 1px; }
.alert-success {
  background: oklch(0.96 0.04 145);
  border: 1px solid oklch(0.85 0.08 145);
  color: oklch(0.35 0.12 145);
}
.alert-error {
  background: oklch(0.97 0.04 25);
  border: 1px solid oklch(0.88 0.07 25);
  color: oklch(0.45 0.16 25);
}

/* ── Form sections ───────────────────────────────── */
.liv-form { display: flex; flex-direction: column; gap: var(--space-6); padding-bottom: 72px; }

.liv-section {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-5) var(--space-6);
}

.liv-section-title {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-ink);
  margin-bottom: var(--space-4);
}

.liv-section-hint {
  font-size: var(--text-sm);
  color: var(--color-muted);
  margin-top: calc(-1 * var(--space-2));
  margin-bottom: var(--space-4);
}

/* ── Field helpers ───────────────────────────────── */
.field-group {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
}
.field { display: flex; flex-direction: column; gap: var(--space-2); }

label {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
}
.req { color: var(--color-primary); }

input[type="email"],
input[type="text"] {
  width: 100%;
  padding: 0.6875rem 0.875rem;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-ink);
  background: var(--color-bg);
  border: 1.5px solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  min-height: 44px;
  outline: none;
  box-sizing: border-box;
  transition: border-color var(--dur-fast), box-shadow var(--dur-fast);
}
input[type="email"]:focus,
input[type="text"]:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px oklch(0.568 0.149 45.9 / 0.15);
}
input::placeholder { color: var(--color-muted); }
.input-readonly {
  color: var(--color-muted);
  background: var(--color-surface);
  cursor: default;
}

/* ── PDV list ────────────────────────────────────── */
.pdv-list { display: flex; flex-direction: column; gap: var(--space-2); }

.pdv-card {
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  transition: border-color var(--dur-fast);
}
.pdv-card--open { border-color: var(--color-primary); }

.pdv-header {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3) var(--space-4);
  cursor: pointer;
  background: var(--color-bg);
  transition: background var(--dur-fast);
}
.pdv-header:hover { background: var(--color-surface); }

.pdv-checkbox {
  width: 16px;
  height: 16px;
  accent-color: var(--color-primary);
  flex-shrink: 0;
  cursor: pointer;
}

.pdv-header-text { flex: 1; min-width: 0; }
.pdv-name { display: block; font-size: var(--text-sm); font-weight: 600; color: var(--color-ink); }
.pdv-client { display: block; font-size: var(--text-xs); color: var(--color-muted); margin-top: 1px; }

.pdv-chevron {
  color: var(--color-muted);
