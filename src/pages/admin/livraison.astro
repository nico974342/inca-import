---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';
import { generateDeliverySummaryPDF, generatePDVDeliveryPDF } from '../../lib/pdf';
import { normalizeEmail } from '../../lib/clients';
import { COMPANY, RESEND_DEFAULT_FROM } from '../../lib/constants';
import { Resend } from 'resend';

const FROM = (import.meta.env.RESEND_FROM as string | undefined) ?? RESEND_DEFAULT_FROM;

function slugPDV(name: string): string {
  return name
    .toLowerCase()
    .normalize('NFD')
    .replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}


const [{ data: clients }, { data: productsRaw }] = await Promise.all([
  supabaseAdmin
    .from('client_accounts')
    .select('id, email, nom, societe, points_de_vente, livraison_rue, livraison_ville, livraison_code_postal, adresse_pdv')
    .not('points_de_vente', 'is', null)
    .neq('points_de_vente', '')
    .order('nom'),
  supabaseAdmin
    .from('products')
    .select('id, name, unit, category, price_ht, sku')
    .eq('in_stock', true)
    .order('category', { ascending: true })
    .order('name', { ascending: true }),
]);

const clientPDVs = (clients ?? []).map(c => ({
  key: `client_${c.id}`,
  name: c.points_de_vente as string,
  clientLabel: c.nom + (c.societe ? ` · ${c.societe}` : ''),
}));

// Email → pdvKey (normalized on both sides to tolerate case/whitespace drift)
const emailToClientKey = new Map(
  (clients ?? [])
    .filter(c => c.email)
    .map(c => [normalizeEmail(c.email as string), `client_${c.id}`])
);
// nom fallback — catches orders where email is null or was stored differently
const nomToClientKey = new Map(
  (clients ?? [])
    .filter(c => c.nom)
    .map(c => [(c.nom as string).trim().toLowerCase(), `client_${c.id}`])
);

const allPDVs = clientPDVs;
const products = productsRaw ?? [];

type Product = (typeof products)[number];
const productsByCategory = products.reduce<Record<string, Product[]>>((acc, p) => {
  const cat = p.category ?? 'Autre';
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(p);
  return acc;
}, {});

let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const notes = (form.get('notes') as string)?.trim() || null;
  const loadedOrderIds = ((form.get('loaded_order_ids') as string) ?? '')
    .split(',').map(s => s.trim()).filter(Boolean);

  const now = new Date();
  const dateStr = now.toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
  const batchId = `REC-${now.toISOString().slice(0, 10).replace(/-/g, '')}-${now.toTimeString().slice(0, 5).replace(':', '')}`;

  const clientById = new Map((clients ?? []).map(c => [c.id, c]));

  const pdvMeta: { key: string; name: string; clientId: string | null }[] = [];
  const deliveryPDVs: {
    name: string;
    items: { product_name: string; quantity: number; unit?: string | null; price_ht?: number | null; sku?: string | null }[];
    client_nom?: string | null;
    client_societe?: string | null;
    client_address?: string | null;
  }[] = [];

  for (const pdv of allPDVs) {
    if (form.get(`included_${pdv.key}`) !== 'on') continue;
    const clientId = pdv.key.startsWith('client_') ? pdv.key.slice('client_'.length) : null;
    const ci = clientId ? clientById.get(clientId) : null;

    const items: { product_name: string; quantity: number; unit?: string | null; price_ht?: number | null; sku?: string | null }[] = [];
    for (const p of products) {
      const qty = parseInt((form.get(`qty_${pdv.key}_${p.id}`) as string) || '0', 10);
      if (qty > 0) items.push({
        product_name: p.name,
        quantity: qty,
        unit: p.unit ?? null,
        price_ht: (p as any).price_ht ?? null,
        sku: (p as any).sku ?? null,
      });
    }
    if (items.length === 0) continue;

    const villePostal = [ci?.livraison_code_postal, ci?.livraison_ville].filter(Boolean).join(' ') || null;
    const addrParts = [ci?.livraison_rue, villePostal, 'La Réunion'].filter(Boolean);
    const clientAddress = addrParts.length > 1
      ? addrParts.join(', ')
      : ((ci as any)?.adresse_pdv ?? null);

    deliveryPDVs.push({
      name: pdv.name,
      items,
      client_nom: ci?.nom ?? null,
      client_societe: ci?.societe ?? null,
      client_address: clientAddress,
    });
    pdvMeta.push({ key: pdv.key, name: pdv.name, clientId });
  }

  if (deliveryPDVs.length === 0) {
    errorMessage = 'Sélectionnez au moins un point de vente avec des produits.';
  } else {
    // One unique BL number per PDV
    const blResults = await Promise.all(deliveryPDVs.map(() => supabaseAdmin.rpc('next_bl_number')));
    const blErr = blResults.find(r => r.error);
    if (blErr) {
      errorMessage = `Erreur lors de la génération des numéros de BL : ${blErr.error!.message}`;
    } else {
      const blNumbers = blResults.map(r => r.data as string);
      try {
        const deliveryData = { id: batchId, date: dateStr, pdvs: deliveryPDVs, notes };

        const [summaryBuffer, ...pdvBuffers] = await Promise.all([
          generateDeliverySummaryPDF(deliveryData),
          ...deliveryPDVs.map((pdv, i) => generatePDVDeliveryPDF(pdv, blNumbers[i], dateStr)),
        ]);

        const attachments = [
          { filename: `recapitulatif-${batchId}.pdf`, content: summaryBuffer },
          ...deliveryPDVs.map((pdv, i) => ({
            filename: `${blNumbers[i]}-${slugPDV(pdv.name)}.pdf`,
            content: pdvBuffers[i],
          })),
        ];

        const pdvListHtml = deliveryPDVs.map((p, i) => `&bull; <strong>${blNumbers[i]}</strong> &mdash; ${p.name}`).join('<br/>');
        const attachListHtml = [
          `&bull; <strong>R&eacute;capitulatif</strong> &mdash; bilan consolid&eacute;`,
          ...deliveryPDVs.map((p, i) => `&bull; <strong>${blNumbers[i]}</strong> &mdash; ${p.name}`),
        ].join('<br/>');

        const resend = new Resend(import.meta.env.RESEND_API_KEY);
        const { error: sendError } = await resend.emails.send({
          from: FROM,
          to: [COMPANY.contactEmail],
          subject: `${blNumbers.join(', ')} · ${dateStr}`,
          html: `<p>Bonjour,</p>
<p>${deliveryPDVs.length} bon${deliveryPDVs.length > 1 ? 's' : ''} de livraison du ${dateStr}.</p>
<p><strong>Points de vente :</strong><br/>${pdvListHtml}</p>
<p><strong>Pi&egrave;ces jointes (${attachments.length}) :</strong><br/>${attachListHtml}</p>
<p>Cordialement,<br/>Inca Import</p>`,
          attachments,
        });

        if (sendError) {
          console.error('[livraison] Resend error:', sendError);
          errorMessage = `PDF générés mais l'envoi a échoué : ${sendError.message}`;
        } else {
          successMessage = `${attachments.length} PDF envoyés (${blNumbers.join(', ')}) → ${COMPANY.contactEmail}`;
          if (loadedOrderIds.length > 0) {
            await supabaseAdmin
              .from('orders')
              .update({ status: 'en_preparation' })
              .in('id', loadedOrderIds);
          }
          try {
            await Promise.all(
              pdvMeta.map(async (meta, i) => {
                const storagePath = `${blNumbers[i]}/${meta.key}.pdf`;
                const { error: upErr } = await supabaseAdmin.storage
                  .from('delivery-notes')
                  .upload(storagePath, pdvBuffers[i], { contentType: 'application/pdf', upsert: false });
                if (upErr) { console.error('[livraison] upload error', meta.key, upErr.message); return; }
                const { error: dbErr } = await supabaseAdmin.from('delivery_notes').insert({
                  delivery_id: blNumbers[i],
                  client_id: meta.clientId,
                  pdv_key: meta.key,
                  pdv_name: meta.name,
                  storage_path: storagePath,
                });
                if (dbErr) console.error('[livraison] delivery_notes insert error:', dbErr.message);
              })
            );
          } catch (e) {
            console.error('[livraison] delivery_notes save failed:', e);
          }
        }
      } catch (e) {
        console.error(e);
        errorMessage = "Une erreur est survenue lors de la génération ou de l'envoi.";
      }
    }
  }
}

const categories = Object.keys(productsByCategory).sort();

// ── Confirmed orders pending delivery ──────────────────────────────────────
const { data: confirmedOrders } = await supabaseAdmin
  .from('orders')
  .select('id, email, nom, societe')
  .eq('status', 'confirmee');

const confirmedOrderIds = (confirmedOrders ?? []).map(o => o.id);

const { data: confirmedItems } = confirmedOrderIds.length > 0
  ? await supabaseAdmin
      .from('order_items')
      .select('order_id, product_id, quantity')
      .in('order_id', confirmedOrderIds)
      .not('product_id', 'is', null)
  : { data: [] as { order_id: string; product_id: string; quantity: number }[] };

// societe fallback — some orders store the company name in societe, not nom
const societeToClientKey = new Map(
  (clients ?? [])
    .filter(c => c.societe)
    .map(c => [(c.societe as string).trim().toLowerCase(), `client_${c.id}`])
);

const orderToPdvKey = new Map<string, string>();
for (const order of confirmedOrders ?? []) {
  const byEmail   = order.email   ? emailToClientKey.get(normalizeEmail(order.email))          : undefined;
  const byNom     = order.nom     ? nomToClientKey.get(order.nom.trim().toLowerCase())         : undefined;
  const bySociete = (order as any).societe ? societeToClientKey.get((order as any).societe.trim().toLowerCase()) : undefined;
  const key = byEmail ?? byNom ?? bySociete;
  if (key) orderToPdvKey.set(order.id, key);
}

const pendingQtys: Record<string, Record<string, number>> = {};
for (const item of confirmedItems ?? []) {
  if (!item.product_id) continue;
  const pdvKey = orderToPdvKey.get(item.order_id);
  if (!pdvKey) continue;
  if (!pendingQtys[pdvKey]) pendingQtys[pdvKey] = {};
  pendingQtys[pdvKey][item.product_id] = (pendingQtys[pdvKey][item.product_id] ?? 0) + item.quantity;
}

// Order count per PDV (for badges and Charger summary)
const orderCountByPDV: Record<string, number> = {};
for (const [, pdvKey] of orderToPdvKey) {
  orderCountByPDV[pdvKey] = (orderCountByPDV[pdvKey] ?? 0) + 1;
}

// PDV name lookup passed to JS (for success state labels + debug)
const pdvNameMap: Record<string, string> = Object.fromEntries(allPDVs.map(p => [p.key, p.name]));

const loadableOrderIds = (confirmedOrders ?? []).filter(o => orderToPdvKey.has(o.id)).map(o => o.id);
const pendingCount = confirmedOrderIds.length;
const pendingPDVNames = Object.keys(pendingQtys)
  .map(key => allPDVs.find(p => p.key === key)?.name)
  .filter((n): n is string => !!n);

// Unmatched orders (for banner warning)
const unmatchedOrders = (confirmedOrders ?? []).filter(o => !orderToPdvKey.has(o.id));
---

<AdminLayout title="Bon de livraison" activeNav="livraison">

  {successMessage && (
    <div class="alert alert-success" role="status">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="7" stroke="oklch(0.52 0.17 145)" stroke-width="1.25"/>
        <path d="M4.5 8l2.5 2.5 4-4" stroke="oklch(0.52 0.17 145)" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {successMessage}
    </div>
  )}
  {errorMessage && (
    <div class="alert alert-error" role="alert">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="7" stroke="oklch(0.50 0.19 25)" stroke-width="1.25"/>
        <path d="M8 5v3.5M8 11h.01" stroke="oklch(0.50 0.19 25)" stroke-width="1.25" stroke-linecap="round"/>
      </svg>
      {errorMessage}
    </div>
  )}

  {pendingCount > 0 && (
    <div class="pending-banner" id="pendingBanner">
      <div class="pending-banner-left">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="8" stroke="oklch(0.52 0.17 145)" stroke-width="1.4"/>
          <path d="M6.5 10.5l2.5 2.5 4.5-5" stroke="oklch(0.52 0.17 145)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="pending-banner-text" id="pendingBannerText">
          <span class="pending-banner-title">
            {pendingCount} commande{pendingCount > 1 ? 's' : ''} prête{pendingCount > 1 ? 's' : ''} à livrer
          </span>
          {pendingPDVNames.length > 0 && (
            <span class="pending-banner-sub">
              {pendingPDVNames.join(' · ')}
            </span>
          )}
          {unmatchedOrders.length > 0 && (
            <span class="pending-banner-warn">
              {unmatchedOrders.length} commande{unmatchedOrders.length > 1 ? 's' : ''} sans PDV associé :
              {unmatchedOrders.map(o => `${o.nom ?? '—'} (email: ${o.email ?? 'null'})`).join(' · ')}
            </span>
          )}
        </div>
      </div>
      {loadableOrderIds.length > 0 && (
        <button type="button" id="loadPendingBtn" class="btn-load-pending">
          Charger dans le formulaire
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
            <path d="M2 6.5h9M7.5 3l4 3.5-4 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      )}
    </div>
  )}

  <script id="pendingData" type="application/json" set:html={JSON.stringify({
    qtys: pendingQtys,
    orderIds: loadableOrderIds,
    orderCountByPDV,
    pdvNames: pdvNameMap,
  })}></script>

  <form method="POST" class="liv-form" id="livForm">
    <input type="hidden" name="loaded_order_ids" id="loadedOrderIds" value="" />

    <!-- Points de vente -->
    <section class="liv-section">
      <h2 class="liv-section-title">Points de vente</h2>
      <p class="liv-section-hint">Cochez les points de vente à livrer, puis renseignez les quantités.</p>

      <div class="pdv-groups">

        {clientPDVs.length > 0 && (
          <div class="pdv-group">
            <div class="pdv-list">
              {clientPDVs.map(pdv => {
                const hasPending = !!pendingQtys[pdv.key];
                const orderCount = orderCountByPDV[pdv.key] ?? 0;
                return (
                  <div class={`pdv-card${hasPending ? ' pdv-card--has-orders' : ''}`} data-pdv={pdv.key}>
                    <label class="pdv-header">
                      <input type="checkbox" name={`included_${pdv.key}`} class="pdv-checkbox" data-target={`pdv-body-${pdv.key}`} />
                      <span class="pdv-header-text">
                        <span class="pdv-name-row">
                          <span class="pdv-name">{pdv.name}</span>
                          {hasPending && (
                            <span class="pdv-order-badge">{orderCount} commande{orderCount > 1 ? 's' : ''}</span>
                          )}
                        </span>
                        {pdv.clientLabel && <span class="pdv-client">{pdv.clientLabel}</span>}
                      </span>
                      <svg class="pdv-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </label>
                    <div class="pdv-body" id={`pdv-body-${pdv.key}`} hidden>
                      <div class="pdv-body-controls">
                        <div class="pdv-search-wrap">
                          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                            <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.25"/>
                            <path d="M10 10l2.5 2.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
                          </svg>
                          <input type="text" class="pdv-search" placeholder="Rechercher un produit…" autocomplete="off" aria-label="Rechercher un produit" />
                        </div>
                      </div>
                      {categories.length === 0 ? (
                        <p class="pdv-empty">Aucun produit en stock.</p>
                      ) : (
                        categories.map(cat => (
                          <div class="pdv-cat">
                            <p class="pdv-cat-name">{cat}</p>
                            <div class="pdv-products">
                              {productsByCategory[cat].map(p => (
                                <div class="pdv-product-row" data-product-id={p.id} data-product-name={p.name.toLowerCase()}>
                                  <span class="pdv-product-name">{p.name}</span>
                                  {p.unit && <span class="pdv-product-unit">{p.unit}</span>}
                                  <div class="stepper">
                                    <button type="button" class="step-btn step-dec" aria-label={`Diminuer ${p.name}`}>−</button>
                                    <input type="number" name={`qty_${pdv.key}_${p.id}`} class="step-input" value="0" min="0" max="9999" aria-label={`Quantité ${p.name}`} />
                                    <button type="button" class="step-btn step-inc" aria-label={`Augmenter ${p.name}`}>+</button>
                                  </div>
                                </div>
                              ))}
                            </div>
                          </div>
                        ))
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

      </div>
    </section>

    <!-- Notes -->
    <section class="liv-section">
      <h2 class="liv-section-title">Notes</h2>
      <textarea name="notes" class="liv-notes" rows="3" placeholder="Instructions de livraison, horaires, remarques…"></textarea>
    </section>

    <!-- Sticky submit bar -->
    <div class="liv-submit-bar">
      <span class="liv-total-label">
        Total articles : <strong id="totalQty">0</strong>
      </span>
      <button type="submit" class="btn btn-primary liv-submit-btn">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2 7h10M7.5 3l4.5 4-4.5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Générer &amp; envoyer le bon
      </button>
    </div>

  </form>
</AdminLayout>

<script>
  // ── PDV body visibility ───────────────────────────────────────────────────
  function refreshBodyVisibility(body: HTMLElement) {
    const searchEl = body.querySelector<HTMLInputElement>('.pdv-search');
    const searchTerm = (searchEl?.value ?? '').toLowerCase().trim();

    body.querySelectorAll<HTMLElement>('.pdv-product-row').forEach(row => {
      const isOrderedZero = row.dataset.orderedZero === 'true';
      const name = row.dataset.productName ?? '';
      row.hidden = searchTerm ? !name.includes(searchTerm) : isOrderedZero;
    });

    body.querySelectorAll<HTMLElement>('.pdv-cat').forEach(cat => {
      cat.hidden = [...cat.querySelectorAll<HTMLElement>('.pdv-product-row')].every(r => r.hidden);
    });
  }

  // ── Toggle PDV body on checkbox change ───────────────────────────────────
  document.querySelectorAll<HTMLInputElement>('.pdv-checkbox').forEach(cb => {
    const targetId = cb.dataset.target!;
    const body = document.getElementById(targetId);
    const card = cb.closest('.pdv-card');

    cb.addEventListener('change', () => {
      if (body) body.hidden = !cb.checked;
      card?.classList.toggle('pdv-card--open', cb.checked);
      if (!cb.checked && body) {
        body.querySelectorAll<HTMLInputElement>('.step-input').forEach(i => { i.value = '0'; });
        body.querySelectorAll<HTMLElement>('.pdv-product-row').forEach(r => {
          delete r.dataset.orderedZero;
          r.hidden = false;
        });
        body.querySelectorAll<HTMLElement>('.pdv-cat').forEach(c => { c.hidden = false; });
        const search = body.querySelector<HTMLInputElement>('.pdv-search');
        if (search) search.value = '';
      }
      updateTotal();
    });
  });

  // ── Search inputs ─────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLInputElement>('.pdv-search').forEach(input => {
    input.addEventListener('input', () => {
      const body = input.closest<HTMLElement>('.pdv-body');
      if (body) refreshBodyVisibility(body);
    });
  });

  // ── Stepper buttons ───────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.pdv-body').forEach(body => {
    body.addEventListener('click', e => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.step-btn');
      if (!btn) return;
      const row = btn.closest('.stepper')!;
      const input = row.querySelector<HTMLInputElement>('.step-input')!;
      let val = parseInt(input.value || '0', 10);
      if (btn.classList.contains('step-dec')) val = Math.max(0, val - 1);
      else val = Math.min(9999, val + 1);
      input.value = String(val);
      updateTotal();
    });

    body.addEventListener('input', e => {
      if ((e.target as HTMLElement).classList.contains('step-input')) updateTotal();
    });
  });

  function updateTotal() {
    let total = 0;
    document.querySelectorAll<HTMLInputElement>('.step-input').forEach(i => {
      total += parseInt(i.value || '0', 10);
    });
    const el = document.getElementById('totalQty');
    if (el) el.textContent = String(total);
  }

  // ── Load pending confirmed orders into form ───────────────────────────────
  const pendingDataEl = document.getElementById('pendingData');
  const loadPendingBtn = document.getElementById('loadPendingBtn') as HTMLButtonElement | null;
  const loadedOrderIdsInput = document.getElementById('loadedOrderIds') as HTMLInputElement | null;

  if (pendingDataEl && loadPendingBtn) {
    const pending = JSON.parse(pendingDataEl.textContent || '{}') as {
      qtys: Record<string, Record<string, number>>;
      orderIds: string[];
      orderCountByPDV: Record<string, number>;
      pdvNames: Record<string, string>;
    };

    loadPendingBtn.addEventListener('click', () => {
      const loaded: { name: string; orders: number; products: number }[] = [];
      const missed: string[] = [];

      for (const [pdvKey, orderedProducts] of Object.entries(pending.qtys ?? {})) {
        const checkbox = document.querySelector<HTMLInputElement>(`input[name="included_${pdvKey}"]`);

        if (!checkbox) {
          // Checkbox not found in DOM — pdvKey doesn't match any rendered PDV card
          console.warn(`[Charger] No checkbox for pdvKey="${pdvKey}" (PDV: "${pending.pdvNames?.[pdvKey] ?? '?'}")`);
          missed.push(pending.pdvNames?.[pdvKey] ?? pdvKey);
          continue;
        }

        // Open the PDV
        if (!checkbox.checked) {
          checkbox.checked = true;
          checkbox.dispatchEvent(new Event('change', { bubbles: true }));
        }

        // Set quantities
        let productCount = 0;
        for (const [productId, qty] of Object.entries(orderedProducts)) {
          const input = document.querySelector<HTMLInputElement>(`input[name="qty_${pdvKey}_${productId}"]`);
          if (input) {
            input.value = String(parseInt(input.value || '0', 10) + (qty as number));
            if ((qty as number) > 0) productCount++;
          }
        }

        // Mark zero rows
        const body = document.getElementById(`pdv-body-${pdvKey}`);
        if (body) {
          body.querySelectorAll<HTMLElement>('.pdv-product-row').forEach(row => {
            const pid = row.dataset.productId!;
            row.dataset.orderedZero = ((orderedProducts[pid] as number | undefined) ?? 0) > 0 ? 'false' : 'true';
          });
          refreshBodyVisibility(body);
        }

        loaded.push({
          name: pending.pdvNames?.[pdvKey] ?? pdvKey,
          orders: pending.orderCountByPDV?.[pdvKey] ?? 0,
          products: productCount,
        });
      }

      if (loadedOrderIdsInput) loadedOrderIdsInput.value = (pending.orderIds ?? []).join(',');
      updateTotal();

      // ── Update banner to show success detail ──────────────────────────────
      const bannerText = document.getElementById('pendingBannerText');
      if (bannerText) {
        const lines = loaded.map(l =>
          `${l.name} — ${l.orders} commande${l.orders > 1 ? 's' : ''}, ${l.products} article${l.products > 1 ? 's' : ''}`
        );
        if (missed.length > 0) {
          lines.push(`⚠ Non trouvé dans le formulaire : ${missed.join(', ')}`);
          console.error('[Charger] PDV manquants — vérifier client_accounts.id vs clé dans pendingQtys:', missed);
        }
        bannerText.innerHTML = `
          <span class="pending-banner-title">✓ Chargement effectué</span>
          ${lines.map(l => `<span class="pending-banner-sub">${l}</span>`).join('')}
        `;
      }

      loadPendingBtn.textContent = '✓ Chargé';
      loadPendingBtn.classList.add('btn-load-pending--done');
      loadPendingBtn.disabled = true;

      document.getElementById('livForm')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }
</script>

