---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../../../lib/supabase';
import { ORDER_STATUS_LABEL, ORDER_STATUS_COLOR, DEFAULT_TVA_RATE, isOrderEditable } from '../../../../lib/constants';

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/commandes');

const { data: order } = await supabaseAdmin
  .from('orders')
  .select('id, status, nom, societe, email, telephone, notes')
  .eq('id', id)
  .single();

if (!order) return Astro.redirect('/admin/commandes');
if (!isOrderEditable(order.status)) return Astro.redirect('/admin/commandes?edit_error=trop_tard');

const { data: orderItemsRaw } = await supabaseAdmin
  .from('order_items')
  .select('product_id, product_name, quantity, unit, price_ht_snapshot, tva_rate_snapshot')
  .eq('order_id', id)
  .order('product_name', { ascending: true });

const existingItems = (orderItemsRaw ?? []).map(it => ({
  product_id: it.product_id,
  name: it.product_name,
  unit: it.unit,
  quantity: it.quantity,
  price: it.price_ht_snapshot != null ? Number(it.price_ht_snapshot) : null,
  tva_rate: it.tva_rate_snapshot != null ? Number(it.tva_rate_snapshot) : DEFAULT_TVA_RATE,
}));

// Only in-stock products can be added as new lines (mirrors commande-rapide);
// existing lines stay visible even if their product later went out of stock.
const { data: productsRaw } = await supabaseAdmin
  .from('products')
  .select('id, name, category, unit, price_ht, tva_rate, stock_quantity, in_stock')
  .eq('in_stock', true)
  .order('category', { ascending: true })
  .order('name', { ascending: true });

const products = (productsRaw ?? []).map(p => ({
  id: p.id,
  name: p.name,
  category: p.category,
  unit: p.unit ?? '',
  price: Number(p.price_ht ?? 0),
  tva_rate: p.tva_rate != null ? Number(p.tva_rate) : DEFAULT_TVA_RATE,
  stock: p.stock_quantity ?? 0,
}));

const CAT_LABEL: Record<string, string> = {
  boissons: 'Boissons', snacks: 'Snacks', confiseries: 'Confiseries', divers: 'Divers',
};
const CATS = ['tous', ...Array.from(new Set(products.map(p => p.category)))];

const errorParam = Astro.url.searchParams.get('error');
const ERROR_MSG: Record<string, string> = {
  empty: 'La commande doit contenir au moins un article.',
  stock: 'Certains articles dépassent le stock disponible. Ajustez les quantités.',
  erreur: 'Une erreur est survenue lors de la mise à jour de la commande.',
};

const STATUS_LABEL = ORDER_STATUS_LABEL;
const STATUS_COLOR = ORDER_STATUS_COLOR;

const EXISTING_ITEMS_JSON = JSON.stringify(existingItems);
const PRODUCTS_JSON = JSON.stringify(products);
---
<AdminLayout title="Modifier la commande" activeNav="commandes">

  <div class="page-header">
    <a href="/admin/commandes" class="back-link">← Retour aux commandes</a>
    <h1 class="page-title">Modifier la commande</h1>
    <div class="order-meta-line">
      <span class="client-name">{order.nom}</span>
      {order.societe && <span class="client-co">— {order.societe}</span>}
      <span class={`badge badge--${STATUS_COLOR[order.status] ?? 'muted'}`}>{STATUS_LABEL[order.status] ?? order.status}</span>
    </div>
  </div>

  {errorParam && (
    <div class="alert-error" role="alert">{ERROR_MSG[errorParam] ?? ERROR_MSG.erreur}</div>
  )}

  <form method="post" action={`/api/admin/orders/${id}/update`} id="editForm">
    <section class="form-section">
      <div class="section-header">
        <h2 class="section-title">Articles</h2>
        <button type="button" id="toggleSearchBtn" class="btn btn-ghost">+ Ajouter un produit</button>
      </div>

      <div id="searchPanel" class="search-panel" style="display:none">
        <input type="text" id="productSearch" class="input" placeholder="Rechercher un produit…" autocomplete="off" />
        <div id="catTabs" class="cat-tabs">
          {CATS.map(cat => (
            <button type="button" class={`cat-tab ${cat === 'tous' ? 'cat-tab--active' : ''}`} data-cat={cat}>
              {cat === 'tous' ? 'Tous' : (CAT_LABEL[cat] ?? cat)}
            </button>
          ))}
        </div>
        <div id="searchResults" class="search-results"></div>
      </div>

      <div class="items-table-wrap">
        <table class="items-table" id="itemsTable">
          <thead>
            <tr>
              <th class="col-product">Produit</th>
              <th class="col-pu th-r">PU HT</th>
              <th class="col-qty th-r">Qté</th>
              <th class="col-total th-r">Total HT</th>
              <th class="col-action"></th>
            </tr>
          </thead>
          <tbody id="itemsBody"></tbody>
        </table>
      </div>
      <p id="noItemsHint" class="items-hint" style="display:none">Aucun article. Ajoutez un produit pour commencer.</p>
    </section>

    <section class="totals-section">
      <div class="totals-row"><span>Total HT</span><span id="totalHt">—</span></div>
      <div class="totals-row"><span>TVA</span><span id="totalTva">—</span></div>
      <div class="totals-row totals-row--ttc"><span>Total TTC</span><span id="totalTtc">—</span></div>
    </section>

    <div class="form-actions">
      <a href="/admin/commandes" class="btn btn-ghost">Annuler</a>
      <button type="submit" class="btn btn-primary" id="submitBtn" disabled>Enregistrer les modifications</button>
    </div>
  </form>
</AdminLayout>

<script define:vars={{ EXISTING_ITEMS_JSON, PRODUCTS_JSON }}>
const existingItems = JSON.parse(EXISTING_ITEMS_JSON);
const products       = JSON.parse(PRODUCTS_JSON);
const productMap = {};
products.forEach(p => { productMap[p.id] = p; });

// Live line-item state: { product_id, name, unit, price, tva_rate, quantity, baseline, maxQty }
let lines = existingItems.map(it => {
  const prod = productMap[it.product_id];
  const stock = prod ? prod.stock : null;
  return {
    product_id: it.product_id,
    name: it.name,
    unit: it.unit,
    price: it.price,
    tva_rate: it.tva_rate,
    quantity: it.quantity,
    baseline: it.quantity,
    // Can always keep the original quantity even if stock has since dropped
    // below it — only an INCREASE is capped by what's currently available.
    maxQty: stock != null ? Math.max(it.quantity, stock) : null,
  };
});

function fmt(n) {
  return n.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', minimumFractionDigits: 2 });
}
function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, ch => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[ch]));
}

const itemsBody     = document.getElementById('itemsBody');
const noItemsHint    = document.getElementById('noItemsHint');
const submitBtn      = document.getElementById('submitBtn');
const totalHtEl      = document.getElementById('totalHt');
const totalTvaEl     = document.getElementById('totalTva');
const totalTtcEl     = document.getElementById('totalTtc');
const editForm       = document.getElementById('editForm');
const toggleSearchBtn = document.getElementById('toggleSearchBtn');
const searchPanel    = document.getElementById('searchPanel');
const productSearch  = document.getElementById('productSearch');
const catTabs        = document.getElementById('catTabs');
const searchResults  = document.getElementById('searchResults');

let activeCat = 'tous';

function renderLines() {
  itemsBody.innerHTML = '';
  lines.forEach((line, idx) => {
    const tr = document.createElement('tr');
    const overStock = line.maxQty != null && line.quantity > line.maxQty;
    const lineTotal = line.price != null ? line.price * line.quantity : null;

    tr.innerHTML =
      '<td class="col-product">' +
        '<span class="item-name">' + escapeHtml(line.name) + '</span>' +
        (line.unit ? '<span class="item-unit">' + escapeHtml(line.unit) + '</span>' : '') +
      '</td>' +
      '<td class="col-pu td-r td-mono">' + (line.price != null ? fmt(line.price) : '—') + '</td>' +
      '<td class="col-qty td-r">' +
        '<input type="number" class="input input--num qty-input" min="1" step="1" value="' + line.quantity + '" data-idx="' + idx + '" />' +
        (overStock ? '<span class="stock-warn">Max ' + line.maxQty + ' disponible' + (line.maxQty > 1 ? 's' : '') + '</span>' : '') +
      '</td>' +
      '<td class="col-total td-r td-mono td-bold">' + (lineTotal != null ? fmt(lineTotal) : '—') + '</td>' +
      '<td class="col-action"><button type="button" class="remove-btn" data-idx="' + idx + '" title="Retirer">×</button></td>';

    itemsBody.appendChild(tr);
  });

  itemsBody.querySelectorAll('.qty-input').forEach(input => {
    input.addEventListener('input', () => {
      const i = Number(input.dataset.idx);
      let val = parseInt(input.value, 10);
      if (!Number.isFinite(val) || val < 1) val = 1;
      lines[i].quantity = val;
      renderLines();
    });
  });
  itemsBody.querySelectorAll('.remove-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const i = Number(btn.dataset.idx);
      lines.splice(i, 1);
      renderLines();
    });
  });

  noItemsHint.style.display = lines.length === 0 ? '' : 'none';
  submitBtn.disabled = lines.length === 0 || lines.some(l => l.maxQty != null && l.quantity > l.maxQty);
  recalcTotals();
}

function recalcTotals() {
  let ht = 0, tva = 0;
  lines.forEach(line => {
    if (line.price == null) return;
    const lineHt = line.price * line.quantity;
    ht  += lineHt;
    tva += lineHt * (line.tva_rate ?? 0);
  });
  totalHtEl.textContent  = fmt(ht);
  totalTvaEl.textContent = fmt(tva);
  totalTtcEl.textContent = fmt(ht + tva);
}

function addProduct(p) {
  const existingIdx = lines.findIndex(l => l.product_id === p.id);
  if (existingIdx !== -1) {
    const line = lines[existingIdx];
    if (line.maxQty == null || line.quantity < line.maxQty) line.quantity += 1;
  } else {
    lines.push({
      product_id: p.id, name: p.name, unit: p.unit, price: p.price, tva_rate: p.tva_rate,
      quantity: 1, baseline: 0, maxQty: p.stock,
    });
  }
  renderLines();
}

function renderSearchResults() {
  const q = (productSearch.value ?? '').trim().toLowerCase();
  const filtered = products.filter(p => {
    const matchesCat   = activeCat === 'tous' || p.category === activeCat;
    const matchesQuery = q.length === 0 || p.name.toLowerCase().includes(q);
    return matchesCat && matchesQuery;
  });

  searchResults.innerHTML = '';
  if (filtered.length === 0) {
    const empty = document.createElement('p');
    empty.className = 'items-hint';
    empty.textContent = 'Aucun produit trouvé.';
    searchResults.appendChild(empty);
    return;
  }

  filtered.forEach(p => {
    const row = document.createElement('button');
    row.type = 'button';
    row.className = 'search-result-row';
    row.innerHTML =
      '<span class="sr-name">' + escapeHtml(p.name) + '</span>' +
      '<span class="sr-price td-mono">' + fmt(p.price) + '</span>';
    row.addEventListener('click', () => addProduct(p));
    searchResults.appendChild(row);
  });
}

toggleSearchBtn.addEventListener('click', () => {
  const isHidden = searchPanel.style.display === 'none';
  searchPanel.style.display = isHidden ? '' : 'none';
  if (isHidden) { renderSearchResults(); productSearch.focus(); }
});

productSearch.addEventListener('input', renderSearchResults);
catTabs.querySelectorAll('.cat-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    activeCat = tab.dataset.cat;
    catTabs.querySelectorAll('.cat-tab').forEach(t => t.classList.toggle('cat-tab--active', t === tab));
    renderSearchResults();
  });
});

editForm.addEventListener('submit', () => {
  editForm.querySelectorAll('input[name="product_id[]"], input[name="quantity[]"]').forEach(el => el.remove());
  lines.forEach(line => {
    const pidInput = document.createElement('input');
    pidInput.type = 'hidden';
    pidInput.name = 'product_id[]';
    pidInput.value = line.product_id;
    editForm.appendChild(pidInput);

    const qtyInput = document.createElement('input');
    qtyInput.type = 'hidden';
    qtyInput.name = 'quantity[]';
    qtyInput.value = String(line.quantity);
    editForm.appendChild(qtyInput);
  });
});

renderLines();
</script>

<style>
.page-header { margin-bottom: var(--space-6); }
.back-link {
  font-size: var(--text-sm);
  color: var(--color-muted);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  margin-bottom: var(--space-2);
}
.back-link:hover { color: var(--color-ink); }

.page-title {
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-ink);
  margin: 0 0 var(--space-2);
}

.order-meta-line {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-wrap: wrap;
}
.client-name { font-size: var(--text-sm); font-weight: 600; color: var(--color-ink); }
.client-co   { font-size: var(--text-sm); color: var(--color-muted); }

.badge {
  display: inline-flex;
  align-items: center;
  font-size: var(--text-xs);
  font-weight: 600;
  padding: 3px 9px;
  border-radius: var(--radius-full);
  white-space: nowrap;
  margin-left: var(--space-2);
}
.badge--muted  { background: var(--color-surface);       color: var(--color-muted); }
.badge--blue   { background: oklch(0.93 0.05 220);       color: oklch(0.33 0.12 220); }
.badge--amber  { background: oklch(0.95 0.07 80);        color: oklch(0.40 0.14 80); }
.badge--purple { background: oklch(0.93 0.05 295);       color: oklch(0.38 0.12 295); }
.badge--green  { background: oklch(0.92 0.08 150);       color: oklch(0.32 0.12 150); }
.badge--red    { background: oklch(0.95 0.04 25);        color: oklch(0.46 0.18 25); }

.alert-error {
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-5);
  font-size: var(--text-sm);
  color: oklch(0.46 0.18 25);
  background: oklch(0.97 0.03 25);
  border: 1px solid oklch(0.88 0.07 25);
  border-radius: var(--radius-sm);
}

.form-section {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-5);
  margin-bottom: var(--space-5);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-4);
}
.section-title { font-size: var(--text-base); font-weight: 600; color: var(--color-ink); margin: 0; }

.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-5);
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
  font-weight: 600;
  text-decoration: none;
  border: 1px solid transparent;
  cursor: pointer;
  font-family: inherit;
  transition: background var(--dur-fast), color var(--dur-fast), border-color var(--dur-fast);
}
.btn:disabled { opacity: 0.45; cursor: not-allowed; }
.btn-primary { background: var(--color-primary); color: white; border-color: var(--color-primary); }
.btn-primary:hover:not(:disabled) { background: var(--color-primary-deep); border-color: var(--color-primary-deep); }
.btn-ghost { background: transparent; color: var(--color-ink); border-color: var(--color-border); }
.btn-ghost:hover { background: var(--color-surface); }

.search-panel {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-surface);
  padding: var(--space-4);
  margin-bottom: var(--space-4);
}

/* Rows below (items, search results) are built client-side via innerHTML,
   so Astro never stamps its scope attribute onto them — every selector that
   can match dynamically-injected content must be :global(). */
:global(.input) {
  width: 100%;
  padding: 8px 10px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-bg);
  color: var(--color-ink);
  font-size: var(--text-sm);
  font-family: var(--font-body);
  box-sizing: border-box;
  transition: border-color var(--dur-fast);
}
:global(.input:focus) { outline: 2px solid var(--color-primary); outline-offset: 2px; border-color: var(--color-primary); }
:global(.input--num) { font-family: var(--font-mono); text-align: right; width: 90px; }

.cat-tabs {
  display: flex;
  gap: var(--space-2);
  overflow-x: auto;
  margin-top: var(--space-3);
}
.cat-tab {
  flex-shrink: 0;
  padding: 4px 12px;
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-muted);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-full);
  cursor: pointer;
  white-space: nowrap;
  transition: all var(--dur-fast);
}
.cat-tab--active { background: var(--color-primary); color: white; border-color: var(--color-primary); }

.search-results {
  margin-top: var(--space-3);
  max-height: 280px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}
:global(.search-result-row) {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-3);
  padding: var(--space-2) var(--space-3);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-family: inherit;
  font-size: var(--text-sm);
  text-align: left;
  transition: border-color var(--dur-fast), background var(--dur-fast);
  width: 100%;
}
:global(.search-result-row:hover) { border-color: var(--color-border-strong); background: var(--color-surface); }
:global(.sr-name) { color: var(--color-ink); font-weight: 500; }
:global(.sr-price) { color: var(--color-primary-deep); font-weight: 600; }

.items-table-wrap { overflow-x: auto; }
.items-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
.items-table thead th {
  padding: var(--space-2) var(--space-3);
  text-align: left;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-muted);
  background: var(--color-surface);
  border-bottom: 1px solid var(--color-border);
  white-space: nowrap;
}
.items-table thead th.th-r { text-align: right; }
:global(.items-table tbody td) {
  padding: var(--space-2) var(--space-3);
  border-bottom: 1px solid var(--color-border);
  vertical-align: middle;
}
:global(.items-table tbody tr:last-child td) { border-bottom: none; }

:global(.col-product) { width: 40%; }
:global(.col-pu), :global(.col-qty), :global(.col-total) { width: 16%; }
:global(.col-action) { width: 40px; text-align: center; }

:global(.item-name) { display: block; font-weight: 500; color: var(--color-ink); }
:global(.item-unit) { display: block; font-size: var(--text-xs); color: var(--color-muted); }

:global(.td-r)    { text-align: right; }
:global(.td-mono) { font-family: var(--font-mono); }
:global(.td-bold) { font-weight: 700; }

:global(.stock-warn) {
  display: block;
  font-size: var(--text-xs);
  color: oklch(0.50 0.19 25);
  margin-top: 2px;
}

:global(.remove-btn) {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 1.1rem;
  color: var(--color-muted);
  padding: 4px 8px;
  border-radius: var(--radius-sm);
  line-height: 1;
  transition: color var(--dur-fast), background var(--dur-fast);
}
:global(.remove-btn:hover) { color: oklch(0.55 0.18 25); background: oklch(0.95 0.04 25); }

:global(.items-hint) {
  margin-top: var(--space-4);
  font-size: var(--text-sm);
  color: var(--color-muted);
  text-align: center;
  font-style: italic;
}

.totals-section {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-5);
  margin-bottom: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  max-width: 360px;
  margin-left: auto;
}
.totals-row {
  display: flex;
  justify-content: space-between;
  font-size: var(--text-sm);
  color: var(--color-muted);
}
.totals-row span:last-child { font-family: var(--font-mono); color: var(--color-ink); font-weight: 600; }
.totals-row--ttc {
  border-top: 1px solid var(--color-border);
  padding-top: var(--space-2);
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-ink);
}
.totals-row--ttc span:last-child { font-size: var(--text-lg); }

.form-actions {
  display: flex;
  justify-content: flex-end;
  gap: var(--space-3);
}

@media (max-width: 640px) {
  .totals-section { max-width: none; }
}
</style>
