---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../../lib/supabase';
import { sanitizeText, sanitizeEmail } from '../../../lib/sanitize';
import { logAdminAction } from '../../../lib/audit';
import { CLIENT_STATUS_LABEL as SHARED_CLIENT_STATUS_LABEL, ORDER_STATUS_LABEL as SHARED_ORDER_STATUS_LABEL, ORDER_STATUS_COLOR as SHARED_ORDER_STATUS_COLOR } from '../../../lib/constants';

const { id } = Astro.params;
let formError = '';

const { data: client } = await supabaseAdmin
  .from('client_accounts')
  .select('*')
  .eq('id', id)
  .single();

if (!client) return Astro.redirect('/admin/clients');

if (Astro.request.method === 'POST') {
  const data       = await Astro.request.formData();
  const nom        = sanitizeText(data.get('nom') as string, 120);
  const societe    = sanitizeText(data.get('societe') as string, 120);
  const email      = sanitizeEmail(data.get('email') as string);
  const telephone  = sanitizeText(data.get('telephone') as string, 40);
  const status     = data.get('status') as string;
  const notes      = sanitizeText(data.get('notes') as string, 500);
  const points_de_vente   = sanitizeText(data.get('points_de_vente') as string, 200);
  const adresse_pdv       = sanitizeText(data.get('adresse_pdv') as string, 200);
  const livraison_rue     = sanitizeText(data.get('livraison_rue') as string, 200);
  const livraison_cp      = sanitizeText(data.get('livraison_code_postal') as string, 20);
  const livraison_ville   = sanitizeText(data.get('livraison_ville') as string, 100);
  const facturation_same  = data.get('facturation_same') === '1';
  const facturation_rue   = sanitizeText(data.get('facturation_rue') as string, 200);
  const facturation_cp    = sanitizeText(data.get('facturation_code_postal') as string, 20);
  const facturation_ville = sanitizeText(data.get('facturation_ville') as string, 100);

  const remiseRaw = (data.get('remise') as string)?.trim();
  const remise    = remiseRaw ? parseFloat(remiseRaw) : null;

  const conditionsRaw       = (data.get('conditions_paiement') as string)?.trim();
  const conditions_paiement = ['comptant', '30j', '60j'].includes(conditionsRaw) ? conditionsRaw : null;

  const plafondRaw     = (data.get('plafond_credit') as string)?.trim();
  const plafond_credit = plafondRaw ? parseFloat(plafondRaw) : null;

  const VALID_STATUS = ['en_attente', 'actif', 'suspendu'];

  if (!nom) {
    formError = 'Le nom est obligatoire.';
  } else if (!email) {
    formError = 'Email invalide.';
  } else if (!VALID_STATUS.includes(status)) {
    formError = 'Statut invalide.';
  } else if (remise != null && (isNaN(remise) || remise < 0 || remise > 100)) {
    formError = 'La remise doit être comprise entre 0 et 100.';
  } else if (plafond_credit != null && (isNaN(plafond_credit) || plafond_credit < 0)) {
    formError = 'Le plafond crédit doit être positif ou nul.';
  } else {
    const { error } = await supabaseAdmin
      .from('client_accounts')
      .update({
        nom,
        societe: societe || null,
        email,
        telephone: telephone || null,
        status,
        notes: notes || null,
        points_de_vente: points_de_vente || null,
        adresse_pdv: adresse_pdv || null,
        livraison_rue: livraison_rue || null,
        livraison_code_postal: livraison_cp || null,
        livraison_ville: livraison_ville || null,
        facturation_same,
        facturation_rue: facturation_same ? null : (facturation_rue || null),
        facturation_code_postal: facturation_same ? null : (facturation_cp || null),
        facturation_ville: facturation_same ? null : (facturation_ville || null),
        remise,
        conditions_paiement,
        plafond_credit,
      })
      .eq('id', id);

    if (error) {
      formError = error.code === '23505'
        ? 'Cet email est déjà utilisé par un autre client.'
        : `Erreur : ${error.message}`;
    } else {
      await logAdminAction({
        adminEmail: (Astro.locals as any).user?.email ?? 'inconnu',
        action: 'client.modification',
        targetType: 'client',
        targetId: id!,
        targetLabel: societe || nom,
      });
      return Astro.redirect(`/admin/clients/${id}`);
    }
  }
}

// ── Order history — orders have no client_id FK; match by email (always
// set, copied verbatim at order-creation time for both self-checkout and
// admin-placed orders) and by user_id (only set for self-checkout orders,
// since commande-rapide stamps the admin's own id there) ──────────────
const orderQueries = [
  supabaseAdmin.from('orders').select('id, status, created_at, email').eq('email', client.email ?? ''),
  ...(client.user_id ? [supabaseAdmin.from('orders').select('id, status, created_at, email').eq('user_id', client.user_id)] : []),
];
const orderResults = await Promise.all(orderQueries);

const orderMap = new Map<string, { id: string; status: string; created_at: string }>();
for (const res of orderResults) {
  for (const o of res.data ?? []) orderMap.set(o.id, o);
}
const clientOrders = Array.from(orderMap.values())
  .sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());

const orderIds = clientOrders.map(o => o.id);
const { data: allItems } = orderIds.length
  ? await supabaseAdmin.from('order_items').select('order_id, quantity, price_ht_snapshot').in('order_id', orderIds)
  : { data: [] };

const totalsByOrder: Record<string, number | null> = {};
for (const item of allItems ?? []) {
  const price = (item as any).price_ht_snapshot;
  if (price != null) {
    totalsByOrder[item.order_id] = (totalsByOrder[item.order_id] ?? 0) + Number(price) * item.quantity;
  }
}

const ordersWithTotal = clientOrders.map(o => ({ ...o, total: totalsByOrder[o.id] ?? null }));
const lastOrderDate   = clientOrders[0]?.created_at ?? null;
const totalCA = ordersWithTotal
  .filter(o => o.status !== 'annulee')
  .reduce((sum, o) => sum + (o.total ?? 0), 0);

const CLIENT_STATUS_LABEL = SHARED_CLIENT_STATUS_LABEL;
const ORDER_STATUS_LABEL  = SHARED_ORDER_STATUS_LABEL;
const ORDER_STATUS_COLOR  = SHARED_ORDER_STATUS_COLOR;

const CONDITIONS_LABEL: Record<string, string> = {
  comptant: 'Comptant',
  '30j':    '30 jours',
  '60j':    '60 jours',
};

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: '2-digit' });
}
function shortId(orderId: string) {
  return orderId.slice(0, 8).toUpperCase();
}

const livraisonAddr = [client.livraison_rue, client.livraison_code_postal, client.livraison_ville]
  .filter(Boolean).join(', ') || '—';
const facturationAddr = client.facturation_same
  ? 'Identique à la livraison'
  : ([client.facturation_rue, client.facturation_code_postal, client.facturation_ville].filter(Boolean).join(', ') || '—');

const { data: deliveryNotes } = await supabaseAdmin
  .from('delivery_notes')
  .select('id, delivery_id, pdv_name, created_at')
  .eq('client_id', id)
  .order('created_at', { ascending: false });

// Resolve auth user and current role
let authUserId: string | null = (client as any).user_id ?? null;
let authRole: string | null = null;
if (client.email) {
  if (authUserId) {
    const { data: found } = await supabaseAdmin.auth.admin.getUserById(authUserId);
    authRole = (found?.user as any)?.user_metadata?.role ?? null;
  } else {
    const { data: users } = await supabaseAdmin.auth.admin.listUsers({ page: 1, perPage: 1000 });
    const found = users?.users?.find((u: any) => u.email === client.email);
    authUserId = found?.id ?? null;
    authRole = (found as any)?.user_metadata?.role ?? null;
  }
}
const hasAuthAccount = !!authUserId;
const isAdminRole = hasAuthAccount && authRole !== 'client';

const roleError = Astro.url.searchParams.get('role_error');
---
<AdminLayout title={`Client — ${client.nom}`} activeNav="clients">
  <a href="/admin/clients" class="back-link">← Retour aux clients</a>

  <div class="client-header">
    <div>
      <h1 class="client-h1">{client.nom}</h1>
      {client.societe && <p class="client-sub">{client.societe}</p>}
    </div>
    <a href={`/admin/commande-rapide?client_id=${client.id}`} class="btn btn-primary">Créer une commande</a>
  </div>

  <div class="addr-summary">
    <div class="addr-block addr-block--fact">
      <p class="addr-label">Adresse de facturation</p>
      <p class="addr-value">{facturationAddr}</p>
    </div>
    <div class="addr-block addr-block--livr">
      <p class="addr-label">
        <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true" class="addr-icon">
          <path d="M7 1C4.79 1 3 2.79 3 5c0 3.25 4 8 4 8s4-4.75 4-8c0-2.21-1.79-4-4-4Zm0 5.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z" fill="currentColor"/>
        </svg>
        Lieu de livraison
      </p>
      {client.points_de_vente && <p class="addr-pdv-name">{client.points_de_vente}</p>}
      <p class="addr-value">{livraisonAddr !== '—' ? livraisonAddr : (client.adresse_pdv ?? '—')}</p>
    </div>
  </div>

  {formError && <p class="form-error" role="alert">{formError}</p>}

  <div class="grid-2col">
    <div class="card">
      <h2 class="card-title">Informations</h2>
      <dl class="info-list">
        <div class="info-row"><dt>Société</dt><dd>{client.societe ?? '—'}</dd></div>
        <div class="info-row"><dt>Email</dt><dd>{client.email ?? '—'}</dd></div>
        <div class="info-row"><dt>Téléphone</dt><dd>{client.telephone ?? '—'}</dd></div>
        <div class="info-row"><dt>Statut</dt><dd><span class={`status-badge status-badge--${client.status}`}>{CLIENT_STATUS_LABEL[client.status] ?? client.status}</span></dd></div>
        <div class="info-row"><dt>Inscription</dt><dd>{formatDate(client.created_at)}</dd></div>
      </dl>
    </div>

    <div class="card">
      <h2 class="card-title">Activité</h2>
      <dl class="info-list">
        <div class="info-row"><dt>Compte créé le</dt><dd>{formatDate(client.created_at)}</dd></div>
        <div class="info-row"><dt>Dernière commande</dt><dd>{lastOrderDate ? formatDate(lastOrderDate) : '—'}</dd></div>
        <div class="info-row"><dt>Nombre de commandes</dt><dd>{clientOrders.length}</dd></div>
        <div class="info-row"><dt>CA total généré</dt><dd class="ca-total">{totalCA.toFixed(2).replace('.', ',')} € HT</dd></div>
      </dl>
    </div>
  </div>

  <div class="card role-card">
    <div class="role-card-inner">
      <div>
        <p class="role-label">Accès plateforme</p>
        {!hasAuthAccount ? (
          <p class="role-value role-value--none">Pas de compte connecté</p>
        ) : isAdminRole ? (
          <p class="role-value role-value--admin">Admin</p>
        ) : (
          <p class="role-value role-value--client">Client</p>
        )}
        {roleError === 'no_auth_user' && <p class="role-error">Aucun compte Supabase trouvé pour cet email.</p>}
        {roleError === 'update_failed' && <p class="role-error">Erreur lors de la mise à jour du rôle.</p>}
      </div>
      {hasAuthAccount && (
        <form method="post" action={`/api/admin/clients/${id}/set-admin`}>
          <input type="hidden" name="action" value={isAdminRole ? 'demote' : 'promote'} />
          <button type="submit" class={`btn-role ${isAdminRole ? 'btn-role--demote' : 'btn-role--promote'}`}>
            {isAdminRole ? 'Rétrograder en client' : 'Promouvoir en admin'}
          </button>
        </form>
      )}
    </div>
  </div>

  <div class="card">
    <h2 class="card-title">Modifier le client</h2>
    <form method="post" class="edit-form" novalidate>
      <input type="hidden" name="action" value="update_client" />

      <h3 class="subsection-title">Identité</h3>
      <div class="field-group">
        <div class="field">
          <label for="nom">Nom <span class="required">*</span></label>
          <input type="text" id="nom" name="nom" required value={client.nom ?? ''} />
        </div>
        <div class="field">
          <label for="societe">Société</label>
          <input type="text" id="societe" name="societe" value={client.societe ?? ''} />
        </div>
      </div>
      <div class="field-group">
        <div class="field">
          <label for="email">Email <span class="required">*</span></label>
          <input type="email" id="email" name="email" required value={client.email ?? ''} />
        </div>
        <div class="field">
          <label for="telephone">Téléphone</label>
          <input type="text" id="telephone" name="telephone" value={client.telephone ?? ''} />
        </div>
      </div>

      <h3 class="subsection-title">Point de vente</h3>
      <div class="field-group">
        <div class="field">
          <label for="points_de_vente">Nom du point de vente</label>
          <input type="text" id="points_de_vente" name="points_de_vente" value={client.points_de_vente ?? ''} />
        </div>
        <div class="field">
          <label for="adresse_pdv">Adresse PDV</label>
          <input type="text" id="adresse_pdv" name="adresse_pdv" value={client.adresse_pdv ?? ''} />
        </div>
      </div>

      <h3 class="subsection-title">Adresse de livraison</h3>
      <div class="field-group field-group--3">
        <div class="field">
          <label for="livraison_rue">Rue</label>
          <input type="text" id="livraison_rue" name="livraison_rue" value={client.livraison_rue ?? ''} />
        </div>
        <div class="field">
          <label for="livraison_code_postal">Code postal</label>
          <input type="text" id="livraison_code_postal" name="livraison_code_postal" value={client.livraison_code_postal ?? ''} />
        </div>
        <div class="field">
          <label for="livraison_ville">Ville</label>
          <input type="text" id="livraison_ville" name="livraison_ville" value={client.livraison_ville ?? ''} />
        </div>
      </div>

      <h3 class="subsection-title">Adresse de facturation</h3>
      <div class="field">
        <label class="checkbox-inline">
          <input type="checkbox" id="facturation_same" name="facturation_same" value="1" checked={!!client.facturation_same} />
          Identique à l'adresse de livraison
        </label>
      </div>
      <div id="facturationAddr" class="field-group field-group--3">
        <div class="field">
          <label for="facturation_rue">Rue</label>
          <input type="text" id="facturation_rue" name="facturation_rue" value={client.facturation_rue ?? ''} />
        </div>
        <div class="field">
          <label for="facturation_code_postal">Code postal</label>
          <input type="text" id="facturation_code_postal" name="facturation_code_postal" value={client.facturation_code_postal ?? ''} />
        </div>
        <div class="field">
          <label for="facturation_ville">Ville</label>
          <input type="text" id="facturation_ville" name="facturation_ville" value={client.facturation_ville ?? ''} />
        </div>
      </div>

      <div class="field">
        <label for="status">Statut</label>
        <select id="status" name="status">
          <option value="en_attente" selected={client.status === 'en_attente'}>En attente</option>
          <option value="actif"      selected={client.status === 'actif'}>Actif</option>
          <option value="suspendu"   selected={client.status === 'suspendu'}>Suspendu</option>
        </select>
      </div>

      <div class="field">
        <label for="notes">Notes internes</label>
        <textarea id="notes" name="notes" rows="3" placeholder="Notes visibles uniquement par l'équipe…">{client.notes ?? ''}</textarea>
      </div>

      <h3 class="subsection-title">Conditions commerciales</h3>
      <div class="field-group field-group--3">
        <div class="field">
          <label for="remise">Remise (%)</label>
          <input type="number" id="remise" name="remise" step="0.5" min="0" max="100" value={client.remise ?? ''} placeholder="0" />
        </div>
        <div class="field">
          <label for="conditions_paiement">Conditions de paiement</label>
          <select id="conditions_paiement" name="conditions_paiement">
            <option value=""         selected={!client.conditions_paiement}>—</option>
            <option value="comptant" selected={client.conditions_paiement === 'comptant'}>Comptant</option>
            <option value="30j"      selected={client.conditions_paiement === '30j'}>30 jours</option>
            <option value="60j"      selected={client.conditions_paiement === '60j'}>60 jours</option>
          </select>
        </div>
        <div class="field">
          <label for="plafond_credit">Plafond crédit (€)</label>
          <input type="number" id="plafond_credit" name="plafond_credit" step="0.01" min="0" value={client.plafond_credit ?? ''} placeholder="0.00" />
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="/admin/clients" class="btn btn-ghost">Annuler</a>
      </div>
    </form>
  </div>

  <div class="card">
    <h2 class="card-title">Historique des commandes</h2>
    {ordersWithTotal.length === 0 ? (
      <p class="empty-orders">Aucune commande pour ce client.</p>
    ) : (
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Référence</th>
              <th class="th-r">Total HT</th>
              <th>Statut</th>
            </tr>
          </thead>
          <tbody>
            {ordersWithTotal.map(o => (
              <tr>
                <td class="td-muted">{formatDate(o.created_at)}</td>
                <td class="td-mono">#{shortId(o.id)}</td>
                <td class="td-r">{o.total != null ? o.total.toFixed(2).replace('.', ',') + ' €' : '—'}</td>
                <td><span class={`badge badge--${ORDER_STATUS_COLOR[o.status] ?? 'muted'}`}>{ORDER_STATUS_LABEL[o.status] ?? o.status}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <div class="card">
    <h2 class="card-title">Bons de livraison</h2>
    {!deliveryNotes?.length ? (
      <p class="empty-orders">Aucun bon de livraison pour ce client.</p>
    ) : (
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Livraison</th>
              <th>Point de vente</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {(deliveryNotes ?? []).map(note => (
              <tr>
                <td class="td-muted">{formatDate(note.created_at)}</td>
                <td class="td-mono">{note.delivery_id}</td>
                <td>{note.pdv_name}</td>
                <td class="td-r">
                  <a
                    href={`/api/delivery-notes/${note.id}/download`}
                    class="btn-dl"
                    aria-label={`Télécharger ${note.delivery_id}`}
                  >
                    <svg width="13" height="13" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <path d="M7 1v8M4 6l3 3 3-3M2 10v1a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    PDF
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AdminLayout>

<style>
.back-link {
  display: inline-flex;
  align-items: center;
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-muted);
  text-decoration: none;
  margin-bottom: var(--space-4);
  transition: color var(--dur-fast);
}
.back-link:hover { color: var(--color-ink); }

.client-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-4);
  margin-bottom: var(--space-6);
  flex-wrap: wrap;
}
.client-h1 {
  font-family: var(--font-display);
  font-size: 1.75rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-ink);
  margin: 0;
}
.client-sub {
  font-size: var(--text-sm);
  color: var(--color-muted);
  margin: var(--space-1) 0 0;
}

.addr-summary {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
  margin-bottom: var(--space-6);
}

.addr-block {
  border-radius: var(--radius-md);
  padding: var(--space-4) var(--space-5);
}

.addr-block--fact {
  background: var(--color-surface, oklch(0.97 0 0));
  border: 1px solid var(--color-border);
}

.addr-block--livr {
  background: oklch(0.96 0.04 45.9);
  border: 1.5px solid oklch(0.88 0.09 45.9);
}

.addr-label {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-muted);
  margin: 0 0 var(--space-2);
}

.addr-block--livr .addr-label {
  color: oklch(0.45 0.12 45.9);
}

.addr-icon {
  color: oklch(0.568 0.149 45.9);
  flex-shrink: 0;
}

.addr-pdv-name {
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-ink);
  margin: 0 0 var(--space-1);
}

.addr-value {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
  margin: 0;
  line-height: 1.5;
}

.grid-2col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
  margin-bottom: var(--space-4);
}

.card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-6);
  margin-bottom: var(--space-4);
}

.card-title {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-ink);
  margin: 0 0 var(--space-4);
}

.info-list { display: flex; flex-direction: column; gap: var(--space-3); margin: 0; }
.info-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: var(--space-4);
  padding-bottom: var(--space-3);
  border-bottom: 1px solid var(--color-border);
}
.info-row:last-child { padding-bottom: 0; border-bottom: none; }
.info-row dt { font-size: var(--text-xs); color: var(--color-muted); white-space: nowrap; }
.info-row dd { font-size: var(--text-sm); font-weight: 500; color: var(--color-ink); text-align: right; margin: 0; }
.ca-total { color: var(--color-primary-deep); font-weight: 700; }

.status-badge {
  display: inline-block;
  padding: 3px 8px;
