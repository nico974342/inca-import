<script>
  const sameCheck = document.getElementById('facturation_same') as HTMLInputElement | null;
  const factAddrDiv = document.getElementById('facturationAddr') as HTMLElement | null;
  if (sameCheck && factAddrDiv) {
    function toggleFactAddr() {
      factAddrDiv!.hidden = sameCheck!.checked;
    }
    sameCheck.addEventListener('change', toggleFactAddr);
    toggleFactAddr();
  }
</script>
