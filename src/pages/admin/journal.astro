---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';
import { ORDER_STATUS_LABEL, CLIENT_STATUS_LABEL, PROSPECT_STATUS_LABEL } from '../../lib/constants';

const PAGE_SIZE = 50;
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1', 10));
const filterAction = Astro.url.searchParams.get('action') ?? '';

let query = supabaseAdmin
  .from('admin_audit_logs')
  .select('*', { count: 'exact' })
  .order('created_at', { ascending: false })
  .range((page - 1) * PAGE_SIZE, page * PAGE_SIZE - 1);

if (filterAction) query = query.eq('action', filterAction);

const { data: logs, count } = await query;

const totalPages = Math.ceil((count ?? 0) / PAGE_SIZE);

const ACTION_LABELS: Record<string, string> = {
  'commande.suppression':      'Commande supprimée',
  'commande.statut':           'Statut commande',
  'commande.creation_admin':   'Commande créée (admin)',
  'client.suppression':     'Client supprimé',
  'client.activation':      'Client activé',
  'client.statut':          'Statut client',
  'client.creation':        'Client créé',
  'client.conversion':      'Contact converti',
  'client.promotion_admin': 'Promu Admin',
  'client.retrogradation':  'Rétrogradé Client',
  'client.modification':    'Client modifié',
  'produit.modification':   'Produit modifié',
  'produit.creation':       'Produit créé',
  'produit.suppression':    'Produit supprimé',
  'reception.creation':     'Réception stock',
  'reception.modification': 'Réception modifiée',
  'reception.suppression':  'Réception supprimée',
  'prospect.creation':      'Prospect ajouté',
  'prospect.contact':       'Prospect contacté',
  'prospect.statut':        'Statut prospect',
  'prospect.conversion':    'Prospect converti en client',
  'prospect.suppression':   'Prospect supprimé',
};

const ACTION_COLOR: Record<string, string> = {
  'commande.suppression':      'red',
  'commande.statut':           'blue',
  'commande.creation_admin':   'green',
  'client.suppression':     'red',
  'client.activation':      'green',
  'client.statut':          'amber',
  'client.creation':        'green',
  'client.conversion':      'green',
  'client.promotion_admin': 'purple',
  'client.retrogradation':  'amber',
  'client.modification':    'blue',
  'produit.modification':   'blue',
  'produit.creation':       'green',
  'produit.suppression':    'red',
  'reception.creation':     'green',
  'reception.modification': 'blue',
  'reception.suppression':  'red',
  'prospect.creation':      'green',
  'prospect.contact':       'blue',
  'prospect.statut':        'amber',
  'prospect.conversion':    'green',
  'prospect.suppression':   'red',
};

function formatDateTime(iso: string) {
  return new Date(iso).toLocaleString('fr-FR', {
    day:    '2-digit',
    month:  '2-digit',
    year:   'numeric',
    hour:   '2-digit',
    minute: '2-digit',
    second: '2-digit',
  });
}

function formatDetails(details: Record<string, unknown> | null, action: string): string {
  if (!details) return '';
  if (action === 'commande.statut' || action === 'client.statut' || action === 'prospect.statut') {
    const STATUS_FR: Record<string, string> = {
      ...ORDER_STATUS_LABEL,
      ...CLIENT_STATUS_LABEL,
      ...PROSPECT_STATUS_LABEL,
      client: 'Client',
      admin:  'Admin',
    };
    const a = STATUS_FR[details.ancien as string] ?? details.ancien;
    const n = STATUS_FR[details.nouveau as string] ?? details.nouveau;
    return `${a} → ${n}`;
  }
  if (action === 'client.promotion_admin' || action === 'client.retrogradation') {
    return `Rôle : ${details.nouveau_role ?? ''}`;
  }
  if (action === 'commande.suppression' || action === 'client.suppression') {
    const parts: string[] = [];
    if (details.orders_deleted != null) parts.push(`${details.orders_deleted} commande(s) supprimée(s)`);
    if (details.stock_restaure) parts.push('stock restauré');
    if (typeof details.ca_ht_supprime === 'number' && details.ca_ht_supprime !== 0) {
      parts.push(`CA HT retiré : ${details.ca_ht_supprime.toFixed(2).replace('.', ',')} €`);
    }
    if (typeof details.marge_ht_supprimee === 'number') {
      parts.push(`marge retirée : ${details.marge_ht_supprimee.toFixed(2).replace('.', ',')} €`);
    }
    if (parts.length) return parts.join(' · ');
  }
  if (details.email) return `${details.email}`;
  return '';
}

const ALL_ACTIONS = Object.keys(ACTION_LABELS);
---
<AdminLayout title="Journal d'activité" activeNav="journal">

  <div class="journal-toolbar">
    <form method="get" class="filter-form">
      <label for="action-filter" class="filter-label">Filtrer par action</label>
      <select id="action-filter" name="action" class="filter-select" onchange="this.form.submit()">
        <option value="">Toutes les actions</option>
        {ALL_ACTIONS.map(a => (
          <option value={a} selected={filterAction === a}>{ACTION_LABELS[a]}</option>
        ))}
      </select>
      {filterAction && (
        <a href="/admin/journal" class="filter-reset">Réinitialiser</a>
      )}
    </form>
    <span class="journal-count">{count ?? 0} entrée{(count ?? 0) !== 1 ? 's' : ''}</span>
  </div>

  {(logs ?? []).length === 0 ? (
    <div class="journal-empty">
      <p>Aucune activité enregistrée pour le moment.</p>
      <p class="journal-empty-hint">Les actions des admins apparaîtront ici dès qu'elles seront effectuées.</p>
    </div>
  ) : (
    <div class="journal-table-wrap">
      <table class="journal-table">
        <thead>
          <tr>
            <th class="col-date">Date / heure</th>
            <th class="col-admin">Admin</th>
            <th class="col-action">Action</th>
            <th class="col-cible">Cible</th>
            <th class="col-details">Détails</th>
          </tr>
        </thead>
        <tbody>
          {(logs ?? []).map(log => (
            <tr class="journal-row">
              <td class="col-date">
                <span class="log-datetime">{formatDateTime(log.created_at)}</span>
              </td>
              <td class="col-admin">
                <span class="log-email">{log.admin_email}</span>
              </td>
              <td class="col-action">
                <span class={`log-badge log-badge--${ACTION_COLOR[log.action] ?? 'muted'}`}>
                  {ACTION_LABELS[log.action] ?? log.action}
                </span>
              </td>
              <td class="col-cible">
                {log.target_label && (
                  <span class="log-target">{log.target_label}</span>
                )}
              </td>
              <td class="col-details">
                <span class="log-details">{formatDetails(log.details as any, log.action)}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {totalPages > 1 && (
    <nav class="pagination" aria-label="Pagination">
      {page > 1 && (
        <a href={`/admin/journal?page=${page - 1}${filterAction ? `&action=${filterAction}` : ''}`} class="page-btn">← Précédent</a>
      )}
      <span class="page-info">Page {page} / {totalPages}</span>
      {page < totalPages && (
        <a href={`/admin/journal?page=${page + 1}${filterAction ? `&action=${filterAction}` : ''}`} class="page-btn">Suivant →</a>
      )}
    </nav>
  )}

</AdminLayout>

<style>
.journal-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  margin-bottom: var(--space-5);
  flex-wrap: wrap;
}

.filter-form {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex-wrap: wrap;
}

.filter-label {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-muted);
  white-space: nowrap;
}

.filter-select {
  padding: 6px 10px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-bg);
  color: var(--color-ink);
  font-size: var(--text-sm);
  font-family: var(--font-body);
  cursor: pointer;
}
.filter-select:focus { outline: 2px solid var(--color-primary); outline-offset: 2px; }

.filter-reset {
  font-size: var(--text-xs);
  color: var(--color-muted);
  text-decoration: none;
  padding: 4px 8px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  transition: color var(--dur-fast), background var(--dur-fast);
}
.filter-reset:hover { color: var(--color-ink); background: var(--color-surface); }

.journal-count {
  font-size: var(--text-xs);
  color: var(--color-muted);
  white-space: nowrap;
}

.journal-empty {
  padding: var(--space-10) var(--space-6);
  text-align: center;
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
}
.journal-empty p { font-size: var(--text-sm); color: var(--color-muted); margin: 0 0 var(--space-2); }
.journal-empty-hint { font-size: var(--text-xs); }

.journal-table-wrap {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  overflow-x: auto;
}

.journal-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 640px;
}

.journal-table thead th {
  padding: var(--space-3) var(--space-4);
  text-align: left;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-muted);
  background: var(--color-surface);
  border-bottom: 1px solid var(--color-border);
  white-space: nowrap;
}

.journal-row td {
  padding: var(--space-3) var(--space-4);
  border-bottom: 1px solid var(--color-border);
  vertical-align: middle;
}
.journal-row:last-child td { border-bottom: none; }
.journal-row:hover td { background: var(--color-surface); }

.col-date    { width: 160px; }
.col-admin   { width: 200px; }
.col-action  { width: 160px; }
.col-cible   { width: 180px; }
.col-details { }

.log-datetime {
  font-size: var(--text-xs);
  font-variant-numeric: tabular-nums;
  color: var(--color-muted);
  white-space: nowrap;
}

.log-email {
  font-size: var(--text-xs);
  color: var(--color-ink);
  font-weight: 500;
  word-break: break-all;
}

.log-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 500;
  white-space: nowrap;
}
.log-badge--muted  { background: var(--color-surface-2);        color: var(--color-muted); }
.log-badge--blue   { background: oklch(0.93 0.05 220);          color: oklch(0.30 0.12 220); }
.log-badge--green  { background: oklch(0.92 0.07 150);          color: oklch(0.28 0.13 150); }
.log-badge--amber  { background: oklch(0.95 0.07 80);           color: oklch(0.38 0.14 80); }
.log-badge--red    { background: oklch(0.95 0.05 25);           color: oklch(0.44 0.18 25); }
.log-badge--purple { background: oklch(0.93 0.05 295);          color: oklch(0.35 0.12 295); }

.log-target {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
}

.log-details {
  font-size: var(--text-xs);
  color: var(--color-muted);
}

.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  margin-top: var(--space-5);
}

.page-btn {
  padding: 6px 14px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
  text-decoration: none;
  background: var(--color-bg);
  transition: border-color var(--dur-fast), background var(--dur-fast);
}
.page-btn:hover { border-color: var(--color-border-strong); background: var(--color-surface); }

.page-info {
  font-size: var(--text-sm);
  color: var(--color-muted);
}

@media (max-width: 600px) {
  .journal-toolbar { flex-direction: column; align-items: flex-start; }
}
</style>
