---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const successParam    = Astro.url.searchParams.get('success');
const success         = successParam === '1';
const successHisto    = successParam === 'historical';
const successUpdate   = successParam === 'updated';
const successDeleted  = successParam === 'deleted';

const { data: receptions } = await supabaseAdmin
  .from('stock_receptions')
  .select('id, supplier_name, received_at, created_at, notes, stock_applied, stock_reception_items(product_id, quantity, unit_cost_ht, products(name))')
  .order('received_at', { ascending: false })
  .limit(100);

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' });
}

function formatPrice(p: number) {
  return p.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', minimumFractionDigits: 2 });
}
---
<AdminLayout title="Réceptions fournisseurs" activeNav="reception">

  {success && (
    <div class="alert alert--success" role="alert">
      Réception enregistrée — stock et PUMP mis à jour.
    </div>
  )}
  {successHisto && (
    <div class="alert alert--histo" role="alert">
      Réception historique enregistrée — PUMP recalculé, stock <strong>non modifié</strong> (date antérieure à aujourd'hui).
    </div>
  )}
  {successUpdate && (
    <div class="alert alert--success" role="alert">
      Réception mise à jour — PUMP recalculé, stock ajusté si nécessaire.
    </div>
  )}
  {successDeleted && (
    <div class="alert alert--danger" role="alert">
      Réception supprimée — stock corrigé et PUMP recalculé.
    </div>
  )}

  <div class="toolbar">
    <a href="/admin/reception/new" class="btn btn-primary">+ Nouvelle réception</a>
  </div>

  {(receptions ?? []).length === 0 ? (
    <div class="empty-state">
      <p class="empty-title">Aucune réception enregistrée.</p>
      <p class="empty-body">Enregistrez votre première livraison fournisseur pour commencer le suivi PUMP.</p>
      <a href="/admin/reception/new" class="btn btn-primary" style="margin-top: var(--space-5)">+ Nouvelle réception</a>
    </div>
  ) : (
    <div class="reception-list">
      {(receptions ?? []).map(r => {
        const items     = (r as any).stock_reception_items ?? [];
        const totalQty  = items.reduce((s: number, i: any) => s + i.quantity, 0);
        const totalCost = items.reduce((s: number, i: any) => s + (i.quantity * i.unit_cost_ht), 0);
        const isHisto   = !(r as any).stock_applied;
        return (
          <div class={`reception-card ${isHisto ? 'reception-card--histo' : ''}`}>
            <div class="rec-header">
              <div class="rec-meta">
                <span class="rec-supplier">{r.supplier_name}</span>
                <span class="rec-date">{formatDate(r.received_at)}</span>
                {isHisto ? (
                  <span class="rec-badge rec-badge--histo">Historique</span>
                ) : (
                  <span class="rec-badge rec-badge--live">Stock appliqué</span>
                )}
              </div>
              <div class="rec-actions">
                <div class="rec-stats">
                  <span class="rec-stat">{items.length} produit{items.length > 1 ? 's' : ''}</span>
                  <span class="rec-stat">{totalQty} unité{totalQty > 1 ? 's' : ''}</span>
                  <span class="rec-stat rec-stat--cost">{formatPrice(totalCost)} HT</span>
                </div>
                <a href={`/admin/reception/${r.id}/edit`} class="edit-btn">Modifier</a>
                <button
                  type="button"
                  class="delete-btn"
                  data-id={r.id}
                  data-supplier={r.supplier_name}
                  data-date={formatDate(r.received_at)}
                  data-stock={String((r as any).stock_applied)}
                >Supprimer</button>
              </div>
            </div>
            {r.notes && <p class="rec-notes">{r.notes}</p>}
            <table class="rec-items">
              <thead>
                <tr>
                  <th>Produit</th>
                  <th class="th-num">Qté</th>
                  <th class="th-num">Coût unitaire HT</th>
                  <th class="th-num">Total HT</th>
                </tr>
              </thead>
              <tbody>
                {items.map((it: any) => (
                  <tr>
                    <td>{it.products?.name ?? it.product_id}</td>
                    <td class="td-num">{it.quantity}</td>
                    <td class="td-num">{formatPrice(it.unit_cost_ht)}</td>
                    <td class="td-num">{formatPrice(it.quantity * it.unit_cost_ht)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        );
      })}
    </div>
  )}

  <!-- Delete confirm dialog -->
  <dialog id="deleteDialog" class="del-dialog">
    <div class="del-body">
      <p class="del-title">Supprimer cette réception ?</p>
      <p class="del-desc" id="deleteDesc"></p>
      <p class="del-warn" id="deleteWarn"></p>
      <div class="del-footer">
        <button type="button" class="del-cancel" id="deleteCancelBtn">Annuler</button>
        <form id="deleteForm" method="post">
          <button type="submit" class="del-confirm">Supprimer définitivement</button>
        </form>
      </div>
    </div>
  </dialog>

</AdminLayout>

<script>
  const dialog    = document.getElementById('deleteDialog') as HTMLDialogElement;
  const desc      = document.getElementById('deleteDesc')!;
  const warn      = document.getElementById('deleteWarn')!;
  const form      = document.getElementById('deleteForm') as HTMLFormElement;
  const cancelBtn = document.getElementById('deleteCancelBtn')!;

  document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id       = btn.dataset.id!;
      const supplier = btn.dataset.supplier!;
      const date     = btn.dataset.date!;
      const stock    = btn.dataset.stock === 'true';
      desc.textContent = `${supplier} — ${date}`;
      warn.textContent = stock
        ? 'Cette réception a été appliquée au stock. La suppression corrigera les quantités et recalculera le PUMP.'
        : 'Réception historique — seul le PUMP sera recalculé (le stock n\'avait pas été modifié).';
      form.action = `/api/admin/reception/${id}/delete`;
      dialog.showModal();
    });
  });

  cancelBtn.addEventListener('click', () => dialog.close());
  dialog.addEventListener('click', e => { if (e.target === dialog) dialog.close(); });
</script>

<style>
.alert {
  margin-bottom: var(--space-5);
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-md);
  font-size: var(--text-sm);
  font-weight: 500;
}
.alert--success {
  background: oklch(0.92 0.08 150);
  border: 1px solid oklch(0.80 0.12 150);
  color: oklch(0.28 0.12 150);
}
.alert--histo {
  background: oklch(0.95 0.06 75);
  border: 1px solid oklch(0.85 0.10 75);
  color: oklch(0.36 0.12 75);
}
.alert--danger {
  background: oklch(0.96 0.04 25);
  border: 1px solid oklch(0.84 0.08 25);
  color: oklch(0.40 0.16 25);
}

.toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: var(--space-5);
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-5);
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
  font-weight: 600;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: background var(--dur-fast);
}
.btn-primary { background: var(--color-primary); color: white; }
.btn-primary:hover { background: var(--color-primary-deep); }

.empty-state {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-16) var(--space-8);
  text-align: center;
}
.empty-title { font-weight: 600; color: var(--color-ink); margin-bottom: var(--space-2); }
.empty-body  { color: var(--color-muted); font-size: var(--text-sm); }

.reception-list { display: flex; flex-direction: column; gap: var(--space-4); }

.reception-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.reception-card--histo {
  border-color: oklch(0.88 0.06 75);
  background: oklch(0.99 0.01 75);
}

.rec-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-5);
  border-bottom: 1px solid var(--color-border);
  gap: var(--space-4);
  flex-wrap: wrap;
}

.rec-meta {
  display: flex;
  align-items: baseline;
  gap: var(--space-3);
  flex-wrap: wrap;
}

.rec-supplier { font-size: var(--text-sm); font-weight: 600; color: var(--color-ink); }
.rec-date     { font-size: var(--text-xs); color: var(--color-muted); }

.rec-badge {
  font-size: var(--text-xs);
  font-weight: 600;
  padding: 2px 8px;
  border-radius: var(--radius-full);
}
.rec-badge--live  { background: oklch(0.92 0.08 145); color: oklch(0.32 0.14 145); }
.rec-badge--histo { background: oklch(0.95 0.06 75);  color: oklch(0.36 0.12 75);  }

.rec-actions {
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.rec-stats {
  display: flex;
  gap: var(--space-3);
  align-items: center;
}

.rec-stat {
  font-size: var(--text-xs);
  color: var(--color-muted);
  padding: 2px 8px;
  background: var(--color-surface);
  border-radius: var(--radius-full);
}
.rec-stat--cost {
  color: var(--color-primary-deep);
  background: oklch(0.568 0.149 45.9 / 0.08);
  font-weight: 600;
}

.edit-btn {
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-primary-deep);
  text-decoration: none;
  padding: 4px 10px;
  border: 1px solid oklch(0.568 0.149 45.9 / 0.3);
  border-radius: var(--radius-sm);
  background: oklch(0.568 0.149 45.9 / 0.06);
  white-space: nowrap;
  transition: background var(--dur-fast), border-color var(--dur-fast);
}
.edit-btn:hover {
  background: oklch(0.568 0.149 45.9 / 0.12);
  border-color: oklch(0.568 0.149 45.9 / 0.5);
}

.rec-notes {
  padding: var(--space-2) var(--space-5);
  font-size: var(--text-xs);
  color: var(--color-muted);
  font-style: italic;
  border-bottom: 1px solid var(--color-border);
  margin: 0;
}

.rec-items { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }

.rec-items thead th {
  padding: var(--space-2) var(--space-5);
  text-align: left;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-muted);
  background: var(--color-surface);
  border-bottom: 1px solid var(--color-border);
}
.th-num { text-align: right; }

.rec-items tbody td {
  padding: var(--space-3) var(--space-5);
  border-bottom: 1px solid var(--color-border);
  color: var(--color-ink);
}
.rec-items tbody tr:last-child td { border-bottom: none; }
.rec-items tbody tr:hover td { background: var(--color-surface); }

.td-num { font-family: var(--font-mono); text-align: right; }

.delete-btn {
  font-size: var(--text-xs);
  font-weight: 600;
  color: oklch(0.46 0.18 25);
  padding: 4px 10px;
  border: 1px solid oklch(0.84 0.08 25);
  border-radius: var(--radius-sm);
  background: oklch(0.97 0.03 25);
  white-space: nowrap;
  cursor: pointer;
  transition: background var(--dur-fast), border-color var(--dur-fast);
}
.delete-btn:hover {
  background: oklch(0.93 0.06 25);
  border-color: oklch(0.75 0.12 25);
}

/* Delete dialog */
.del-dialog {
  border: none;
  border-radius: var(--radius-md);
  padding: 0;
  box-shadow: 0 8px 32px oklch(0 0 0 / 0.18);
  max-width: 420px;
  width: calc(100vw - 2rem);
}
.del-dialog::backdrop { background: oklch(0 0 0 / 0.4); }

.del-body {
  padding: var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.del-title {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-ink);
  margin: 0;
}

.del-desc {
  font-size: var(--text-sm);
  color: var(--color-muted);
  margin: 0;
}

.del-warn {
  font-size: var(--text-xs);
  color: oklch(0.40 0.15 25);
  background: oklch(0.97 0.03 25);
  border: 1px solid oklch(0.88 0.07 25);
  border-radius: var(--radius-sm);
  padding: var(--space-3) var(--space-4);
  margin: 0;
}

.del-footer {
  display: flex;
  justify-content: flex-end;
  gap: var(--space-3);
  margin-top: var(--space-2);
}

.del-cancel {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-muted);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: var(--space-2) var(--space-5);
  cursor: pointer;
  transition: background var(--dur-fast);
}
.del-cancel:hover { background: var(--color-surface-2); }

.del-confirm {
  font-size: var(--text-sm);
  font-weight: 600;
  color: white;
  background: oklch(0.46 0.18 25);
  border: none;
  border-radius: var(--radius-sm);
  padding: var(--space-2) var(--space-5);
  cursor: pointer;
  transition: background var(--dur-fast);
}
.del-confirm:hover { background: oklch(0.38 0.20 25); }
</style>
