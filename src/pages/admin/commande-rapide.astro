---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';
import { Resend } from 'resend';
import { generateOrderPDF } from '../../lib/pdf';
import { sanitizeText } from '../../lib/sanitize';
import { normalizeEmail, applyRemise } from '../../lib/clients';
import { COMPANY, RESEND_DEFAULT_FROM } from '../../lib/constants';
import { logAdminAction } from '../../lib/audit';

const adminUser = Astro.locals.user;

// ── POST: create order ─────────────────────────────────────────
if (Astro.request.method === 'POST') {
  const form         = await Astro.request.formData();
  const clientIdRaw  = form.get('client_id') as string;
  const notes        = sanitizeText(form.get('notes') as string, 1000);

  const [clientKind, clientId] = (clientIdRaw ?? '').split(':');

  let client: { nom: string; societe: string | null; email: string | null; telephone: string | null; points_de_vente?: string | null; remise?: number | null } | null = null;

  if (clientKind === 'contact') {
    const { data } = await supabaseAdmin
      .from('contact_requests')
      .select('nom, societe, email, telephone')
      .eq('id', clientId)
      .single();
    client = data;
  } else if (clientKind === 'client') {
    const { data } = await supabaseAdmin
      .from('client_accounts')
      .select('nom, societe, email, telephone, points_de_vente, remise')
      .eq('id', clientId)
      .single();
    client = data;
  }

  if (!client) return Astro.redirect('/admin/commande-rapide?error=client');
  const remisePct = client.remise ?? null;

  // Build product map for price lookup
  const { data: allProducts } = await supabaseAdmin
    .from('products')
    .select('id, name, unit, price_ht, tva_rate, prix_achat_moyen_ht, stock_quantity');
  const productMap: Record<string, { name: string; unit: string | null; price_ht: number | null; tva_rate: number | null; prix_achat_moyen_ht: number | null; stock_quantity: number | null }> = {};
  for (const p of allProducts ?? []) productMap[p.id] = p;

  // Parse qty_<id> fields
  const orderItems: Array<{
    product_id: string; product_name: string;
    quantity: number; unit: string | null; price_ht: number | null;
    tva_rate: number | null; pump: number | null;
  }> = [];

  for (const [key, val] of form.entries()) {
    if (!key.startsWith('qty_')) continue;
    const productId = key.slice(4);
    const qty       = parseInt(val as string, 10);
    if (qty > 0 && productMap[productId]) {
      const p = productMap[productId];
      orderItems.push({
        product_id: productId, product_name: p.name, quantity: qty, unit: p.unit,
        // price includes the client's negotiated remise; PUMP stays the
        // real cost so margin math on this order is unaffected by it
        price_ht: applyRemise(p.price_ht, remisePct), tva_rate: p.tva_rate, pump: p.prix_achat_moyen_ht,
      });
    }
  }

  if (orderItems.length === 0) return Astro.redirect('/admin/commande-rapide?error=empty');

  // Same stock guard as client checkout — block if any line exceeds stock
  const stockViolations = orderItems.filter(item => {
    const stock = productMap[item.product_id]?.stock_quantity;
    return typeof stock === 'number' && item.quantity > stock;
  });
  if (stockViolations.length > 0) return Astro.redirect('/admin/commande-rapide?error=stock');

  // Create order
  const { data: order, error: orderErr } = await supabaseAdmin
    .from('orders')
    .insert({
      user_id:   null,
      nom:       client.nom,
      societe:   client.societe ?? '',
      telephone: client.telephone ?? '',
      email:     client.email ? normalizeEmail(client.email) : null,
      notes,
      status:    'en_attente',
    })
    .select('id')
    .single();

  if (orderErr || !order) {
    console.error('[commande-rapide] order insert error:', JSON.stringify(orderErr));
    return Astro.redirect('/admin/commande-rapide?error=order');
  }

  const { error: itemsErr } = await supabaseAdmin.from('order_items').insert(
    orderItems.map(item => ({
      order_id:          order.id,
      product_id:        item.product_id,
      product_name:      item.product_name,
      quantity:          item.quantity,
      unit:              item.unit,
      price_ht_snapshot: item.price_ht,
      tva_rate_snapshot: item.tva_rate,
      pump_snapshot:     item.pump,
    }))
  );
  if (itemsErr) {
    console.error('[commande-rapide] order_items insert error:', JSON.stringify(itemsErr));
    await supabaseAdmin.from('orders').delete().eq('id', order.id);
    return Astro.redirect('/admin/commande-rapide?error=order');
  }

  const totalHT = orderItems.reduce((s, i) => s + i.quantity * Number(i.price_ht ?? 0), 0);
  const today   = new Date().toLocaleDateString('fr-FR');

  // Generate PDF
  let pdfBuffer: Buffer | null = null;
  try {
    pdfBuffer = await generateOrderPDF({
      id: order.id, nom: client.nom, societe: client.societe,
      email: client.email, telephone: client.telephone,
      points_de_vente: client.points_de_vente ?? null,
      notes, items: orderItems, totalHT, date: today,
    });
  } catch (err) { console.error('[PDF] Error:', err); }

  const lignes = orderItems.map(item => {
    const lineHT = (item.quantity * Number(item.price_ht ?? 0)).toFixed(2).replace('.', ',');
    const unit   = item.unit ? ` (${item.unit})` : '';
    return `• ${item.product_name} × ${item.quantity}${unit} — ${lineHT} € HT`;
  }).join('\n');

  const emailBody = [
    '=== Commande Inca Import ===',
    '',
    `Client    : ${client.nom}`,
    `Société   : ${client.societe || '—'}`,
    `Email     : ${client.email}`,
    `Téléphone : ${client.telephone || '—'}`,
    '',
    'Articles :',
    lignes,
    '',
    `Total HT  : ${totalHT.toFixed(2).replace('.', ',')} €`,
    ...(notes ? ['', `Notes : ${notes}`] : []),
    '',
    `Réf. : ${order.id}`,
  ].join('\n');

  const attachments = pdfBuffer
    ? [{ filename: `commande_${order.id.slice(0, 8)}.pdf`, content: pdfBuffer }]
    : [];

  const resend = new Resend(import.meta.env.RESEND_API_KEY);
  const from = (import.meta.env.RESEND_FROM as string | undefined) ?? RESEND_DEFAULT_FROM;

  if (client.email) {
    const { error: e1 } = await resend.emails.send({
      from,
      to:   client.email,
      subject: `Votre commande Inca Import`,
      text: emailBody,
      attachments,
    });
    if (e1) console.error('[Resend] client email error:', JSON.stringify(e1));
  }

  const { error: e2 } = await resend.emails.send({
    from,
    to:   COMPANY.contactEmail,
    subject: `Commande — ${client.nom}${client.societe ? ` (${client.societe})` : ''}`,
    text: emailBody,
    attachments,
  });
  if (e2) console.error('[Resend] admin email error:', JSON.stringify(e2));

  await logAdminAction({
    adminEmail: adminUser?.email ?? 'inconnu',
    action: 'commande.creation_admin',
    targetType: 'order',
    targetId: order.id,
    targetLabel: client.societe || client.nom,
    details: { total_ht: totalHT, products_count: orderItems.length },
  });

  return Astro.redirect('/admin/commande-rapide?success=1');
}

// ── GET ────────────────────────────────────────────────────────
const success   = Astro.url.searchParams.get('success') === '1';
const errorType = Astro.url.searchParams.get('error');

const { data: clientAccounts } = await supabaseAdmin
  .from('client_accounts')
  .select('id, nom, societe, email, points_de_vente, contact_request_id, remise')
  .eq('status', 'actif')
  .order('nom', { ascending: true });

const { data: convertedContacts } = await supabaseAdmin
  .from('contact_requests')
  .select('id, nom, societe, email')
  .eq('status', 'converti')
  .order('nom', { ascending: true });

const linkedContactIds = new Set((clientAccounts ?? []).map(c => c.contact_request_id).filter(Boolean));

const clients = [
  ...(clientAccounts ?? []).map(c => ({
    value: `client:${c.id}`, nom: c.nom, societe: c.societe ?? '', pdv: c.points_de_vente ?? '',
    remise: c.remise ?? null,
  })),
  ...(convertedContacts ?? [])
    .filter(ct => !linkedContactIds.has(ct.id))
    .map(ct => ({ value: `contact:${ct.id}`, nom: ct.nom, societe: ct.societe ?? '', pdv: '', remise: null })),
].sort((a, b) => a.nom.localeCompare(b.nom));

const { data: productsRaw } = await supabaseAdmin
  .from('products')
  .select('id, name, category, unit, price_ht, image_url, stock_quantity')
  .eq('in_stock', true)
  .order('category', { ascending: true })
  .order('name', { ascending: true });

const products = (productsRaw ?? []).map(p => ({
  id: p.id, name: p.name, category: p.category, unit: p.unit ?? '',
  price: Number(p.price_ht ?? 0), image: p.image_url ?? '',
  stock: p.stock_quantity ?? 0,
}));

const CAT_LABEL: Record<string, string> = {
  boissons: 'Boissons', snacks: 'Snacks', confiseries: 'Confiseries', divers: 'Divers',
};
const CATS = ['tous', ...Array.from(new Set(products.map(p => p.category)))];

const ERROR_MSG: Record<string, string> = {
  client: 'Client introuvable.',
  empty:  'Veuillez ajouter au moins un produit.',
  order:  'Erreur lors de la création de la commande.',
  stock:  'Certains articles dépassent le stock disponible. Ajustez les quantités.',
};

const preselectId    = Astro.url.searchParams.get('client_id');
const PRESELECT_VALUE = preselectId ? `client:${preselectId}` : null;

const CLIENTS_JSON  = JSON.stringify(clients);
const PRODUCTS_JSON = JSON.stringify(products);
---
<AdminLayout title="Prise de commande" activeNav="commande-rapide">

  {errorType && (
    <div style="padding:14px 18px;border-radius:10px;font-size:15px;font-weight:600;margin-bottom:14px;background:oklch(0.96 0.04 25);color:oklch(0.45 0.18 25);border:1px solid oklch(0.86 0.08 25);" role="alert">
      {ERROR_MSG[errorType] ?? 'Une erreur est survenue.'}
    </div>
  )}

  {!clients?.length ? (
    <div style="text-align:center;padding:64px 0;font-size:16px;color:var(--color-muted);">
      <p>Aucun client enregistré.</p>
      <a href="/admin/clients" style="color:var(--color-primary-deep);font-weight:600;text-decoration:none;">Voir les clients →</a>
    </div>
  ) : success ? (
    <!-- ── Success screen ─────────────────────────────────────── -->
    <div id="successScreen" style="display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:64px 20px;min-height:60vh;gap:18px;">
      <div style="width:72px;height:72px;border-radius:50%;background:oklch(0.93 0.06 145);display:flex;align-items:center;justify-content:center;">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12.5 10 17.5 19 7" stroke="oklch(0.38 0.12 145)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h2 style="font-size:22px;font-weight:700;color:var(--color-ink);margin:0;">Commande envoyée !</h2>
      <p style="font-size:17px;color:var(--color-muted);margin:0;max-width:320px;">Les emails de confirmation ont été transmis au client et à Inca Import.</p>
      <a href="/admin/commande-rapide" style="display:flex;align-items:center;justify-content:center;min-height:56px;padding:0 32px;background:var(--color-primary);color:white;font-size:18px;font-weight:700;border-radius:12px;text-decoration:none;margin-top:8px;">
        Nouvelle commande
      </a>
    </div>
  ) : (
    <form method="POST" id="orderForm" style="padding-bottom:108px;">
      <input type="hidden" name="client_id" id="clientIdInput" required />

      <!-- ══ STEP 1 — Client selection ══════════════════════════ -->
      <div id="step1">
        <div style="position:sticky;top:0;z-index:var(--z-sticky);background:var(--color-bg);padding:10px 0 12px;">
          <input
            type="text"
            id="clientSearch"
            placeholder="Rechercher un client par nom ou société…"
            style="width:100%;box-sizing:border-box;min-height:56px;padding:0 18px;font-size:18px;font-family:var(--font-body);color:var(--color-ink);background:var(--color-surface);border:1.5px solid var(--color-border-strong);border-radius:14px;outline:none;"
          />
        </div>
        <div id="clientList" style="display:flex;flex-direction:column;gap:10px;"></div>
      </div>

      <!-- ══ Selected client pinned bar ══════════════════════════ -->
      <div id="selectedClientBar" style="display:none;position:sticky;top:0;z-index:var(--z-sticky);background:var(--color-primary);color:white;border-radius:14px;padding:14px 16px;margin-bottom:16px;align-items:center;justify-content:space-between;gap:12px;">
        <div style="min-width:0;">
          <div id="selectedClientName" style="font-size:17px;font-weight:700;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>
          <div id="selectedClientMeta" style="font-size:13px;opacity:0.85;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>
        </div>
        <button type="button" id="changeClientBtn" style="flex-shrink:0;min-height:44px;padding:0 16px;background:oklch(1 0 0 / 0.18);color:white;border:none;border-radius:10px;font-size:14px;font-weight:600;touch-action:manipulation;-webkit-tap-highlight-color:transparent;">
          Changer
        </button>
      </div>

      <!-- ══ STEP 2 — Products ═══════════════════════════════════ -->
      <div id="step2" style="display:none;">
        <div style="position:sticky;top:64px;z-index:var(--z-sticky);background:var(--color-surface);padding:0 0 10px;">
          <input
            type="text"
            id="productSearch"
            placeholder="Rechercher un produit…"
            style="width:100%;box-sizing:border-box;min-height:52px;padding:0 16px;font-size:17px;font-family:var(--font-body);color:var(--color-ink);background:var(--color-bg);border:1.5px solid var(--color-border-strong);border-radius:12px;outline:none;margin-bottom:10px;"
          />
          <div id="catTabs" style="display:flex;gap:8px;overflow-x:auto;-webkit-overflow-scrolling:touch;padding-bottom:2px;">
            {CATS.map(cat => (
              <button
                type="button"
                class="cat-tab"
                data-cat={cat}
                style={`flex-shrink:0;min-height:48px;padding:0 20px;border-radius:24px;font-size:15px;font-weight:600;border:1.5px solid var(--color-border-strong);background:${cat === 'tous' ? 'var(--color-primary)' : 'var(--color-bg)'};color:${cat === 'tous' ? 'white' : 'var(--color-ink)'};touch-action:manipulation;-webkit-tap-highlight-color:transparent;white-space:nowrap;`}
              >
                {cat === 'tous' ? 'Tous' : (CAT_LABEL[cat] ?? cat)}
              </button>
            ))}
          </div>
        </div>

        <div id="productList" style="display:flex;flex-direction:column;gap:10px;margin-top:4px;"></div>

        <div style="margin-top:20px;">
          <label for="notes" style="display:block;font-size:13px;font-weight:600;color:var(--color-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px;">Notes</label>
          <textarea
            name="notes"
            id="notes"
            rows="3"
            placeholder="Précisions, contraintes de livraison…"
            style="width:100%;box-sizing:border-box;padding:14px 16px;font-family:var(--font-body);font-size:16px;color:var(--color-ink);background:var(--color-bg);border:1.5px solid var(--color-border-strong);border-radius:12px;resize:vertical;outline:none;"
          ></textarea>
        </div>
      </div>
    </form>
  )}

  <!-- ══ STEP 3 — Sticky bottom bar ═══════════════════════════ -->
  <div id="submitBar" style="display:none;position:fixed;left:0;right:0;bottom:0;background:var(--color-ink);padding:14px 18px calc(14px + env(safe-area-inset-bottom));z-index:var(--z-sticky);box-shadow:0 -4px 24px oklch(0.148 0.020 45.9 / 0.25);">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:14px;max-width:680px;margin:0 auto;">
      <div style="display:flex;flex-direction:column;gap:2px;white-space:nowrap;">
        <span id="submitCount" style="font-size:13px;font-weight:500;color:oklch(1 0 0 / 0.6);">0 article</span>
        <span id="submitTotal" style="font-size:19px;font-weight:700;color:white;">0,00 € HT</span>
      </div>
      <button type="button" id="openConfirmBtn" style="flex:1;max-width:220px;min-height:56px;background:var(--color-primary);color:white;font-size:18px;font-weight:700;border:none;border-radius:14px;touch-action:manipulation;-webkit-tap-highlight-color:transparent;">
        Envoyer la commande
      </button>
    </div>
  </div>

  <!-- ══ Confirm overlay ══════════════════════════════════════ -->
  <div id="confirmOverlay" style="display:none;position:fixed;inset:0;background:oklch(0.148 0.020 45.9 / 0.55);z-index:var(--z-modal);align-items:flex-end;justify-content:center;">
    <div style="width:100%;max-width:560px;background:var(--color-bg);border-radius:20px 20px 0 0;padding:24px 22px calc(22px + env(safe-area-inset-bottom));max-height:85vh;display:flex;flex-direction:column;">
      <h2 style="font-size:20px;font-weight:700;color:var(--color-ink);margin:0 0 4px;">Confirmer la commande</h2>
      <div id="confirmClientName" style="font-size:16px;color:var(--color-muted);margin-bottom:16px;"></div>
      <div id="confirmItems" style="flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:10px;border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);padding:14px 0;margin-bottom:16px;"></div>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;">
        <span style="font-size:16px;font-weight:600;color:var(--color-ink);">Total HT</span>
        <span id="confirmTotal" style="font-size:22px;font-weight:700;color:var(--color-primary-deep);"></span>
      </div>
      <div style="display:flex;gap:10px;">
        <button type="button" id="cancelConfirmBtn" style="flex:1;min-height:56px;background:var(--color-surface);color:var(--color-ink);font-size:16px;font-weight:600;border:1.5px solid var(--color-border-strong);border-radius:14px;touch-action:manipulation;-webkit-tap-highlight-color:transparent;">
          Annuler
        </button>
        <button type="button" id="confirmSubmitBtn" style="flex:2;min-height:56px;background:var(--color-primary);color:white;font-size:17px;font-weight:700;border:none;border-radius:14px;touch-action:manipulation;-webkit-tap-highlight-color:transparent;">
          Confirmer
        </button>
      </div>
    </div>
  </div>

</AdminLayout>

<script define:vars={{ CLIENTS_JSON, PRODUCTS_JSON, CAT_LABEL, PRESELECT_VALUE }}>
  const clients  = JSON.parse(CLIENTS_JSON);
  const products = JSON.parse(PRODUCTS_JSON);

  const qty = {}; // productId -> quantity
  let selectedClient = null;

  // Mirrors lib/clients.ts applyRemise() — keeps the live preview in sync
  // with the discounted price that will actually be saved on the order.
  function discountedPrice(price) {
    const pct = selectedClient && selectedClient.remise;
    if (!pct) return price;
    return Math.round(price * (1 - pct / 100) * 10000) / 10000;
  }

  const clientSearch       = document.getElementById('clientSearch');
  const clientList         = document.getElementById('clientList');
  const step1               = document.getElementById('step1');
  const step2               = document.getElementById('step2');
  const selectedClientBar   = document.getElementById('selectedClientBar');
  const selectedClientName  = document.getElementById('selectedClientName');
  const selectedClientMeta  = document.getElementById('selectedClientMeta');
  const changeClientBtn     = document.getElementById('changeClientBtn');
  const clientIdInput       = document.getElementById('clientIdInput');
  const productSearch       = document.getElementById('productSearch');
  const productList         = document.getElementById('productList');
  const catTabs              = document.getElementById('catTabs');
  const submitBar            = document.getElementById('submitBar');
  const submitCount          = document.getElementById('submitCount');
  const submitTotal          = document.getElementById('submitTotal');
  const openConfirmBtn       = document.getElementById('openConfirmBtn');
  const confirmOverlay       = document.getElementById('confirmOverlay');
  const cancelConfirmBtn     = document.getElementById('cancelConfirmBtn');
  const confirmSubmitBtn     = document.getElementById('confirmSubmitBtn');
  const confirmClientName    = document.getElementById('confirmClientName');
  const confirmItems         = document.getElementById('confirmItems');
  const confirmTotal         = document.getElementById('confirmTotal');
  const orderForm             = document.getElementById('orderForm');

  if (!orderForm || !clientSearch) {
    // Success screen or empty-clients state — no order form to wire up.
  } else {

  let activeCat = 'tous';

  // ── Client cards ──────────────────────────────────────────
  function renderClients(query) {
    const q = (query ?? '').trim().toLowerCase();
    const filtered = q.length >= 2
      ? clients.filter(c => c.nom.toLowerCase().includes(q) || c.societe.toLowerCase().includes(q))
      : clients;

    clientList.innerHTML = '';
    filtered.forEach(c => {
      const card = document.createElement('button');
      card.type = 'button';
      card.style.cssText = 'display:flex;flex-direction:column;align-items:flex-start;gap:2px;width:100%;text-align:left;min-height:64px;padding:14px 16px;background:var(--color-bg);border:1.5px solid var(--color-border);border-radius:14px;touch-action:manipulation;-webkit-tap-highlight-color:transparent;';
      const sub = [c.societe, c.pdv].filter(Boolean).join(' — ');
      card.innerHTML =
        '<span style="font-size:17px;font-weight:700;color:var(--color-ink);">' + escapeHtml(c.nom) + '</span>' +
        (sub ? '<span style="font-size:14px;color:var(--color-muted);">' + escapeHtml(sub) + '</span>' : '');
      card.addEventListener('click', () => selectClient(c));
      clientList.appendChild(card);
    });

    if (filtered.length === 0) {
      const empty = document.createElement('p');
      empty.style.cssText = 'text-align:center;color:var(--color-muted);font-size:15px;padding:24px 0;';
      empty.textContent = 'Aucun client trouvé.';
      clientList.appendChild(empty);
    }
  }

  function selectClient(c) {
    selectedClient = c;
    clientIdInput.value = c.value;
    selectedClientName.textContent = c.nom;
    selectedClientMeta.textContent = [c.societe, c.pdv].filter(Boolean).join(' — ') || ' ';
    selectedClientBar.style.display = 'flex';
    step1.style.display = 'none';
    step2.style.display = 'block';
    submitBar.style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  changeClientBtn.addEventListener('click', () => {
    selectedClient = null;
    clientIdInput.value = '';
    selectedClientBar.style.display = 'none';
    step1.style.display = 'block';
    step2.style.display = 'none';
    submitBar.style.display = 'none';
  });

  clientSearch.addEventListener('input', () => renderClients(clientSearch.value));
  renderClients('');

  if (PRESELECT_VALUE) {
    const pre = clients.find(c => c.value === PRESELECT_VALUE);
    if (pre) selectClient(pre);
  }

  // ── Product cards ─────────────────────────────────────────
  function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, ch => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[ch]));
  }

  function cardStyle(hasQty) {
    const borderWidth = hasQty ? '2px' : '1.5px';
    const borderColor = hasQty ? 'var(--color-primary)' : 'var(--color-border)';
    const bg          = hasQty ? 'oklch(0.568 0.149 45.9 / 0.07)' : 'var(--color-bg)';
    return 'display:flex;align-items:center;gap:14px;width:100%;padding:12px;border-radius:14px;' +
      'border:' + borderWidth + ' solid ' + borderColor + ';' +
      'background:' + bg + ';touch-action:manipulation;-webkit-tap-highlight-color:transparent;text-align:left;';
  }

  function updateCardVisual(card, id) {
    const q = qty[id] || 0;
    card.style.cssText = cardStyle(q > 0);
    const badge = card.querySelector('.qty-badge');
    const stepper = card.querySelector('.stepper-row');
    if (badge) badge.textContent = q > 0 ? String(q) : '';
    if (badge) badge.style.display = q > 0 ? 'flex' : 'none';
    const stepInput = card.querySelector('.step-val');
    if (stepInput) stepInput.textContent = String(q);
  }

  function renderProducts() {
    const q = (productSearch.value ?? '').trim().toLowerCase();
    const filtered = products.filter(p => {
      const matchesCat   = activeCat === 'tous' || p.category === activeCat;
      const matchesQuery = q.length === 0 || p.name.toLowerCase().includes(q);
      return matchesCat && matchesQuery;
    });

    productList.innerHTML = '';

    if (filtered.length === 0) {
      const empty = document.createElement('p');
      empty.style.cssText = 'text-align:center;color:var(--color-muted);font-size:15px;padding:24px 0;';
      empty.textContent = 'Aucun produit trouvé.';
      productList.appendChild(empty);
      return;
    }

    filtered.forEach(p => {
      const card = document.createElement('button');
      card.type = 'button';
      card.dataset.id = p.id;
      card.style.cssText = cardStyle((qty[p.id] || 0) > 0);

      const imgHtml = p.image
        ? '<img src="' + p.image.replace(/"/g, '&quot;') + '" alt="" style="width:80px;height:80px;flex-shrink:0;border-radius:10px;object-fit:cover;background:var(--color-surface-2);" />'
        : '<div style="width:80px;height:80px;flex-shrink:0;border-radius:10px;background:var(--color-surface-2);display:flex;align-items:center;justify-content:center;font-size:24px;color:var(--color-border-strong);">📦</div>';

      card.innerHTML =
        imgHtml +
        '<div style="flex:1;min-width:0;display:flex;flex-direction:column;gap:4px;position:relative;">' +
          '<span style="font-size:18px;font-weight:700;color:var(--color-ink);line-height:1.25;">' + escapeHtml(p.name) + '</span>' +
          '<div style="display:flex;align-items:baseline;gap:8px;">' +
            '<span style="font-size:17px;font-weight:700;color:var(--color-primary-deep);">' + p.price.toFixed(2).replace('.', ',') + ' €</span>' +
            (p.unit ? '<span style="font-size:13px;color:var(--color-muted);">' + escapeHtml(p.unit) + '</span>' : '') +
          '</div>' +
          '<div class="stepper-row" style="display:none;align-items:center;gap:10px;margin-top:6px;">' +
            '<button type="button" class="step-dec" style="width:44px;height:44px;border-radius:10px;border:1.5px solid var(--color-border-strong);background:var(--color-bg);font-size:20px;font-weight:700;color:var(--color-ink);touch-action:manipulation;-webkit-tap-highlight-color:transparent;">−</button>' +
            '<span class="step-val" style="min-width:32px;text-align:center;font-size:18px;font-weight:700;color:var(--color-ink);">0</span>' +
            '<button type="button" class="step-inc" style="width:44px;height:44px;border-radius:10px;border:1.5px solid var(--color-border-strong);background:var(--color-primary);color:white;font-size:20px;font-weight:700;touch-action:manipulation;-webkit-tap-highlight-color:transparent;">+</button>' +
          '</div>' +
        '</div>' +
        '<span class="qty-badge" style="display:none;align-items:center;justify-content:center;min-width:26px;height:26px;padding:0 6px;border-radius:13px;background:var(--color-primary);color:white;font-size:13px;font-weight:700;flex-shrink:0;">0</span>';

      const stepperRow = card.querySelector('.stepper-row');
      const decBtn = card.querySelector('.step-dec');
      const incBtn = card.querySelector('.step-inc');

      function toggleStepper() {
        stepperRow.style.display = stepperRow.style.display === 'none' ? 'flex' : 'none';
      }

      card.addEventListener('click', toggleStepper);
      decBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        qty[p.id] = Math.max(0, (qty[p.id] || 0) - 1);
        syncHiddenInput(p.id);
        updateCardVisual(card, p.id);
        recalcTotals();
      });
      incBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        qty[p.id] = (qty[p.id] || 0) + 1;
        syncHiddenInput(p.id);
        updateCardVisual(card, p.id);
        recalcTotals();
      });

      productList.appendChild(card);
      updateCardVisual(card, p.id);
    });
  }

  function syncHiddenInput(id) {
    let input = orderForm.querySelector('input[name="qty_' + id + '"]');
    if (!input) {
      input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'qty_' + id;
      orderForm.appendChild(input);
    }
    input.value = String(qty[id] || 0);
  }

  function recalcTotals() {
    let count = 0, total = 0;
    products.forEach(p => {
      const q = qty[p.id] || 0;
      count += q;
      total += q * discountedPrice(p.price);
    });
    submitCount.textContent = count + (count === 1 ? ' article' : ' articles');
    submitTotal.textContent = total.toFixed(2).replace('.', ',') + ' € HT';
  }

  productSearch.addEventListener('input', renderProducts);

  catTabs.querySelectorAll('.cat-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      activeCat = tab.dataset.cat;
      catTabs.querySelectorAll('.cat-tab').forEach(t => {
        const isActive = t === tab;
        t.style.background = isActive ? 'var(--color-primary)' : 'var(--color-bg)';
        t.style.color = isActive ? 'white' : 'var(--color-ink)';
      });
      renderProducts();
    });
  });

  renderProducts();
  recalcTotals();

  // ── Confirm overlay ──────────────────────────────────────
  openConfirmBtn.addEventListener('click', () => {
    if (!selectedClient) return;
    const items = products.filter(p => (qty[p.id] || 0) > 0);
    if (items.length === 0) return;

    confirmClientName.textContent = selectedClient.nom + (selectedClient.societe ? ' — ' + selectedClient.societe : '');
    confirmItems.innerHTML = items.map(p => {
      const q = qty[p.id];
      const lineTotal = (q * discountedPrice(p.price)).toFixed(2).replace('.', ',');
      return '<div style="display:flex;justify-content:space-between;gap:10px;font-size:15px;">' +
        '<span style="color:var(--color-ink);">' + escapeHtml(p.name) + ' × ' + q + '</span>' +
        '<span style="font-weight:600;color:var(--color-ink);white-space:nowrap;">' + lineTotal + ' €</span>' +
      '</div>';
    }).join('');

    const total = items.reduce((s, p) => s + qty[p.id] * discountedPrice(p.price), 0);
    confirmTotal.textContent = total.toFixed(2).replace('.', ',') + ' €';

    confirmOverlay.style.display = 'flex';
  });

  cancelConfirmBtn.addEventListener('click', () => { confirmOverlay.style.display = 'none'; });
  confirmOverlay.addEventListener('click', (e) => { if (e.target === confirmOverlay) confirmOverlay.style.display = 'none'; });

  confirmSubmitBtn.addEventListener('click', () => {
    confirmSubmitBtn.disabled = true;
    confirmSubmitBtn.textContent = 'Envoi…';
    orderForm.requestSubmit();
  });

  } // end orderForm guard
</script>

