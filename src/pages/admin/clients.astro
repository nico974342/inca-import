---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

if (Astro.request.method === 'POST') {
  const data   = await Astro.request.formData();
  const action = data.get('action') as string;

  if (action === 'convert') {
    const contactId = data.get('contact_id') as string;
    const { data: contact } = await supabaseAdmin
      .from('contact_requests')
      .select('*')
      .eq('id', contactId)
      .single();

    if (contact) {
      await supabaseAdmin.from('client_accounts').insert({
        contact_request_id: contact.id,
        nom: contact.nom,
        societe: contact.societe,
        telephone: contact.telephone,
        email: contact.email,
        notes: contact.notes,
        status: 'actif',
      });
      await supabaseAdmin.from('contact_requests').update({ status: 'converti' }).eq('id', contact.id);
    }
  } else if (action === 'update_client') {
    const id     = data.get('id')     as string;
    const status = data.get('status') as string;
    const notes  = data.get('notes')  as string | null;
    if (id && status) {
      await supabaseAdmin.from('client_accounts').update({ status, notes: notes ?? null }).eq('id', id);
    }
  } else if (action === 'update_contact_notes') {
    const id    = data.get('id')    as string;
    const notes = data.get('notes') as string | null;
    if (id) {
      await supabaseAdmin.from('contact_requests').update({ notes: notes ?? null }).eq('id', id);
    }
  }
  return Astro.redirect('/admin/clients');
}

const { data: clientsRaw }  = await supabaseAdmin.from('client_accounts').select('*').order('created_at', { ascending: false });
const { data: contactsRaw } = await supabaseAdmin.from('contact_requests').select('*').order('created_at', { ascending: false });

const clients  = clientsRaw  ?? [];
const contacts = contactsRaw ?? [];

const convertedContactIds = new Set(clients.map(c => c.contact_request_id).filter(Boolean));

const CLIENT_STATUS_LABELS: Record<string, string> = {
  en_attente: 'Client en attente',
  actif:      'Client actif',
  suspendu:   'Client suspendu',
};

type Row = {
  kind: 'client' | 'contact';
  id: string;
  nom: string;
  societe: string | null;
  telephone: string | null;
  email: string | null;
  pointsDeVente: string | null;
  status: string;
  statusLabel: string;
  notes: string | null;
  created_at: string;
};

const rows: Row[] = [
  ...clients.map((c): Row => ({
    kind: 'client',
    id: c.id,
    nom: c.nom,
    societe: c.societe,
    telephone: c.telephone,
    email: c.email,
    pointsDeVente: c.points_de_vente ?? null,
    status: c.status,
    statusLabel: CLIENT_STATUS_LABELS[c.status] ?? c.status,
    notes: c.notes,
    created_at: c.created_at,
  })),
  ...contacts
    .filter(ct => !convertedContactIds.has(ct.id))
    .map((ct): Row => ({
      kind: 'contact',
      id: ct.id,
      nom: ct.nom,
      societe: ct.societe,
      telephone: ct.telephone,
      email: ct.email,
      pointsDeVente: null,
      status: ct.status,
      statusLabel: ct.status === 'converti' ? 'Converti' : 'Nouveau contact',
      notes: ct.notes,
      created_at: ct.created_at,
    })),
].sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: '2-digit' });
}
---
<AdminLayout title="Clients" activeNav="clients">
  {rows.length > 0 ? (
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Nom</th>
            <th>Société</th>
            <th>Téléphone</th>
            <th>Email</th>
            <th>Point de vente</th>
            <th>Statut</th>
            <th>Inscription</th>
            <th>Notes</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {rows.map(r => (
            <tr>
              <td class="td-strong">{r.nom}</td>
              <td>{r.societe ?? '—'}</td>
              <td class="td-mono">{r.telephone ?? '—'}</td>
              <td class="td-mono">{r.email ?? '—'}</td>
              <td>{r.pointsDeVente ?? '—'}</td>
              <td>
                {r.kind === 'client' ? (
                  <form method="post" class="inline-form">
                    <input type="hidden" name="action" value="update_client" />
                    <input type="hidden" name="id"     value={r.id} />
                    <input type="hidden" name="notes"  value={r.notes ?? ''} />
                    <select
                      name="status"
                      class={`status-select status-select--${r.status}`}
                      onchange="this.form.submit()"
                      aria-label="Changer le statut"
                    >
                      <option value="en_attente" selected={r.status === 'en_attente'}>En attente</option>
                      <option value="actif"      selected={r.status === 'actif'}>Actif</option>
                      <option value="suspendu"   selected={r.status === 'suspendu'}>Suspendu</option>
                    </select>
                  </form>
                ) : (
                  <span class={`status-badge status-badge--${r.status === 'converti' ? 'converti' : 'nouveau'}`}>{r.statusLabel}</span>
                )}
              </td>
              <td class="td-muted">{formatDate(r.created_at)}</td>
              <td>
                <form
                  method="post"
                  class="notes-form"
                >
                  <input type="hidden" name="action" value={r.kind === 'client' ? 'update_client' : 'update_contact_notes'} />
                  <input type="hidden" name="id"      value={r.id} />
                  {r.kind === 'client' && <input type="hidden" name="status" value={r.status} />}
                  <input
                    type="text"
                    name="notes"
                    class="notes-input"
                    value={r.notes ?? ''}
                    placeholder="Notes…"
                    aria-label="Notes"
                  />
                  <button type="submit" class="notes-save" aria-label="Enregistrer">✓</button>
                </form>
              </td>
              <td>
                {r.kind === 'contact' && r.status !== 'converti' && (
                  <form method="post">
                    <input type="hidden" name="action"     value="convert" />
                    <input type="hidden" name="contact_id" value={r.id} />
                    <button type="submit" class="convert-btn">Convertir en client</button>
                  </form>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <div class="empty-state">
      <p class="empty-title">Aucun contact ni client.</p>
      <p class="empty-body">Les demandes du formulaire de contact et les inscriptions apparaîtront ici.</p>
    </div>
  )}
</AdminLayout>

<style>
.table-wrap {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow-x: auto;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--text-sm);
}

.data-table thead th {
  padding: var(--space-3) var(--space-4);
  text-align: left;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-bottom: 1px solid var(--color-border);
  white-space: nowrap;
}

.data-table tbody td {
  padding: var(--space-3) var(--space-4);
  border-bottom: 1px solid var(--color-border);
  vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover td { background: var(--color-surface); }

.td-strong { font-weight: 500; color: var(--color-ink); white-space: nowrap; }
.td-muted  { color: var(--color-muted); white-space: nowrap; }
.td-mono   { font-family: var(--font-mono); }

.inline-form { display: contents; }

.status-select,
.status-badge {
  display: inline-block;
  padding: 3px 8px;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 500;
  border: 1.5px solid transparent;
  white-space: nowrap;
}
.status-select {
  cursor: pointer;
  outline: none;
  appearance: none;
  -webkit-appearance: none;
}
.status-select:focus { outline: 2px solid var(--color-primary); outline-offset: 2px; }
.status-select--en_attente { background: oklch(0.95 0.02 60);  color: oklch(0.45 0.10 60);  }
.status-select--actif      { background: oklch(0.93 0.06 145); color: oklch(0.38 0.12 145); }
.status-select--suspendu   { background: oklch(0.95 0.02 25);  color: oklch(0.45 0.10 25);  }
.status-badge--nouveau     { background: oklch(0.95 0.02 220); color: oklch(0.35 0.08 220); }
.status-badge--converti    { background: oklch(0.93 0.06 145); color: oklch(0.38 0.12 145); }

.notes-form {
  display: flex;
  gap: var(--space-2);
  align-items: center;
  min-width: 180px;
}

.notes-input {
  flex: 1;
  padding: 4px 8px;
  font-family: var(--font-body);
  font-size: var(--text-xs);
  color: var(--color-ink);
  background: var(--color-surface);
  border: 1px solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  min-height: 30px;
  outline: none;
  transition: border-color var(--dur-fast);
}
.notes-input:focus { border-color: var(--color-primary); }
.notes-input::placeholder { color: var(--color-muted); }

.notes-save {
  flex-shrink: 0;
  padding: 4px 8px;
  background: var(--color-surface-2);
  border: 1px solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  color: var(--color-muted);
  cursor: pointer;
  font-size: var(--text-xs);
  min-height: 30px;
  transition: color var(--dur-fast), background var(--dur-fast);
}
.notes-save:hover { color: var(--color-ink); background: var(--color-border); }

.convert-btn {
  padding: 4px 10px;
  background: var(--color-surface-2);
  border: 1px solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  color: var(--color-primary-deep);
  cursor: pointer;
  font-size: var(--text-xs);
  font-weight: 500;
  white-space: nowrap;
  min-height: 30px;
  transition: color var(--dur-fast), background var(--dur-fast);
}
.convert-btn:hover { background: oklch(0.568 0.149 45.9 / 0.1); }

.empty-state {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-16) var(--space-8);
  text-align: center;
}
.empty-title { font-weight: 600; color: var(--color-ink); margin-bottom: var(--space-2); }
.empty-body  { color: var(--color-muted); }
</style>
