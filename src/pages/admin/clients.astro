---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';
import { sanitizeText, sanitizeEmail } from '../../lib/sanitize';
import { normalizeEmail } from '../../lib/clients';
import { sendClientActivationEmail } from '../../lib/email';
import { logAdminAction } from '../../lib/audit';
import { CLIENT_STATUSES, CLIENT_STATUS_LABEL, CLIENT_STATUS_COLOR, CLIENT_TYPES, CLIENT_TYPE_LABEL } from '../../lib/constants';

if (Astro.request.method === 'POST') {
  const data   = await Astro.request.formData();
  const action = data.get('action') as string;

  const adminEmail = (Astro.locals as any).user?.email ?? 'inconnu';

  if (action === 'convert') {
    const contactId = data.get('contact_id') as string;
    const { data: contact } = await supabaseAdmin
      .from('contact_requests')
      .select('*')
      .eq('id', contactId)
      .single();

    if (contact) {
      const { error: insertErr } = await supabaseAdmin.from('client_accounts').insert({
        contact_request_id: contact.id,
        nom: contact.nom,
        societe: contact.societe,
        points_de_vente: contact.societe,
        telephone: contact.telephone,
        email: contact.email ? normalizeEmail(contact.email) : null,
        notes: contact.notes,
        status: 'actif',
      });

      if (insertErr) {
        console.error('[admin/clients] convert insert error:', insertErr.code, insertErr.message);
        const reason = insertErr.code === '23505' ? 'email_existe' : 'erreur';
        return Astro.redirect(`/admin/clients?client_error=${reason}`);
      }

      await supabaseAdmin.from('contact_requests').update({ status: 'converti' }).eq('id', contact.id);
      await logAdminAction({
        adminEmail,
        action: 'client.conversion',
        targetType: 'client',
        targetLabel: contact.societe ?? contact.nom,
        details: { email: contact.email },
      });
    }
  } else if (action === 'update_client') {
    const id     = data.get('id')     as string;
    const status = data.get('status') as string;
    const notes  = sanitizeText(data.get('notes') as string, 500);
    if (id && status) {
      const { data: prev } = await supabaseAdmin.from('client_accounts').select('nom, societe, status').eq('id', id).single();
      await supabaseAdmin.from('client_accounts').update({ status, notes: notes || null }).eq('id', id);
      if (prev && prev.status !== status) {
        await logAdminAction({
          adminEmail,
          action: 'client.statut',
          targetType: 'client',
          targetId: id,
          targetLabel: prev.societe ?? prev.nom,
          details: { ancien: prev.status, nouveau: status },
        });
      }
    }
  } else if (action === 'activate_client') {
    const id = data.get('id') as string;
    if (id) {
      const { data: client } = await supabaseAdmin
        .from('client_accounts')
        .select('email, nom')
        .eq('id', id)
        .single();
      await supabaseAdmin
        .from('client_accounts')
        .update({ status: 'actif' })
        .eq('id', id);
      if (client?.email) {
        try {
          await sendClientActivationEmail({ to: client.email, nom: client.nom ?? client.email });
        } catch (e) {
          console.error('[admin/clients] activation email failed:', e);
        }
      }
      await logAdminAction({
        adminEmail,
        action: 'client.activation',
        targetType: 'client',
        targetId: id,
        targetLabel: client?.nom ?? id,
        details: { email: client?.email },
      });
    }
  } else if (action === 'create_client') {
    const nom           = sanitizeText(data.get('nom')            as string, 120);
    const societe       = sanitizeText(data.get('societe')        as string, 120);
    const typeRaw       = (data.get('type') as string) ?? '';
    const type          = (CLIENT_TYPES as readonly string[]).includes(typeRaw) ? typeRaw : null;
    const commune       = sanitizeText(data.get('commune')        as string, 100);
    const telephone     = sanitizeText(data.get('telephone')      as string, 30);
    const email         = sanitizeEmail(data.get('email')         as string);
    const pointsDeVente = sanitizeText(data.get('points_de_vente') as string, 120);
    const notes         = sanitizeText(data.get('notes')          as string, 500);
    const status        = (data.get('status') as string) || 'prospect';

    // Prospects are a lightweight first-contact record — only the name is
    // required. A real client account (en_attente/actif/suspendu) still
    // needs an email since login/access-linking depends on it.
    const requiresEmail = status !== 'prospect';

    if (nom && (!requiresEmail || email)) {
      const { error: insertErr } = await supabaseAdmin.from('client_accounts').insert({
        nom, societe: societe || null, type, commune: commune || null,
        telephone: telephone || null, email: email || null,
        points_de_vente: pointsDeVente || null, notes: notes || null, status,
      });

      if (insertErr) {
        console.error('[admin/clients] create_client insert error:', insertErr.code, insertErr.message);
        const reason = insertErr.code === '23505' ? 'email_existe' : 'erreur';
        return Astro.redirect(`/admin/clients?client_error=${reason}`);
      }

      await logAdminAction({
        adminEmail,
        action: 'client.creation',
        targetType: 'client',
        targetLabel: societe || nom,
        details: { email, status },
      });
    } else {
      return Astro.redirect('/admin/clients?client_error=champs_requis');
    }
  } else if (action === 'update_contact_notes') {
    const id    = data.get('id') as string;
    const notes = sanitizeText(data.get('notes') as string, 500);
    if (id) {
      await supabaseAdmin.from('contact_requests').update({ notes: notes || null }).eq('id', id);
    }
  }
  return Astro.redirect('/admin/clients');
}

const [
  { data: clientsRaw },
  { data: contactsRaw },
  { data: authUsersData },
] = await Promise.all([
  supabaseAdmin.from('client_accounts').select('*').order('created_at', { ascending: false }),
  supabaseAdmin.from('contact_requests').select('*').order('created_at', { ascending: false }),
  supabaseAdmin.auth.admin.listUsers({ page: 1, perPage: 1000 }),
]);

const clients  = clientsRaw  ?? [];
const contacts = contactsRaw ?? [];

// Build a set of emails that have admin role in Supabase auth
const adminEmailSet = new Set(
  ((authUsersData as any)?.users ?? [])
    .filter((u: any) => u.user_metadata?.role !== 'client')
    .map((u: any) => u.email as string)
    .filter(Boolean)
);

const pendingCount = clients.filter(c => c.status === 'en_attente').length;
const deleted      = !!Astro.url.searchParams.get('deleted');
const convertedContactIds = new Set(clients.map(c => c.contact_request_id).filter(Boolean));

const clientError = Astro.url.searchParams.get('client_error');
const CLIENT_ERROR_MSG: Record<string, string> = {
  email_existe:  'Cette adresse email est déjà utilisée par un autre client.',
  champs_requis: 'Le nom est obligatoire (email en plus pour un client actif/en attente/suspendu).',
  erreur:        "Une erreur est survenue lors de l'enregistrement du client.",
};

const CLIENT_STATUS_LABELS: Record<string, string> = {
  prospect:   'Prospect',
  en_attente: 'Client en attente',
  actif:      'Client actif',
  suspendu:   'Client suspendu',
};

type Row = {
  kind: 'client' | 'contact';
  id: string;
  nom: string;
  societe: string | null;
  type: string | null;
  commune: string | null;
  telephone: string | null;
  email: string | null;
  pointsDeVente: string | null;
  status: string;
  statusLabel: string;
  notes: string | null;
  created_at: string;
  isAdmin: boolean;
};

const allRows: Row[] = [
  ...clients.map((c): Row => ({
    kind: 'client',
    id: c.id,
    nom: c.nom,
    societe: c.societe,
    type: (c as any).type ?? null,
    commune: (c as any).commune ?? null,
    telephone: c.telephone,
    email: c.email,
    pointsDeVente: c.points_de_vente ?? null,
    status: c.status,
    statusLabel: CLIENT_STATUS_LABELS[c.status] ?? c.status,
    notes: c.notes,
    created_at: c.created_at,
    isAdmin: !!(c.email && adminEmailSet.has(c.email)),
  })),
  ...contacts
    .filter(ct => !convertedContactIds.has(ct.id))
    .map((ct): Row => ({
      kind: 'contact',
      id: ct.id,
      nom: ct.nom,
      societe: ct.societe,
      type: null,
      commune: null,
      telephone: ct.telephone,
      email: ct.email,
      pointsDeVente: null,
      status: ct.status,
      statusLabel: ct.status === 'converti' ? 'Converti' : 'Nouveau contact',
      notes: ct.notes,
      created_at: ct.created_at,
      isAdmin: false,
    })),
].sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());

// ── Filter tabs: client statuses + a bucket for contact-request rows ──────
const filterView = Astro.url.searchParams.get('view') ?? '';
const viewCounts: Record<string, number> = { contact: 0 };
for (const s of CLIENT_STATUSES) viewCounts[s] = 0;
for (const r of allRows) {
  if (r.kind === 'contact') viewCounts.contact++;
  else viewCounts[r.status] = (viewCounts[r.status] ?? 0) + 1;
}

const rows = filterView
  ? allRows.filter(r => (filterView === 'contact' ? r.kind === 'contact' : r.kind === 'client' && r.status === filterView))
  : allRows;

// Clients and contact requests are two tables merged and globally sorted
// above, so pagination happens on the merged list rather than in the DB.
const PAGE_SIZE = 30;
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1', 10));
const totalPages = Math.max(1, Math.ceil(rows.length / PAGE_SIZE));
const pageRows = rows.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: '2-digit' });
}
---
<AdminLayout title="Clients" activeNav="clients">
  <details class="new-client-panel">
    <summary class="new-client-toggle">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      </svg>
      Nouveau client / prospect
    </summary>
    <form method="post" class="new-client-form">
      <input type="hidden" name="action" value="create_client" />
      <div class="ncf-grid">
        <div class="ncf-field">
          <label for="ncf-nom">Nom <span class="ncf-req" aria-hidden="true">*</span></label>
          <input type="text" id="ncf-nom" name="nom" required placeholder="Jean Dupont" autocomplete="off" />
        </div>
        <div class="ncf-field">
          <label for="ncf-societe">Société</label>
          <input type="text" id="ncf-societe" name="societe" placeholder="Ma Supérette" autocomplete="off" />
        </div>
        <div class="ncf-field">
          <label for="ncf-type">Type</label>
          <select id="ncf-type" name="type">
            <option value="">—</option>
            {CLIENT_TYPES.map(t => <option value={t}>{CLIENT_TYPE_LABEL[t]}</option>)}
          </select>
        </div>
        <div class="ncf-field">
          <label for="ncf-commune">Commune</label>
          <input type="text" id="ncf-commune" name="commune" placeholder="Saint-Paul" autocomplete="off" />
        </div>
        <div class="ncf-field">
          <label for="ncf-email">Email <span class="ncf-req" id="ncf-email-req" aria-hidden="true">*</span></label>
          <input type="email" id="ncf-email" name="email" placeholder="jean@exemple.re" autocomplete="off" />
        </div>
        <div class="ncf-field">
          <label for="ncf-telephone">Téléphone</label>
          <input type="tel" id="ncf-telephone" name="telephone" placeholder="+262 692 00 00 00" autocomplete="off" />
        </div>
        <div class="ncf-field">
          <label for="ncf-pdv">Point de vente</label>
          <input type="text" id="ncf-pdv" name="points_de_vente" placeholder="Station Total Les Tamarins" autocomplete="off" />
        </div>
        <div class="ncf-field">
          <label for="ncf-status">Statut</label>
          <select id="ncf-status" name="status">
            <option value="prospect" selected>Prospect</option>
            <option value="en_attente">En attente</option>
            <option value="actif">Actif</option>
            <option value="suspendu">Suspendu</option>
          </select>
        </div>
        <div class="ncf-field ncf-field--full">
          <label for="ncf-notes">Notes</label>
          <input type="text" id="ncf-notes" name="notes" placeholder="Informations complémentaires…" autocomplete="off" />
        </div>
      </div>
      <div class="ncf-footer">
        <button type="submit" class="btn-create">Ajouter</button>
        <p class="ncf-hint">Un prospect n'a besoin que d'un nom. Pour un client actif/en attente/suspendu, l'email est requis (accès à la plateforme).</p>
      </div>
    </form>
  </details>

  {deleted && (
    <div class="success-alert" role="status">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Client supprimé avec succès.
    </div>
  )}
  {clientError && (
    <div class="error-alert" role="alert">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M8 5v3.5M8 11h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      {CLIENT_ERROR_MSG[clientError] ?? CLIENT_ERROR_MSG.erreur}
    </div>
  )}
  {pendingCount > 0 && (
    <div class="pending-alert">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M8 4.5v3.5l1.5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <strong>{pendingCount}</strong>&nbsp;client{pendingCount > 1 ? 's' : ''} en attente de validation — activez leur compte pour qu'ils puissent consulter les tarifs et passer commande.
    </div>
  )}

  <!-- Filter tabs -->
  <div class="filter-bar">
    <a href="/admin/clients" class={`filter-tab ${!filterView ? 'filter-tab--active' : ''}`}>
      Tous
      <span class="filter-count">{allRows.length}</span>
    </a>
    {CLIENT_STATUSES.map(s => (
      <a href={`/admin/clients?view=${s}`} class={`filter-tab filter-tab--${CLIENT_STATUS_COLOR[s]} ${filterView === s ? 'filter-tab--active' : ''}`}>
        {CLIENT_STATUS_LABEL[s]}
        {viewCounts[s] > 0 && <span class="filter-count">{viewCounts[s]}</span>}
      </a>
    ))}
    <a href="/admin/clients?view=contact" class={`filter-tab ${filterView === 'contact' ? 'filter-tab--active' : ''}`}>
      Demandes contact
      {viewCounts.contact > 0 && <span class="filter-count">{viewCounts.contact}</span>}
    </a>
  </div>

  {rows.length > 0 ? (
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Nom</th>
            <th>Société</th>
            <th>Type</th>
            <th>Commune</th>
            <th>Téléphone</th>
            <th>Email</th>
            <th>Point de vente</th>
            <th>Statut</th>
            <th>Accès</th>
            <th>Inscription</th>
            <th>Notes</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {pageRows.map(r => (
            <tr
              class={r.kind === 'client' ? 'client-row' : ''}
              data-href={r.kind === 'client' ? `/admin/clients/${r.id}` : undefined}
              data-pending={r.kind === 'client' && r.status === 'en_attente' ? 'true' : undefined}
            >
              <td class="td-strong">
                {r.kind === 'client' ? (
                  <a
                    href={`/admin/clients/${r.id}`}
                    class="client-link"
                    style="position: relative; z-index: 5; display: inline-block; cursor: pointer; pointer-events: auto; color: var(--color-primary); text-decoration: none;"
                  >{r.nom}</a>
                ) : r.nom}
              </td>
              <td>{r.societe ?? '—'}</td>
              <td class="td-muted">{r.type ? CLIENT_TYPE_LABEL[r.type as keyof typeof CLIENT_TYPE_LABEL] ?? r.type : '—'}</td>
              <td class="td-muted">{r.commune ?? '—'}</td>
              <td class="td-mono">{r.telephone ?? '—'}</td>
              <td class="td-mono">{r.email ?? '—'}</td>
              <td>{r.pointsDeVente ?? '—'}</td>
              <td>
                {r.kind === 'client' ? (
                  <form method="post" class="inline-form">
                    <input type="hidden" name="action" value="update_client" />
                    <input type="hidden" name="id"     value={r.id} />
                    <input type="hidden" name="notes"  value={r.notes ?? ''} />
                    <select
                      name="status"
                      class={`status-select status-select--${r.status}`}
                      onchange="this.form.submit()"
                      aria-label="Changer le statut"
                    >
                      {CLIENT_STATUSES.map(s => (
                        <option value={s} selected={r.status === s}>{CLIENT_STATUS_LABEL[s]}</option>
                      ))}
                    </select>
                  </form>
                ) : (
                  <span class={`status-badge status-badge--${r.status === 'converti' ? 'converti' : 'nouveau'}`}>{r.statusLabel}</span>
                )}
              </td>
              <td>
                {r.kind === 'client' && r.isAdmin && (
                  <span class="badge-admin">Admin</span>
                )}
              </td>
              <td class="td-muted">{formatDate(r.created_at)}</td>
              <td>
                <form
                  method="post"
                  class="notes-form"
                >
                  <input type="hidden" name="action" value={r.kind === 'client' ? 'update_client' : 'update_contact_notes'} />
                  <input type="hidden" name="id"      value={r.id} />
                  {r.kind === 'client' && <input type="hidden" name="status" value={r.status} />}
                  <input
                    type="text"
                    name="notes"
                    class="notes-input"
                    value={r.notes ?? ''}
                    placeholder="Notes…"
                    aria-label="Notes"
                  />
                  <button type="submit" class="notes-save" aria-label="Enregistrer">✓</button>
                </form>
              </td>
              <td class="td-actions">
                {r.kind === 'contact' && r.status !== 'converti' && (
                  <form method="post">
                    <input type="hidden" name="action"     value="convert" />
                    <input type="hidden" name="contact_id" value={r.id} />
                    <button type="submit" class="convert-btn">Convertir en client</button>
                  </form>
                )}
                {r.kind === 'client' && r.status === 'en_attente' && (
                  <form method="post" style="margin-bottom: var(--space-2);">
                    <input type="hidden" name="action" value="activate_client" />
                    <input type="hidden" name="id"     value={r.id} />
                    <button type="submit" class="activate-btn">Activer</button>
                  </form>
                )}
                {r.kind === 'client' && (
                  <form
                    method="post"
                    action={`/api/admin/clients/${r.id}/delete`}
                    onsubmit={`return confirm('Supprimer ${r.nom.replace(/'/g, "\\'")} ?\\nSes commandes, bons de livraison et compte seront définitivement supprimés.')`}
                  >
                    <button type="submit" class="delete-btn">Supprimer</button>
                  </form>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <div class="empty-state">
      <p class="empty-title">Aucun contact ni client.</p>
      <p class="empty-body">Les demandes du formulaire de contact et les inscriptions apparaîtront ici.</p>
    </div>
  )}

  {totalPages > 1 && (
    <nav class="pagination" aria-label="Pagination">
      {page > 1 && (
        <a href={`/admin/clients?page=${page - 1}${filterView ? `&view=${filterView}` : ''}`} class="page-btn">← Précédent</a>
      )}
      <span class="page-info">Page {page} / {totalPages}</span>
      {page < totalPages && (
        <a href={`/admin/clients?page=${page + 1}${filterView ? `&view=${filterView}` : ''}`} class="page-btn">Suivant →</a>
      )}
    </nav>
  )}
</AdminLayout>

<script>
  document.querySelectorAll<HTMLTableRowElement>('tr.client-row').forEach(row => {
    row.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a, form, input, select, button, textarea')) return;
      const href = row.dataset.href;
      if (href) window.location.href = href;
    });
  });

  // Email is only required for a real client account, not a bare prospect
  const statusSelect = document.getElementById('ncf-status') as HTMLSelectElement | null;
  const emailInput    = document.getElementById('ncf-email') as HTMLInputElement | null;
  const emailReq      = document.getElementById('ncf-email-req');
  function syncEmailRequirement() {
    if (!statusSelect || !emailInput) return;
    const needsEmail = statusSelect.value !== 'prospect';
    emailInput.required = needsEmail;
    if (emailReq) emailReq.style.visibility = needsEmail ? 'visible' : 'hidden';
  }
  statusSelect?.addEventListener('change', syncEmailRequirement);
  syncEmailRequirement();
</script>

<style>
.success-alert {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  background: oklch(0.96 0.04 145);
  border: 1px solid oklch(0.88 0.08 145);
  border-radius: var(--radius-md);
  color: oklch(0.35 0.12 145);
  padding: var(--space-3) var(--space-4);
  font-size: var(--text-sm);
  margin-bottom: var(--space-5);
}
.success-alert svg { flex-shrink: 0; }

.error-alert {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  background: oklch(0.97 0.03 25);
  border: 1px solid oklch(0.88 0.07 25);
  border-radius: var(--radius-md);
  color: oklch(0.46 0.18 25);
  padding: var(--space-3) var(--space-4);
  font-size: var(--text-sm);
  margin-bottom: var(--space-5);
}
.error-alert svg { flex-shrink: 0; }

.pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  margin-top: var(--space-5);
}

.page-btn {
  padding: 6px 14px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
  text-decoration: none;
  background: var(--color-bg);
  transition: border-color var(--dur-fast), background var(--dur-fast);
}
.page-btn:hover { border-color: var(--color-border-strong); background: var(--color-surface); }

.page-info {
  font-size: var(--text-sm);
  color: var(--color-muted);
}

.pending-alert {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  background: oklch(0.96 0.04 75);
  border: 1px solid oklch(0.88 0.09 75);
  border-radius: var(--radius-md);
