---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

// Handle status update or notes
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const id     = data.get('id')     as string;
  const status = data.get('status') as string;
  const notes  = data.get('notes')  as string | null;

  if (id && status) {
    await supabaseAdmin
      .from('contact_requests')
      .update({ status, notes: notes ?? null })
      .eq('id', id);
  }
  return Astro.redirect('/admin/contacts');
}

const { data: contacts } = await supabaseAdmin
  .from('contact_requests')
  .select('*')
  .order('created_at', { ascending: false });

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: '2-digit' });
}

const STATUS_OPTS = [
  { value: 'nouveau',   label: 'Nouveau'  },
  { value: 'contacte',  label: 'Contacté' },
  { value: 'converti',  label: 'Converti' },
  { value: 'rejete',    label: 'Rejeté'   },
];
---
<AdminLayout title="Contacts" activeNav="contacts">
  {contacts && contacts.length > 0 ? (
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Nom</th>
            <th>Société</th>
            <th>Téléphone</th>
            <th>Statut</th>
            <th>Date</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          {contacts.map(c => (
            <tr>
              <td class="td-strong">{c.nom}</td>
              <td>{c.societe ?? '—'}</td>
              <td class="td-mono">{c.telephone ?? '—'}</td>
              <td>
                <form method="post" class="inline-form">
                  <input type="hidden" name="id"    value={c.id} />
                  <input type="hidden" name="notes" value={c.notes ?? ''} />
                  <select
                    name="status"
                    class={`status-select status-select--${c.status}`}
                    onchange="this.form.submit()"
                    aria-label="Changer le statut"
                  >
                    {STATUS_OPTS.map(opt => (
                      <option value={opt.value} selected={c.status === opt.value}>
                        {opt.label}
                      </option>
                    ))}
                  </select>
                </form>
              </td>
              <td class="td-muted">{formatDate(c.created_at)}</td>
              <td>
                <form method="post" class="notes-form">
                  <input type="hidden" name="id"     value={c.id} />
                  <input type="hidden" name="status" value={c.status} />
                  <input
                    type="text"
                    name="notes"
                    class="notes-input"
                    value={c.notes ?? ''}
                    placeholder="Ajouter une note…"
                    aria-label="Notes"
                  />
                  <button type="submit" class="notes-save" aria-label="Enregistrer la note">✓</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : (
    <div class="empty-state">
      <p class="empty-title">Aucune demande reçue.</p>
      <p class="empty-body">Les demandes soumises via le formulaire du site apparaîtront ici.</p>
    </div>
  )}
</AdminLayout>

<style>
.table-wrap {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow-x: auto;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--text-sm);
}

.data-table thead th {
  padding: var(--space-3) var(--space-4);
  text-align: left;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-bottom: 1px solid var(--color-border);
  white-space: nowrap;
}

.data-table tbody td {
  padding: var(--space-3) var(--space-4);
  border-bottom: 1px solid var(--color-border);
  vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover td { background: var(--color-surface); }

.td-strong { font-weight: 500; color: var(--color-ink); white-space: nowrap; }
.td-muted  { color: var(--color-muted); white-space: nowrap; }
.td-mono   { font-family: var(--font-mono); }

.inline-form { display: contents; }

.status-select {
  padding: 3px 8px;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 500;
  border: 1.5px solid transparent;
  cursor: pointer;
  outline: none;
  appearance: none;
  -webkit-appearance: none;
}
.status-select:focus { outline: 2px solid var(--color-primary); outline-offset: 2px; }
.status-select--nouveau   { background: oklch(0.95 0.02 220); color: oklch(0.35 0.08 220); }
.status-select--contacte  { background: oklch(0.95 0.04 60);  color: oklch(0.45 0.10 60);  }
.status-select--converti  { background: oklch(0.93 0.06 145); color: oklch(0.38 0.12 145); }
.status-select--rejete    { background: oklch(0.95 0.02 25);  color: oklch(0.45 0.10 25);  }

.notes-form {
  display: flex;
  gap: var(--space-2);
  align-items: center;
  min-width: 180px;
}

.notes-input {
  flex: 1;
  padding: 4px 8px;
  font-family: var(--font-body);
  font-size: var(--text-xs);
  color: var(--color-ink);
  background: var(--color-surface);
  border: 1px solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  min-height: 30px;
  outline: none;
  transition: border-color var(--dur-fast);
}
.notes-input:focus { border-color: var(--color-primary); }
.notes-input::placeholder { color: var(--color-muted); }

.notes-save {
  flex-shrink: 0;
  padding: 4px 8px;
  background: var(--color-surface-2);
  border: 1px solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  color: var(--color-muted);
  cursor: pointer;
  font-size: var(--text-xs);
  min-height: 30px;
  transition: color var(--dur-fast), background var(--dur-fast);
}
.notes-save:hover { color: var(--color-ink); background: var(--color-border); }

.empty-state {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-16) var(--space-8);
  text-align: center;
}
.empty-title { font-weight: 600; color: var(--color-ink); margin-bottom: var(--space-2); }
.empty-body  { color: var(--color-muted); }
</style>
