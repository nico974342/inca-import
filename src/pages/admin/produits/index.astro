---
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../../lib/supabase';
import { marginColorClass, computeGmroi, gmroiColorClass, computeStockRotation, rotationColorClass } from '../../../lib/constants';

const REVENUE_STATUSES = ['confirmee', 'en_preparation', 'expediee', 'livree'];

const { data: products, error } = await supabaseAdmin
  .from('products')
  .select('id, name, category, sku, price_ht, unit, in_stock, stock_quantity, position, prix_achat_moyen_ht')
  .order('position', { ascending: true })
  .order('name', { ascending: true });

// ── GMROI + rotation: both derive from the same 12-month order_items pull —
//    GMROI's numerator is gross margin (qty × (price − PUMP)), rotation's
//    is cost of goods sold (qty × PUMP) — same denominator (stock value). ──
const twelveMonthsAgoIso = new Date(new Date().setMonth(new Date().getMonth() - 12)).toISOString();
const { data: marginRows } = await supabaseAdmin
  .from('order_items')
  .select('product_id, quantity, price_ht_snapshot, pump_snapshot, orders!inner(status, created_at)')
  .in('orders.status', REVENUE_STATUSES)
  .gte('orders.created_at', twelveMonthsAgoIso);

const margin12moByProduct = new Map<string, number>();
const cogs12moByProduct = new Map<string, number>();
for (const row of (marginRows ?? [])) {
  if (!row.product_id) continue;
  const prix = row.price_ht_snapshot != null ? Number(row.price_ht_snapshot) : null;
  const pump = row.pump_snapshot != null ? Number(row.pump_snapshot) : null;
  if (prix == null || pump == null) continue;
  margin12moByProduct.set(row.product_id, (margin12moByProduct.get(row.product_id) ?? 0) + (prix - pump) * row.quantity);
  cogs12moByProduct.set(row.product_id, (cogs12moByProduct.get(row.product_id) ?? 0) + pump * row.quantity);
}

function productGmroi(p: { id: string; stock_quantity: number | null; prix_achat_moyen_ht: number | null }): number | null {
  return computeGmroi(p.stock_quantity, p.prix_achat_moyen_ht, margin12moByProduct.get(p.id) ?? null);
}

function productRotation(p: { id: string; stock_quantity: number | null; prix_achat_moyen_ht: number | null }): number | null {
  return computeStockRotation(p.stock_quantity, p.prix_achat_moyen_ht, cogs12moByProduct.get(p.id) ?? null);
}

const CAT_LABEL: Record<string, string> = {
  boissons: 'Boissons',
  snacks: 'Snacks',
  confiseries: 'Confiseries',
  divers: 'Divers',
};
const CATEGORIES = ['boissons', 'snacks', 'confiseries', 'divers'];

// ── Filter by "famille de produit" (category) ─────────────────────────────
const filterCat = Astro.url.searchParams.get('cat') ?? '';
const catCounts: Record<string, number> = {};
for (const c of CATEGORIES) catCounts[c] = 0;
for (const p of (products ?? [])) catCounts[p.category] = (catCounts[p.category] ?? 0) + 1;

const filteredProducts = filterCat
  ? (products ?? []).filter(p => p.category === filterCat)
  : (products ?? []);

// ── Sortable columns ───────────────────────────────────────────────────
// Marge/GMROI/rotation are computed values, so sorting happens in-memory
// here rather than pushed down to the DB query.
const SORT_KEYS = ['nom', 'categorie', 'prix', 'stock', 'marge', 'gmroi', 'rotation'] as const;
type SortKey = (typeof SORT_KEYS)[number];

const sortParam = Astro.url.searchParams.get('sort') ?? '';
const currentSort: SortKey | '' = (SORT_KEYS as readonly string[]).includes(sortParam) ? (sortParam as SortKey) : '';
const currentDir: 'asc' | 'desc' = Astro.url.searchParams.get('dir') === 'desc' ? 'desc' : 'asc';

function sortUrl(key: SortKey): string {
  const params = new URLSearchParams(Astro.url.searchParams);
  params.delete('delete_error');
  const nextDir = currentSort === key && currentDir === 'asc' ? 'desc' : 'asc';
  params.set('sort', key);
  params.set('dir', nextDir);
  return `/admin/produits?${params.toString()}`;
}

function catUrl(cat: string): string {
  const params = new URLSearchParams(Astro.url.searchParams);
  params.delete('delete_error');
  if (cat) params.set('cat', cat); else params.delete('cat');
  const qs = params.toString();
  return `/admin/produits${qs ? `?${qs}` : ''}`;
}

const rows = filteredProducts.map(p => {
  const pump = (p as any).prix_achat_moyen_ht ?? null;
  const prix = p.price_ht ?? null;
  const margePct = pump == null || prix == null || prix === 0 ? null : ((prix - pump) / prix) * 100;
  return { ...p, margePct, gmroi: productGmroi(p as any), rotation: productRotation(p as any) };
});

// Nulls (no data yet — "—") always sort to the bottom, regardless of direction.
function compareNullableNumber(a: number | null, b: number | null, dir: 1 | -1): number {
  if (a == null && b == null) return 0;
  if (a == null) return 1;
  if (b == null) return -1;
  return dir * (a - b);
}

if (currentSort) {
  const dir = currentDir === 'asc' ? 1 : -1;
  rows.sort((a, b) => {
    switch (currentSort) {
      case 'nom':       return dir * a.name.localeCompare(b.name, 'fr');
      case 'categorie': return dir * (CAT_LABEL[a.category] ?? a.category).localeCompare(CAT_LABEL[b.category] ?? b.category, 'fr');
      case 'prix':      return compareNullableNumber(a.price_ht, b.price_ht, dir as 1 | -1);
      case 'stock':     return compareNullableNumber(a.stock_quantity, b.stock_quantity, dir as 1 | -1);
      case 'marge':     return compareNullableNumber(a.margePct, b.margePct, dir as 1 | -1);
      case 'gmroi':     return compareNullableNumber(a.gmroi, b.gmroi, dir as 1 | -1);
      case 'rotation':  return compareNullableNumber(a.rotation, b.rotation, dir as 1 | -1);
      default:          return 0;
    }
  });
}

function formatPrice(p: number | null) {
  if (p == null) return '—';
  return p.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR' });
}

function margeClass(marge: number | null): string {
  return `marge--${marginColorClass(marge)}`;
}

function margeInfo(pct: number | null): { label: string; cls: string } {
  if (pct == null) return { label: '—', cls: 'marge--none' };
  return { label: pct.toFixed(1) + '%', cls: margeClass(pct) };
}

const deleteError = Astro.url.searchParams.get('delete_error');
const DELETE_ERROR_MSG: Record<string, string> = {
  reference:   'Suppression impossible : ce produit est référencé par des réceptions ou des paniers. Passez-le plutôt en rupture de stock.',
  introuvable: 'Produit introuvable — il a peut-être déjà été supprimé.',
  erreur:      'La suppression a échoué. Veuillez réessayer.',
};
---
<AdminLayout title="Produits" activeNav="produits">
  {deleteError && (
    <div class="alert-delete-error" role="alert">
      {DELETE_ERROR_MSG[deleteError] ?? DELETE_ERROR_MSG.erreur}
    </div>
  )}
  <div class="toolbar">
    <a href="/admin/produits/new" class="btn btn-primary">+ Nouveau produit</a>
  </div>

  <div class="filter-bar">
    <a href={catUrl('')} class={`filter-tab ${!filterCat ? 'filter-tab--active' : ''}`}>
      Tous
      <span class="filter-count">{(products ?? []).length}</span>
    </a>
    {CATEGORIES.map(c => (
      <a href={catUrl(c)} class={`filter-tab ${filterCat === c ? 'filter-tab--active' : ''}`}>
        {CAT_LABEL[c]}
        {catCounts[c] > 0 && <span class="filter-count">{catCounts[c]}</span>}
      </a>
    ))}
  </div>

  {rows && rows.length > 0 ? (
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>
              <a href={sortUrl('nom')} class={`th-sort ${currentSort === 'nom' ? 'th-sort--active' : ''}`}>
                Nom
                {currentSort === 'nom' && <span class="sort-arrow">{currentDir === 'asc' ? '▲' : '▼'}</span>}
              </a>
            </th>
            <th>
              <a href={sortUrl('categorie')} class={`th-sort ${currentSort === 'categorie' ? 'th-sort--active' : ''}`}>
                Catégorie
                {currentSort === 'categorie' && <span class="sort-arrow">{currentDir === 'asc' ? '▲' : '▼'}</span>}
              </a>
            </th>
            <th>SKU</th>
            <th>
              <a href={sortUrl('prix')} class={`th-sort ${currentSort === 'prix' ? 'th-sort--active' : ''}`}>
                Prix HT
                {currentSort === 'prix' && <span class="sort-arrow">{currentDir === 'asc' ? '▲' : '▼'}</span>}
              </a>
            </th>
            <th>Coût moy. HT</th>
            <th>
              <a href={sortUrl('marge')} class={`th-sort ${currentSort === 'marge' ? 'th-sort--active' : ''}`}>
                Marge
                {currentSort === 'marge' && <span class="sort-arrow">{currentDir === 'asc' ? '▲' : '▼'}</span>}
              </a>
            </th>
            <th>
              <a href={sortUrl('gmroi')} class={`th-sort ${currentSort === 'gmroi' ? 'th-sort--active' : ''}`}>
                GMROI
                {currentSort === 'gmroi' && <span class="sort-arrow">{currentDir === 'asc' ? '▲' : '▼'}</span>}
              </a>
              <span
                class="help-icon"
                tabindex="0"
                title="Combien vous rapporte chaque euro immobilisé en stock sur ce produit. GMROI = marge brute générée sur 12 mois ÷ valeur du stock actuel (stock × coût moyen). > 2 = excellent, 1-2 = correct, < 1 = ce produit immobilise plus de capital qu'il ne rapporte."
              >?</span>
            </th>
            <th>
              <a href={sortUrl('rotation')} class={`th-sort ${currentSort === 'rotation' ? 'th-sort--active' : ''}`}>
                Rotation
                {currentSort === 'rotation' && <span class="sort-arrow">{currentDir === 'asc' ? '▲' : '▼'}</span>}
              </a>
              <span
                class="help-icon"
                tabindex="0"
                title="Combien de fois votre stock se renouvelle par an sur ce produit. Rotation = coût des ventes sur 12 mois ÷ valeur du stock actuel. > 6x/an = excellent, 3-6x/an = correct, < 3x/an = stock qui tourne lentement, capital immobilisé trop longtemps."
              >?</span>
            </th>
            <th>
              <a href={sortUrl('stock')} class={`th-sort ${currentSort === 'stock' ? 'th-sort--active' : ''}`}>
                Stock
                {currentSort === 'stock' && <span class="sort-arrow">{currentDir === 'asc' ? '▲' : '▼'}</span>}
              </a>
            </th>
            <th>Pos.</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {rows.map(p => (
            <tr>
              <td class="td-strong">{p.name}</td>
              <td>
                <span class={`badge badge--${p.category}`}>
                  {CAT_LABEL[p.category] ?? p.category}
                </span>
              </td>
              <td class="td-mono">{p.sku ?? '—'}</td>
              <td class="td-mono">{formatPrice(p.price_ht)}</td>
              <td class="td-mono td-muted">{formatPrice((p as any).prix_achat_moyen_ht ?? null)}</td>
              {(() => {
                const mi = margeInfo(p.margePct);
                return <td><span class={`marge-chip ${mi.cls}`}>{mi.label}</span></td>;
              })()}
              <td>
                <span class={`marge-chip marge--${gmroiColorClass(p.gmroi)}`}>
                  {p.gmroi != null ? p.gmroi.toFixed(1) + '×' : '—'}
                </span>
              </td>
              <td>
                <span class={`marge-chip marge--${rotationColorClass(p.rotation)}`}>
                  {p.rotation != null ? p.rotation.toFixed(1) + 'x/an' : '—'}
                </span>
              </td>
              <td>
                {(p.stock_quantity ?? 0) === 0 ? (
                  <span class="stock-chip stock-chip--out">Rupture</span>
                ) : (p.stock_quantity ?? 0) < 5 ? (
                  <span class="stock-chip stock-chip--low" title="Stock bas">{p.stock_quantity}</span>
                ) : (
                  <span class="stock-chip stock-chip--ok">{p.stock_quantity}</span>
                )}
              </td>
              <td class="td-muted">{p.position}</td>
              <td class="td-actions">
                <div class="actions-inner">
                  <a href={`/admin/produits/${p.id}/edit`} class="action-link">Modifier</a>
                  <form
                    action={`/api/produits/${p.id}/delete`}
                    method="post"
                    class="delete-form"
                    onsubmit="return confirm('Supprimer ce produit ?')"
                  >
                    <button type="submit" class="action-link action-link--danger">Supprimer</button>
                  </form>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  ) : filterCat ? (
    <div class="empty-state">
      <p class="empty-title">Aucun produit dans "{CAT_LABEL[filterCat] ?? filterCat}".</p>
      <p class="empty-body">Essayez une autre famille de produit ou affichez tous les produits.</p>
      <a href="/admin/produits" class="btn btn-primary" style="margin-top: var(--space-5)">Voir tous les produits</a>
    </div>
  ) : (
    <div class="empty-state">
      <p class="empty-title">Aucun produit encore.</p>
      <p class="empty-body">Ajoutez votre premier produit pour le voir apparaître dans le catalogue.</p>
      <a href="/admin/produits/new" class="btn btn-primary" style="margin-top: var(--space-5)">+ Ajouter un produit</a>
    </div>
  )}
</AdminLayout>

<style>
.alert-delete-error {
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-5);
  font-size: var(--text-sm);
  color: oklch(0.46 0.18 25);
  background: oklch(0.97 0.03 25);
  border: 1px solid oklch(0.88 0.07 25);
  border-radius: var(--radius-sm);
}

.toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: var(--space-5);
}

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-bottom: var(--space-4);
}
.filter-tab {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-1) var(--space-3);
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-muted);
  text-decoration: none;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-full);
  background: var(--color-bg);
  transition: all var(--dur-fast);
}
.filter-tab:hover { color: var(--color-ink); border-color: var(--color-border-strong); }
.filter-tab--active {
  color: var(--color-ink);
  background: var(--color-surface-2);
  border-color: var(--color-border-strong);
  font-weight: 600;
}
.filter-count {
  font-size: 0.6875rem;
  font-weight: 700;
  color: var(--color-muted);
  background: var(--color-surface);
  padding: 1px 5px;
  border-radius: 99px;
  border: 1px solid var(--color-border);
  min-width: 18px;
  text-align: center;
}

.table-wrap {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow-x: auto;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--text-sm);
}

.data-table thead th {
  padding: var(--space-3) var(--space-4);
  text-align: left;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-bottom: 1px solid var(--color-border);
  white-space: nowrap;
}

.th-sort {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: inherit;
  text-decoration: none;
  cursor: pointer;
}
.th-sort:hover { color: var(--color-ink); }
.th-sort--active { color: var(--color-ink); }
.sort-arrow {
  font-size: 0.625rem;
  color: var(--color-primary-deep);
}

.help-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 14px;
  height: 14px;
  margin-left: 4px;
  border-radius: 50%;
  background: var(--color-surface-2);
  color: var(--color-muted);
  font-size: 0.625rem;
  font-weight: 700;
  text-transform: none;
  letter-spacing: normal;
  cursor: help;
  vertical-align: middle;
}

.data-table tbody td {
  padding: var(--space-3) var(--space-4);
  border-bottom: 1px solid var(--color-border);
  vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover td { background: var(--color-surface); }

.td-strong { font-weight: 500; color: var(--color-ink); }
.td-muted  { color: var(--color-muted); }
.td-mono   { font-family: var(--font-mono); color: var(--color-ink); }
.td-actions { white-space: nowrap; }
.actions-inner {
  display: flex;
  gap: var(--space-4);
  align-items: center;
}

.badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 500;
  white-space: nowrap;
}
.badge--boissons    { background: oklch(0.93 0.05 220); color: oklch(0.35 0.10 220); }
.badge--snacks      { background: oklch(0.94 0.05 60);  color: oklch(0.40 0.12 60);  }
.badge--confiseries { background: oklch(0.93 0.06 330); color: oklch(0.40 0.12 330); }
.badge--divers      { background: oklch(0.93 0.05 275); color: oklch(0.40 0.12 275); }

.marge-chip {
  display: inline-flex;
  align-items: center;
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  font-weight: 600;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  white-space: nowrap;
}
.marge--none  { background: var(--color-surface-2); color: var(--color-muted); }
.marge--green { background: oklch(0.92 0.08 145); color: oklch(0.32 0.14 145); }
.marge--amber { background: oklch(0.95 0.07 60);  color: oklch(0.38 0.15 55);  }
.marge--red   { background: oklch(0.95 0.04 25);  color: oklch(0.46 0.18 25);  }

.stock-chip {
  display: inline-flex;
  align-items: center;
  font-size: var(--text-xs);
  font-weight: 600;
  padding: 2px 9px;
  border-radius: var(--radius-full);
  white-space: nowrap;
}
.stock-chip--ok  { background: oklch(0.92 0.08 145); color: oklch(0.32 0.14 145); }
.stock-chip--low { background: oklch(0.95 0.07 60);  color: oklch(0.38 0.15 55);  }
.stock-chip--out { background: oklch(0.95 0.04 25);  color: oklch(0.46 0.18 25);  }

.action-link {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-primary-deep);
  text-decoration: none;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  font-family: inherit;
  line-height: inherit;
}
.action-link:hover { text-decoration: underline; }
.action-link--danger { color: oklch(0.50 0.19 25); }

.delete-form { display: contents; }

.empty-state {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-16) var(--space-8);
  text-align: center;
}
.empty-title { font-weight: 600; color: var(--color-ink); margin-bottom: var(--space-2); }
.empty-body  { color: var(--color-muted); }
</style>
