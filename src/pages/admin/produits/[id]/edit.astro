---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../../../lib/supabase';
import { logAdminAction } from '../../../../lib/audit';
import { marginColorClass } from '../../../../lib/constants';

const { id } = Astro.params;
let formError = '';

const { data: product } = await supabaseAdmin
  .from('products')
  .select('*')
  .eq('id', id)
  .single();

if (!product) return Astro.redirect('/admin/produits');

// Purchase history for this product
const { data: purchaseHistory } = await supabaseAdmin
  .from('stock_reception_items')
  .select('quantity, unit_cost_ht, stock_receptions(supplier_name, received_at, stock_applied)')
  .eq('product_id', id)
  .order('created_at', { ascending: false })
  .limit(50);

const pump = (product as any).prix_achat_moyen_ht as number | null;

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const name        = (data.get('name')        as string)?.trim();
  const slug        = (data.get('slug')        as string)?.trim();
  const category    = (data.get('category')    as string)?.trim();
  const description = (data.get('description') as string)?.trim() || null;
  const sku         = (data.get('sku')         as string)?.trim() || null;
  const price_ht         = data.get('price_ht')         ? parseFloat(data.get('price_ht') as string) : null;
  const tva_preset       = data.get('tva_preset') as string;
  const tva_manual_str   = data.get('tva_manual')  as string;
  let   tva_rate: number = 0.085;
  if (tva_preset === '0.021') tva_rate = 0.021;
  else if (tva_preset === 'custom' && tva_manual_str) {
    const p = parseFloat(tva_manual_str.replace(',', '.')) / 100;
    if (!isNaN(p) && p >= 0 && p <= 1) tva_rate = p;
  }
  const unit             = (data.get('unit')             as string)?.trim() || 'carton';
  const units_per_carton = data.get('units_per_carton')  ? parseInt(data.get('units_per_carton') as string, 10) || null : null;
  const image_url        = (data.get('image_url')        as string)?.trim() || null;
  const position       = data.get('position') ? parseInt(data.get('position') as string) : 0;
  const stock_quantity = data.get('stock_quantity') ? parseInt(data.get('stock_quantity') as string, 10) : 0;
  const in_stock       = stock_quantity > 0;

  if (!name || !slug || !category) {
    formError = 'Le nom, le slug et la catégorie sont requis.';
  } else {
    const { error } = await supabaseAdmin
      .from('products')
      .update({ name, slug, category, description, sku, price_ht, tva_rate, unit, units_per_carton, image_url, in_stock, position, stock_quantity })
      .eq('id', id);

    if (error) {
      formError = error.code === '23505'
        ? 'Ce slug existe déjà. Choisissez-en un autre.'
        : `Erreur : ${error.message}`;
    } else {
      await logAdminAction({
        adminEmail: (Astro.locals as any).user?.email ?? 'inconnu',
        action: 'produit.modification',
        targetType: 'produit',
        targetId: id!,
        targetLabel: name,
      });
      return Astro.redirect('/admin/produits');
    }
  }
}
---
<AdminLayout title={`Modifier — ${product.name}`} activeNav="produits">
  <div class="form-shell">
    <div class="form-card">
      {formError && <p class="form-error" role="alert">{formError}</p>}

      <form method="post" class="prod-form" novalidate>
        <div class="field-group">
          <div class="field">
            <label for="name">Nom <span class="required">*</span></label>
            <input type="text" id="name" name="name" required value={product.name} />
          </div>
          <div class="field">
            <label for="slug">Slug <span class="required">*</span></label>
            <input type="text" id="slug" name="slug" required value={product.slug} />
          </div>
        </div>

        <div class="field-group">
          <div class="field">
            <label for="category">Catégorie <span class="required">*</span></label>
            <select id="category" name="category" required>
              <option value="boissons"    selected={product.category === 'boissons'}>Boissons</option>
              <option value="snacks"      selected={product.category === 'snacks'}>Snacks</option>
              <option value="confiseries" selected={product.category === 'confiseries'}>Confiseries</option>
              <option value="divers"      selected={product.category === 'divers'}>Divers</option>
            </select>
          </div>
          <div class="field">
            <label for="sku">SKU</label>
            <input type="text" id="sku" name="sku" value={product.sku ?? ''} placeholder="REF-001" />
          </div>
        </div>

        <div class="field">
          <label for="description">Description</label>
          <textarea id="description" name="description" rows="3">{product.description ?? ''}</textarea>
        </div>

        <div class="field-group field-group--3">
          <div class="field">
            <label for="price_ht">Prix HT (€)</label>
            <input type="number" id="price_ht" name="price_ht" step="0.01" min="0" value={product.price_ht ?? ''} />
          </div>
          <div class="field">
            <label for="unit">Unité</label>
            <input type="text" id="unit" name="unit" value={product.unit ?? 'carton'} />
          </div>
          <div class="field">
            <label for="units_per_carton">Unités par carton</label>
            <input type="number" id="units_per_carton" name="units_per_carton" min="1" value={product.units_per_carton ?? ''} placeholder="ex : 24" />
          </div>
        </div>

        {(() => {
          const rate    = (product as any).tva_rate ?? 0.085;
          const preset  = rate === 0.085 ? '0.085' : rate === 0.021 ? '0.021' : 'custom';
          const manPct  = preset === 'custom' ? (rate * 100).toFixed(2) : '';
          return (
            <div class="field-group tva-row">
              <div class="field">
                <label for="tva_preset">Taux de TVA</label>
                <select id="tva_preset" name="tva_preset" data-tva-select>
                  <option value="0.085" selected={preset === '0.085'}>8,5 %</option>
                  <option value="0.021" selected={preset === '0.021'}>2,1 %</option>
                  <option value="custom"  selected={preset === 'custom'}>Manuel…</option>
                </select>
              </div>
              <div class={`field tva-manual-field${preset !== 'custom' ? ' tva-manual-hidden' : ''}`} data-tva-manual-field>
                <label for="tva_manual">Taux personnalisé (%)</label>
                <input type="number" id="tva_manual" name="tva_manual" min="0" max="100" step="0.01"
                  placeholder="ex: 3.50" value={manPct} />
              </div>
            </div>
          );
        })()}

        <div class="field">
          <label for="image_url">URL de l'image</label>
          <input type="url" id="image_url" name="image_url" value={product.image_url ?? ''} placeholder="https://…" />
        </div>

        <div class="field">
          <label for="image_file">Ou téléverser une image (JPEG, PNG, WEBP — max 5 Mo)</label>
          <input type="file" id="image_file" accept="image/jpeg,image/png,image/webp" />
          <p class="upload-status" id="uploadStatus"></p>
        </div>

        <div class="image-preview-wrap" id="imagePreviewWrap" style={product.image_url ? '' : 'display:none'}>
          <img id="imagePreview" src={product.image_url ?? ''} alt="Aperçu de l'image produit" class="image-preview" />
        </div>

        <div class="field-group field-group--3">
          <div class="field">
            <label for="stock_quantity">Quantité en stock</label>
            <input type="number" id="stock_quantity" name="stock_quantity" min="0" value={product.stock_quantity ?? 0} />
          </div>
          <div class="field">
            <label>Disponibilité</label>
            <div class="status-display" id="stockStatus">
              {(product.stock_quantity ?? 0) > 0
                ? <span class="status-badge status-badge--ok">En stock</span>
                : <span class="status-badge status-badge--out">Rupture de stock</span>
              }
            </div>
          </div>
          <div class="field">
            <label for="position">Position</label>
            <input type="number" id="position" name="position" min="0" value={product.position ?? 0} />
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Enregistrer</button>
          <a href="/admin/produits" class="btn btn-ghost">Annuler</a>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Achats & Coût PUMP ──────────────────────────────────────────── -->
  <div class="pump-shell">
    <div class="pump-header">
      <h2 class="pump-title">Achats &amp; Coût</h2>
      <a href={`/admin/reception/new`} class="btn btn-ghost btn-sm">+ Enregistrer une réception</a>
    </div>

    <div class="pump-stat-row">
      <div class="pump-stat">
        <span class="pump-stat-label">Prix de vente HT</span>
        <span class="pump-stat-value">
          {(product as any).price_ht != null
            ? Number((product as any).price_ht).toLocaleString('fr-FR', { style: 'currency', currency: 'EUR' })
            : '—'}
        </span>
      </div>
      <div class="pump-stat">
        <span class="pump-stat-label">Coût moyen pondéré (PUMP)</span>
        <span class="pump-stat-value pump-stat-value--pump">
          {pump != null
            ? pump.toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', minimumFractionDigits: 4, maximumFractionDigits: 4 })
            : <span class="pump-none">Non calculé</span>}
        </span>
      </div>
      {pump != null && (product as any).price_ht != null && (
        (() => {
          const marge = ((Number((product as any).price_ht) - pump) / Number((product as any).price_ht)) * 100;
          const cls   = marginColorClass(marge);
          return (
            <div class="pump-stat">
              <span class="pump-stat-label">Marge</span>
              <span class={`pump-marge pump-marge--${cls}`}>{marge.toFixed(1)} %</span>
            </div>
          );
        })()
      )}
    </div>

    {(purchaseHistory ?? []).length === 0 ? (
      <p class="pump-empty">Aucun achat enregistré pour ce produit.</p>
    ) : (
      <table class="pump-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Fournisseur</th>
            <th class="th-num">Qté</th>
            <th class="th-num">Coût unitaire HT</th>
            <th class="th-num">Total HT</th>
            <th>Stock</th>
          </tr>
        </thead>
        <tbody>
          {(purchaseHistory ?? []).map((h: any) => {
            const rec = h.stock_receptions ?? {};
            return (
              <tr>
                <td class="td-date">{new Date(rec.received_at).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: 'numeric' })}</td>
                <td class="td-supplier">{rec.supplier_name ?? '—'}</td>
                <td class="td-num">{h.quantity}</td>
                <td class="td-num">{Number(h.unit_cost_ht).toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', minimumFractionDigits: 2 })}</td>
                <td class="td-num">{(h.quantity * h.unit_cost_ht).toLocaleString('fr-FR', { style: 'currency', currency: 'EUR', minimumFractionDigits: 2 })}</td>
                <td>
                  {rec.stock_applied
                    ? <span class="rec-chip rec-chip--live">Stock appliqué</span>
                    : <span class="rec-chip rec-chip--histo">Historique</span>}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>

<style>
.form-shell { max-width: 720px; }

/* ── PUMP / Achats section ──────────────────────────────── */
.pump-shell {
  max-width: 720px;
  margin-top: var(--space-6);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.pump-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-6);
  border-bottom: 1px solid var(--color-border);
  background: var(--color-surface);
}

.pump-title {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-ink);
  margin: 0;
}

.btn {
  display: inline-flex;
  align-items: center;
  padding: var(--space-2) var(--space-4);
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
  font-weight: 600;
  text-decoration: none;
  border: 1px solid var(--color-border);
  background: var(--color-bg);
  color: var(--color-ink);
  cursor: pointer;
  transition: background var(--dur-fast);
}
.btn:hover { background: var(--color-surface-2); }
.btn-sm { font-size: var(--text-xs); padding: 5px 12px; }

.pump-stat-row {
  display: flex;
  gap: var(--space-6);
  padding: var(--space-5) var(--space-6);
  border-bottom: 1px solid var(--color-border);
  flex-wrap: wrap;
}

.pump-stat { display: flex; flex-direction: column; gap: var(--space-1); }

.pump-stat-label {
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-muted);
  white-space: nowrap;
}

.pump-stat-value {
  font-family: var(--font-mono);
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-ink);
}

.pump-stat-value--pump { color: oklch(0.38 0.12 220); }

.pump-none {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 400;
  color: var(--color-muted);
  font-style: italic;
}

.pump-marge {
  font-family: var(--font-mono);
  font-size: var(--text-lg);
  font-weight: 700;
  padding: 2px 10px;
  border-radius: var(--radius-full);
  display: inline-block;
}
.pump-marge--green { background: oklch(0.92 0.08 145); color: oklch(0.32 0.14 145); }
.pump-marge--amber { background: oklch(0.95 0.07 60);  color: oklch(0.38 0.15 55);  }
.pump-marge--red   { background: oklch(0.95 0.04 25);  color: oklch(0.46 0.18 25);  }

.pump-empty {
  padding: var(--space-6) var(--space-6);
  font-size: var(--text-sm);
  color: var(--color-muted);
  font-style: italic;
  margin: 0;
}

.pump-table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--text-sm);
}

.pump-table thead th {
  padding: var(--space-2) var(--space-4);
  text-align: left;
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-muted);
  background: var(--color-surface);
  border-bottom: 1px solid var(--color-border);
}
.pump-table .th-num { text-align: right; }

.pump-table tbody td {
  padding: var(--space-3) var(--space-4);
  border-bottom: 1px solid var(--color-border);
  color: var(--color-ink);
}
.pump-table tbody tr:last-child td { border-bottom: none; }
.pump-table tbody tr:hover td { background: var(--color-surface); }

.td-date     { white-space: nowrap; font-size: var(--text-xs); color: var(--color-muted); }
.td-supplier { font-weight: 500; }
.td-num      { font-family: var(--font-mono); text-align: right; }

.rec-chip {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: 500;
  padding: 2px 8px;
  border-radius: var(--radius-full);
}
.rec-chip--live  { background: oklch(0.92 0.08 145); color: oklch(0.32 0.14 145); }
.rec-chip--histo { background: oklch(0.95 0.06 75);  color: oklch(0.36 0.12 75);  }

.form-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-8);
}

.form-error {
  font-size: var(--text-sm);
  color: oklch(0.50 0.19 25);
  background: oklch(0.97 0.04 25);
  border: 1px solid oklch(0.88 0.07 25);
  border-radius: var(--radius-sm);
  padding: var(--space-3) var(--space-4);
  margin-bottom: var(--space-6);
}

.prod-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.field-group {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
}

.field {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

label {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
}

.required { color: var(--color-primary); }

input[type="text"],
input[type="url"],
input[type="number"],
select,
textarea {
  width: 100%;
  padding: 0.6875rem 0.875rem;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-ink);
  background: var(--color-bg);
  border: 1.5px solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  min-height: 44px;
  outline: none;
  transition: border-color var(--dur-fast), box-shadow var(--dur-fast);
}
textarea { min-height: 80px; resize: vertical; }
input::placeholder, textarea::placeholder { color: var(--color-muted); }
input:focus, select:focus, textarea:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px oklch(0.568 0.149 45.9 / 0.15);
}

.form-actions {
  display: flex;
  gap: var(--space-3);
  padding-top: var(--space-3);
  border-top: 1px solid var(--color-border);
}

.field-group--3 { grid-template-columns: 1fr 1fr 1fr; }
.tva-row { grid-template-columns: 1fr 1fr; }
.tva-manual-hidden { display: none; }

@media (max-width: 560px) {
  .field-group,
  .field-group--3 { grid-template-columns: 1fr; }
}

.status-display {
  display: flex;
  align-items: center;
  min-height: 44px;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: var(--radius-full);
  font-size: var(--text-sm);
  font-weight: 500;
}
.status-badge--ok  { background: oklch(0.92 0.08 145); color: oklch(0.32 0.14 145); }
.status-badge--out { background: oklch(0.95 0.04 25);  color: oklch(0.46 0.18 25); }

.upload-status {
  margin: 0;
  font-size: var(--text-xs);
  color: var(--color-muted);
  min-height: 1em;
}
.upload-status--error   { color: oklch(0.50 0.19 25); }
.upload-status--success { color: oklch(0.38 0.14 145); }

.image-preview-wrap {
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: var(--space-3);
  background: var(--color-surface);
  align-self: flex-start;
}
.image-preview {
  display: block;
  max-width: 160px;
  max-height: 160px;
  object-fit: contain;
  border-radius: var(--radius-sm);
}
</style>

<script>
const tvaSelect = document.querySelector<HTMLSelectElement>('[data-tva-select]');
const tvaField  = document.querySelector<HTMLElement>('[data-tva-manual-field]');
if (tvaSelect && tvaField) {
  tvaSelect.addEventListener('change', () => {
    tvaField.classList.toggle('tva-manual-hidden', tvaSelect.value !== 'custom');
  });
}

const qtyInput  = document.getElementById('stock_quantity') as HTMLInputElement | null;
const statusEl  = document.getElementById('stockStatus');
if (qtyInput && statusEl) {
  qtyInput.addEventListener('input', () => {
    const qty = parseInt(qtyInput.value) || 0;
    statusEl.innerHTML = qty > 0
      ? '<span class="status-badge status-badge--ok">En stock</span>'
      : '<span class="status-badge status-badge--out">Rupture de stock</span>';
  });
}

// ── Image: URL field or file upload, either populates the same field ──
const imageUrlInput  = document.getElementById('image_url') as HTMLInputElement | null;
const imageFileInput = document.getElementById('image_file') as HTMLInputElement | null;
const uploadStatus   = document.getElementById('uploadStatus') as HTMLElement | null;
const previewWrap    = document.getElementById('imagePreviewWrap') as HTMLElement | null;
const previewImg     = document.getElementById('imagePreview') as HTMLImageElement | null;

function updatePreview() {
  if (!imageUrlInput || !previewWrap || !previewImg) return;
  const url = imageUrlInput.value.trim();
  if (url) { previewImg.src = url; } else { previewWrap.style.display = 'none'; }
}
imageUrlInput?.addEventListener('input', updatePreview);
previewImg?.addEventListener('load',  () => { if (previewWrap) previewWrap.style.display = ''; });
previewImg?.addEventListener('error', () => { if (previewWrap) previewWrap.style.display = 'none'; });

const MAX_IMAGE_SIZE = 5 * 1024 * 1024;
const ALLOWED_IMAGE_TYPES = ['image/jpeg', 'image/png', 'image/webp'];

imageFileInput?.addEventListener('change', async () => {
  const file = imageFileInput.files?.[0];
  if (!file || !uploadStatus) return;

  uploadStatus.textContent = '';
  uploadStatus.className = 'upload-status';

  if (!ALLOWED_IMAGE_TYPES.includes(file.type)) {
    uploadStatus.textContent = 'Format non supporté (JPEG, PNG ou WEBP uniquement).';
    uploadStatus.className = 'upload-status upload-status--error';
    imageFileInput.value = '';
    return;
  }
  if (file.size > MAX_IMAGE_SIZE) {
    uploadStatus.textContent = 'Fichier trop volumineux (max 5 Mo).';
    uploadStatus.className = 'upload-status upload-status--error';
    imageFileInput.value = '';
    return;
  }

  uploadStatus.textContent = 'Téléversement en cours…';

  const fd = new FormData();
  fd.append('image', file);

  try {
    const res  = await fetch('/api/produits/upload-image', { method: 'POST', body: fd });
    const body = await res.json();
    if (!res.ok) {
      uploadStatus.textContent = body.error || 'Erreur lors du téléversement.';
      uploadStatus.className = 'upload-status upload-status--error';
      return;
    }
    if (imageUrlInput) imageUrlInput.value = body.url;
    updatePreview();
    uploadStatus.textContent = 'Image téléversée avec succès.';
    uploadStatus.className = 'upload-status upload-status--success';
  } catch {
    uploadStatus.textContent = 'Erreur réseau lors du téléversement.';
    uploadStatus.className = 'upload-status upload-status--error';
  } finally {
    imageFileInput.value = '';
  }
});
</script>
