---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const now = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1).toISOString();

const [
  { count: totalProduits },
  { count: commandesEnAttente },
  { count: totalClients },
  { count: livraisonsEnAttente },
  { data: recentOrders },
  { data: recentContacts },
  { data: lowStockItems },
  { data: monthOrders },
] = await Promise.all([
  supabaseAdmin.from('products').select('*', { count: 'exact', head: true }),
  supabaseAdmin.from('orders').select('*', { count: 'exact', head: true }).eq('status', 'en_attente'),
  supabaseAdmin.from('client_accounts').select('*', { count: 'exact', head: true }).eq('status', 'actif'),
  supabaseAdmin.from('orders').select('*', { count: 'exact', head: true }).in('status', ['confirmee', 'en_preparation', 'expediee']),
  supabaseAdmin.from('orders').select('id, nom, societe, status, created_at').order('created_at', { ascending: false }).limit(5),
  supabaseAdmin.from('contact_requests').select('id, nom, societe, status, created_at').order('created_at', { ascending: false }).limit(5),
  supabaseAdmin.from('products').select('id, name, stock_quantity').lt('stock_quantity', 5).order('stock_quantity', { ascending: true }).limit(6),
  supabaseAdmin.from('orders').select('id, order_items(quantity, products(price_ht))').in('status', ['confirmee', 'en_preparation', 'expediee', 'livree']).gte('created_at', monthStart),
]);

const caMonth = (monthOrders ?? []).reduce((sum, order) => {
  const orderTotal = ((order as any).order_items ?? []).reduce((s: number, item: any) => {
    return s + Number(item.products?.price_ht ?? 0) * item.quantity;
  }, 0);
  return sum + orderTotal;
}, 0);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: '2-digit' });
}

function formatCA(amount: number): string {
  return new Intl.NumberFormat('fr-FR', {
    style: 'currency', currency: 'EUR',
    minimumFractionDigits: 0, maximumFractionDigits: 0,
  }).format(amount);
}

const ORDER_STATUS_LABEL: Record<string, string> = {
  en_attente:     'En attente',
  confirmee:      'Confirmée',
  en_preparation: 'En prépa.',
  expediee:       'Expédiée',
  livree:         'Livrée',
  annulee:        'Annulée',
};

const ORDER_STATUS_COLOR: Record<string, string> = {
  en_attente:     'blue',
  confirmee:      'amber',
  en_preparation: 'purple',
  expediee:       'coral',
  livree:         'green',
  annulee:        'muted',
};

const CONTACT_LABEL: Record<string, string> = {
  nouveau:  'Nouveau',
  contacte: 'Contacté',
  converti: 'Converti',
  rejete:   'Rejeté',
};

const CONTACT_COLOR: Record<string, string> = {
  nouveau:  'blue',
  contacte: 'amber',
  converti: 'green',
  rejete:   'muted',
};

const hasLowStock        = (lowStockItems ?? []).length > 0;
const hasPendingDelivery = (livraisonsEnAttente ?? 0) > 0;
---
<AdminLayout title="Tableau de bord" activeNav="dashboard">

  <!-- ── Stats row ─────────────────────────────────── -->
  <div class="stats-grid">

    <a href="/admin/stocks" class="stat-card">
      <div class="stat-icon stat-icon--slate">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3 5.5 9 2l6 3.5v5L9 14l-6-3.5v-5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M3 5.5 9 9l6-3.5M9 9v5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="stat-body">
        <span class="stat-value">{totalProduits ?? 0}</span>
        <span class="stat-label">Produits en stock</span>
      </div>
    </a>

    <a href="/admin/commandes?status=en_attente" class="stat-card stat-card--urgent">
      <div class="stat-icon stat-icon--amber">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
          <path d="M9 5v4l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="stat-body">
        <span class="stat-value">{commandesEnAttente ?? 0}</span>
        <span class="stat-label">Commandes en attente</span>
      </div>
    </a>

    <a href="/admin/clients" class="stat-card">
      <div class="stat-icon stat-icon--blue">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M8.5 3a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM14 4.5a2 2 0 1 1 0 4 2 2 0 0 1 0-4ZM1 13.5c0-2.5 3.36-4.5 7.5-4.5S16 11 16 13.5M14 11c1.94.37 3 1.38 3 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="stat-body">
        <span class="stat-value">{totalClients ?? 0}</span>
        <span class="stat-label">Clients actifs</span>
      </div>
    </a>

    <div class="stat-card stat-card--ca">
      <div class="stat-icon stat-icon--green">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 13L6 9l3 3 4-5 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="stat-body">
        <span class="stat-value stat-value--ca">{formatCA(caMonth)}</span>
        <span class="stat-label">CA du mois (HT)</span>
      </div>
    </div>

  </div>

  <!-- ── Alerts ─────────────────────────────────────── -->
  {(hasLowStock || hasPendingDelivery) && (
    <div class="alerts-row">
      {hasPendingDelivery && (
        <a href="/admin/livraison" class="alert-card alert-card--delivery">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M1 3h9v7H1zM10 5h3l2 2.5V10h-5V5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="3.5" cy="12" r="1.5" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="11.5" cy="12" r="1.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          <span>
            <strong>{livraisonsEnAttente}</strong>
            {(livraisonsEnAttente ?? 0) > 1 ? ' commandes confirmées en attente de livraison' : ' commande confirmée en attente de livraison'}
          </span>
          <span class="alert-cta">Préparer →</span>
        </a>
      )}
      {hasLowStock && (
        <div class="alert-card alert-card--stock">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M8 2L1.5 13h13L8 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <path d="M8 6v4M8 11.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="alert-label">Stock bas :</span>
          <div class="alert-pills">
            {(lowStockItems ?? []).map(p => (
              <a href="/admin/stocks" class="stock-pill">
                <span class="stock-pill-qty" class:list={[{ 'stock-pill-qty--zero': (p.stock_quantity ?? 0) === 0 }]}>
                  {p.stock_quantity ?? 0}
                </span>
                {p.name}
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  )}

  <!-- ── Activity grid ──────────────────────────────── -->
  <div class="activity-grid">

    <!-- Recent orders -->
    <div class="panel">
      <div class="panel-header">
        <h2 class="panel-title">Dernières commandes</h2>
        <a href="/admin/commandes" class="panel-link">Voir tout →</a>
      </div>
      {(recentOrders ?? []).length > 0 ? (
        <table class="act-table">
          <tbody>
            {(recentOrders ?? []).map(order => (
              <tr class="act-row">
                <td class="act-name">
                  <span class="act-primary">{order.nom}</span>
                  {order.societe && <span class="act-secondary">{order.societe}</span>}
                </td>
                <td class="act-badge">
                  <span class={`badge badge--${ORDER_STATUS_COLOR[order.status ?? 'en_attente'] ?? 'muted'}`}>
                    {ORDER_STATUS_LABEL[order.status ?? 'en_attente'] ?? order.status}
                  </span>
                </td>
                <td class="act-date">{formatDate(order.created_at)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="panel-empty">Aucune commande pour l'instant.</p>
      )}
    </div>

    <!-- Recent contacts -->
    <div class="panel">
      <div class="panel-header">
        <h2 class="panel-title">Dernières demandes clients</h2>
        <a href="/admin/clients" class="panel-link">Voir tout →</a>
      </div>
      {(recentContacts ?? []).length > 0 ? (
        <table class="act-table">
          <tbody>
            {(recentContacts ?? []).map(c => (
              <tr class="act-row">
                <td class="act-name">
                  <span class="act-primary">{c.nom}</span>
                  {c.societe && <span class="act-secondary">{c.societe}</span>}
                </td>
                <td class="act-badge">
                  <span class={`badge badge--${CONTACT_COLOR[c.status] ?? 'muted'}`}>
                    {CONTACT_LABEL[c.status] ?? c.status}
                  </span>
                </td>
                <td class="act-date">{formatDate(c.created_at)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      ) : (
        <p class="panel-empty">Aucune demande pour l'instant.</p>
      )}
    </div>

  </div>

  <!-- ── Quick actions ──────────────────────────────── -->
  <div class="actions-section">
    <h2 class="actions-heading">Actions rapides</h2>
    <div class="actions-grid">

      <a href="/admin/produits/new" class="action-card">
        <div class="action-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="1.5"/>
            <path d="M10 6v8M6 10h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <span class="action-label">Nouveau produit</span>
        <span class="action-arrow">→</span>
      </a>

      <a href="/admin/commande-rapide" class="action-card">
        <div class="action-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M3 4h2l2.5 8h8l2-6H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="8" cy="15.5" r="1.5" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="14" cy="15.5" r="1.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <span class="action-label">Prise de commande</span>
        <span class="action-arrow">→</span>
      </a>

      <a href="/admin/livraison" class="action-card">
        <div class="action-icon">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M2 4h11v9H2zM13 7h3.5L19 10v3h-6V7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="5" cy="15" r="2" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="14" cy="15" r="2" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <span class="action-label">Préparer une livraison</span>
        <span class="action-arrow">→</span>
      </a>

    </div>
  </div>

</AdminLayout>

<style>
/* ── Stats ────────────────────────────────────────── */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-4);
  margin-bottom: var(--space-5);
}

.stat-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-5);
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
  text-decoration: none;
  transition: border-color var(--dur-fast), box-shadow var(--dur-fast);
}
a.stat-card:hover {
  border-color: var(--color-border-strong);
  box-shadow: 0 2px 8px oklch(0.148 0.020 45.9 / 0.06);
}

.stat-card--urgent { border-color: oklch(0.568 0.149 45.9 / 0.35); }
a.stat-card--urgent:hover { border-color: var(--color-primary); }

.stat-card--ca { cursor: default; }

.stat-icon {
  width: 38px;
  height: 38px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.stat-icon--slate  { background: var(--color-surface-2);       color: var(--color-muted); }
.stat-icon--amber  { background: oklch(0.95 0.07 80);          color: oklch(0.42 0.14 80); }
.stat-icon--blue   { background: oklch(0.93 0.05 220);         color: oklch(0.38 0.12 220); }
.stat-icon--green  { background: oklch(0.92 0.07 150);         color: oklch(0.36 0.13 150); }

.stat-body {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  min-width: 0;
}

.stat-value {
  font-size: 1.875rem;
  font-weight: 700;
  line-height: 1;
  color: var(--color-ink);
  letter-spacing: -0.03em;
}
.stat-card--urgent .stat-value { color: var(--color-primary-deep); }

.stat-value--ca {
  font-size: 1.375rem;
  letter-spacing: -0.02em;
}

.stat-label {
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-muted);
  white-space: nowrap;
}

/* ── Alerts ───────────────────────────────────────── */
.alerts-row {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  margin-bottom: var(--space-5);
}

.alert-card {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-md);
  font-size: var(--text-sm);
  text-decoration: none;
  flex-wrap: wrap;
}

.alert-card--delivery {
  background: oklch(0.95 0.04 220);
  border: 1px solid oklch(0.86 0.07 220);
  color: oklch(0.30 0.10 220);
  transition: background var(--dur-fast);
}
.alert-card--delivery:hover { background: oklch(0.91 0.06 220); }
.alert-card--delivery svg { flex-shrink: 0; }

.alert-cta {
  margin-left: auto;
  font-weight: 600;
  flex-shrink: 0;
}

.alert-card--stock {
  background: oklch(0.96 0.05 75);
  border: 1px solid oklch(0.88 0.09 75);
  color: oklch(0.38 0.12 75);
}

.alert-label { font-weight: 600; flex-shrink: 0; }

.alert-pills {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.stock-pill {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  padding: 2px 8px 2px 4px;
  background: oklch(0.92 0.08 75);
  border: 1px solid oklch(0.82 0.10 75);
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 500;
  color: oklch(0.32 0.12 75);
  text-decoration: none;
  white-space: nowrap;
  transition: background var(--dur-fast);
}
.stock-pill:hover { background: oklch(0.86 0.10 75); }

.stock-pill-qty {
  min-width: 18px;
  height: 18px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: oklch(0.42 0.14 75);
  color: white;
  font-size: 0.65rem;
  font-weight: 700;
  padding: 0 4px;
}
.stock-pill-qty--zero {
  background: oklch(0.52 0.20 25);
}

/* ── Activity panels ──────────────────────────────── */
.activity-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-5);
  margin-bottom: var(--space-5);
  align-items: start;
}

.panel {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-5);
  border-bottom: 1px solid var(--color-border);
}

.panel-title {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-ink);
}

.panel-link {
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-primary-deep);
  text-decoration: none;
  white-space: nowrap;
}
.panel-link:hover { text-decoration: underline; }

.panel-empty {
  padding: var(--space-6) var(--space-5);
  font-size: var(--text-sm);
  color: var(--color-muted);
  text-align: center;
}

/* Activity table */
.act-table {
  width: 100%;
  border-collapse: collapse;
}

.act-row td {
  padding: var(--space-3) var(--space-5);
  border-bottom: 1px solid var(--color-border);
  vertical-align: middle;
}
.act-row:last-child td { border-bottom: none; }
.act-row:hover td { background: var(--color-surface); }

.act-name {
  width: 100%;
}

.act-primary {
  display: block;
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 180px;
}

.act-secondary {
  display: block;
  font-size: var(--text-xs);
  color: var(--color-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 180px;
}

.act-badge { white-space: nowrap; padding-right: var(--space-3); }
.act-date  { white-space: nowrap; font-size: var(--text-xs); color: var(--color-muted); }

/* Badges */
.badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 500;
  white-space: nowrap;
}
.badge--muted  { background: var(--color-surface-2);      color: var(--color-muted); }
.badge--blue   { background: oklch(0.93 0.05 220);        color: oklch(0.33 0.12 220); }
.badge--amber  { background: oklch(0.95 0.07 80);         color: oklch(0.40 0.14 80); }
.badge--purple { background: oklch(0.93 0.05 295);        color: oklch(0.38 0.12 295); }
.badge--coral  { background: oklch(0.568 0.149 45.9 / 0.12); color: var(--color-primary-deep); }
.badge--green  { background: oklch(0.92 0.08 150);        color: oklch(0.32 0.12 150); }
.badge--red    { background: oklch(0.95 0.04 25);         color: oklch(0.46 0.18 25); }

/* ── Quick actions ────────────────────────────────── */
.actions-section { }

.actions-heading {
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-muted);
  margin-bottom: var(--space-3);
}

.actions-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-3);
}

.action-card {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-4) var(--space-5);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  text-decoration: none;
  transition: border-color var(--dur-fast), box-shadow var(--dur-fast), background var(--dur-fast);
}
.action-card:hover {
  border-color: var(--color-border-strong);
  background: var(--color-surface);
  box-shadow: 0 1px 4px oklch(0.148 0.020 45.9 / 0.05);
}

.action-icon {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-sm);
  background: oklch(0.568 0.149 45.9 / 0.09);
  color: var(--color-primary-deep);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background var(--dur-fast);
}
.action-card:hover .action-icon { background: oklch(0.568 0.149 45.9 / 0.15); }

.action-label {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
  flex: 1;
}

.action-arrow {
  font-size: var(--text-sm);
  color: var(--color-muted);
  transition: color var(--dur-fast), transform var(--dur-fast);
}
.action-card:hover .action-arrow {
  color: var(--color-primary-deep);
  transform: translateX(2px);
}

/* ── Responsive ───────────────────────────────────── */
@media (max-width: 900px) {
  .stats-grid    { grid-template-columns: repeat(2, 1fr); }
  .activity-grid { grid-template-columns: 1fr; }
  .actions-grid  { grid-template-columns: 1fr; }
}

@media (max-width: 480px) {
  .stats-grid { grid-template-columns: 1fr; }
  .stat-value { font-size: 1.5rem; }
}
</style>
