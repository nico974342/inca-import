<script define:vars={{ CHART_JSON }}>
  const chart = JSON.parse(CHART_JSON);
  const crosshair  = document.getElementById('crosshairLine');
  const caHiDot    = document.getElementById('caHiDot');
  const margeHiDot = document.getElementById('margeHiDot');
  const tooltip    = document.getElementById('chartTooltip');
  const wrap       = document.getElementById('chartWrap');
  const hitRects   = document.querySelectorAll('.chart-hit');

  function fmtEUR(n) {
    return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR', minimumFractionDigits: 0, maximumFractionDigits: 0 }).format(n);
  }

  function showPoint(i) {
    const p = chart.points[i];
    if (!p) return;

    crosshair.setAttribute('x1', String(p.x));
    crosshair.setAttribute('x2', String(p.x));
    crosshair.style.opacity = '1';

    caHiDot.setAttribute('cx', String(p.x));
    caHiDot.setAttribute('cy', String(p.caY));
    caHiDot.style.opacity = '1';

    margeHiDot.setAttribute('cx', String(p.x));
    margeHiDot.setAttribute('cy', String(p.margeY));
    margeHiDot.style.opacity = '1';

    tooltip.innerHTML =
      '<div class="tt-month">' + p.label + '</div>' +
      '<div class="tt-row"><span class="tt-swatch tt-swatch--ca"></span><span class="tt-label">CA</span><strong>' + fmtEUR(p.ca) + '</strong></div>' +
      '<div class="tt-row"><span class="tt-swatch tt-swatch--marge"></span><span class="tt-label">Marge</span><strong>' + fmtEUR(p.marge) + (p.hasPump ? '' : ' *') + '</strong></div>';

    const pct = p.x / chart.width;
    tooltip.style.left = (pct * 100) + '%';
    tooltip.style.transform = pct > 0.68 ? 'translate(-100%, -8px)' : 'translate(0, -8px)';
    tooltip.style.opacity = '1';
  }

  function hideAll() {
    crosshair.style.opacity = '0';
    caHiDot.style.opacity = '0';
    margeHiDot.style.opacity = '0';
    tooltip.style.opacity = '0';
  }

  hitRects.forEach((rect, i) => {
    rect.addEventListener('mouseenter', () => showPoint(i));
    rect.addEventListener('focus', () => showPoint(i));
  });
  wrap?.addEventListener('mouseleave', hideAll);
  wrap?.addEventListener('focusout', (e) => {
    if (!wrap.contains(e.relatedTarget)) hideAll();
  });
</script>

