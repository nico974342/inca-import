---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

const [
  { count: totalProduits },
  { count: totalContacts },
  { count: totalClients },
  { data: recentContacts },
] = await Promise.all([
  supabaseAdmin.from('products').select('*', { count: 'exact', head: true }).eq('in_stock', true),
  supabaseAdmin.from('contact_requests').select('*', { count: 'exact', head: true }).eq('status', 'nouveau'),
  supabaseAdmin.from('client_accounts').select('*', { count: 'exact', head: true }).eq('status', 'actif'),
  supabaseAdmin.from('contact_requests').select('id, nom, societe, telephone, status, created_at').order('created_at', { ascending: false }).limit(5),
]);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: '2-digit' });
}

const STATUS_LABEL: Record<string, string> = {
  nouveau: 'Nouveau',
  contacte: 'Contacté',
  converti: 'Converti',
  rejete: 'Rejeté',
};
---
<AdminLayout title="Tableau de bord" activeNav="dashboard">
  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-value">{totalProduits ?? 0}</span>
      <span class="stat-label">Produits en stock</span>
    </div>
    <div class="stat-card stat-card--alert">
      <span class="stat-value">{totalContacts ?? 0}</span>
      <span class="stat-label">Contacts à traiter</span>
    </div>
    <div class="stat-card">
      <span class="stat-value">{totalClients ?? 0}</span>
      <span class="stat-label">Clients actifs</span>
    </div>
  </div>

  <div class="section">
    <div class="section-header">
      <h2 class="section-title">Dernières demandes</h2>
      <a href="/admin/clients" class="section-link">Voir tout →</a>
    </div>

    {recentContacts && recentContacts.length > 0 ? (
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Nom</th>
              <th>Société</th>
              <th>Téléphone</th>
              <th>Statut</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            {recentContacts.map(c => (
              <tr>
                <td class="td-strong">{c.nom}</td>
                <td>{c.societe ?? '—'}</td>
                <td>{c.telephone ?? '—'}</td>
                <td>
                  <span class={`badge badge--${c.status}`}>
                    {STATUS_LABEL[c.status] ?? c.status}
                  </span>
                </td>
                <td class="td-muted">{formatDate(c.created_at)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="empty-state">
        <p>Aucune demande pour l'instant.</p>
        <p class="empty-hint">Les demandes du formulaire de contact apparaîtront ici.</p>
      </div>
    )}
  </div>

  <div class="actions-row">
    <a href="/admin/produits/new" class="btn btn-primary">+ Nouveau produit</a>
    <a href="/admin/clients" class="btn btn-ghost">Gérer les clients</a>
  </div>
</AdminLayout>

<style>
/* ── Stats ────────────────────────────────────────── */
.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-4);
  margin-bottom: var(--space-8);
}

.stat-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}
.stat-card--alert { border-color: oklch(0.568 0.149 45.9 / 0.4); }

.stat-value {
  font-size: 2rem;
  font-weight: 700;
  color: var(--color-ink);
  line-height: 1;
}
.stat-card--alert .stat-value { color: var(--color-primary-deep); }

.stat-label {
  color: var(--color-muted);
  line-height: 1.4;
}

/* ── Section ─────────────────────────────────────── */
.section {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: var(--space-6);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) var(--space-5);
  border-bottom: 1px solid var(--color-border);
}

.section-title {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-ink);
}

.section-link {
  font-size: var(--text-sm);
  color: var(--color-primary-deep);
  text-decoration: none;
  font-weight: 500;
}
.section-link:hover { text-decoration: underline; }

/* ── Table ───────────────────────────────────────── */
.table-wrap { overflow-x: auto; }

.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: var(--text-sm);
}

.data-table thead th {
  padding: var(--space-3) var(--space-5);
  text-align: left;
  font-weight: 600;
  font-size: var(--text-xs);
  color: var(--color-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-bottom: 1px solid var(--color-border);
  white-space: nowrap;
}

.data-table tbody td {
  padding: var(--space-3) var(--space-5);
  border-bottom: 1px solid var(--color-border);
  vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover td { background: var(--color-surface); }

.td-strong { font-weight: 500; color: var(--color-ink); }
.td-muted  { color: var(--color-muted); }

/* ── Badges ──────────────────────────────────────── */
.badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: var(--radius-full);
  font-size: var(--text-xs);
  font-weight: 500;
  white-space: nowrap;
}
.badge--nouveau   { background: oklch(0.95 0.02 220); color: oklch(0.35 0.08 220); }
.badge--contacte  { background: oklch(0.95 0.04 60);  color: oklch(0.45 0.10 60);  }
.badge--converti  { background: oklch(0.93 0.06 145); color: oklch(0.38 0.12 145); }
.badge--rejete    { background: oklch(0.95 0.02 25);  color: oklch(0.45 0.10 25);  }

/* ── Empty state ─────────────────────────────────── */
.empty-state {
  padding: var(--space-10) var(--space-5);
  text-align: center;
  color: var(--color-muted);
}
.empty-hint { font-size: var(--text-xs); margin-top: var(--space-2); }

/* ── Actions ─────────────────────────────────────── */
.actions-row {
  display: flex;
  gap: var(--space-3);
  flex-wrap: wrap;
}

@media (max-width: 640px) {
  .stats-row { grid-template-columns: 1fr; }
}
</style>
