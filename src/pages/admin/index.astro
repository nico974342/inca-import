---
import AdminLayout from '../../components/admin/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';
import { ORDER_STATUS_LABEL, ORDER_STATUS_COLOR, CONTACT_STATUS_LABEL, CONTACT_STATUS_COLOR, computeGmroi, gmroiColorClass } from '../../lib/constants';

const REVENUE_STATUSES = ['confirmee', 'en_preparation', 'expediee', 'livree'] as const;

const now = new Date();
const monthStart = new Date(now.getFullYear(), now.getMonth(), 1).toISOString();

// ── 6 calendar months (oldest first, current month last), for the chart ──
const MONTHS_BACK = 6;
const monthDefs: { label: string; start: Date; end: Date }[] = [];
for (let i = MONTHS_BACK - 1; i >= 0; i--) {
  const start = new Date(now.getFullYear(), now.getMonth() - i, 1);
  const end   = new Date(now.getFullYear(), now.getMonth() - i + 1, 1);
  const label = start.toLocaleDateString('fr-FR', { month: 'short' }).replace('.', '');
  monthDefs.push({ label: label.charAt(0).toUpperCase() + label.slice(1), start, end });
}

// Order data is fetched 12 months back (for GMROI) in one query; the chart
// simply ignores rows older than its own 6-month window (idx === -1 below).
const marginWindowStart = new Date(now.getFullYear(), now.getMonth() - 12, now.getDate()).toISOString();

const [
  { count: commandesEnAttente },
  { count: livraisonsEnAttente },
  { count: clientsEnAttente },
  { data: recentOrders },
  { data: recentContacts },
  { data: lowStockItems },
  { data: twelveMonthOrders },
  { data: allProductsRaw },
] = await Promise.all([
  supabaseAdmin.from('orders').select('*', { count: 'exact', head: true }).eq('status', 'en_attente'),
  supabaseAdmin.from('orders').select('*', { count: 'exact', head: true }).in('status', ['confirmee', 'en_preparation', 'expediee']),
  supabaseAdmin.from('client_accounts').select('*', { count: 'exact', head: true }).eq('status', 'en_attente'),
  supabaseAdmin.from('orders').select('id, nom, societe, status, created_at').order('created_at', { ascending: false }).limit(5),
  supabaseAdmin.from('contact_requests').select('id, nom, societe, status, created_at').order('created_at', { ascending: false }).limit(5),
  supabaseAdmin.from('products').select('id, name, stock_quantity').lt('stock_quantity', 5).order('stock_quantity', { ascending: true }).limit(6),
  supabaseAdmin
    .from('orders')
    .select('id, created_at, order_items(product_id, product_name, quantity, unit, price_ht_snapshot, pump_snapshot, products(category))')
    .in('status', REVENUE_STATUSES)
    .gte('created_at', marginWindowStart),
  supabaseAdmin.from('products').select('id, name, stock_quantity, prix_achat_moyen_ht'),
]);

// ── Bucket the order set by month for the 6-month chart, aggregate
//    current-month products/categories, AND sum 12-month margin per
//    product for GMROI — all in one pass over one query's data. ──────────
type MonthBucket = { label: string; caHt: number; margeHt: number; hasPump: boolean; orderCount: number };
const buckets: MonthBucket[] = monthDefs.map(m => ({ label: m.label, caHt: 0, margeHt: 0, hasPump: false, orderCount: 0 }));

const productAgg = new Map<string, { productId: string | null; name: string; unit: string | null; qty: number; ca: number; marge: number; hasPump: boolean }>();
const categoryAgg = new Map<string, number>();
const margin12moByProduct = new Map<string, number>();
const CURRENT_IDX = MONTHS_BACK - 1;

for (const order of (twelveMonthOrders ?? [])) {
  const ts = new Date(order.created_at).getTime();
  const idx = monthDefs.findIndex(m => ts >= m.start.getTime() && ts < m.end.getTime());
  const isCurrentMonth = idx === CURRENT_IDX;
  if (idx !== -1) buckets[idx].orderCount++;

  for (const item of ((order as any).order_items ?? [])) {
    const qty  = item.quantity ?? 0;
    const prix = item.price_ht_snapshot != null ? Number(item.price_ht_snapshot) : null;
    const pump = item.pump_snapshot != null ? Number(item.pump_snapshot) : null;
    if (prix == null) continue;

    if (item.product_id != null && pump != null) {
      margin12moByProduct.set(item.product_id, (margin12moByProduct.get(item.product_id) ?? 0) + (prix - pump) * qty);
    }

    if (idx === -1) continue; // outside the 6-month chart window

    buckets[idx].caHt += prix * qty;
    if (pump != null) {
      buckets[idx].margeHt += (prix - pump) * qty;
      buckets[idx].hasPump = true;
    }

    if (isCurrentMonth) {
      const key  = item.product_id ?? item.product_name ?? 'inconnu';
      const prev = productAgg.get(key) ?? { productId: item.product_id ?? null, name: item.product_name ?? 'Produit', unit: item.unit ?? null, qty: 0, ca: 0, marge: 0, hasPump: false };
      prev.qty += qty;
      prev.ca  += prix * qty;
      if (pump != null) {
        prev.marge += (prix - pump) * qty;
        prev.hasPump = true;
      }
      productAgg.set(key, prev);

      const cat = (item as any).products?.category ?? null;
      if (cat) categoryAgg.set(cat, (categoryAgg.get(cat) ?? 0) + prix * qty);
    }
  }
}

// ── GMROI per product + "produits à surveiller" (worst performers) ───────
const allProducts = allProductsRaw ?? [];
const productGmroiList = allProducts.map(p => ({
  id: p.id,
  name: p.name,
  stock: p.stock_quantity ?? 0,
  gmroi: computeGmroi(p.stock_quantity, p.prix_achat_moyen_ht, margin12moByProduct.get(p.id) ?? null),
}));

const produitsASurveiller = productGmroiList
  .filter(p => p.gmroi != null && p.gmroi < 1 && p.stock > 0)
  .sort((a, b) => (a.gmroi ?? 0) - (b.gmroi ?? 0))
  .slice(0, 5);

const gmroiById = new Map(productGmroiList.map(p => [p.id, p.gmroi]));

const caMonth         = buckets[CURRENT_IDX].caHt;
const margeMonthHt     = buckets[CURRENT_IDX].margeHt;
const margeMonthPct    = buckets[CURRENT_IDX].hasPump && caMonth > 0 ? (margeMonthHt / caMonth) * 100 : null;
const orderCountMonth  = buckets[CURRENT_IDX].orderCount;
const panierMoyen      = orderCountMonth > 0 ? caMonth / orderCountMonth : 0;

const caPrev           = buckets[CURRENT_IDX - 1].caHt;
const margePrevPct     = buckets[CURRENT_IDX - 1].hasPump && caPrev > 0 ? (buckets[CURRENT_IDX - 1].margeHt / caPrev) * 100 : null;
const orderCountPrev   = buckets[CURRENT_IDX - 1].orderCount;
const panierMoyenPrev  = orderCountPrev > 0 ? caPrev / orderCountPrev : 0;

const missingPumpSomeMonth = buckets.some(b => b.caHt > 0 && !b.hasPump);

// ── Trend helper: direction + % change vs the prior month ────────────────
type Trend = { dir: 'up' | 'down' | 'flat' | 'none'; pct: number | null };

function trend(curr: number, prev: number): Trend {
  if (!prev) return { dir: curr > 0 ? 'up' : 'none', pct: null };
  const pct = ((curr - prev) / prev) * 100;
  if (Math.abs(pct) < 0.5) return { dir: 'flat', pct: 0 };
  return { dir: pct > 0 ? 'up' : 'down', pct };
}

function trendLabel(t: Trend, suffix = '%'): string {
  if (t.pct == null) return t.dir === 'up' ? 'Nouveau' : '—';
  const sign = t.pct > 0 ? '+' : '';
  return `${sign}${t.pct.toFixed(1)}${suffix}`;
}

const caTrend     = trend(caMonth, caPrev);
const orderTrend  = trend(orderCountMonth, orderCountPrev);
const panierTrend = trend(panierMoyen, panierMoyenPrev);

const margeTrend: Trend = margeMonthPct != null && margePrevPct != null
  ? (Math.abs(margeMonthPct - margePrevPct) < 0.05
      ? { dir: 'flat', pct: 0 }
      : { dir: margeMonthPct > margePrevPct ? 'up' : 'down', pct: margeMonthPct - margePrevPct })
  : { dir: 'none', pct: null };

// ── Top 5 products this month, by margin HT generated ──────────────────────
const top5Products = Array.from(productAgg.values())
  .sort((a, b) => b.marge - a.marge)
  .slice(0, 5);

// ── Category split this month ──────────────────────────────────────────
const CAT_ORDER = ['boissons', 'snacks', 'confiseries', 'divers'] as const;
const CAT_LABEL: Record<string, string> = {
  boissons: 'Boissons', snacks: 'Snacks', confiseries: 'Confiseries', divers: 'Divers',
};
// Chart-strength steps of the same hues used by the category badges elsewhere
// in the app (boissons/snacks/confiseries/divers = 220/60/330/275), re-stepped
// for CVD separation as solid marks (validated: adjacent ΔE 7.9, normal ΔE 16.6).
const CAT_COLOR: Record<string, string> = {
  boissons:    'oklch(0.60 0.14 220)',
  snacks:      'oklch(0.68 0.15 55)',
  confiseries: 'oklch(0.60 0.16 350)',
  divers:      'oklch(0.50 0.13 285)',
};
const categoryTotal = Array.from(categoryAgg.values()).reduce((s, v) => s + v, 0);
const categorySplit = CAT_ORDER
  .map(cat => ({ cat, label: CAT_LABEL[cat], color: CAT_COLOR[cat], ca: categoryAgg.get(cat) ?? 0 }))
  .filter(c => c.ca > 0)
  .map(c => ({ ...c, pct: categoryTotal > 0 ? (c.ca / categoryTotal) * 100 : 0 }));

// ── Trend chart geometry (plain SVG, computed server-side) ────────────────
const CHART_W = 640, CHART_H = 200;
const PAD_L = 8, PAD_R = 66, PAD_T = 14, PAD_B = 24;
const plotW = CHART_W - PAD_L - PAD_R;
const plotH = CHART_H - PAD_T - PAD_B;

function niceMax(v: number): number {
  if (v <= 0) return 100;
  const exp  = Math.pow(10, Math.floor(Math.log10(v)));
  const norm = v / exp;
  const step = norm <= 1 ? 1 : norm <= 2 ? 2 : norm <= 5 ? 5 : 10;
  return step * exp;
}
const maxCa = Math.max(1, ...buckets.map(b => b.caHt));
const yMax  = niceMax(maxCa * 1.2);

const xAt = (i: number) => PAD_L + (i / (MONTHS_BACK - 1)) * plotW;
const yAt = (v: number) => PAD_T + plotH - (Math.max(0, v) / yMax) * plotH;

const chartPoints = buckets.map((b, i) => ({
  label: b.label, x: xAt(i), caY: yAt(b.caHt), margeY: yAt(b.margeHt),
  ca: b.caHt, marge: b.margeHt, hasPump: b.hasPump,
}));

const caLinePath    = chartPoints.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.caY.toFixed(1)}`).join(' ');
const margeLinePath = chartPoints.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.margeY.toFixed(1)}`).join(' ');
const baselineY = (PAD_T + plotH).toFixed(1);
const caAreaPath = `${caLinePath} L${xAt(MONTHS_BACK - 1).toFixed(1)},${baselineY} L${xAt(0).toFixed(1)},${baselineY} Z`;

const gridLines = [0, yMax / 2, yMax].map(v => ({ v, y: yAt(v) }));
const hitBandW = plotW / MONTHS_BACK;

const lastPoint = chartPoints[CURRENT_IDX];
const CHART_JSON = JSON.stringify({ points: chartPoints, width: CHART_W });

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', year: '2-digit' });
}

function formatCA(amount: number): string {
  return new Intl.NumberFormat('fr-FR', {
    style: 'currency', currency: 'EUR',
    minimumFractionDigits: 0, maximumFractionDigits: 0,
  }).format(amount);
}

const CONTACT_LABEL = CONTACT_STATUS_LABEL;
const CONTACT_COLOR = CONTACT_STATUS_COLOR;

const hasLowStock        = (lowStockItems ?? []).length > 0;
const hasPendingDelivery = (livraisonsEnAttente ?? 0) > 0;
const hasPendingClients  = (clientsEnAttente ?? 0) > 0;
const hasPendingOrders   = (commandesEnAttente ?? 0) > 0;
---
<AdminLayout title="Tableau de bord" activeNav="dashboard">

  <!-- ── KPI row ─────────────────────────────────────── -->
  <div class="kpi-grid">

    <div class="kpi-card">
      <div class="kpi-icon kpi-icon--green">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 13L6 9l3 3 4-5 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="kpi-label">CA du mois (HT)</span>
      <span class="kpi-value">{formatCA(caMonth)}</span>
      <span class={`kpi-trend kpi-trend--${caTrend.dir}`}>
        <span class="kpi-trend-arrow">{caTrend.dir === 'up' ? '▲' : caTrend.dir === 'down' ? '▼' : '–'}</span>
        {trendLabel(caTrend)}
        <span class="kpi-trend-caption">vs mois dernier</span>
      </span>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon kpi-icon--coral">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <circle cx="5.5" cy="12.5" r="2" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="12.5" cy="5.5" r="2" stroke="currentColor" stroke-width="1.5"/>
          <path d="M13 4 5 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="kpi-label">Marge du mois (HT)</span>
      <span class="kpi-value">
        {formatCA(margeMonthHt)}
        {margeMonthPct != null && <span class="kpi-value-sub">{margeMonthPct.toFixed(1)} %</span>}
      </span>
      <span class={`kpi-trend kpi-trend--${margeTrend.dir}`}>
        <span class="kpi-trend-arrow">{margeTrend.dir === 'up' ? '▲' : margeTrend.dir === 'down' ? '▼' : '–'}</span>
        {trendLabel(margeTrend, ' pts')}
        <span class="kpi-trend-caption">vs mois dernier</span>
      </span>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon kpi-icon--blue">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M4 5h10M4 9h10M4 13h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="kpi-label">Commandes ce mois</span>
      <span class="kpi-value">{orderCountMonth}</span>
      <span class={`kpi-trend kpi-trend--${orderTrend.dir}`}>
        <span class="kpi-trend-arrow">{orderTrend.dir === 'up' ? '▲' : orderTrend.dir === 'down' ? '▼' : '–'}</span>
        {trendLabel(orderTrend)}
        <span class="kpi-trend-caption">vs mois dernier</span>
      </span>
    </div>

    <div class="kpi-card">
      <div class="kpi-icon kpi-icon--amber">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3 6h12l-1.2 8.5a1.5 1.5 0 0 1-1.5 1.3H5.7a1.5 1.5 0 0 1-1.5-1.3L3 6Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M6.5 6 8 2.5M11.5 6 10 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="kpi-label">Panier moyen (HT)</span>
      <span class="kpi-value">{formatCA(panierMoyen)}</span>
      <span class={`kpi-trend kpi-trend--${panierTrend.dir}`}>
        <span class="kpi-trend-arrow">{panierTrend.dir === 'up' ? '▲' : panierTrend.dir === 'down' ? '▼' : '–'}</span>
        {trendLabel(panierTrend)}
        <span class="kpi-trend-caption">vs mois dernier</span>
      </span>
    </div>

  </div>

  <!-- ── Chart + side stack ──────────────────────────── -->
  <div class="visual-grid">

    <div class="panel chart-panel">
      <div class="panel-header">
        <h2 class="panel-title">CA &amp; Marge — 6 derniers mois</h2>
        <div class="chart-legend">
          <span class="legend-item"><span class="legend-swatch legend-swatch--ca"></span>CA HT</span>
          <span class="legend-item"><span class="legend-swatch legend-swatch--marge"></span>Marge HT</span>
        </div>
      </div>
      <div class="chart-body">
        <div class="chart-wrap" id="chartWrap">
          <svg id="trendChart" viewBox={`0 0 ${CHART_W} ${CHART_H}`} preserveAspectRatio="xMidYMid meet" role="img" aria-label="Évolution du chiffre d'affaires et de la marge sur les 6 derniers mois">
            {gridLines.map(g => (
              <line x1={PAD_L} x2={PAD_L + plotW} y1={g.y} y2={g.y} class="chart-grid" />
            ))}
            <text x={PAD_L} y={yAt(0) + 12} class="chart-axis-label">0 €</text>
            <text x={PAD_L} y={yAt(yMax) - 3} class="chart-axis-label">{formatCA(yMax)}</text>

            <path d={caAreaPath} class="chart-area chart-area--ca" />
            <path d={margeLinePath} class="chart-line chart-line--marge" />
            <path d={caLinePath} class="chart-line chart-line--ca" />

            {/* End-of-line emphasis + direct labels for the current month */}
            <circle cx={lastPoint.x} cy={lastPoint.caY} r="5" class="chart-dot-ring" />
            <circle cx={lastPoint.x} cy={lastPoint.caY} r="3.5" class="chart-dot chart-dot--ca" />
            <circle cx={lastPoint.x} cy={lastPoint.margeY} r="5" class="chart-dot-ring" />
            <circle cx={lastPoint.x} cy={lastPoint.margeY} r="3.5" class="chart-dot chart-dot--marge" />
            <text x={lastPoint.x + 9} y={lastPoint.caY + 4} class="chart-end-label">{formatCA(lastPoint.ca)}</text>
            <text x={lastPoint.x + 9} y={lastPoint.margeY + 4} class="chart-end-label chart-end-label--muted">{formatCA(lastPoint.marge)}</text>

            {chartPoints.map(p => (
              <text x={p.x} y={CHART_H - 4} class="chart-x-label">{p.label}</text>
            ))}

            {/* Hover layer */}
            <line id="crosshairLine" x1="0" x2="0" y1={PAD_T} y2={PAD_T + plotH} class="chart-crosshair" />
            <circle id="caHiDot" r="5" class="chart-dot chart-dot--ca chart-dot--hover" />
            <circle id="margeHiDot" r="5" class="chart-dot chart-dot--marge chart-dot--hover" />

            {chartPoints.map((p, i) => (
              <rect
                class="chart-hit"
                x={PAD_L + i * hitBandW} y={PAD_T} width={hitBandW} height={plotH}
                fill="transparent" tabindex="0" role="button"
                aria-label={`${p.label} — CA ${formatCA(p.ca)}, marge ${formatCA(p.marge)}`}
              />
            ))}
          </svg>
          <div id="chartTooltip" class="chart-tooltip" role="status" aria-live="polite"></div>
        </div>

        {missingPumpSomeMonth && (
          <p class="chart-footnote">* Marge partielle certains mois — PUMP non défini pour certains produits.</p>
        )}

        <details class="chart-table-toggle">
          <summary>Voir le détail par mois</summary>
          <table class="chart-data-table">
            <thead>
              <tr><th>Mois</th><th class="th-r">CA HT</th><th class="th-r">Marge HT</th><th class="th-r">Marge %</th></tr>
            </thead>
            <tbody>
              {buckets.map((b, i) => (
                <tr>
                  <td>{monthDefs[i].label}</td>
                  <td class="th-r">{formatCA(b.caHt)}</td>
                  <td class="th-r">{formatCA(b.margeHt)}</td>
                  <td class="th-r">{b.hasPump && b.caHt > 0 ? ((b.margeHt / b.caHt) * 100).toFixed(1) + ' %' : '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      </div>
    </div>

    <div class="side-stack">

      <!-- Category split -->
      <div class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Répartition par catégorie</h2>
        </div>
        <div class="cat-split-body">
          {categorySplit.length > 0 ? (
            <>
              <div class="cat-bar">
                {categorySplit.map(c => (
                  <div
                    class="cat-bar-segment"
                    style={`width:${c.pct}%; background:${c.color};`}
                    title={`${c.label} — ${formatCA(c.ca)} (${c.pct.toFixed(1)} %)`}
                  ></div>
                ))}
              </div>
              <ul class="cat-legend">
                {categorySplit.map(c => (
                  <li class="cat-legend-item">
                    <span class="cat-legend-swatch" style={`background:${c.color};`}></span>
                    <span class="cat-legend-name">{c.label}</span>
                    <span class="cat-legend-pct">{c.pct.toFixed(0)} %</span>
                    <span class="cat-legend-ca">{formatCA(c.ca)}</span>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <p class="panel-empty">Aucune vente ce mois-ci.</p>
          )}
        </div>
      </div>

      <!-- Top 5 products -->
      <div class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Top 5 produits du mois</h2>
        </div>
        {top5Products.length > 0 ? (
          <div class="top5-table-wrap">
            <table class="top5-table">
              <thead>
                <tr><th>Produit</th><th class="th-r">Qté</th><th class="th-r">CA HT</th><th class="th-r">Marge HT</th><th class="th-r">GMROI</th></tr>
              </thead>
              <tbody>
                {top5Products.map(p => {
                  const g = p.productId ? gmroiById.get(p.productId) ?? null : null;
                  return (
                    <tr>
                      <td class="top5-name">{p.name}</td>
                      <td class="th-r top5-qty">{p.qty}{p.unit ? <span class="top5-unit"> {p.unit}{p.qty > 1 ? 's' : ''}</span> : null}</td>
                      <td class="th-r top5-ca">{formatCA(p.ca)}</td>
                      <td class="th-r top5-marge">{p.hasPump ? formatCA(p.marge) : '—'}</td>
                      <td class="th-r"><span class={`gmroi-chip gmroi-chip--${gmroiColorClass(g)}`}>{g != null ? g.toFixed(1) + '×' : '—'}</span></td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        ) : (
          <p class="panel-empty">Aucune vente ce mois-ci.</p>
        )}
      </div>

      <!-- Produits à surveiller (GMROI < 1, capital dormant) -->
      <div class="panel">
        <div class="panel-header">
          <h2 class="panel-title">
            Produits à surveiller
            <span
              class="help-icon"
              tabindex="0"
              title="Produits en stock dont le GMROI est inférieur à 1 : ils immobilisent plus de capital qu'ils n'en rapportent sur les 12 derniers mois."
            >?</span>
          </h2>
          <a href="/admin/produits" class="panel-link">Voir tout →</a>
        </div>
        {produitsASurveiller.length > 0 ? (
          <div class="top5-table-wrap">
            <table class="top5-table">
              <thead>
