---
const communes = [
  { name: 'Saint-Denis',   x: 205, y: 42  },
  { name: 'Sainte-Marie',  x: 248, y: 60  },
  { name: 'Saint-André',   x: 280, y: 96  },
  { name: 'Saint-Benoît',  x: 300, y: 165 },
  { name: 'Saint-Pierre',  x: 192, y: 342 },
  { name: 'Saint-Leu',     x: 104, y: 222 },
  { name: 'Le Port',       x: 122, y: 72  },
  { name: 'Saint-Paul',    x: 104, y: 112 },
];
---

<section class="coverage" aria-labelledby="coverage-heading">
  <div class="container">
    <div class="coverage-header">
      <h2 class="coverage-heading" id="coverage-heading">Nous livrons partout à La Réunion</h2>
      <p class="coverage-sub">Du littoral aux hauts, votre commande arrive en 48h où que vous soyez sur l'île.</p>
    </div>

    <div class="coverage-map-wrap">
      <svg
        class="coverage-map"
        viewBox="0 0 400 400"
        role="img"
        aria-labelledby="coverage-map-title"
      >
        <title id="coverage-map-title">Carte des communes livrées à La Réunion</title>

        <path
          class="island-shape"
          d="M205,40 C262,40 318,68 348,138 C368,186 362,258 322,308
             C282,354 232,366 190,356 C132,344 90,300 70,240
             C53,188 58,128 98,84 C128,54 166,40 205,40 Z"
        />

        {communes.map(c => (
          <g
            class="map-pin"
            tabindex="0"
            role="button"
            aria-label={c.name}
            transform={`translate(${c.x} ${c.y})`}
          >
            <circle class="pin-halo" r="11" />
            <circle class="pin-dot" r="6.5" />
            <circle class="pin-core" r="2.25" />

            <g class="pin-tooltip" transform={`translate(0 ${-18 - 22})`}>
              <rect
                x={-(c.name.length * 3.6 + 10)}
                y="0"
                width={c.name.length * 7.2 + 20}
                height="24"
                rx="6"
              />
              <text x="0" y="16">{c.name}</text>
            </g>
          </g>
        ))}
      </svg>
    </div>

    <ul class="sr-only">
      {communes.map(c => <li>{c.name}</li>)}
    </ul>
  </div>
</section>

<style>
.coverage {
  padding: clamp(var(--space-16), 7vw, var(--space-24)) 0;
  background: var(--color-bg);
  border-top: 1px solid var(--color-border);
}

.coverage-header {
  text-align: center;
  max-width: 560px;
  margin: 0 auto clamp(var(--space-10), 5vw, var(--space-14));
}

.coverage-heading {
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--color-ink);
  margin-bottom: var(--space-3);
  text-wrap: balance;
}

.coverage-sub {
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: 1.6;
  color: var(--color-muted);
}

/* Map */
.coverage-map-wrap {
  max-width: 700px;
  margin: 0 auto;
}

.coverage-map {
  display: block;
  width: 100%;
  height: auto;
  overflow: visible;
}

.island-shape {
  fill: var(--color-surface-2);
  stroke: var(--color-border-strong);
  stroke-width: 2;
}

.map-pin {
  cursor: pointer;
  outline: none;
}

.pin-halo {
  fill: var(--color-primary);
  opacity: 0.16;
}

.pin-dot {
  fill: var(--color-primary);
  stroke: white;
  stroke-width: 2;
}

.pin-core {
  fill: white;
}

.map-pin,
.pin-halo,
.pin-dot {
  transform-box: fill-box;
  transform-origin: center;
}

@media (prefers-reduced-motion: no-preference) {
  .pin-halo,
  .pin-dot {
    transition: transform var(--dur-fast) var(--ease-out-quart);
  }
}

.map-pin:hover .pin-dot,
.map-pin:focus-visible .pin-dot {
  transform: scale(1.18);
}

.map-pin:hover .pin-halo,
.map-pin:focus-visible .pin-halo {
  transform: scale(1.6);
}

/* Tooltip */
.pin-tooltip {
  opacity: 0;
  pointer-events: none;
  transform-box: fill-box;
  transform-origin: center;
}

@media (prefers-reduced-motion: no-preference) {
  .pin-tooltip {
    transition: opacity var(--dur-fast) var(--ease-out-quart),
                transform var(--dur-fast) var(--ease-out-quart);
    transform: translateY(4px);
  }
}

.map-pin:hover .pin-tooltip,
.map-pin:focus-visible .pin-tooltip {
  opacity: 1;
  transform: translateY(0);
}

.pin-tooltip rect {
  fill: var(--color-ink);
}

.pin-tooltip text {
  fill: white;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 600;
  text-anchor: middle;
}

@media (max-width: 480px) {
  .pin-tooltip text { font-size: 12px; }
}
</style>
