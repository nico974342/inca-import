---
const communes = [
  'Saint-Denis',
  'Saint-Paul',
  'Le Port',
  'Saint-Pierre',
  'Saint-Leu',
  'Saint-Benoît',
  'Sainte-Marie',
  'Saint-André',
];

const lat = -21.115141;
const lng = 55.536384;
const zoom = 10;
const mapSrc = `https://www.google.com/maps?q=${lat},${lng}&z=${zoom}&output=embed`;
---

<section class="coverage" aria-labelledby="coverage-heading">
  <div class="container">
    <div class="coverage-header">
      <h2 class="coverage-heading" id="coverage-heading">Nous livrons partout à La Réunion</h2>
      <p class="coverage-sub">Du littoral aux hauts, votre commande arrive en 48h où que vous soyez sur l'île.</p>
    </div>

    <div class="coverage-map-wrap">
      <iframe
        class="coverage-map"
        src={mapSrc}
        title="Carte de La Réunion — zone de livraison Inca Import"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>

    <ul class="coverage-pills">
      {communes.map(c => (
        <li class="coverage-pill">{c}</li>
      ))}
    </ul>
  </div>
</section>

<style>
.coverage {
  padding: clamp(var(--space-16), 7vw, var(--space-24)) 0;
  background: var(--color-bg);
  border-top: 1px solid var(--color-border);
}

.coverage-header {
  text-align: center;
  max-width: 560px;
  margin: 0 auto clamp(var(--space-10), 5vw, var(--space-14));
}

.coverage-heading {
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--color-ink);
  margin-bottom: var(--space-3);
  text-wrap: balance;
}

.coverage-sub {
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: 1.6;
  color: var(--color-muted);
}

/* Map */
.coverage-map-wrap {
  max-width: 700px;
  margin: 0 auto clamp(var(--space-8), 4vw, var(--space-10));
  aspect-ratio: 4 / 3;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1px solid var(--color-border);
}

.coverage-map {
  display: block;
  width: 100%;
  height: 100%;
  border: 0;
}

/* Commune pills */
.coverage-pills {
  list-style: none;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: var(--space-3);
  max-width: 700px;
  margin: 0 auto;
}

.coverage-pill {
  padding: var(--space-2) var(--space-5);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-full);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-ink);
}
</style>
