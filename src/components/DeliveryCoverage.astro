---
const communes = [
  'Saint-Denis',
  'Saint-Paul',
  'Le Port',
  'Saint-Pierre',
  'Saint-Leu',
  'Saint-Benoît',
  'Sainte-Marie',
  'Saint-André',
];
---

<section class="coverage" aria-labelledby="coverage-heading">
  <div class="container">
    <div class="coverage-header">
      <h2 class="coverage-heading" id="coverage-heading">Nous livrons partout à La Réunion</h2>
      <p class="coverage-sub">Du littoral aux hauts, votre commande arrive en 48h où que vous soyez sur l'île.</p>
    </div>

    <ul class="coverage-grid">
      {communes.map(c => (
        <li class="coverage-item">
          <svg class="coverage-pin" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M9 1.5c-2.9 0-5.25 2.32-5.25 5.18 0 3.88 5.25 9.32 5.25 9.32s5.25-5.44 5.25-9.32C14.25 3.82 11.9 1.5 9 1.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
            <circle cx="9" cy="6.7" r="1.7" stroke="currentColor" stroke-width="1.4"/>
          </svg>
          <span>{c}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
.coverage {
  padding: clamp(var(--space-16), 7vw, var(--space-24)) 0;
  background: var(--color-bg);
  border-top: 1px solid var(--color-border);
}

.coverage-header {
  text-align: center;
  max-width: 560px;
  margin: 0 auto clamp(var(--space-10), 5vw, var(--space-14));
}

.coverage-heading {
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--color-ink);
  margin-bottom: var(--space-3);
  text-wrap: balance;
}

.coverage-sub {
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: 1.6;
  color: var(--color-muted);
}

.coverage-grid {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
  gap: var(--space-4);
  max-width: 900px;
  margin: 0 auto;
}

.coverage-item {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-4) var(--space-5);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-ink);
}

.coverage-pin {
  flex-shrink: 0;
  color: var(--color-primary);
}
</style>
