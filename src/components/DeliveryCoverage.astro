---
const communes = [
  { name: 'Saint-Denis',  x: 194.79, y: 54.39  },
  { name: 'Sainte-Marie', x: 253.35, y: 65.02  },
  { name: 'Saint-André',  x: 311.15, y: 106.79 },
  { name: 'Saint-Benoît', x: 347.98, y: 150.16 },
  { name: 'Saint-Pierre', x: 212.08, y: 338.85 },
  { name: 'Saint-Leu',    x: 103.68, y: 234.25 },
  { name: 'Le Port',      x: 104.66, y: 90.48  },
  { name: 'Saint-Paul',   x: 92.44,  y: 135.15 },
];

const islandPath =
  'M61.28,153.33 L65.62,162.51 L64.15,178 L83.01,197.2 L82.39,199.53 L92.74,210.59 ' +
  'L93.19,221.8 L101.82,228.51 L102.18,242.3 L98.16,254.69 L105.41,271.37 L127.09,289.19 ' +
  'L128.1,298.12 L132.2,302.84 L162.48,310.27 L181.88,329.86 L195.25,332.02 L201.76,340.19 ' +
  'L210.28,343.23 L212.97,340.12 L212.35,344.3 L215.63,346.62 L225.81,346.01 L246.77,354.08 ' +
  'L253.71,360.4 L256.34,358.46 L266.11,361.73 L274.42,358.73 L288.03,368.42 L303.5,365.64 ' +
  'L309.1,370 L316.63,365.65 L323.43,366.42 L328.69,360.77 L345,361.89 L356.09,357.49 ' +
  'L369.24,356.42 L372.59,353.42 L383.38,355.02 L396.04,345.7 L402.05,336.87 L399.84,320.32 ' +
  'L402.42,306.96 L398.52,289.73 L402.6,269.56 L411.89,254.68 L412.48,244.2 L418.72,242.49 ' +
  'L417.79,228.31 L412.49,217.87 L403.22,214.14 L395.46,206.71 L387.23,205.66 L361.65,172.33 ' +
  'L357.91,165.46 L358.68,159.8 L350.12,148.76 L344.48,146.18 L341.53,139.95 L338.11,107.31 ' +
  'L320.27,83.39 L312.2,78.14 L294.09,73.96 L277.86,64.92 L258.63,62.2 L248.55,64.11 ' +
  'L227.62,56.57 L207.78,57.83 L196.46,50 L168.14,54.89 L149.08,66.26 L134.66,81.11 ' +
  'L127.32,84.49 L122.06,83.61 L123.79,89.25 L117.03,87.87 L120.61,86.72 L120.49,84.11 ' +
  'L103.51,87.84 L99.31,95.41 L100.69,90.94 L98.68,90.38 L96.39,100.49 L99.43,114.27 ' +
  'L96.39,128.68 L83.81,139.43 L72.12,140.25 L61.28,153.33 Z';

const sub = 'Livraison 48h';
function tooltipWidth(name) {
  return Math.max(name.length, sub.length) * 6.6 + 28;
}
---

<section class="coverage" aria-labelledby="coverage-heading">
  <div class="container">
    <div class="coverage-header">
      <h2 class="coverage-heading" id="coverage-heading">Nous livrons partout à La Réunion</h2>
      <p class="coverage-sub">Du littoral aux hauts, votre commande arrive en 48h où que vous soyez sur l'île.</p>
    </div>

    <div class="coverage-map-wrap">
      <svg
        class="coverage-map"
        viewBox="0 0 480 420"
        role="img"
        aria-labelledby="coverage-map-title"
        style="display:block; width:100%; height:auto; overflow:visible;"
      >
        <title id="coverage-map-title">Carte de La Réunion — communes livrées par Inca Import</title>

        <rect
          x="0" y="0" width="480" height="420" rx="24"
          style={`fill: oklch(0.95 0.01 220);`}
        />

        <path
          d={islandPath}
          style="fill: white; stroke: oklch(0.568 0.149 45.9); stroke-width: 2; stroke-linejoin: round; filter: drop-shadow(0 10px 18px oklch(0.30 0.03 230 / 0.18));"
        />

        {communes.map((c, i) => (
          <g
            class="map-pin"
            tabindex="0"
            role="button"
            aria-label={`${c.name} — Livraison 48h`}
            transform={`translate(${c.x} ${c.y})`}
            style="cursor: pointer; outline: none;"
          >
            <circle
              class="pin-pulse"
              r="7"
              style={`fill: none; stroke: oklch(0.568 0.149 45.9); stroke-width: 2; transform-box: fill-box; transform-origin: center; animation-delay: ${i * 0.28}s;`}
            />
            <circle
              class="pin-dot"
              r="6.5"
              style="fill: oklch(0.568 0.149 45.9); stroke: white; stroke-width: 2; transform-box: fill-box; transform-origin: center;"
            />
            <circle class="pin-core" r="2.25" style="fill: white;" />

            <g
              class="pin-tooltip"
              transform={`translate(0 ${-18 - 40})`}
              style="transform-box: fill-box; transform-origin: center;"
            >
              <rect
                x={-(tooltipWidth(c.name) / 2)}
                y="0"
                width={tooltipWidth(c.name)}
                height="42"
                rx="9"
                style="fill: white; stroke: oklch(0.90 0.01 220); stroke-width: 1; filter: drop-shadow(0 6px 14px oklch(0.30 0.03 230 / 0.20));"
              />
              <text
                x="0" y="17"
                style="fill: var(--color-ink); font-family: var(--font-body); font-size: 13px; font-weight: 700; text-anchor: middle;"
              >{c.name}</text>
              <text
                x="0" y="32"
                style="fill: oklch(0.568 0.149 45.9); font-family: var(--font-body); font-size: 11px; font-weight: 600; text-anchor: middle;"
              >{sub}</text>
            </g>
          </g>
        ))}
      </svg>
    </div>

    <div class="coverage-legend">
      <span class="legend-dot" style="background: oklch(0.568 0.149 45.9);"></span>
      <span class="legend-label">Zone de livraison Inca Import</span>
    </div>

    <ul class="sr-only">
      {communes.map(c => <li>{c.name}</li>)}
    </ul>
  </div>
</section>

<style>
.coverage {
  padding: clamp(var(--space-16), 7vw, var(--space-24)) 0;
  background: var(--color-bg);
  border-top: 1px solid var(--color-border);
}

.coverage-header {
  text-align: center;
  max-width: 560px;
  margin: 0 auto clamp(var(--space-10), 5vw, var(--space-14));
}

.coverage-heading {
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--color-ink);
  margin-bottom: var(--space-3);
  text-wrap: balance;
}

.coverage-sub {
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: 1.6;
  color: var(--color-muted);
}

.coverage-map-wrap {
  max-width: 700px;
  margin: 0 auto;
}

/* Pulse ring */
@media (prefers-reduced-motion: no-preference) {
  .pin-pulse {
    animation: pin-pulse 2.4s ease-out infinite;
  }
}

@keyframes pin-pulse {
  0%   { transform: scale(1);    opacity: 0.55; }
  100% { transform: scale(2.6);  opacity: 0; }
}

/* Pin hover / focus */
@media (prefers-reduced-motion: no-preference) {
  .pin-dot {
    transition: transform var(--dur-fast) var(--ease-out-quart);
  }
}

.map-pin:hover .pin-dot,
.map-pin:focus-visible .pin-dot {
  transform: scale(1.25);
}

/* Tooltip */
.pin-tooltip {
  opacity: 0;
  pointer-events: none;
}

@media (prefers-reduced-motion: no-preference) {
  .pin-tooltip {
    transition: opacity var(--dur-fast) var(--ease-out-quart),
                transform var(--dur-fast) var(--ease-out-quart);
    transform: translateY(4px);
  }
}

.map-pin:hover .pin-tooltip,
.map-pin:focus-visible .pin-tooltip {
  opacity: 1;
  transform: translateY(0);
}

/* Legend */
.coverage-legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  margin-top: clamp(var(--space-6), 3vw, var(--space-8));
}

.legend-dot {
  width: 10px;
  height: 10px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.legend-label {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-muted);
}
</style>
