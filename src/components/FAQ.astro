---
const faqs = [
  {
    q: 'Y a-t-il un minimum de commande ?',
    a: 'Non, il n\'y a aucun minimum de commande imposé. Vous commandez selon vos besoins, sans engagement.',
  },
  {
    q: 'Quels sont les délais de livraison ?',
    a: 'Vos commandes sont livrées en 48h, directement à votre point de vente, partout à La Réunion.',
  },
  {
    q: 'Livrez-vous toute l\'île de La Réunion ?',
    a: 'Oui, nous livrons l\'ensemble des communes de l\'île, du littoral aux hauts.',
  },
  {
    q: 'Puis-je commander par téléphone ou WhatsApp ?',
    a: 'Bien sûr. Vous pouvez nous appeler au 0692 47 89 41 ou nous écrire directement sur WhatsApp pour passer commande.',
  },
  {
    q: 'Comment ouvrir un compte professionnel ?',
    a: 'Remplissez le formulaire ci-dessous ou inscrivez-vous directement en ligne. Votre accès catalogue est activé sous 24h ouvrées.',
  },
  {
    q: 'Les prix sont-ils HT ou TTC ?',
    a: 'Tous les prix affichés dans notre catalogue sont exprimés hors taxes (HT), conformément aux usages B2B.',
  },
  {
    q: 'C\'est réservé aux professionnels uniquement ?',
    a: 'Oui, Inca Import est un grossiste B2B réservé aux gérants de stations-service, supérettes et commerces professionnels.',
  },
];
---

<section class="faq" aria-labelledby="faq-heading">
  <div class="container">
    <h2 class="faq-heading" id="faq-heading">Questions fréquentes</h2>

    <div class="faq-list">
      {faqs.map((item, i) => (
        <div class="faq-item">
          <button
            class="faq-trigger"
            type="button"
            aria-expanded="false"
            aria-controls={`faq-panel-${i}`}
            id={`faq-trigger-${i}`}
          >
            <span class="faq-question">{item.q}</span>
            <svg class="faq-icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M1 5l6 6 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div
            class="faq-panel"
            id={`faq-panel-${i}`}
            role="region"
            aria-labelledby={`faq-trigger-${i}`}
          >
            <p class="faq-answer">{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.faq {
  padding: clamp(var(--space-16), 7vw, var(--space-24)) 0;
  background: var(--color-surface);
  border-top: 1px solid var(--color-border);
}

.faq-heading {
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--color-ink);
  text-align: center;
  margin-bottom: clamp(var(--space-10), 5vw, var(--space-14));
}

.faq-list {
  max-width: 760px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
}

.faq-item {
  border-bottom: 1px solid var(--color-border);
}
.faq-item:first-child { border-top: 1px solid var(--color-border); }

.faq-trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  padding: var(--space-5) var(--space-1);
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  font-family: var(--font-body);
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-ink);
}

.faq-icon {
  flex-shrink: 0;
  color: var(--color-primary);
  transition: transform var(--dur-base) var(--ease-out-quart);
}

.faq-trigger[aria-expanded="true"] .faq-icon {
  transform: rotate(180deg);
}

.faq-panel {
  overflow: hidden;
  height: 0;
  transition: height var(--dur-base) var(--ease-out-quart);
}

.faq-answer {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  line-height: 1.7;
  color: var(--color-muted);
  max-width: 64ch;
  padding: 0 var(--space-1) var(--space-5);
}

@media (prefers-reduced-motion: reduce) {
  .faq-icon, .faq-panel { transition: none; }
}
</style>

<script>
  const items = document.querySelectorAll<HTMLElement>('.faq-item');

  items.forEach(item => {
    const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger');
    const panel = item.querySelector<HTMLElement>('.faq-panel');
    if (!trigger || !panel) return;

    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      items.forEach(other => {
        if (other === item) return;
        const otherTrigger = other.querySelector<HTMLButtonElement>('.faq-trigger');
        const otherPanel = other.querySelector<HTMLElement>('.faq-panel');
        if (otherTrigger && otherPanel) {
          otherTrigger.setAttribute('aria-expanded', 'false');
          otherPanel.style.height = '0px';
        }
      });

      if (isOpen) {
        trigger.setAttribute('aria-expanded', 'false');
        panel.style.height = '0px';
      } else {
        trigger.setAttribute('aria-expanded', 'true');
        panel.style.height = panel.scrollHeight + 'px';
      }
    });
  });

  window.addEventListener('resize', () => {
    items.forEach(item => {
      const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger');
      const panel = item.querySelector<HTMLElement>('.faq-panel');
      if (trigger?.getAttribute('aria-expanded') === 'true' && panel) {
        panel.style.height = panel.scrollHeight + 'px';
      }
    });
  });
</script>
