---
const steps = [
  {
    n: '01',
    title: 'Créez votre compte',
    body: 'Remplissez notre formulaire en ligne. Validation sous 24h ouvrées, sans engagement.',
  },
  {
    n: '02',
    title: 'Parcourez le catalogue',
    body: '120+ références classées par catégorie, avec prix et disponibilité en temps réel.',
  },
  {
    n: '03',
    title: 'Recevez votre commande',
    body: 'Livraison sous 48h à votre point de vente, partout à La Réunion.',
  },
];
---

<section class="how-it-works" aria-labelledby="hiw-heading">
  <div class="container">
    <h2 class="hiw-heading" id="hiw-heading">Comment ça marche&nbsp;?</h2>

    <div class="steps-row">
      {steps.map((step, i) => (
        <>
          <div class="step">
            <span class="step-n" aria-hidden="true">{step.n}</span>
            <h3 class="step-title">{step.title}</h3>
            <p class="step-body">{step.body}</p>
          </div>
          {i < steps.length - 1 && (
            <div class="step-connector" aria-hidden="true">
              <svg width="32" height="2" viewBox="0 0 32 2" fill="none">
                <line x1="0" y1="1" x2="32" y2="1"
                  stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 3"/>
              </svg>
            </div>
          )}
        </>
      ))}
    </div>
  </div>
</section>

<style>
.how-it-works {
  padding: clamp(var(--space-16), 7vw, var(--space-24)) 0;
  background: var(--color-surface);
}

.hiw-heading {
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--color-ink);
  margin-bottom: clamp(var(--space-12), 5vw, var(--space-16));
  line-height: 1.1;
}

.steps-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-4);
}

.step { flex: 1; }

/* Large proud numeral — no circle */
.step-n {
  display: block;
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 6vw, 4rem);
  font-weight: 700;
  letter-spacing: -0.04em;
  color: var(--color-primary);
  line-height: 1;
  margin-bottom: var(--space-5);
  font-variant-numeric: tabular-nums;
}

.step-title {
  font-family: var(--font-display);
  font-size: clamp(1.125rem, 2vw, 1.375rem);
  font-weight: 700;
  letter-spacing: -0.015em;
  color: var(--color-ink);
  margin-bottom: var(--space-3);
  line-height: 1.2;
}

.step-body {
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: 1.65;
  color: var(--color-muted);
  max-width: 26ch;
}

/* Connector — aligned to midpoint of numeral */
.step-connector {
  color: var(--color-border-strong);
  flex-shrink: 0;
  /* align to vertical center of the step-n numeral */
  margin-top: calc(clamp(2.5rem, 6vw, 4rem) / 2 - 1px);
  align-self: flex-start;
}

/* Scroll reveals — staggered per child */
@media (prefers-reduced-motion: no-preference) {
  .step.will-animate,
  .step-connector.will-animate {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s var(--ease-out-expo), transform 0.65s var(--ease-out-expo);
  }
  .step.will-animate.is-revealed,
  .step-connector.will-animate.is-revealed {
    opacity: 1;
    transform: none;
  }
}

@media (max-width: 640px) {
  .steps-row {
    flex-direction: column;
    gap: var(--space-8);
  }
  .step-connector {
    transform: rotate(90deg);
    margin-top: 0;
    align-self: flex-start;
    margin-left: clamp(1.25rem, 3vw, 2rem);
  }
  .step-connector.will-animate { transform: rotate(90deg) translateY(28px); }
  .step-connector.will-animate.is-revealed { transform: rotate(90deg); }
  .step-body { max-width: none; }
}
</style>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    const section = document.querySelector('.how-it-works');
    const items   = section?.querySelectorAll<HTMLElement>('.step, .step-connector');
    items?.forEach(el => el.classList.add('will-animate'));

    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        items?.forEach((el, i) =>
          setTimeout(() => el.classList.add('is-revealed'), i * 110)
        );
        obs.unobserve(e.target);
      });
    }, { threshold: 0.15 });

    if (section) obs.observe(section);
  }
</script>
