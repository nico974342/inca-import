---
const points = [
  { word: 'Stock permanent', sub: '120+ références toujours disponibles, jamais de rupture.' },
  { word: 'Livraison 48h', sub: 'Partout à La Réunion, sans exception.' },
  { word: 'Famille réunionnaise 7j/7', sub: "Une équipe locale qui vous connaît, pas un centre d'appels." },
];
---

<section class="why-inca" aria-label="Pourquoi Inca Import">
  <div class="container">
    <div class="why-grid">
      {points.map(p => (
        <div class="why-col">
          <p class="why-word">{p.word}</p>
          <p class="why-sub">{p.sub}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.why-inca {
  padding: clamp(var(--space-16), 7vw, var(--space-24)) 0;
  background: var(--color-bg);
  border-top: 1px solid var(--color-border);
}

.why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: clamp(var(--space-8), 5vw, var(--space-12));
}

.why-col {
  position: relative;
  padding: 0 clamp(var(--space-4), 3vw, var(--space-8));
}

.why-col + .why-col::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.2em;
  bottom: 0.2em;
  width: 1px;
  background: var(--color-border-strong);
}

.why-word {
  font-family: var(--font-display);
  font-size: clamp(1.625rem, 3.4vw, 2.25rem);
  font-weight: 700;
  letter-spacing: -0.025em;
  line-height: 1.1;
  color: var(--color-ink);
  margin-bottom: var(--space-3);
}

.why-sub {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  line-height: 1.6;
  color: var(--color-muted);
  max-width: 30ch;
}

@media (prefers-reduced-motion: no-preference) {
  .why-col.will-animate {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
  }
  .why-col.will-animate:nth-child(2) { transition-delay: 0.1s; }
  .why-col.will-animate:nth-child(3) { transition-delay: 0.2s; }
  .why-col.will-animate.is-revealed  { opacity: 1; transform: none; }
}

@media (max-width: 720px) {
  .why-grid {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  .why-col { padding: 0; }
  .why-col + .why-col::before { display: none; }
  .why-col + .why-col {
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border-strong);
  }
}
</style>

<script>
  const cols = document.querySelectorAll<HTMLElement>('.why-col');
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    cols.forEach(el => el.classList.add('will-animate'));

    const obs = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-revealed');
          obs.unobserve(e.target);
        }
      }),
      { threshold: 0.2 }
    );

    cols.forEach(el => obs.observe(el));
  }
</script>
