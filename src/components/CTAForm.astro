---
---
<section class="cta-section" id="compte" aria-labelledby="cta-heading">
  <div class="container">
    <div class="cta-inner">
      <div class="cta-header">
        <h2 class="cta-heading" id="cta-heading">
          Ouvrez votre compte professionnel
        </h2>
        <p class="cta-sub">
          Rejoignez les gérants de La Réunion qui font confiance à Inca Import
          pour un réassort sans surprise.
        </p>
        <ul class="cta-perks" aria-label="Avantages">
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Activation sous 24h ouvrées
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Catalogue complet avec prix
          </li>
          <li>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Sans engagement ni minimum
          </li>
        </ul>
      </div>

      <div class="cta-form-wrap">
        <form class="cta-form" novalidate aria-label="Demande d'ouverture de compte">
          <div class="form-row">
            <div class="form-group">
              <label for="f-nom">Prénom &amp; Nom</label>
              <input
                type="text"
                id="f-nom"
                name="nom"
                placeholder="Marie Dupont"
                required
                autocomplete="name"
              />
            </div>
            <div class="form-group">
              <label for="f-societe">Société</label>
              <input
                type="text"
                id="f-societe"
                name="societe"
                placeholder="Station Total Saint-Denis"
                required
                autocomplete="organization"
              />
            </div>
          </div>
          <div class="form-group">
            <label for="f-telephone">Téléphone</label>
            <input
              type="tel"
              id="f-telephone"
              name="telephone"
              placeholder="+262 6 92 XX XX XX"
              required
              autocomplete="tel"
            />
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary cta-submit">
              Envoyer ma demande
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <p class="form-alt">
            Ou <a href="/inscription" class="form-alt-link">inscrivez-vous directement →</a>
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector('.cta-form') as HTMLFormElement | null;
  const btn  = form?.querySelector('.cta-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async e => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.querySelectorAll('input').forEach(input => {
        if (!input.validity.valid) input.classList.add('input-error');
      });
      return;
    }
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Envoi en cours…';
    }
    try {
      const res = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
      if (res.ok) {
        form.innerHTML = `
          <p class="form-success" role="alert">
            Merci&nbsp;! Votre demande a bien été envoyée. Nous vous contactons sous 24h.
          </p>
        `;
      } else {
        if (btn) { btn.disabled = false; btn.textContent = 'Envoyer ma demande'; }
        alert('Une erreur est survenue. Veuillez réessayer.');
      }
    } catch {
      if (btn) { btn.disabled = false; btn.textContent = 'Envoyer ma demande'; }
      alert('Une erreur réseau est survenue. Veuillez réessayer.');
    }
  });

  form?.querySelectorAll('input').forEach(input => {
    input.addEventListener('input', () => input.classList.remove('input-error'));
  });
</script>

<style>
.cta-section {
  padding: clamp(var(--space-16), 7vw, var(--space-24)) 0;
  background: var(--color-bg);
  border-top: 1px solid var(--color-border);
}

.cta-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(var(--space-12), 7vw, var(--space-24));
  align-items: start;
}

/* Header */
.cta-heading {
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  font-weight: 700;
  letter-spacing: -0.025em;
  color: var(--color-ink);
  line-height: 1.08;
  margin-bottom: var(--space-5);
}

.cta-sub {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  line-height: 1.65;
  color: var(--color-muted);
  max-width: 38ch;
  margin-bottom: var(--space-8);
}

/* Perks list */
.cta-perks {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.cta-perks li {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
}

.cta-perks li svg {
  color: var(--color-primary);
  flex-shrink: 0;
}

/* Form */
.cta-form { display: flex; flex-direction: column; gap: var(--space-5); }

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-4);
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.cta-form label {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-ink);
}

.cta-form input[type="text"],
.cta-form input[type="tel"] {
  width: 100%;
  padding: 0.8125rem 1rem;
  font-family: var(--font-body);
  font-size: var(--text-base);
  color: var(--color-ink);
  background: var(--color-bg);
  border: 1.5px solid var(--color-border-strong);
  border-radius: var(--radius-sm);
  transition: border-color var(--dur-fast), box-shadow var(--dur-fast);
  min-height: 44px;
  outline: none;
  box-sizing: border-box;
}

.cta-form input::placeholder { color: var(--color-muted); }

.cta-form input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px oklch(0.568 0.149 45.9 / 0.15);
}

.cta-form input.input-error {
  border-color: oklch(0.55 0.20 25);
  box-shadow: 0 0 0 3px oklch(0.55 0.20 25 / 0.12);
}

.form-actions { display: flex; }

.cta-submit { gap: var(--space-3); }

/* Alt link */
.form-alt {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-muted);
  margin-top: calc(-1 * var(--space-2));
}

.form-alt-link {
  color: var(--color-primary-deep);
  font-weight: 500;
  text-decoration: none;
  transition: color var(--dur-fast);
}
.form-alt-link:hover { color: var(--color-primary); }

/* Success */
.form-success {
  font-family: var(--font-body);
  font-size: var(--text-lg);
  font-weight: 500;
  color: var(--color-accent);
  padding: var(--space-8) 0;
  line-height: 1.5;
}

/* Scroll reveal */
@media (prefers-reduced-motion: no-preference) {
  .cta-inner.will-animate {
    opacity: 0;
    transform: translateY(36px);
    transition: opacity 0.85s var(--ease-out-expo), transform 0.85s var(--ease-out-expo);
  }
  .cta-inner.will-animate.is-revealed {
    opacity: 1;
    transform: none;
  }
}

/* Responsive */
@media (max-width: 900px) {
  .cta-inner { grid-template-columns: 1fr; }
  .cta-sub   { max-width: none; }
}

@media (max-width: 480px) {
  .form-row { grid-template-columns: 1fr; }
}
</style>

<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const inner = document.querySelector<HTMLElement>('.cta-inner');
    if (inner) {
      inner.classList.add('will-animate');
      new IntersectionObserver(([e], obs) => {
        if (!e.isIntersecting) return;
        inner.classList.add('is-revealed');
        obs.unobserve(inner);
      }, { threshold: 0.12 }).observe(inner);
    }
  }
</script>
