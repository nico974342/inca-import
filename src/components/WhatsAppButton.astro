---
const phone = '262692478941';
const message = 'Bonjour Inca Import, je souhaite passer une commande.';
const href = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a
  href={href}
  class="whatsapp-fab"
  id="whatsappFab"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contacter Inca Import sur WhatsApp"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.87.51 3.62 1.4 5.12L2 22l5.13-1.5a9.85 9.85 0 0 0 4.91 1.31c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2zm0 18.06c-1.6 0-3.13-.43-4.46-1.24l-.32-.19-3.32.97.99-3.25-.21-.33a8.06 8.06 0 0 1-1.27-4.35c0-4.46 3.63-8.09 8.09-8.09a8.04 8.04 0 0 1 8.06 8.06c0 4.46-3.63 8.09-8.09 8.09zm4.45-6.06c-.24-.12-1.43-.7-1.65-.78-.22-.08-.38-.12-.54.12-.16.24-.62.78-.76.94-.14.16-.28.18-.52.06-.24-.12-1-.37-1.9-1.18-.7-.62-1.18-1.39-1.32-1.63-.14-.24-.01-.37.11-.49.12-.12.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.04-.42-.08-.12-.5-1.2-.68-1.64-.18-.43-.36-.37-.5-.38-.13-.01-.28-.01-.43-.01-.15 0-.39.06-.6.3-.21.24-.8.78-.8 1.9 0 1.12.82 2.2.93 2.35.12.16 1.6 2.44 3.88 3.33 2.28.89 2.28.59 2.69.55.41-.04 1.31-.53 1.5-1.05.18-.51.18-.95.12-1.05-.06-.1-.22-.16-.46-.27z"/>
  </svg>
</a>

<style>
.whatsapp-fab {
  position: fixed;
  left: calc(var(--space-5) + env(safe-area-inset-left, 0px));
  bottom: calc(var(--space-5) + env(safe-area-inset-bottom, 0px));
  z-index: var(--z-tooltip, 60);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  color: white;
  box-shadow: 0 8px 24px oklch(0.568 0.149 45.9 / 0.35);
  opacity: 0;
  transform: translateY(12px) scale(0.9);
  pointer-events: none;
  transition: opacity var(--dur-slow) var(--ease-out-quart),
              transform var(--dur-slow) var(--ease-out-quart);
}

.whatsapp-fab.is-visible {
  opacity: 1;
  transform: none;
  pointer-events: auto;
}

.whatsapp-fab::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  z-index: -1;
}

@media (prefers-reduced-motion: no-preference) {
  .whatsapp-fab.is-visible::after {
    animation: whatsapp-pulse 2.4s var(--ease-out-quart) infinite;
  }
}

@keyframes whatsapp-pulse {
  0%   { transform: scale(1);   opacity: 0.55; }
  100% { transform: scale(1.55); opacity: 0; }
}

@media (prefers-reduced-motion: reduce) {
  .whatsapp-fab { transition: opacity var(--dur-base); }
}

@media (max-width: 480px) {
  .whatsapp-fab {
    width: 52px;
    height: 52px;
    left: calc(var(--space-4) + env(safe-area-inset-left, 0px));
    bottom: calc(var(--space-4) + env(safe-area-inset-bottom, 0px));
  }
}
</style>

<script>
  const fab = document.getElementById('whatsappFab');
  if (fab) {
    setTimeout(() => fab.classList.add('is-visible'), 3000);
  }
</script>
