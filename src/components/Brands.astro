---
const brands = [
  { name: 'Monster Energy', domain: 'monsterenergy.com', color: '#1AB549' },
  { name: 'Red Bull',       domain: 'redbull.com',        color: '#002776' },
  { name: 'Coca-Cola',      domain: 'coca-cola.com',       color: '#F40009' },
  { name: 'Schweppes',      domain: 'schweppes.com',       color: '#C9A646' },
  { name: 'Lipton',         domain: 'lipton.com',          color: '#D9A400' },
  { name: 'Haribo',         domain: 'haribo.com',          color: '#E2231A' },
];
---

<section class="brands" aria-labelledby="brands-heading">
  <div class="container">
    <p class="brands-label" id="brands-heading">Marques distribuées</p>
  </div>

  <!-- Screen-reader list -->
  <ul class="sr-only">
    {brands.map(b => <li>{b.name}</li>)}
  </ul>

  <!-- Visual marquee -->
  <div class="marquee-outer" aria-hidden="true">
    <div class="marquee-track">
      {[...brands, ...brands].map(b => (
        <span class="brand-item" style={`--brand-color:${b.color};`}>
          <img
            class="brand-logo"
            src={`https://logo.clearbit.com/${b.domain}?size=160`}
            alt=""
            loading="lazy"
            width="120"
            height="40"
          />
          <span class="brand-fallback">{b.name}</span>
          <span class="brand-sep">·</span>
        </span>
      ))}
    </div>
  </div>
</section>

<style>
.brands {
  padding: clamp(var(--space-12), 5vw, var(--space-20)) 0;
  border-top: 1px solid var(--color-border);
  overflow: hidden;
}

.brands-label {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-muted);
  letter-spacing: 0.01em;
  margin-bottom: var(--space-8);
}

/* Marquee */
.marquee-outer {
  mask-image: linear-gradient(
    to right,
    transparent 0,
    black 10%,
    black 90%,
    transparent 100%
  );
  -webkit-mask-image: linear-gradient(
    to right,
    transparent 0,
    black 10%,
    black 90%,
    transparent 100%
  );
}

.marquee-track {
  display: flex;
  align-items: center;
  width: max-content;
  animation: brands-marquee 30s linear infinite;
}

.brand-item {
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  padding: var(--space-2) clamp(var(--space-5), 3vw, var(--space-8));
}

.brand-logo {
  display: block;
  height: clamp(22px, 3vw, 30px);
  width: auto;
  max-width: 130px;
  object-fit: contain;
  filter: grayscale(1) opacity(0.55);
  transition: filter var(--dur-fast);
}
.brand-item:hover .brand-logo { filter: grayscale(0) opacity(1); }

.brand-logo.is-error { display: none; }

.brand-fallback {
  display: none;
  font-family: var(--font-display);
  font-size: clamp(1.125rem, 2vw, 1.5rem);
  font-weight: 600;
  letter-spacing: -0.01em;
  color: var(--brand-color);
}
.brand-logo.is-error + .brand-fallback { display: inline-flex; }

.brand-sep {
  display: inline-block;
  margin-left: clamp(var(--space-5), 3vw, var(--space-8));
  color: var(--color-border-strong);
  font-weight: 400;
}

@keyframes brands-marquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

@media (prefers-reduced-motion: reduce) {
  .marquee-track { animation-play-state: paused; }
}
</style>

<script>
  document.querySelectorAll<HTMLImageElement>('.brand-logo').forEach(img => {
    img.addEventListener('error', () => img.classList.add('is-error'), { once: true });
  });
</script>
