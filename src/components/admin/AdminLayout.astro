---
import '../../styles/global.css';

interface Props {
  title: string;
  activeNav?: 'dashboard' | 'produits' | 'contacts' | 'clients' | 'temoignages' | 'commande-rapide' | 'livraison';
}

const { title, activeNav } = Astro.props;
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Inca Import Admin</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body class="admin-body">

  <!-- Mobile top bar -->
  <header class="admin-topbar">
    <button class="topbar-menu-btn" id="sidebarToggle" aria-label="Menu" aria-expanded="false" aria-controls="adminSidebar">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <span class="topbar-wordmark">
      <span class="wm-inca">Inca</span><span class="wm-import">Import</span>
      <span class="wm-admin">Admin</span>
    </span>
  </header>

  <div class="admin-shell">
    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar" role="navigation" aria-label="Navigation admin">
      <div class="sidebar-brand">
        <a href="/" class="sidebar-wordmark" aria-label="Aller au site public">
          <span class="wm-inca">Inca</span><span class="wm-import">Import</span>
        </a>
        <span class="sidebar-badge">Admin</span>
      </div>

      <nav class="sidebar-nav">
        <a href="/admin" class={`nav-link ${activeNav === 'dashboard' ? 'nav-link--active' : ''}`}>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect x="1" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/>
            <rect x="9" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/>
            <rect x="1" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/>
            <rect x="9" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          Tableau de bord
        </a>
        <a href="/admin/produits" class={`nav-link ${activeNav === 'produits' ? 'nav-link--active' : ''}`}>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 4h12M2 8h12M2 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Produits
        </a>
        <a href="/admin/contacts" class={`nav-link ${activeNav === 'contacts' ? 'nav-link--active' : ''}`}>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M10.5 2.5a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0ZM2 13c0-2.761 2.686-5 6-5s6 2.239 6 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Contacts
        </a>
        <a href="/admin/clients" class={`nav-link ${activeNav === 'clients' ? 'nav-link--active' : ''}`}>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M7.5 2a2 2 0 1 1 0 4 2 2 0 0 1 0-4ZM12 3a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM1 11c0-2.2 2.91-4 6.5-4S14 8.8 14 11M12 8.5c1.38.37 2.5 1.16 2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          Clients
        </a>
        <a href="/admin/temoignages" class={`nav-link ${activeNav === 'temoignages' ? 'nav-link--active' : ''}`}>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 4.5C2 3.67 2.67 3 3.5 3h9C13.33 3 14 3.67 14 4.5v5c0 .83-.67 1.5-1.5 1.5H9l-3 2.5V11H3.5C2.67 11 2 10.33 2 9.5v-5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          </svg>
          Témoignages
        </a>
        <a href="/admin/commande-rapide" class={`nav-link ${activeNav === 'commande-rapide' ? 'nav-link--active' : ''}`}>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 3h1.5l2 7h7l1.5-5H5.5M6 12.5a.5.5 0 1 1 1 0 .5.5 0 0 1-1 0Zm5 0a.5.5 0 1 1 1 0 .5.5 0 0 1-1 0Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Prise de commande
        </a>
        <a href="/admin/livraison" class={`nav-link ${activeNav === 'livraison' ? 'nav-link--active' : ''}`}>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M1 3h9v7H1zM10 5h3l2 2.5V10h-5V5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
            <circle cx="3.5" cy="12" r="1.5" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="11.5" cy="12" r="1.5" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          Livraisons
        </a>
      </nav>

      <div class="sidebar-footer">
        <a href="/" class="sidebar-site-link" target="_blank" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M5.5 2.5H2.5A1 1 0 0 0 1.5 3.5v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-3M8 1.5h4.5m0 0v4.5m0-4.5-5.5 5.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Voir le site
        </a>
        <form action="/api/auth/logout" method="post">
          <button type="submit" class="sidebar-logout-btn">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M5 2H3a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h2M9.5 9.5 12 7m0 0-2.5-2.5M12 7H5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Déconnexion
          </button>
        </form>
      </div>
    </aside>

    <!-- Overlay for mobile -->
    <div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>

    <!-- Main content -->
    <main class="admin-main">
      <div class="admin-page-header">
        <h1 class="admin-page-title">{title}</h1>
      </div>
      <div class="admin-content">
        <slot />
      </div>
    </main>
  </div>

  <script>
    const toggle = document.getElementById('sidebarToggle');
    const sidebar = document.getElementById('adminSidebar');
    const overlay = document.getElementById('sidebarOverlay');

    function openSidebar() {
      sidebar?.classList.add('is-open');
      overlay?.classList.add('is-visible');
      toggle?.setAttribute('aria-expanded', 'true');
    }
    function closeSidebar() {
      sidebar?.classList.remove('is-open');
      overlay?.classList.remove('is-visible');
      toggle?.setAttribute('aria-expanded', 'false');
    }

    toggle?.addEventListener('click', () => {
      sidebar?.classList.contains('is-open') ? closeSidebar() : openSidebar();
    });
    overlay?.addEventListener('click', closeSidebar);
  </script>
</body>
</html>

<style>
/* ── Admin shell ─────────────────────────────────── */
.admin-body {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-ink);
  background: var(--color-surface);
  min-height: 100dvh;
}

.admin-shell {
  display: flex;
  min-height: 100dvh;
}

/* ── Sidebar ─────────────────────────────────────── */
.admin-sidebar {
  width: 220px;
  flex-shrink: 0;
  background: var(--color-bg);
  border-right: 1px solid var(--color-border);
  display: flex;
  flex-direction: column;
  position: sticky;
  top: 0;
  height: 100dvh;
  overflow-y: auto;
}

.sidebar-brand {
  padding: var(--space-5) var(--space-5) var(--space-4);
  display: flex;
  align-items: center;
  gap: var(--space-2);
  border-bottom: 1px solid var(--color-border);
}

.sidebar-wordmark {
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  text-decoration: none;
}
.wm-inca   { color: var(--color-primary); }
.wm-import { color: var(--color-ink); font-weight: 400; }

.sidebar-badge {
  font-family: var(--font-body);
  font-size: 0.625rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--color-muted);
  background: var(--color-surface-2);
  padding: 2px 6px;
  border-radius: var(--radius-full);
  border: 1px solid var(--color-border);
}

.sidebar-nav {
  padding: var(--space-3) var(--space-3);
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-2) var(--space-3);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-muted);
  text-decoration: none;
  border-radius: var(--radius-sm);
  transition: color var(--dur-fast), background var(--dur-fast);
  line-height: 1.4;
}
.nav-link svg { flex-shrink: 0; }
.nav-link:hover { color: var(--color-ink); background: var(--color-surface); }
.nav-link--active {
  color: var(--color-primary-deep);
  background: oklch(0.568 0.149 45.9 / 0.07);
  font-weight: 600;
}
.nav-link:focus-visible {
  outline: 2px solid var(--color-primary);
  outline-offset: 2px;
}

.sidebar-footer {
  padding: var(--space-3) var(--space-3);
  border-top: 1px solid var(--color-border);
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sidebar-site-link,
.sidebar-logout-btn {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-2) var(--space-3);
  font-size: var(--text-sm);
  font-weight: 400;
  color: var(--color-muted);
  text-decoration: none;
  border-radius: var(--radius-sm);
  background: transparent;
  border: none;
  cursor: pointer;
  width: 100%;
  transition: color var(--dur-fast), background var(--dur-fast);
}
.sidebar-site-link:hover,
.sidebar-logout-btn:hover {
  color: var(--color-ink);
  background: var(--color-surface);
}

/* ── Mobile topbar ───────────────────────────────── */
.admin-topbar {
  display: none;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3) var(--space-4);
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: var(--z-sticky);
}

.topbar-menu-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: transparent;
  border: none;
  border-radius: var(--radius-sm);
  color: var(--color-ink);
  cursor: pointer;
  flex-shrink: 0;
}
.topbar-menu-btn:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }

.topbar-wordmark {
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}
.wm-admin {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--color-muted);
  margin-left: var(--space-2);
}

/* ── Overlay ─────────────────────────────────────── */
.sidebar-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: oklch(0 0 0 / 0.35);
  z-index: calc(var(--z-sticky) + 1);
  opacity: 0;
  transition: opacity var(--dur-base);
}
.sidebar-overlay.is-visible { opacity: 1; }

/* ── Main content ────────────────────────────────── */
.admin-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.admin-page-header {
  padding: var(--space-6) var(--space-8);
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
}

.admin-page-title {
  font-size: 1.375rem;
  font-weight: 600;
  color: var(--color-ink);
  line-height: 1.3;
}

.admin-content {
  padding: var(--space-6) var(--space-8);
  flex: 1;
}

/* ── Responsive ──────────────────────────────────── */
@media (max-width: 768px) {
  .admin-topbar { display: flex; }
  .admin-shell  { display: block; }

  .admin-sidebar {
    position: fixed;
    left: 0;
    top: 0;
    bottom: 0;
    z-index: calc(var(--z-sticky) + 2);
    transform: translateX(-100%);
    transition: transform var(--dur-base) var(--ease-out-quart);
  }
  .admin-sidebar.is-open { transform: translateX(0); }
  .sidebar-overlay { display: block; }

  .admin-page-header { padding: var(--space-4) var(--space-5); }
  .admin-content     { padding: var(--space-4) var(--space-5); }
}
</style>
