---
import { supabaseAdmin } from '../lib/supabase';

type Testimonial = { texte: string; nom: string; role: string };

let testimonial: Testimonial | null = null;

const { data, error } = await supabaseAdmin
  .from('testimonials')
  .select('texte, nom, role')
  .eq('actif', true)
  .order('position', { ascending: true })
  .limit(1)
  .single();

if (!error && data) {
  testimonial = { texte: data.texte, nom: data.nom, role: data.role ?? '' };
}

const initials = testimonial
  ? testimonial.nom.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase()
  : '';
---

<section class="testimonial" aria-label="Témoignage client">
  <div class="container">
    {testimonial ? (
      <blockquote class="quote-block">
        <div class="quote-mark" aria-hidden="true">"</div>
        <p class="quote-text">{testimonial.texte}</p>
        <footer class="quote-footer">
          <div class="quote-avatar" aria-hidden="true">{initials}</div>
          <div class="quote-byline">
            <cite class="quote-name">{testimonial.nom}</cite>
            {testimonial.role && <p class="quote-role">{testimonial.role}</p>}
          </div>
        </footer>
      </blockquote>
    ) : (
      <div class="quote-block quote-placeholder">
        <div class="quote-mark" aria-hidden="true">"</div>
        <p class="quote-text quote-text--placeholder">Témoignage à venir</p>
      </div>
    )}
  </div>
</section>

<style>
.testimonial {
  background: var(--color-primary);
  padding: clamp(var(--space-20), 9vw, 9rem) 0;
  overflow: hidden;
}

.quote-block {
  max-width: 860px;
  position: relative;
  padding-top: clamp(var(--space-8), 5vw, var(--space-14));
}

/* Structural quote mark — watermark, not decoration */
.quote-mark {
  position: absolute;
  top: -0.12em;
  left: -0.055em;
  font-family: var(--font-display);
  font-size: clamp(8rem, 22vw, 16rem);
  font-weight: 700;
  line-height: 1;
  color: rgba(255, 255, 255, 0.10);
  user-select: none;
  pointer-events: none;
}

.quote-text {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 3.5vw, 2.5rem);
  font-weight: 400;
  line-height: 1.42;
  letter-spacing: -0.02em;
  color: white;
  margin-bottom: clamp(var(--space-8), 4vw, var(--space-12));
  text-wrap: pretty;
  position: relative;
  z-index: 1;
}

.quote-placeholder { padding-bottom: clamp(var(--space-8), 4vw, var(--space-12)); }
.quote-text--placeholder {
  color: rgba(255, 255, 255, 0.55);
  margin-bottom: 0;
}

/* Footer */
.quote-footer {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  position: relative;
  z-index: 1;
}

.quote-avatar {
  width: 46px;
  height: 46px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  color: white;
  font-family: var(--font-display);
  font-size: 0.9375rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  letter-spacing: 0.02em;
}

.quote-byline {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.quote-name {
  font-family: var(--font-body);
  font-size: var(--text-base);
  font-weight: 600;
  color: rgba(255, 255, 255, 0.95);
  font-style: normal;
}

.quote-role {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.4;
}
</style>
