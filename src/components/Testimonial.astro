---
import { supabaseAdmin } from '../lib/supabase';

const FALLBACK = {
  texte: "Depuis qu'on travaille avec Inca Import, le réassort est simple. Stock fiable, livraison dans les temps — et quand on a un souci, y'a toujours quelqu'un qui répond.",
  nom: 'Jean-Marc Payet',
  role: 'Gérant, Station Total — Saint-Denis',
};

let testimonial = FALLBACK;

const { data, error } = await supabaseAdmin
  .from('testimonials')
  .select('texte, nom, role')
  .eq('actif', true)
  .order('position', { ascending: true })
  .limit(1)
  .single();

if (!error && data) {
  testimonial = { texte: data.texte, nom: data.nom, role: data.role ?? '' };
}
---
<section class="testimonial" aria-label="Témoignage client">
  <div class="container">
    <blockquote class="quote-block">
      <div class="quote-mark" aria-hidden="true">"</div>
      <p class="quote-text">{testimonial.texte}</p>
      <footer class="quote-footer">
        <cite class="quote-name">{testimonial.nom}</cite>
        {testimonial.role && <span class="quote-role">{testimonial.role}</span>}
      </footer>
    </blockquote>
  </div>
</section>

<style>
.testimonial {
  padding: clamp(var(--space-16), 7vw, var(--space-24)) 0;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}

.quote-block {
  max-width: 780px;
  position: relative;
  padding-left: clamp(var(--space-8), 5vw, var(--space-16));
}

.quote-mark {
  position: absolute;
  left: 0;
  top: -0.15em;
  font-family: var(--font-display);
  font-size: clamp(4rem, 9vw, 7rem);
  font-weight: 700;
  line-height: 1;
  color: var(--color-primary);
  user-select: none;
  aria-hidden: true;
}

.quote-text {
  font-family: var(--font-display);
  font-size: clamp(1.375rem, 3vw, 2rem);
  font-weight: 400;
  line-height: 1.45;
  letter-spacing: -0.015em;
  color: var(--color-ink);
  margin-bottom: var(--space-8);
  text-wrap: pretty;
}

.quote-footer {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.quote-name {
  font-family: var(--font-body);
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-ink);
  font-style: normal;
}

.quote-role {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-muted);
}

@media (max-width: 640px) {
  .quote-block { padding-left: var(--space-6); }
}
</style>
